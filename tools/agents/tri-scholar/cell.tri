[cell]
id = "trinity.agent.tri-scholar"
name = "Tri Scholar Agent"
version = "1.0.0"
kind = "agent"
path = "tools/agents/tri-scholar"
status = "stable"
description = "Research agent — searches for DESI, DUNE, NANOGrav papers and experimental results for Sacred predictions"
capabilities = ["research", "perplexity", "papers", "sacred"]
owner = "agent:ralph"

[tags]
scope = "agent"
type = "agent"

[agent]
definition = ".claude/agents/tri-scholar.md"
model = "sonnet"
max_turns = 15
tools = "Read,Grep,Glob,mcp__perplexity__perplexity_search,mcp__perplexity__perplexity_ask,mcp__perplexity__perplexity_research"
isolation = ""

[permissions]
level = "L0"
filesystem = "read"
network = "none"
process = "none"
ffi = "none"
concurrency = "none"

[security]
signed = "true"
