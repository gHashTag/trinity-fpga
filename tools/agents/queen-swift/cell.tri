[cell]
id = "trinity.agent.queen-swift"
name = "Queen Swift Agent"
version = "1.0.0"
kind = "agent"
path = "tools/agents/queen-swift"
status = "stable"
description = "SwiftUI developer for Queen UI — builds screens, widgets, navigation, and visual components"
capabilities = ["swiftui", "macos", "queen-ui"]
owner = "agent:ralph"

[tags]
scope = "agent"
type = "agent"

[agent]
definition = ".claude/agents/queen-swift.md"
model = "opus"
max_turns = 30
tools = "Read,Edit,Write,Bash,Grep,Glob"
isolation = "worktree"

[permissions]
level = "L0"
filesystem = "read"
network = "none"
process = "none"
ffi = "none"
concurrency = "none"

[security]
signed = "true"
