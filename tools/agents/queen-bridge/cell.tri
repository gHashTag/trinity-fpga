[cell]
id = "trinity.agent.queen-bridge"
name = "Queen Bridge Agent"
version = "1.0.0"
kind = "agent"
path = "tools/agents/queen-bridge"
status = "stable"
description = "Bridge/Network layer developer for Queen UI — ChatClient, ThreadStore, ModelProvider, RepoContext"
capabilities = ["swift", "networking", "queen-ui", "bridge"]
owner = "agent:ralph"

[tags]
scope = "agent"
type = "agent"

[agent]
definition = ".claude/agents/queen-bridge.md"
model = "opus"
max_turns = 25
tools = "Read,Edit,Write,Bash,Grep,Glob"
isolation = "worktree"

[permissions]
level = "L2"
filesystem = "write"
network = "none"
process = "spawn"
ffi = "none"
concurrency = "none"

[security]
signed = "true"
