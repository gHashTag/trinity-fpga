# Zsh completion for TRI CLI command
# Install: place in ~/.zsh/completion/_tri or add to fpath
#
# φ² + 1/φ² = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

typeset -A _tri_call_tags
_tri_call_tags=(
    # Core commands
    help "Show help message"
    version "Show version information"
    info "Show system information"
    phi "Calculate golden ratio power"
    fib "Calculate Fibonacci number"
    lucas "Calculate Lucas number"
    spiral "Calculate φ-spiral coordinates"
    gematria "Calculate gematria value"
    gem "Calculate gematria value (alias)"
    formula "Evaluate mathematical formula"
    constants "Show sacred constants"
    sacred "Sacred mathematics suite"

    # Chemistry
    chem "Chemistry commands"
    periodic "Show periodic table"
    element "Show element information"
    mass "Calculate molar mass"
    formula_cmd "Analyze chemical formula"

    # Biology
    bio "Biology commands"
    dna "DNA analysis"
    rna "RNA analysis"
    protein "Protein analysis"

    # Cosmology
    cosmos "Cosmology commands"
    hubble "Hubble tension resolution"
    dark "Dark energy patterns"
    predict "Predict sacred constants"

    # Neuroscience
    neuro "Neuroscience commands"
    waves "Brain wave analysis"
    consciousness "Consciousness computation"
    regions "Sacred brain regions"
    network "Neural network analysis"

    # SWE Agent
    gen "Generate code from VIBEE spec"
    fix "Detect and fix bugs"
    explain "Explain code or concept"
    test "Generate tests"
    doc "Generate documentation"
    refactor "Suggest refactoring"
    reason "Chain-of-thought reasoning"

    # Git
    commit "Git commit"
    diff "Git diff"
    status "Git status"
    log "Git log"

    # Golden Chain
    pipeline "Run Golden Chain pipeline"
    decompose "Break task into sub-tasks"
    plan "Generate implementation plan"
    verify "Run tests and benchmarks"
    verdict "Generate toxic verdict"

    # Dev utilities
    doctor "System diagnostics"
    clean "Clean build artifacts"
    fmt "Format code"
    stats "Show project statistics"
    igla "IGLA agent interface"

    # Server
    serve "Start HTTP server"

    # Flags
    --verbose "Verbose output"
    --dry-run "Show what would be done"
    --yes "Auto-confirm prompts"
    --output "Output format (text/json/yaml)"
    --port "Server port"
    --daemon "Background mode"
)

_tri() {
    local -a commands
    commands=(
        'help:Show help message'
        'version:Show version information'
        'info:Show system information'
        'phi:Calculate golden ratio power'
        'fib:Calculate Fibonacci number'
        'lucas:Calculate Lucas number'
        'spiral:Calculate φ-spiral coordinates'
        'gematria:Calculate gematria value'
        'gem:Calculate gematria value (alias)'
        'formula:Evaluate mathematical formula'
        'constants:Show sacred constants'
        'sacred:Sacred mathematics suite'
        'chem:Chemistry commands'
        'bio:Biology commands'
        'cosmos:Cosmology commands'
        'neuro:Neuroscience commands'
        'gen:Generate code from VIBEE spec'
        'fix:Detect and fix bugs'
        'explain:Explain code or concept'
        'test:Generate tests'
        'doc:Generate documentation'
        'refactor:Suggest refactoring'
        'reason:Chain-of-thought reasoning'
        'commit:Git commit'
        'diff:Git diff'
        'status:Git status'
        'log:Git log'
        'pipeline:Run Golden Chain pipeline'
        'decompose:Break task into sub-tasks'
        'plan:Generate implementation plan'
        'verify:Run tests and benchmarks'
        'verdict:Generate toxic verdict'
        'doctor:System diagnostics'
        'clean:Clean build artifacts'
        'fmt:Format code'
        'stats:Show project statistics'
        'igla:IGLA agent interface'
        'serve:Start HTTP server'
        '--verbose:Verbose output'
        '--dry-run:Show what would be done'
        '--yes:Auto-confirm prompts'
        '--help:Show this help'
    )

    if (( CURRENT == 2 )); then
        _describe -V commands 'command'
        return
    fi

    case $words[2] in
        chem)
            local -a chem_subcmds
            chem_subcmds=(
                'periodic:Show periodic table'
                'element:Show element info'
                'mass:Calculate molar mass'
                'formula:Analyze formula'
                'balance:Balance equation'
                'moles:Calculate moles'
                'atoms:Calculate atom counts'
                'ideal-gas:Solve PV=nRT'
                'ph:Calculate pH'
                'redox:Balance redox equation'
            )
            _describe -V chem_subcmds 'chemistry subcommand'
            ;;

        bio)
            local -a bio_subcmds
            bio_subcmds=(
                'dna:DNA analysis'
                'rna:RNA analysis'
                'protein:Protein analysis'
                'codon:Codon table'
                'genome:Genome analysis'
                'sequence:Sequence analysis'
            )
            _describe -V bio_subcmds 'biology subcommand'
            ;;

        cosmos)
            local -a cosmos_subcmds
            cosmos_subcmds=(
                'hubble:Hubble tension resolution'
                'dark:Dark energy patterns'
                'predict:Predict sacred constants'
                'expand:Universe expansion'
                'big-bang:Big Bang theory'
            )
            _describe -V cosmos_subcmds 'cosmology subcommand'
            ;;

        neuro)
            local -a neuro_subcmds
            neuro_subcmds=(
                'waves:Brain wave analysis'
                'consciousness:Consciousness computation'
                'regions:Sacred brain regions'
                'network:Neural network analysis'
                'synapse:Synaptic transmission'
                'neurons:Brain statistics'
            )
            _describe -V neuro_subcmds 'neuroscience subcommand'
            ;;

        gem|gematria)
            _arguments '1: :_gematria_formats'
            ;;

        serve)
            _arguments \
                '(--port -p)[port]' \
                '(--host)[host]' \
                '(--daemon -d)[daemon mode]' \
                '(--verbose -v)[verbose]' \
                '(--help -h)[show help]'
            ;;

        gen)
            _arguments \
                '(--chat)[chat mode]' \
                '(--model)[model path]' \
                '(--serve)[start server]' \
                '*:spec file:_files -g "*.vibee"'
            ;;

        fix)
            _arguments \
                '(--file -f)[file to fix]' \
                '(--line -l)[line number]' \
                '(--all -a)[fix all issues]'
            ;;

        phi)
            _arguments \
                '(--inverse)[show 1/φⁿ]' \
                '(--powers)[show powers]' \
                '(--fibonacci)[show Fibonacci relation]' \
                '1:number'
            ;;
    esac
}

_gematria_formats() {
    local -a formats
    formats=(
        'english:English gematria'
        'hebrew:Hebrew gematria'
        'greek:Greek gematria'
        'isopsophy:Isopsephy'
        'full-reduction:Full reduction method'
        'kv:KV method'
    )
    _describe -V formats 'gematria format'
}

_tri "$@"
