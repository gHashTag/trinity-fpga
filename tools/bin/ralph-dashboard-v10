#!/bin/bash
# TRI COMMANDER v10.6 — Catppuccin Mocha Design
cd /Users/playra/trinity

# Stop old handlers and sessions
pkill -f tri_cmd_handler 2>/dev/null || true
pkill -f tri_cmd_real_handler_v2 2>/dev/null || true
tmux kill-session -t ralph 2>/dev/null || true
sleep 0.5

# Source env
if [ -f ".ralph/.env" ]; then
    source ".ralph/.env"
fi

# Start handler
bash .ralph/scripts/tri_cmd_real_handler_v2.sh > /dev/null 2>&1 &
HANDLER_PID=$!

# === HOME window ===
# Left: OUTPUT (70%), Right: TRI COMMANDER (30%)

tmux new-session -s ralph -n "HOME" -d
# Split: 70% left, 30% right
tmux split-window -h -p 30 -t ralph:1

# Left pane = OUTPUT monitor
tmux send-keys -t ralph:1.1 "bash .ralph/scripts/output_monitor_v4.sh" C-m

# Right pane = TRI COMMANDER (split: output top, input bottom)
tmux split-window -v -p 40 -t ralph:1.2
# Top-right = Output tail
tmux send-keys -t ralph:1.2 "tail -f .ralph/queue/responses/current.resp 2>/dev/null || echo 'Waiting for commands...'" C-m
# Bottom-right = TRI COMMANDER input
tmux send-keys -t ralph:1.3 "bash .ralph/scripts/tri-commander.sh" C-m

# Select TRI COMMANDER input pane
tmux select-pane -t ralph:1.3

# === Other windows ===
tmux new-window -t ralph -n "Loop"
tmux send-keys -t ralph:2 "while true; do clear; bash .ralph/scripts/tmux_status_v4.sh welcome; sleep 10; done" C-m

tmux new-window -t ralph -n "Tasks"
tmux send-keys -t ralph:3 "while true; do clear; .ralph/scripts/tmux_status.sh panel2; sleep 5; done" C-m

tmux new-window -t ralph -n "Memory"
tmux send-keys -t ralph:4 "while true; do clear; .ralph/scripts/tmux_status.sh panel4; sleep 15; done" C-m

tmux new-window -t ralph -n "Log"
tmux send-keys -t ralph:5 "cd .ralph/logs && tail -f ralph.log" C-m

# Select HOME
tmux select-window -t ralph:1

echo ""
echo "   ╔═══════════════════════════════════════════════════╗"
echo "   ║  TRI COMMANDER v10.6 — CATPPUCCIN MOCHA DESIGN     ║"
echo "   ╠═══════════════════════════════════════════════════╣"
echo "   ║  Handler PID: $HANDLER_PID"
echo "   ║  Layout: HOME(70% left) | TRI(30% right)"
echo "   ║                                                   ║"
echo "   ║  Style: Catppuccin Mocha (pastel + rounded)       ║"
echo "   ║  Prompt: GREEN TRI COMMANDER>                     ║"
echo "   ║                                                   ║"
echo "   ║  Присоединяйся: tmux attach -t ralph              ║"
echo "   ╚═══════════════════════════════════════════════════╝"
echo ""
