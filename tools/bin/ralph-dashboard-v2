#!/bin/bash
# Ralph Dashboard v2.1 — Truth Mode + TRI COMMANDER
# Генерал Grok армии агентов Trinity

cd /Users/playra/trinity

# Убиваем старую сессию
tmux kill-session -t ralph 2>/dev/null || true

# Window 0: HOME (Админ-панель) + TRI COMMANDER справа
tmux new-session -s ralph -n "HOME" -d
tmux send-keys -t ralph:0 "while true; do clear; .ralph/scripts/tmux_status.sh welcome; sleep 30; done" C-m
# Правая панель — TRI COMMANDER (28% ширины)
tmux split-window -h -p 28 -t ralph:0
tmux send-keys -t ralph:0.2 ".ralph/scripts/tri-commander.sh" C-m
tmux select-pane -t ralph:0.1

# Window 1: Loop (Ralph Loop Status + Workers)
tmux new-window -t ralph -n "Loop"
tmux send-keys -t ralph:1 "while true; do clear; .ralph/scripts/tmux_status.sh panel0; sleep 2; done" C-m
tmux split-window -h -t ralph:1
tmux send-keys -t ralph:1.2 "while true; do clear; .ralph/scripts/tmux_status.sh panel1; sleep 5; done" C-m
tmux select-pane -t ralph:1.1

# Window 2: Tasks (fix_plan.md + TechTree)
tmux new-window -t ralph -n "Tasks"
tmux send-keys -t ralph:2 "while true; do clear; .ralph/scripts/tmux_status.sh panel2; sleep 5; done" C-m
tmux split-window -h -p 60 -t ralph:2
tmux send-keys -t ralph:2.2 "while true; do clear; .ralph/scripts/tmux_status.sh panel3; sleep 10; done" C-m
tmux select-pane -t ralph:2.1

# Window 3: Memory (SUCCESS_HISTORY + Логи)
tmux new-window -t ralph -n "Memory"
tmux send-keys -t ralph:3 "while true; do clear; .ralph/scripts/tmux_status.sh panel4; sleep 15; done" C-m
tmux split-window -h -p 60 -t ralph:3
tmux send-keys -t ralph:3.2 "cd /Users/playra/trinity/.ralph/logs && tail -f \$(ls -t *.log 2>/dev/null | head -1 || echo ralph.log)" C-m
tmux select-pane -t ralph:3.1

# Window 4: Log (Полный live-лог)
tmux new-window -t ralph -n "Log"
tmux send-keys -t ralph:4 "cd /Users/playra/trinity/.ralph/logs && tail -f ralph.log" C-m

# Выбираем HOME окно (индекс 0)
tmux select-window -t ralph:0

echo "=== Ralph Dashboard v2.1 запущен ==="
echo "Присоединяйся: tmux attach -t ralph"
