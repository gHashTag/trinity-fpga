{
  "mcpServers": {
    "trinity": {
      "command": "/data/trinity/zig-out/bin/trinity-mcp",
      "args": [],
      "env": {"TRINITY_MCP_PORT": "8899"}
    },
    "zig-docs": {
      "command": "npx",
      "args": ["-y", "@nichochar/zig-mcp@latest"],
      "env": {}
    },
    "railway-mcp-server": {
      "command": "npx",
      "args": ["-y", "@railway/mcp-server"]
    },
    "telegram": {
      "command": "npx",
      "args": ["-y", "@iqai/mcp-telegram"],
      "env": {
        "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}"
      }
    }
  }
}
