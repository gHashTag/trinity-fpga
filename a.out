#! /opt/homebrew/Cellar/icarus-verilog/12.0/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/system.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/vhdl_sys.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/vhdl_textio.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/v2005_math.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/va_math.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/v2009.vpi";
S_0x144a04180 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x144a0eac0 .scope module, "tf3_simple_test" "tf3_simple_test" 3 4;
 .timescale -9 -12;
v0x144a0bba0_0 .var "clk", 0 0;
v0x144a1dbe0_0 .var "in_a", 17 0;
v0x144a1dc80_0 .var "in_b", 17 0;
o0x1480400a0 .functor BUFZ 1, C4<z>; HiZ drive
v0x144a1dd30_0 .net "in_ready", 0 0, o0x1480400a0;  0 drivers
v0x144a1ddd0_0 .var "in_valid", 0 0;
v0x144a1deb0_0 .var "mode", 1 0;
v0x144a1df60_0 .var "out_ready", 0 0;
o0x148040160 .functor BUFZ 1, C4<z>; HiZ drive
v0x144a1e000_0 .net "out_valid", 0 0, o0x148040160;  0 drivers
o0x148040190 .functor BUFZ 18, C4<zzzzzzzzzzzzzzzzzz>; HiZ drive
v0x144a1e0a0_0 .net "out_y", 17 0, o0x148040190;  0 drivers
v0x144a1e1b0_0 .var "rst", 0 0;
v0x144a1e250_0 .var/i "test_num", 31 0;
E_0x144a0ea70 .event posedge, v0x144a0bba0_0;
    .scope S_0x144a0eac0;
T_0 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x144a0bba0_0, 0, 1;
T_0.0 ;
    %delay 5000, 0;
    %load/vec4 v0x144a0bba0_0;
    %inv;
    %store/vec4 v0x144a0bba0_0, 0, 1;
    %jmp T_0.0;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x144a1e250_0, 0, 32;
    %vpi_call/w 3 24 "$display", "\012\012========================================" {0 0 0};
    %vpi_call/w 3 25 "$display", "  TF3 ALU Simple Test" {0 0 0};
    %vpi_call/w 3 26 "$display", "========================================\012" {0 0 0};
    %vpi_call/w 3 27 "$display", "Testing: result_reg assignment" {0 0 0};
    %wait E_0x144a0ea70;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x144a1e1b0_0, 0, 1;
    %wait E_0x144a0ea70;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x144a1e1b0_0, 0, 1;
    %wait E_0x144a0ea70;
    %pushi/vec4 0, 0, 2;
    %store/vec4 v0x144a1deb0_0, 0, 2;
    %pushi/vec4 1, 0, 18;
    %store/vec4 v0x144a1dbe0_0, 0, 18;
    %pushi/vec4 0, 0, 18;
    %store/vec4 v0x144a1dc80_0, 0, 18;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x144a1ddd0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x144a1df60_0, 0, 1;
    %wait E_0x144a0ea70;
T_0.1 ;
    %load/vec4 v0x144a1dd30_0;
    %nor/r;
    %flag_set/vec4 8;
    %jmp/0xz T_0.2, 8;
    %wait E_0x144a0ea70;
    %jmp T_0.1;
T_0.2 ;
    %wait E_0x144a0ea70;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x144a1ddd0_0, 0, 1;
    %wait E_0x144a0ea70;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x144a1df60_0, 0, 1;
T_0.3 ;
    %load/vec4 v0x144a1e000_0;
    %nor/r;
    %flag_set/vec4 8;
    %jmp/0xz T_0.4, 8;
    %wait E_0x144a0ea70;
    %jmp T_0.3;
T_0.4 ;
    %wait E_0x144a0ea70;
    %delay 10000, 0;
    %wait E_0x144a0ea70;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x144a1df60_0, 0, 1;
T_0.5 ;
    %load/vec4 v0x144a1e000_0;
    %nor/r;
    %flag_set/vec4 8;
    %jmp/0xz T_0.6, 8;
    %wait E_0x144a0ea70;
    %jmp T_0.5;
T_0.6 ;
    %vpi_call/w 3 66 "$display", "[%0t] result_reg = 0x%h, out_y = 0x%h", $time, 18'b000000000000000000, v0x144a1e0a0_0 {0 0 0};
    %load/vec4 v0x144a1e0a0_0;
    %cmpi/ne 0, 0, 18;
    %jmp/0xz  T_0.7, 6;
    %vpi_call/w 3 68 "$display", "FAIL!" {0 0 0};
T_0.7 ;
    %delay 100000, 0;
    %vpi_call/w 3 72 "$finish" {0 0 0};
    %end;
    .thread T_0;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "-";
    "fpga/openxc7-synth/tf3_simple_test.v";
