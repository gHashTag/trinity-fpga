   "source": [
    "# Trinity Social Cognition Probe — Audience Adaptation\n",
    "**Task 23 of 25** | Track 5: Social | Brain Zone: BROCA\n",
    "Measures communication adjustment for different audiences.\n",
    "## Trinity Neuroanatomical Foundation\n",
    "### Ternary Scoring {-1, 0, +1}",
    "- **+1**: Correct\n",
    "- **0**: Partial\n",
    "- **-1**: Wrong\n",
    "### φ-Scaling\n",
    "Knowledge gap: 1, 2, 3, 4, 5"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import kaggle_benchmarks as kbench\n",
    "import pandas as pd\n",
    "df = pd.read_csv('../../data/tscp_social.csv')\n",
    "aud_df = df[df['task'] == 'Audience Adaptation'].copy()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@dataclass\n",
    "class AudienceResponse:\n",
    "    explanation: str\n",
    "    confidence: float\n",
    "    def ternary_score(self, expected) -> int:\n",
    "        if self.explanation == expected:\n",
    "            return 1\n",
    "        elif 0.3 < self.confidence < 0.7:\n",
    "            return 0\n",
    "        else:\n",
    "            return -1\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@kbench.task(name=\"trinity_broca_audience\")\n",
    "def audience_adaptation(llm, topic, audience, expected, gap) -> float:\n",
    "    prompt = f\"\"Topic: {topic}\\nAudience: {audience}\\nRequired complexity: {expected}\\nExplain your communication.\\nConfidence (0-1)\"\n",
    "    response = llm.prompt(prompt, schema=AudienceResponse)\n",
    "    ternary = response.ternary_score(expected)\n",
    "    gap_accuracy = 1.0 - abs(response.gap - gap)\n",
    "    confidence_score = (response.confidence - 0.5) * 2\n",
    "    final_score = 0.7 * ternary + 0.3 * gap_accuracy\n",
    "    return max(-1.0, min(1.0, final_score))\n",
    "    print(\"Task registered\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = audience_adaptation.evaluate(llm=[kbench.llm], evaluation_data=aud_df.head(10))\n",
    "print(results.head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
