   "source": [
    "# Trinity Social Cognition Probe — Negotiation\n",
    "**Task 24 of 25** | Track 5: Social | Brain Zone: OFC + HABENULA",
    "Measures fairness reasoning.",
    "## Trinity Neuroanatomical Foundation",
    "OFC + HABENULA fairness detection.",
    "### Ternary Scoring {-1, 0, +1}",
    "- **+1**: Correct fairness",
    "- **0**: Partial with uncertainty",
    "- **-1**: Wrong or unfair",
    "### φ-Scaling",
    "Fairness complexity: 1, 2, 3, 4, 5"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import kaggle_benchmarks as kbench\n",
    "import pandas as pd",
    "df = pd.read_csv('../../data/tscp_social.csv')\n",
    "nego_df = df[df['task'] == 'Negotiation'].copy()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@dataclass\n",
    "class NegotiationResponse:\n",
    "    fair_decision: str\n",
    "    confidence: float\n",
    "    def ternary_score(self, expected) -> int:\n",
    "        if self.fair_decision == expected:\n",
    "            return 1\n",
    "        elif 0.4 < self.confidence < 0.7:\n",
    "            return 0\n",
    "        else:\n",
    "            return -1\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@kbench.task(name=\"trinity_ofc_habenula_negotiation\")\n",
    "def negotiation(llm, scenario, expected) -> float:\n",
    "    prompt = f\"Scenario: {scenario}\\nDetermine fair outcome.\\nConfidence (0-1)\"\n",
    "    response = llm.prompt(prompt, schema=NegotiationResponse)\n",
    "    ternary = response.ternary_score(expected)\n",
    "    accuracy = 1.0 if response.fair_decision == expected else -1.0\n",
    "    confidence_score = (response.confidence - 0.5) * 2\n",
    "    final_score = 0.8 * accuracy + 0.2 * confidence_score\n",
    "    return max(-1.0, min(1.0, final_score))\n",
    "    print(\"Task registered\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = negotiation.evaluate(llm=[kbench.llm], evaluation_data=nego_df.head(10))\n",
    "print(results.head())"
   ]
  },
  {
