# ═════════════════════════════════════════════════════════════════════════════
# TVC-POWERED CODE INDEXER Phase 2 — FULL RAG (Cycle 71)
# ═════════════════════════════════════════════════════════════════════════════

name: tvc_indexer_full
version: "2.0.0"
language: zig
module: tvc_indexer_full

# ═════════════════════════════════════════════════════════════════════════════
# TYPES
# ═════════════════════════════════════════════════════════════════════════════

types:
  TVCEmbedding:
    description: "Hybrid ternary + float32 embedding with 1.58 bits/trit density"
    fields:
      ternary: Hypervector256  # Packed ternary, 1.58 bits/trit!
      float32: Vector384       # Float32 fallback for compatibility
      mode: EmbeddingMode
      timestamp: i64

  EmbeddingMode:
    variants:
      - tvc_ternary    # Pure ternary (fastest, most memory efficient)
      - float32_384    # Pure float32 (compatible)
      - hybrid          # Both ternary + float32

  FileWatcher:
    description: "Real-time file watcher for auto-indexing"
    fields:
      watcher_handle: WatcherHandle
      indexer: CodeIndexer
      running: bool
      debounce_ms: u32  # Debounce delay to avoid excessive reindexing

  RAGContext:
    description: "Retrieval-Augmented Generation context for LLM"
    fields:
      query: string
      chunks: list<CodeChunk>
      scores: list<float>
      sacred_score: float  # φ-weighted final score
      total_chunks: int

  CodeChunk:
    description: "Single code chunk retrieved for RAG"
    fields:
      symbol_name: string
      file_path: string
      line_number: int
      snippet: string
      similarity: float
      sacred_bonus: float  # PAS sacred scoring bonus

  IndexStats:
    description: "Indexer statistics and metrics"
    fields:
      files_indexed: int
      symbols_indexed: int
      total_embeddings: int
      avg_query_time_ms: float
      memory_usage_bytes: int
      last_update_time: i64

  IndexConfig:
    description: "Configuration for TVC indexer"
    fields:
      embedding_mode: EmbeddingMode
      chunk_size: int
      top_k: int
      min_similarity: float
      enable_watcher: bool
      sacred_scoring: bool  # Enable PAS φ-weighted scoring

# ═════════════════════════════════════════════════════════════════════════════
# BEHAVIORS
# ═════════════════════════════════════════════════════════════════════════════

behaviors:
  - name: generate_embedding
    description: "Generate TVC embedding from symbol (ternary + float32)"
    given: "AST symbol with name, signature, and context"
    when: "generate_embedding is called"
    then: |
      1. Convert symbol to searchable text (kind:name:signature:context)
      2. Generate 256-dim ternary VSA embedding using bind/bundle
      3. Generate 384-dim float32 embedding for compatibility
      4. Return TVCEmbedding with both modes

  - name: index_file_with_embeddings
    description: "Index file with full TVC embeddings (Phase 2)"
    given: "File path and CodeIndexer"
    when: "index_file_with_embeddings is called"
    then: |
      1. Parse file with Tree-sitter to extract symbols
      2. For each symbol (function, type, constant):
         a. Generate TVCEmbedding (ternary + float32)
         b. Insert into HNSW-256 index (ternary)
         c. Insert into HNSW-384 index (float32) if hybrid mode
      3. Update IndexStats
      4. Return number of symbols indexed

  - name: reindex_file_on_change
    description: "Re-index file when it's modified (watcher callback)"
    given: "File path that was modified"
    when: "File watcher detects change"
    then: |
      1. Remove all existing embeddings for the file
      2. Call index_file_with_embeddings to re-index
      3. Debounce rapid changes (default 300ms)
      4. Log reindex event

  - name: retrieve_for_rag
    description: "Retrieve top-k chunks for RAG context with sacred scoring"
    given: "Query string and top-k limit"
    when: "retrieve_for_rag is called"
    then: |
      1. Generate query embedding (ternary + float32)
      2. Search HNSW-256 for top-k*2 candidates
      3. Apply PAS sacred scoring (φ-weighted ranking)
      4. Re-rank by: 60% semantic + 30% name_match + 10% recency
      5. Return top-k chunks as RAGContext

  - name: sacred_rank_results
    description: "Apply PAS sacred φ-weighted scoring to search results"
    given: "Search results and query"
    when: "sacred_rank_results is called"
    then: |
      1. Compute base score: similarity * 0.6
      2. Add name match score: * 0.3
      3. Add recency boost: * 0.1
      4. Apply φ-weighting: score * φ² + sacred_bonus * 1/φ²
         Where φ = 1.618033988749, φ² = 2.618..., 1/φ² = 0.382...
      5. Sort by final_score (descending)
      6. Return re-ranked results

  - name: start_file_watcher
    description: "Start real-time file watcher for auto-indexing"
    given: "Root directory path"
    when: "start_file_watcher is called"
    then: |
      1. Initialize file system watcher
      2. Register callback for on_file_changed
      3. Watch recursively for .zig and .vibee files
      4. Start watcher thread
      5. Return FileWatcher handle

  - name: stop_file_watcher
    description: "Stop file watcher and cleanup resources"
    given: "FileWatcher handle"
    when: "stop_file_watcher is called"
    then: |
      1. Set running = false
      2. Unwatch all files
      3. Cleanup watcher resources
      4. Return success

  - name: augment_prompt_with_context
    description: "Augment LLM prompt with retrieved RAG context"
    given: "Original prompt and RAGContext"
    when: "LLM command is executed (code, fix, explain, etc.)"
    then: |
      1. Format retrieved chunks as markdown code blocks
      2. Add context header with file paths and line numbers
      3. Prepend context to original prompt
      4. Add instruction: "Use the above context when answering"
      5. Return augmented prompt

  - name: save_index_to_disk
    description: "Persist index to disk for fast startup"
    given: "Output file path"
    when: "save_index_to_disk is called"
    then: |
      1. Serialize HNSW indices to binary format
      2. Write IndexStats metadata
      3. Compress with gzip for storage efficiency
      4. Return bytes written

  - name: load_index_from_disk
    description: "Load persisted index from disk"
    given: "Index file path"
    when: "load_index_from_disk is called"
    then: |
      1. Verify file exists and is valid
      2. Decompress and deserialize HNSW indices
      3. Load IndexStats metadata
      4. Verify embedding mode matches
      5. Return loaded CodeIndexer

# ═════════════════════════════════════════════════════════════════════════════
# SACRED CONSTANTS (PAS PHI MATH)
# ═════════════════════════════════════════════════════════════════════════════

constants:
  PHI: 1.618033988749           # Golden ratio
  PHI_SQ: 2.618033988749          # φ² = 2.618...
  PHI_INV_SQ: 0.38196601125       # 1/φ² = 0.382...
  TRINITY: 3.0                    # φ² + 1/φ² = 3

  SEMANTIC_WEIGHT: 0.6            # Semantic similarity
  NAME_MATCH_WEIGHT: 0.3          # Symbol name matching
  RECENCY_WEIGHT: 0.1             # Recent files boost
  DEBOUNCE_MS: 300                # File change debounce

  TVC_BITS_PER_TRIT: 1.58         # Information density
  TVC_MEMORY_SAVINGS: 20.0        # vs float32

# ═════════════════════════════════════════════════════════════════════════════
# TEST CASES
# ═════════════════════════════════════════════════════════════════════════════

tests:
  - name: test_generate_embedding_ternary
    description: "Verify ternary embedding generation and bit density"
    given: "Symbol with name 'test_function'"
    when: "generate_embedding is called"
    then: |
      1. TVCEmbedding is returned
      2. ternary.dimension == 256
      3. ternary.bits_per_trit == 1.58
      4. float32.dimension == 384

  - name: test_retrieve_for_rag
    description: "Verify RAG retrieval returns relevant chunks"
    given: "Indexed codebase with VSA functions"
    when: "retrieve_for_rag('VSA bind operation', 5) is called"
    then: |
      1. RAGContext is returned
      2. context.chunks.length == 5
      3. All chunks have similarity > 0.3
      4. context.sacred_score > 0.5

  - name: test_sacred_ranking
    description: "Verify PAS sacred scoring applies φ-weighting"
    given: "Search results with various similarities"
    when: "sacred_rank_results is called"
    then: |
      1. Results are re-ranked by final_score
      2. final_score = (similarity * 0.6 + name_match * 0.3 + recency * 0.1) * φ²
      3. Results sorted in descending order
      4. Top result has highest sacred_score

  - name: test_file_watcher_reindex
    description: "Verify file watcher triggers reindex on change"
    given: "Active FileWatcher and indexed file"
    when: "File is modified"
    then: |
      1. on_file_changed is called within DEBOUNCE_MS
      2. Old embeddings are removed
      3. New embeddings are generated
      4. IndexStats.symbols_indexed is updated

  - name: test_augment_prompt
    description: "Verify prompt augmentation with RAG context"
    given: "RAGContext with 3 chunks and original prompt"
    when: "augment_prompt_with_context is called"
    then: |
      1. Augmented prompt contains context header
      2. All 3 chunks are formatted as code blocks
      3. File paths and line numbers are shown
      4. Original prompt is preserved at the end

  - name: test_index_persistence
    description: "Verify index can be saved and loaded"
    given: "CodeIndexer with 100 indexed symbols"
    when: "save_index_to_disk and load_index_from_disk are called"
    then: |
      1. Index file is created
      2. Loaded indexer has same symbol count
      3. Query returns same results
      4. IndexStats are preserved

# ═════════════════════════════════════════════════════════════════════════════
# GENERATED OUTPUT
# ═════════════════════════════════════════════════════════════════════════════

generated:
  output: "trinity-nexus/output/tri/zig/tvc_indexer_full.zig"
  format: zig
  compiler: "vibeec v7+"

# ═════════════════════════════════════════════════════════════════════════════
# CYCLE 71 DELIVERABLES
# ═════════════════════════════════════════════════════════════════════════════

deliverables:
  - name: TVC Embeddings Generation
    status: pending
    files:
      - "src/tvc/embeddings.zig"

  - name: RAG Retrieval with Sacred Scoring
    status: pending
    files:
      - "src/tvc/rag.zig"

  - name: Real-time File Watching
    status: pending
    files:
      - "src/tvc/watcher.zig"

  - name: CLI Context Command
    status: pending
    files:
      - "src/tri/tri_context.zig"

  - name: RAG Integration
    status: pending
    files:
      - "src/tri/tri_commands.zig (modify)"
      - "src/tri/tri_utils.zig (modify)"
      - "src/tri/main.zig (modify)"

