# ═══════════════════════════════════════════════════════════════════════════════
# TEST EMITTER - VIBEE Codegen Module Specification
# ═══════════════════════════════════════════════════════════════════════════════
#
# Module: test_emitter.zig
# Purpose: Generate Zig test functions from .vibee Behavior definitions
#
# φ² + 1/φ² = 3
#
# ═══════════════════════════════════════════════════════════════════════════════

name: test_emitter
version: "10.1.0"
language: zig
module: vibeec.codegen.test_emitter

dependencies:
  - module: std
    used_as: standard library, testing
  - module: vibeec.codegen.builder
    used_as: CodeBuilder for output
  - module: vibeec.codegen.types
    used_as: Behavior definitions

behaviors:
  - name: writeTests
    given: Array of Behavior definitions
    when: After all behavior functions
    then:
      - Write section header "TESTS"
      - For each behavior:
        - Generate test function named "test.{behavior_name}_behavior"
        - Include given/when/then as comments
        - Add try std.testing.expect calls for assertions
        - If behavior has expected results, add assertions

  - name: writeSpecLevelTests
    given: Array of test case definitions
    when: After behavior-level tests
    then:
      - For each test_case in spec:
        - Generate test function named "test.{test_case.name}"
        - Include test description as comment
        - Implement test logic

test_format: |
  test "behavior_name_behavior" {
      // Given: {given}
      // When: {when}
      // Then: {then}
      try std.testing.expectEqual(expected, actual);
  }

phi_test:
  always_include: true
  test_name: "phi_constants"
  assertions:
    - "PHI * PHI_INV == 1.0"
    - "PHI_SQ - PHI == 1.0"

implementation:
  cycle: "73"
  status: "delegates to tests_gen.zig"
  notes: "Actual implementation in vibeec.codegen.tests_gen"
