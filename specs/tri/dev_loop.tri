# ═══════════════════════════════════════════════════════════════════════════════
# dev_loop v1.0.0 — Full autonomous development cycle
# ═══════════════════════════════════════════════════════════════════════════════
#
# tri dev loop [--iterations N] [--interval Ns]
# Wires: scan → pick → spec create → pipeline gen → test → verdict → commit
# into a single autonomous iteration. The "outer loop" that replaces manual
# issue selection and pipeline invocation.
#
# Part of Trinity Tech Tree: Integration Layer [I1]
# Dependencies: dev_scan (F1), dev_pick (L1), spec_create (L2),
#               toxic_verdict (F2), loop_decide (L3), tri_experience (F3)
#
# Architecture: each step = tri CLI + experience
# scan → pick --smart → spec create → gen → test → verdict → experience save → commit
#
# phi^2 + 1/phi^2 = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

name: dev_loop
version: "1.0.0"
language: zig
module: dev_loop

# ═══════════════════════════════════════════════════════════════════════════════
# TYPES
# ═══════════════════════════════════════════════════════════════════════════════

types:
  LoopPhase:
    enum: [scan, pick, research, spec, gen, verify, verdict, commit, experience, decide]

  LoopStep:
    fields:
      phase: LoopPhase
      started_at: Int64
      finished_at: Int64
      success: Bool
      output: String            # summary of step result
      issue_comment: String     # GitHub comment posted (Protocol v2)

  LoopIteration:
    fields:
      number: UInt32
      issue_number: UInt32      # picked issue
      steps: String
      verdict_score: Float32
      decision: String          # continue/fix/stop from loop_decide
      total_seconds: UInt32

  DevLoopState:
    fields:
      current_iteration: UInt32
      max_iterations: UInt32    # 0 = infinite
      interval_seconds: UInt32  # between iterations
      history: String
      consecutive_failures: UInt32
      total_commits: UInt32
      total_specs_created: UInt32

# ═══════════════════════════════════════════════════════════════════════════════
# BEHAVIORS
# ═══════════════════════════════════════════════════════════════════════════════

behaviors:
  run_once:
    description: >
      Execute one full development iteration:
      (1) tri dev scan → get work queue
      (2) tri dev pick --smart → select issue
      (3) tri issue comment N "RESEARCH Step 1/10" → Protocol v2
      (4) tri spec create <name> --issue N → create .tri if needed
      (5) tri gen → .tri → .zig via vibee gen
      (6) tri issue comment N "CODEGEN Step 5/10"
      (7) tri test → run tests, save failures to .trinity/mistakes/
      (8) tri verdict --toxic → score the iteration
      (9) tri issue comment N "VERDICT: score/100"
      (10) tri experience save → persist episode + learnings + mistakes
      (11) tri git commit "feat(scope): description (#N)"
      (12) tri issue comment N "DONE Step 10/10"
      (13) tri loop decide → continue or stop
      Each step records LoopStep with timing and success status.
      If any step fails, save to mistakes and continue to verdict.
    input: state DevLoopState, allocator
    output: LoopIteration

  run_continuous:
    description: >
      Run dev loop iterations until max_iterations reached or loop_decide
      returns escalate/idle_wait. Sleep interval_seconds between iterations.
      Track consecutive_failures for escalation threshold.
    input: max_iterations UInt32, interval_seconds UInt32, allocator
    output: void

  post_issue_comment:
    description: >
      Post Protocol v2 formatted comment to GitHub issue:
      "{emoji} Agent: dev_loop | {timestamp}"
      "Step: {N}/{total} — {description}"
      "Status: {THINKING|ACTING|DONE|FAILED}"
      Uses tri issue comment N "body" (gh CLI).
    input: issue_number UInt32, step_number UInt32, total_steps UInt32, description String, status String
    output: void

  save_mistakes:
    description: >
      When a step fails, save to .trinity/mistakes/:
      (1) Error message and context
      (2) Which step failed (phase)
      (3) Issue number and spec name
      (4) Timestamp
      This feeds tri dev pick --smart MNL anti-pattern detection.
    input: phase LoopPhase, error String, issue_number UInt32, allocator
    output: void

  render_iteration_summary:
    description: >
      After iteration completes, print summary:
      "Iteration N: #42 Fix VSA bind — VERDICT 78/100 SOLID"
      "Steps: 10/10 completed | Time: 45s | Decision: CONTINUE"
      Compare with past: "Past: 3/7. Now: 7/7"
    input: LoopIteration
    output: void

  run_dev_loop_command:
    description: >
      CLI entrypoint for tri dev loop [--iterations N] [--interval Ns].
      Default: 1 iteration, 0 interval. With --iterations 0: infinite loop.
      Loads/creates DevLoopState from .trinity/dev_loop_state.json.
      Runs iterations, saves state between each.
    input: args String, allocator
    output: void

# ═══════════════════════════════════════════════════════════════════════════════
# REUSES
# ═══════════════════════════════════════════════════════════════════════════════

reuses:
  - dev_scan.zig (runScanCommand, ScanResult)
  - dev_pick.zig (runPickCommand, PickResult)
  - spec_create.zig (runSpecCreateCommand)
  - toxic_verdict.zig (runVerdictCommand, VerdictScore)
  - loop_decide.zig (runLoopDecideCommand, DecisionReport)
  - tri_experience.zig (saveEpisode, updateMistakePatterns)
  - github_commands.zig (issue comment)
  - pipeline_executor.zig (run pipeline links)

# ═══════════════════════════════════════════════════════════════════════════════
# TESTS
# ═══════════════════════════════════════════════════════════════════════════════

tests:
  test_single_iteration:
    description: One iteration completes all 10 phases in order
  test_failure_recovery:
    description: Test failure at gen phase still reaches verdict and experience save
  test_consecutive_failures:
    description: 5 consecutive failures triggers escalate decision
  test_issue_comments:
    description: Each phase posts Protocol v2 formatted comment
  test_state_persistence:
    description: DevLoopState saved to JSON between iterations
  test_mistakes_saved:
    description: Failed step saves to .trinity/mistakes/ with error context
