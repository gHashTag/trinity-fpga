name: e2e_job_tests
version: "1.0.0"
language: zig
module: e2e_job_tests

types: {}

behaviors:
  - name: "e2e.job.happy_path_constants_command"
    given: "Fresh JobManager initialized with testing allocator"
    when: "Job started with command='constants', status queried, logs retrieved, artifacts retrieved"
    then: |
      - job_id is non-null and caller-owned
      - status.state == .completed, status.exit_code == 0
      - logs.stdout is non-empty and contains "Golden Ratio"
      - artifacts list is returned without error (may be empty)

  - name: "e2e.job.replayable_state_from_disk"
    given: "Job started via job_manager1, then new job_manager2 initialized separately"
    when: "job_manager2 queries status and logs for the same job_id"
    then: |
      - job_manager2.jobs in-memory map does NOT contain the job_id
      - status is still loadable from disk: state == .completed
      - logs are still loadable from disk

  - name: "e2e.job.project_root_normalized"
    given: "Fresh JobManager"
    when: "project_root field is inspected and .trinity/jobs directory opened"
    then: |
      - project_root.len > 0
      - Directory at <project_root>/.trinity/jobs/ exists and can be opened

  - name: "e2e.job.list_scans_disk"
    given: "JobManager after starting at least one job"
    when: "list() is called"
    then: |
      - Returns at least 1 job ID
      - The newly started job_id is present in the returned list

  - name: "e2e.job.cancel_completed_job"
    given: "JobManager after job completes"
    when: "cancel(job_id) is called on an already-completed job"
    then: |
      - Returns false (not an error)
      - Subsequent status query still shows state == .completed
