# Ternary Matrix Multiplication Specification v2.0
# BitNet-style {-1, 0, +1} weights — 10x matmul speedup, 16-20x compression
# OPT-T02: Phase 2 — consolidates ternary_weights + tnn + ternary_packing
# φ² + 1/φ² = 3 | KOSCHEI IS IMMORTAL

name: ternary_matmul
version: "2.0.0"
language: zig
module: ternary_matmul

description: |
  Standalone ternary matrix multiplication engine for LLM inference.
  Consolidates best patterns from ternary_weights.zig, tnn.zig, ternary_packing.zig.
  2-bit encoding: 00=0, 01=+1, 10=-1. 4 trits per byte.
  Per-row scale factors for quantization accuracy.
  SIMD-optimized (8-wide + 16-wide), batched (4-row + 8-row).
  MatVec AND MatMat (true matrix-matrix multiplication).
  Zero external dependencies — fully self-contained generated module.

types:
  TernaryMatrix:
    description: "Packed ternary weight matrix with per-row scales"
    fields:
      data: List<Int>
      scales: List<Float>
      rows: Int
      cols: Int
      cols_packed: Int

  QuantConfig:
    description: "Quantization configuration"
    fields:
      mode: String
    modes:
      - absmean: "threshold = mean(|w|) * 0.5"
      - rms: "threshold = rms(w) * 0.5"
      - max: "threshold = max(|w|) * 0.5"

  MemoryStats:
    description: "Memory usage comparison"
    fields:
      f32_bytes: Int
      ternary_bytes: Int
      compression_ratio: Float
      rows: Int
      cols: Int

behaviors:
  - name: quantize_row
    given: f32 row vector and threshold
    when: Packing weights to ternary
    then: Returns packed bytes + scale factor for the row

  - name: quantize_matrix
    given: f32 weight matrix (rows x cols) and QuantConfig
    when: Converting full weight matrix to ternary
    then: Returns TernaryMatrix with per-row scales

  - name: dequantize_row
    given: Packed ternary bytes, scale, and row length
    when: Reconstructing f32 approximation
    then: Returns f32 vector where trit * scale

  - name: ternary_matvec_scalar
    given: TernaryMatrix and f32 input vector
    when: Computing y = W * x (scalar path)
    then: Output via add/sub only — no multiplication

  - name: ternary_matvec_simd8
    given: TernaryMatrix and f32 input vector
    when: Computing y = W * x with @Vector(8, f32)
    then: 8-wide SIMD with sign LUT decode, scalar tail

  - name: ternary_matvec_simd16
    given: TernaryMatrix and f32 input vector
    when: Computing y = W * x with @Vector(16, f32)
    then: 16-wide SIMD (AVX-512), scalar tail

  - name: ternary_matvec_batch4
    given: TernaryMatrix and f32 input vector
    when: Computing 4 output rows simultaneously
    then: 4x register-level parallelism

  - name: ternary_matvec_batch8
    given: TernaryMatrix and f32 input vector
    when: Computing 8 output rows simultaneously
    then: 8x register-level parallelism, falls back to batch4/scalar

  - name: ternary_matmat
    given: TernaryMatrix W and f32 matrix X (cols x batch)
    when: Computing Y = W * X for batched inference
    then: Column-major output, reuses matvec kernels

  - name: compute_memory_stats
    given: Matrix dimensions (rows, cols)
    when: Analyzing memory savings
    then: Returns compression ratio (16-20x vs f32)

  - name: accuracy_check
    given: f32 weights and TernaryMatrix
    when: Validating quantization quality
    then: Cosine similarity per row, mean absolute error

optimizations:
  - name: sign_lookup_table
    description: "SIGN_LUT[4] = {0.0, 1.0, -1.0, 0.0} for instant trit decode"

  - name: no_multiplication
    description: "y += x (trit=+1), y -= x (trit=-1), skip (trit=0)"

  - name: per_row_scales
    description: "Each row has independent scale for accuracy"

  - name: simd_reduction
    description: "@reduce(.Add, vec) for horizontal sum"

  - name: batch_row_parallelism
    description: "Process 4-8 rows simultaneously for register reuse"

  - name: cache_friendly_layout
    description: "Row-major packed data, sequential access pattern"

benchmarks:
  - name: throughput
    metric: "GFLOPS equivalent"
    target: ">100 GFLOPS on AVX2"

  - name: memory_compression
    metric: "ratio"
    target: "16-20x vs f32"

  - name: accuracy
    metric: "cosine similarity"
    target: ">0.90 per row"

  - name: simd_vs_scalar_speedup
    metric: "ratio"
    target: ">3x"

integration:
  - target: inference_pipeline
    description: "Replace float matmul in forward pass"

  - target: ternary_kv_cache
    description: "Complement OPT-T03 for full ternary attention"

  - target: kv_cache_optimized
    description: "Use with ring buffer for streaming inference"
