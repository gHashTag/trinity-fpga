# ═══════════════════════════════════════════════════════════════════════════════
# e2e_toxic_test v1.0.0 — E2E test framework with toxic verdict
# ═══════════════════════════════════════════════════════════════════════════════
#
# tri test e2e [--toxic] [--threshold N]
# Runs full pipeline on test scenarios, captures verdict, asserts score >= threshold.
# --toxic: verdict below threshold = test FAIL with roast.
#
# Part of Trinity Tech Tree: Integration Layer [I2]
# Dependencies: toxic_verdict.zig (F2), tri_experience.zig (F3)
#
# phi^2 + 1/phi^2 = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

name: e2e_toxic_test
version: "1.0.0"
language: zig
module: e2e_toxic_test

# ═══════════════════════════════════════════════════════════════════════════════
# TYPES
# ═══════════════════════════════════════════════════════════════════════════════

types:
  E2EScenario:
    fields:
      name: String
      description: String
      spec_path: String         # .tri file to test
      expected_compile: Bool
      min_verdict_score: Float32  # threshold for PASS

  E2EResult:
    fields:
      scenario: String
      compile_ok: Bool
      verdict_score: Float32
      passed: Bool              # score >= threshold AND compile matches expected
      duration_ms: UInt32
      error_detail: String

  E2ESuite:
    fields:
      results: String
      total: UInt32
      passed: UInt32
      failed: UInt32
      avg_verdict: Float32
      total_duration_ms: UInt32

# ═══════════════════════════════════════════════════════════════════════════════
# BEHAVIORS
# ═══════════════════════════════════════════════════════════════════════════════

behaviors:
  discover_scenarios:
    description: >
      Scan specs/tri/*.tri for testable specs. Each spec = one scenario.
      Filter to specs with test blocks defined. Set min_verdict_score
      from --threshold flag (default 50). Cap at 20 specs per run for speed.
    input: args String, allocator
    output: String

  run_scenario:
    description: >
      For one scenario:
      (1) Run vibee gen <spec_path> → check compile
      (2) Run zig ast-check on generated .zig
      (3) Compute verdict score (build + compile + coverage)
      (4) Compare with threshold → PASS/FAIL
      Record timing.
    input: scenario E2EScenario, allocator
    output: E2EResult

  run_suite:
    description: >
      Run all scenarios sequentially. Aggregate results into E2ESuite.
      Compute average verdict score. Save results to .trinity/e2e_results.json.
    input: scenarios String, allocator
    output: E2ESuite

  render_results:
    description: >
      Display results table with pass/fail per scenario.
      Show aggregate: "E2E: 15/20 PASS (75%) — avg verdict 68/100"
      In toxic mode: roast failures brutally.
      Compare with previous run from .trinity/e2e_results.json.
    input: suite E2ESuite, toxic Bool
    output: void

  run_e2e_command:
    description: >
      CLI entrypoint for tri test e2e [--toxic] [--threshold N].
      Discover scenarios → run suite → render results.
      Exit code = number of failures (0 = all pass).
    input: args String, allocator
    output: void

# ═══════════════════════════════════════════════════════════════════════════════
# REUSES
# ═══════════════════════════════════════════════════════════════════════════════

reuses:
  - toxic_verdict.zig (VerdictScore, compute_score)
  - tri_experience.zig (save results as episodes)

# ═══════════════════════════════════════════════════════════════════════════════
# TESTS
# ═══════════════════════════════════════════════════════════════════════════════

tests:
  test_discover_specs:
    description: Finds at least 10 testable specs in specs/tri/
  test_pass_threshold:
    description: Score above threshold = PASS
  test_fail_threshold:
    description: Score below threshold = FAIL with error detail
  test_comparison:
    description: Previous run results compared with current
