name: agent_mu_self_evolution_guard
version: "8.8.0"
language: zig
module: trinity-nexus

description: |
  AGENT MU — Post-Generation Guard & Self-Evolution
  μ = 1/φ²/10 = 0.0382 — священная мутация, превращающая ошибки в преимущества

  Стоит на страже после каждого TRI GEN:
  - Проверяет качество (build + test + format)
  - Автоматически фиксит генератор
  - Каждый фейл → SUCCESS_HISTORY
  - Каждая ошибка → исключена навсегда

types:
  # Священные фазы μ-мутации (ASCII identifiers for Zig compatibility)
  # V = Verification, φ = Phi, π = Pi, e = E, μ = Mu, χ = Chi, σ = Sigma, ε = Epsilon, L = Loop
  MuPhase:
    enum:
      - V01      # φ⁰: Verification (build + test + format check)
      - Phi02    # φ¹: Pattern Search (REGRESSION_PATTERNS.md)
      - Pi03     # φ²: Diagnostic (FixType classification)
      - E04      # φ³: Pattern Match (apply known solution)
      - Mu05     # φ⁴: Auto-Fix (apply correction)
      - Chi06    # φ⁵: Regress (failures → REGRESSION_PATTERNS.md)
      - Sigma07  # φ⁶: Success (fix → SUCCESS_HISTORY.md)
      - Epsilon08 # φ⁷: Template Update (mutate generator)
      - L09      # φ⁸: Loop (integrate with AGENT L)

  # Тип исправления
  FixType:
    enum:
      - SPEC_FIX          # .vibee синтаксическая ошибка
      - GENERATOR_PATCH    # баг в vibee компиляторе
      - TEMPLATE_FIX      # ошибка в шаблоне кода
      - IMPORT_FIX        # пропущенный импорт
      - TYPE_FIX          # несоответствие типов
      - SYNTAX_FIX        # синтаксическая ошибка Zig

  # Результат верификации
  VerifyResult:
    fields:
      phase: MuPhase
      success: Bool
      build_passed: Bool
      test_passed: Bool
      format_passed: Bool
      exit_code: Int
      stderr: String
      stdout: String

  # Диагностика ошибки
  ErrorDiagnostic:
    fields:
      fix_type: FixType
      message: String
      file: String
      line: Int
      column: Int
      code_snippet: String

  # Результат попытки фикса
  FixAttempt:
    fields:
      phase: MuPhase
      success: Bool
      fix_description: String
      files_modified: List<String>
      new_exit_code: Int
      attempts_made: Int

  # Паттерн из REGRESSION_PATTERNS.md
  RegressionPattern:
    fields:
      date: String
      anti_pattern: String
      root_cause: String
      symptom: String
      correct_approach: String
      files: List<String>
      attempted_fixes: List<String>
      manual_review_required: Bool

behaviors:
  - name: post_gen_guard_mu
    given: После триггера выхода из gen_cmd.zig (строка 222)
    when: Немедленно после записи сгенерированного .zig файла
    then:
      - Синхронизировать файл (out_file.sync())
      - Инициализировать VerifyResult с фазой V01
      - Запустить verifier.verify(build + test + format)
      - Если всё ОК → финализировать с фазой Sigma07
      - Если ошибка → передать управление diagnostic_and_fix

  - name: verify_code_quality
    given: Сгенерированный .zig файл
    when: Фаза V01
    then:
      - Запустить zig build-obj (проверка компиляции)
      - Если success → запустить zig test (проверка тестов)
      - Если tests pass → запустить zig fmt --check (проверка форматирования)
      - Собрать все stderr в combined_stderr
      - Вернуть VerifyResult с деталями каждого этапа

  - name: diagnostic_and_fix
    given: VerifyResult с success = false
    when: Когда верификация провалилась
    then:
      - Передать stderr в diagnostic.parse для классификации
      - Получить ErrorDiagnostic с FixType
      - Передать в pattern_matcher.search для поиска известных решений
      - Если паттерн найден → apply_known_fix (фаза E04)
      - Если паттерн не найден → attempt_new_fix (фаза Mu05)
      - Максимум 3 попытки (sacred number 1/φ²)
      - Если все попытки неудачны → log_regression (фаза Chi06)
      - Если успех → log_success (фаза Sigma07)

  - name: classify_error
    given: stderr от zig build
    when: Фаза Pi03
    then:
      - Парсить формат Zig: /path/to/file.zig:42:15: error: message
      - Извлечь: путь, строку, колонку, сообщение
      - Классифицировать в FixType по ключевым словам:
        - "use of undeclared identifier" → IMPORT_FIX
        - "expected type" → TYPE_FIX
        - "expected ';'" → SYNTAX_FIX
        - "no field named" → TEMPLATE_FIX
        - .vibee расширение → SPEC_FIX
        - иначе → GENERATOR_PATCH

  - name: search_regression_patterns
    given: ErrorDiagnostic с известным FixType
    when: Фаза Phi02
    then:
      - Открыть .ralph/memory/REGRESSION_PATTERNS.md
      - Поиск по FixType + ключевым словам из error message
      - Если найдено → извлечь correct_approach
      - Вернуть RegressionPattern с known_solution = true

  - name: apply_known_fix
    given: RegressionPattern с correct_approach
    when: Фаза E04
    then:
      - Применить correct_approach из паттерна
      - Записать FixAttempt с success = true/false
      - Повторить верификацию
      - Если success → log_success
      - Если failure → следующая попытка

  - name: attempt_new_fix
    given: ErrorDiagnostic без известного паттерна
    when: Фаза Mu05
    then:
      - IMPORT_FIX: добавить недостающий импорт
      - SYNTAX_FIX: исправить синтаксис (semicolon, brace)
      - SPEC_FIX: исправить .vibee синтаксис
      - TYPE_FIX: добавить приведение типа
      - TEMPLATE_FIX: обновить шаблон кодогенерации
      - GENERATOR_PATCH: требуется ручное вмешательство
      - Повторить верификацию
      - Вернуть FixAttempt с результатом

  - name: log_regression
    given: 3 неудачные попытки фикса
    when: Фаза Chi06
    then:
      - Добавить запись в .ralph/memory/REGRESSION_PATTERNS.md:
        - date: ISO 8601 timestamp
        - anti_pattern: описание ошибки
        - root_cause: анализ причины
        - symptom: error message
        - correct_approach: TBD
        - files: список затронутых файлов
        - attempted_fixes: все 3 попытки
        - manual_review_required: true
      - Уведомить AGENT PHI через callback
      - Установить фазу = L09 (требуется человек)

  - name: log_success
    given: Успешный фикс (верификация passed)
    when: Фаза Sigma07
    then:
      - Добавить запись в .ralph/memory/SUCCESS_HISTORY.md:
        - date: ISO 8601 timestamp
        - type: feature / fix
        - files: список изменённых файлов
        - branch: ralph/agent-mu-auto
        - tech_tree: NEXUS-011
        - status: success
        - Pattern: что было исправлено
        - What worked: как было исправлено
        - Lesson: урок на будущее
      - Удалить соответствующий паттерн из REGRESSION_PATTERNS.md (если был)
      - Вычислить μ-мутацию: 1/φ²/10 = 0.0382
      - Обновить шаблоны генератора (если нужно)
      - Установить фазу = Epsilon08 (Template Update)

  - name: update_generator_templates
    given: Успешный фикс с new pattern
    when: Фаза Epsilon08
    then:
      - Определить какой шаблон кодогенерации нужно обновить
      - Применить μ-мутацию (1/φ²/10)
      - Обновить src/vibeec/codegen/ patterns
      - Сохранить backup предыдущей версии
      - Следующая генерация будет лучше

  - name: integrate_with_agent_l
    given: Результат верификации
    when: Фаза L09
    then:
      - Передать результат в AGENT L (Loop Decision)
      - Если success → продолжить Golden Chain
      - Если regression с manual_review = true → эскалировать человеку
      - Если regression без manual → попробовать альтернативные подходы

quality_gates:
  - name: gate_code_quality
    description: |
      Каждый сгенерированный .zig файл должен:
      - Компилироваться без ошибок (zig build-obj)
      - Проходить тесты (zig test)
      - Проходить формат-чек (zig fmt --check)
    acceptance:
      - Все generated файлы проходят верификацию
      - Ошибки классифицированы в FixType
      - Известные паттерны исправляются автоматически
      - Новые паттерны логируются для анализа

config:
  max_retries: 3
  timeout_seconds: 120
  enable_auto_fix: true
  enable_template_update: true
  verbose_logging: true

output:
  module: agent_mu
  files:
    - src/agent_mu/agent_mu.zig       # Главный модуль
    - src/agent_mu/verifier.zig       # Вертификация
    - src/agent_mu/diagnostic.zig     # Диагностика
    - src/agent_mu/pattern_matcher.zig # Поиск паттернов
    - src/agent_mu/fixer.zig          # Применение фиксов
    - src/agent_mu/logger.zig         # Логирование
    - src/agent_mu/template_updater.zig # Обновление шаблонов
