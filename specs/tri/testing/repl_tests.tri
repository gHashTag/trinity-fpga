name: repl_tests
version: "1.0.0"
language: zig
module: testing

types:
  TestCase:
    fields:
      command: String
      expected_output: String
      sacred_assertions: List<String>
      category: String

  TestResult:
    fields:
      test_name: String
      passed: Bool
      output: String
      error: Option<String>

  ReplTestSuite:
    fields:
      name: String
      tests: List<TestCase>
      setup_commands: List<String>
      teardown_commands: List<String>

behaviors:
  - name: init_repl_tester
    given: Allocator available
    when: ReplTester initialized
    then: Returns tester with isolated CLIState and output buffer

  - name: test_math_phi
    given: ReplTester initialized
    when: "phi <n>" command executed
    then: Output contains "φ^n" and correct value
    test_data:
      - { command: "phi 0", expected: "φ^0 = 1", category: "math" }
      - { command: "phi 1", expected: "φ^1 = 1.618", category: "math" }
      - { command: "phi 10", expected: "122.99", category: "math" }
      - { command: "phi 20", expected: "15126", category: "math" }

  - name: test_math_fib
    given: ReplTester initialized
    when: "fib <n>" command executed
    then: Output contains "F(n)" and correct Fibonacci number
    test_data:
      - { command: "fib 0", expected: "F(0) = 0", category: "math" }
      - { command: "fib 1", expected: "F(1) = 1", category: "math" }
      - { command: "fib 10", expected: "F(10) = 55", category: "math" }
      - { command: "fib 20", expected: "F(20) = 6765", category: "math" }

  - name: test_math_lucas
    given: ReplTester initialized
    when: "lucas <n>" command executed
    then: Output contains "L(n)" and correct Lucas number
    test_data:
      - { command: "lucas 0", expected: "L(0) = 2", category: "math" }
      - { command: "lucas 1", expected: "L(1) = 1", category: "math" }
      - { command: "lucas 2", expected: "L(2) = 3", category: "math" }
      - { command: "lucas 10", expected: "L(10) = 123", category: "math" }
    sacred_assertions:
      - "L(2) = 3 represents Trinity"

  - name: test_math_constants
    given: ReplTester initialized
    when: "constants" command executed
    then: Output displays sacred constants (φ, π, e, μ, χ, σ, ε)
    sacred_assertions:
      - "expectSacredConstants"
      - "expectPhiPresent"

  - name: test_math_formula_trinity
    given: ReplTester initialized
    when: "formula trinity" command executed
    then: Output shows Trinity Identity "φ² + 1/φ² = 3"
    sacred_assertions:
      - "expectTrinityIdentity"

  - name: test_agent_identity
    given: ReplTester initialized
    when: "identity" command executed
    then: Output contains "I am Sacred Intelligence" and Trinity Identity
    test_data:
      - { command: "identity", expected: "Sacred Intelligence", category: "agent" }
    sacred_assertions:
      - "expectSacredIntelligence"
      - "expectTrinityIdentity"

  - name: test_agent_omega
    given: ReplTester initialized
    when: "omega" command executed
    then: Output mentions omega awakening and Ω symbol
    test_data:
      - { command: "omega", expected: "Ω", category: "agent" }

  - name: test_agent_dashboard
    given: ReplTester initialized
    when: "dashboard" command executed
    then: Output mentions dashboard or canvas interface
    test_data:
      - { command: "dashboard", expected: "dashboard", category: "agent" }

  - name: test_swe_explain
    given: ReplTester initialized
    when: "explain <topic>" command executed
    then: Output provides explanation of topic
    test_data:
      - { command: "explain What is Zig?", expected: "Zig", category: "swe" }

  - name: test_swe_reason
    given: ReplTester initialized
    when: "reason <query>" command executed
    then: Output shows chain-of-thought reasoning
    test_data:
      - { command: "reason 2 + 2", expected: "4", category: "swe" }

  - name: test_info_version
    given: ReplTester initialized
    when: "version" command executed
    then: Output shows TRINITY version number
    test_data:
      - { command: "version", expected: "TRINITY", category: "info" }

  - name: test_info_help
    given: ReplTester initialized
    when: "help" command executed
    then: Output shows USAGE and COMMANDS sections
    test_data:
      - { command: "help", expected: "USAGE", category: "info" }

  - name: test_chain_spec_create
    given: ReplTester initialized
    when: "spec_create <name>" command executed
    then: Output confirms spec creation
    test_data:
      - { command: "spec_create test_module", expected: "spec", category: "chain" }

  - name: test_chain_plan
    given: ReplTester initialized
    when: "plan <task>" command executed
    then: Output generates implementation plan
    test_data:
      - { command: "plan Implement feature X", expected: "Plan", category: "chain" }

  - name: test_error_invalid_command
    given: ReplTester initialized
    when: Invalid command executed
    then: Returns non-zero exit code
    test_data:
      - { command: "invalid_command_xyz", expected: "error", category: "error" }

  - name: test_error_missing_argument
    given: ReplTester initialized
    when: Command executed without required argument
    then: Output mentions error or usage
    test_data:
      - { command: "phi", expected: "error", category: "error" }

  - name: test_integration_multiple_commands
    given: ReplTester initialized
    when: Multiple commands executed in sequence
    then: Each command produces correct output
    test_data:
      - { command: "phi 1", expected: "1.618", category: "integration" }
      - { command: "fib 10", expected: "55", category: "integration" }
      - { command: "constants", expected: "φ", category: "integration" }

  - name: test_regression_trinity_identity
    given: ReplTester initialized
    when: "identity" command executed
    then: Trinity Identity always present
    sacred_assertions:
      - "expectTrinityIdentity"
    category: "regression"

  - name: test_sacred_assertions_phi
    given: Output from phi command
    when: Checked for phi presence
    then: Contains φ or "phi" or numeric value
    sacred_assertions:
      - "expectPhiPresent"

  - name: test_sacred_assertions_gematria
    given: Output from gematria command
    when: Checked for gematria values
    then: Contains "Gematria:" or "g:"
    sacred_assertions:
      - "expectGematria"

  - name: test_sacred_assertions_fibonacci
    given: Output from fib command
    when: Checked for Fibonacci reference
    then: Contains "Fibonacci:" or "Fib:"
    sacred_assertions:
      - "expectFibonacci"

  - name: test_sacred_assertions_lucas
    given: Output from lucas command
    when: Checked for Lucas reference
    then: Contains "Lucas:" or Lucas number
    sacred_assertions:
      - "expectLucas"

  - name: test_sacred_assertions_trit_symbols
    given: Output with trit symbols
    when: Checked for ▲ ▼ ● symbols
    then: Contains at least one trit symbol
    sacred_assertions:
      - "expectTritSymbols"

  - name: run_repl_test_suite
    given: Test suite defined with test cases
    when: Test suite executed
    then: Returns aggregate results with pass/fail counts

  - name: assert_sacred_score
    given: Output containing sacred score
    when: Score validated against minimum threshold
    then: Passes if score >= threshold

  - name: expect_pattern_match
    given: Output text and pattern with wildcards
    when: Pattern matched against output
    then: Returns true if pattern matches

  - name: strip_ansi_codes
    given: Text with ANSI escape codes
    when: Codes stripped
    then: Returns clean text

  - name: wildcard_match
    given: Text and pattern with * and ?
    when: Pattern matched
    then: Returns true if match
