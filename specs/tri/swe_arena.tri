# ═══════════════════════════════════════════════════════════════════════════════
# swe_arena v1.0.0 — SWE Agent Benchmark Arena
# ═══════════════════════════════════════════════════════════════════════════════
#
# Standardized benchmarks for dev agents. 10 tasks (easy/medium/hard).
# Compare Trinity pipeline vs raw Claude Code vs competitors.
#
# φ² + 1/φ² = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

name: swe_arena
version: "1.0.0"
language: zig
module: swe_arena

types:
  Difficulty:
    enum:
      - easy       # single-file fix, <10 lines
      - medium     # multi-file, new function
      - hard       # new module, cross-cutting

  BenchmarkTask:
    fields:
      id: String
      title: String
      description: String
      difficulty: Difficulty
      expected_files: List<String>
      expected_tests: UInt32
      time_budget_minutes: UInt32

  ArenaResult:
    fields:
      task_id: String
      solver: String             # "trinity-pipeline", "claude-code", "manual"
      solved: Bool
      time_seconds: UInt32
      tokens_used: UInt32
      test_pass_rate: Float32
      code_quality: Float32      # 0.0-1.0
      cost_usd: Float32

  CompetitorScore:
    fields:
      name: String
      tasks_solved: UInt32
      total_tasks: UInt32
      avg_time_seconds: UInt32
      avg_cost_usd: Float32
      solve_rate: Float32        # tasks_solved / total_tasks

behaviors:
  - name: run_local
    given: Local codebase with zig build and tests
    when: User runs `tri dev arena run local`
    then: |
      1. Run `zig build test` and capture output
      2. Count passed/failed tests, measure elapsed time
      3. Run `zig build` and check compile success
      4. Create ArenaResult with solver="local", test_pass_rate, time_seconds
      5. Save result to .trinity/arena_results.json

  - name: run_benchmark
    given: A benchmark task ID or "all"
    when: User runs `tri dev arena run <ID>`
    then: Spawn dev agent for task, collect ArenaResult (requires Railway)

  - name: compare
    given: ArenaResults stored in .trinity/arena_results.json
    when: User runs `tri dev arena compare`
    then: |
      1. Load results from .trinity/arena_results.json
      2. Group by solver, compute CompetitorScore per solver
      3. Display side-by-side table sorted by solve rate

  - name: generate_leaderboard
    given: All ArenaResults
    when: Comparison complete
    then: Markdown leaderboard sorted by solve_rate, then time, then cost

test_cases:
  - name: easy_task_solves
    given: Easy benchmark task (single-file fix)
    when: Trinity pipeline agent runs
    then: solved=true, time < 5min

  - name: leaderboard_format
    given: Results from 3 solvers
    when: Leaderboard generated
    then: Markdown table with correct ranking

  - name: parse_test_output
    given: "42/42 tests passed" output from zig build test
    when: Parsed
    then: passed=42, total=42, rate=1.0

  - name: parse_test_failures
    given: "38/42 tests passed" with failures
    when: Parsed
    then: passed=38, total=42, rate=0.905

  - name: result_save_load
    given: ArenaResult with solver="local", solved=true
    when: Saved and loaded
    then: Fields preserved

  - name: competitor_aggregation
    given: 3 results for solver "local"
    when: Aggregated into CompetitorScore
    then: tasks_solved and avg_time computed correctly

exit_criteria:
  compiles: true
  benchmark_tasks_loadable: true
  leaderboard_renders: true

metadata:
  author: Trinity SWE Pipeline
  date: 2026-03-14
  phase: 1
  depends_on:
    - dev_farm.tri
    - dev_pipeline.tri
    - swe_entrypoint.tri
