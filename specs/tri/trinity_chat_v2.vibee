name: trinity_chat_v2
version: "2.0.0"
language: zig
module: igla_hybrid_chat

description: |
  Trinity Chat v2.0 - Self-learning, energy-saving, multi-provider hybrid chat.
  3-level cache: Symbolic -> TVC Corpus -> Multi-provider LLM cascade.
  LLM responses saved to TVC corpus for future fast retrieval (self-learning).
  Energy metrics track symbolic vs LLM usage for green computing.
  φ² + 1/φ² = 3 saves energy — Koschei is energy immortal!

constants:
  SYMBOLIC_THRESHOLD: 0.3
  TVC_THRESHOLD: 0.55
  TVC_AUTOSAVE_INTERVAL: 5
  MAX_TOKENS: 32
  TEMPERATURE: 0.7
  TOP_P: 0.9
  ENERGY_SYMBOLIC_WH: 0.0001
  ENERGY_TVC_WH: 0.001
  ENERGY_LOCAL_LLM_WH: 0.05
  ENERGY_CLOUD_LLM_WH: 0.1
  GROQ_MODEL: "llama-3.3-70b-versatile"
  CLAUDE_MODEL: "claude-3-5-sonnet-20241022"

types:
  ResponseSource:
    description: "Where the response originated"
    variants:
      - Symbolic
      - TVCCorpus
      - LocalLLM
      - GroqAPI
      - ClaudeAPI
      - Error

  HybridConfig:
    description: "Configuration for hybrid chat v2"
    fields:
      symbolic_confidence_threshold: Float
      tvc_similarity_threshold: Float
      tvc_corpus_path: Option<String>
      tvc_autosave_interval: Int
      max_tokens: Int
      temperature: Float
      top_p: Float
      use_ternary: Bool
      system_prompt: String
      groq_api_key: Option<String>
      groq_model: String
      claude_api_key: Option<String>
      claude_model: String
      enable_reflection: Bool
      enable_energy_metrics: Bool

  EnergyMetrics:
    description: "Track energy savings from symbolic/TVC cache hits vs LLM calls"
    fields:
      symbolic_hits: Int
      tvc_hits: Int
      local_llm_calls: Int
      groq_calls: Int
      claude_calls: Int
      total_queries: Int
      symbolic_latency_sum_us: Int
      tvc_latency_sum_us: Int
      llm_latency_sum_us: Int

  HybridResponse:
    description: "Response with source tracking and energy metadata"
    fields:
      response: String
      source: ResponseSource
      language: String
      confidence: Float
      latency_us: Int
      tvc_similarity: Option<Float>

  Stats:
    description: "Session statistics with energy metrics"
    fields:
      total_queries: Int
      symbolic_hits: Int
      llm_calls: Int
      symbolic_hit_rate: Float
      llm_loaded: Bool
      tvc_enabled: Bool
      tvc_hits: Int
      tvc_corpus_size: Int
      tvc_hit_rate: Float
      cache_hit_rate: Float
      energy_saved_wh: Float
      groq_calls: Int
      claude_calls: Int

behaviors:
  - name: respond
    description: "3-level cache: symbolic -> TVC corpus -> multi-provider LLM"
    given: "User query string"
    when: "respond() is called"
    then: >
      1. Try symbolic pattern matcher (igla_local_chat)
      2. If confidence >= symbolic_threshold: return Symbolic response (0 energy)
      3. Search TVC corpus for similar cached query
      4. If TVC similarity >= tvc_threshold: return TVCCorpus response (low energy)
      5. Call llmCascade: local GGUF -> Groq -> Claude
      6. On LLM success: save (query, response) to TVC corpus (self-learning)
      7. Update energy metrics
      8. Return response with source metadata

  - name: llm_cascade
    description: "Multi-provider LLM fallback chain"
    given: "Query that failed symbolic + TVC lookup"
    when: "LLM inference needed"
    then: >
      1. If local GGUF model available: try local inference
      2. If local fails and GROQ_API_KEY set: try Groq API
      3. If Groq fails and ANTHROPIC_API_KEY set: try Claude API
      4. If all fail: return symbolic response with low confidence
      5. Track which provider succeeded in energy metrics

  - name: self_reflect
    description: "Save LLM response to TVC corpus for future fast retrieval"
    given: "Successful LLM response for a query"
    when: "LLM call succeeds and enable_reflection is true"
    then: >
      1. Store (query, response) pair in TVC corpus via VSA encoding
      2. Auto-save corpus to disk if stores >= autosave_interval
      3. Next identical/similar query will hit TVC cache (0 LLM energy)

  - name: get_energy_stats
    description: "Return energy efficiency metrics"
    given: "Current session energy metrics"
    when: "Stats requested"
    then: >
      Return symbolic_hit_rate, tvc_hit_rate, cache_hit_rate,
      energy_saved_wh (symbolic saves ~0.1 Wh/query, TVC saves ~0.099 Wh/query)

  - name: init_with_corpus
    description: "Initialize hybrid chat with TVC corpus for self-learning"
    given: "Allocator, optional model path, TVC corpus pointer"
    when: "Chat engine created with learning capability"
    then: >
      Initialize symbolic matcher, set corpus pointer, configure providers.
      Backward-compatible: init() without corpus still works.

integration:
  - target: igla_local_chat.zig
    description: "Symbolic pattern matcher (1100+ patterns, 60+ categories)"
  - target: tvc_corpus.zig
    description: "VSA-based query/response cache (10K capacity, cosine similarity search)"
  - target: openai_client.zig
    description: "OpenAI-compatible client (Groq, Together, Ollama)"
  - target: anthropic_client.zig
    description: "Anthropic Claude client"
  - target: gguf_model.zig
    description: "Local GGUF model loader (TinyLlama, DeepSeek, SmolLM)"

business_value:
  energy_saving:
    - "Symbolic responses: 0.0001 Wh vs 0.1 Wh cloud LLM = 1000x energy savings"
    - "TVC cached responses: 0.001 Wh vs 0.1 Wh cloud LLM = 100x energy savings"
    - "Self-learning: every LLM call makes future similar queries free"
    - "Target: 99% cache hit rate after warm-up = near-zero energy chat"
  competitive:
    - "ChatGPT/Claude/Grok: 100% cloud LLM, no caching, no learning"
    - "Ollama: local LLM only, no symbolic fast path, no caching"
    - "Trinity: symbolic + TVC cache + multi-provider = best of all worlds"
