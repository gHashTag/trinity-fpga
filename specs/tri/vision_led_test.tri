name: vision_led_test
version: "1.0.0"
language: zig
module: tri.vision_led_test

description: |
  Camera-based LED verification for FPGA (Golden Chain Link 23).
  Captures photos from HTTP camera endpoint, analyzes LED state via vision API,
  detects blinking by sampling multiple frames, reports with confidence score.

behaviors:
  - name: captureLedImage
    given: HTTP camera endpoint URL
    when: LED verification is triggered
    then: Captures photo from camera for analysis

  - name: analyzeLedState
    given: Captured image data
    when: Vision analysis is invoked
    then: Determines LED state (ON/OFF) with confidence score

  - name: detectBlinking
    given: Multiple frame samples over time
    when: Blink detection is requested
    then: Samples frames and reports blink frequency and pattern

export_functions:
  - captureLedImage
  - analyzeLedState
  - detectBlinking
