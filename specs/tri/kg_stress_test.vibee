name: kg_stress_test
version: "1.0.0"
language: zig
module: kg_stress_test
description: "Level 11.9 — KG stress test: 6-hop chains, memory capacity scaling, noise tolerance"

constants:
  DIM: 1024
  MAX_HOPS: 6
  MAX_MEMORY: 25

types:
  HopResult:
    fields:
      hops: Int
      correct: Int
      total: Int
      avg_sim: Float
      description: "Multi-hop chain result at a given depth. Bipolar achieves sim=1.0 at all depths including 6."

  MemoryLoadResult:
    fields:
      entities: Int
      correct: Int
      accuracy: Float
      description: "Associative memory accuracy as number of stored entities increases. Capacity limit near sqrt(DIM)."

behaviors:
  - name: extendedMultiHop
    given: 15 chains of 7 bipolar entities each, tested at 1-6 hop depths
    when: Build composite relations and apply to source, check target match
    then: 100% accuracy at all depths 1-6, sim=1.0000 — bipolar composition is depth-independent

  - name: memoryCapacityScaling
    given: Associative memories with 5, 10, 15, 20, 25 entities
    when: Build tree-bundled memory, query each entity
    then: 100% up to 20 entities, degrades to 92% at 25 — approaching sqrt(1024) capacity limit

  - name: noisyMemoryRetrieval
    given: Memory with 15 entities, noise levels 0-5 added to retrieved vectors
    when: Unbind memory, add ternary noise, search codebook
    then: 100% at noise 0-1, 80% at noise 2, 66.7% at noise 3, 40% at noise 5 — consistent with signal fraction threshold
