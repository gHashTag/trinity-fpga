# VIBEE Test Generator Full - Complete Test Generator Spec (Cycle 51)
# Full specification of tests_gen.zig with implementation block support

name: tests_gen_full
version: "1.0.0"
language: zig
module: tests_gen_full

types:
  BehaviorMetadata:
    fields:
      name: String
      has_implementation: Bool
      implementation_code: String
      line_number: Int

  TestGenConfig:
    fields:
      skip_stubs_with_impl: Bool
      generate_impl_tests: Bool
      preserve_doc_comments: Bool

behaviors:
  - name: detect_implementation_block
    given: behavior text from .vibee spec
    when: scanning for implementation marker
    then: returns true if implementation: block exists
    implementation: |
      pub fn detectImplementationBlock(behavior_text: []const u8) bool {
          const impl_marker = "implementation:";
          return std.mem.indexOf(u8, behavior_text, impl_marker) != null;
      }

  - name: generate_test_for_behavior
    given: behavior with optional implementation
    when: generating test case
    then: creates test that verifies function exists and is callable
    implementation: |
      pub fn generateTestForBehavior(
          writer: anytype,
          behavior_name: []const u8,
          has_implementation: bool,
      ) !void {
          // Use snake_case version for test name
          try.writer.print("test \"{s}_behavior\" {{\n", .{behavior_name});
          try.writer.writeAll("    // Test that implementation function exists and is callable\n");
          
          if (has_implementation) {
              // If there's an implementation block, test that the function exists
              try.writer.print("    const func = @TypeOf({s});\n", .{behavior_name});
              try.writer.writeAll("    try std.testing.expect(func != void);\n");
          } else {
              // If no implementation, test stub exists
              try.writer.print("    const func = @TypeOf({s});\n", .{behavior_name});
              try.writer.writeAll("    try std.testing.expect(func != void);\n");
          }
          
          try.writer.writeAll("}\n\n");
      }

  - name: generate_test_from_test_case
    given: test case with input and expected output
    when: generating test from spec
    then: creates test with proper assertions
    implementation: |
      pub fn generateTestFromTestCase(
          writer: anytype,
          test_case: TestCase,
      ) !void {
          try.writer.print("test \"{s}\" {{\n", .{test_case.name});
          
          if (test_case.input.len > 0) {
              try.writer.print("    const input = {s};\n", .{test_case.input});
          }
          
          if (test_case.expected.len > 0) {
              try.writer.print("    const expected = {s};\n", .{test_case.expected});
              try.writer.writeAll("    try std.testing.expectEqual(expected, actual);\n");
          }
          
          try.writer.writeAll("}\n\n");
      }
