# ═══════════════════════════════════════════════════════════════════════════════
# dev_evolve v1.0.0 — ASHA+PBT Evolution for Dev Agents
# ═══════════════════════════════════════════════════════════════════════════════
#
# Adapts training farm evolution (tri_farm_evolve.zig) for development agents.
# Fitness = code quality, not loss/PPL.
#
# φ² + 1/φ² = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

name: dev_evolve
version: "1.0.0"
language: zig
module: dev_farm_evolve

types:
  FitnessMetrics:
    fields:
      test_pass_rate: Float32    # 0.0-1.0 from zig build test
      spec_compliance: Float32   # 0.0-1.0 from tri verify
      time_hours: Float32        # wall clock time
      pr_merged: Bool            # ultimate success signal
      lines_changed: UInt32      # code volume
      build_success: Bool        # zig build passes

  EvolutionRung:
    fields:
      time_threshold_hours: Float32  # min hours before evaluation
      kill_ratio: Float32            # fraction to kill (0.0-1.0)
      min_fitness: Float32           # minimum fitness to survive

  DevEvolution:
    fields:
      generation: UInt32
      population: List<DevAgent>
      rungs: List<EvolutionRung>
      history: List<String>          # event log

behaviors:
  - name: init
    given: Running dev agents across accounts
    when: User runs `tri dev evolve init`
    then: |
      1. Load DevFarmState from .trinity/dev_agents.json (shared with tri_dev.zig)
      2. Display population summary with agent count, fitness stats
      3. Show ASHA rung configuration

  - name: step
    given: Initialized evolution state with agents that have fitness
    when: User runs `tri dev evolve step`
    then: |
      1. Load DevFarmState from .trinity/dev_agents.json
      2. Find current rung based on elapsed time
      3. Sort agents by fitness (descending)
      4. Identify agents to kill (below min_fitness or in bottom kill_ratio)
      5. Print kill/survive decisions with reasoning
      6. Save decisions (actual kill via tri dev kill is manual for safety)

  - name: status
    given: DevFarmState exists with agents
    when: User runs `tri dev evolve status`
    then: |
      1. Load DevFarmState from .trinity/dev_agents.json
      2. Show ranked leaderboard with fitness breakdown
      3. Show rung progress (which rung we're in based on oldest agent)
      4. Show evolution recommendations

  - name: kill_worst
    given: Agents below fitness threshold at current rung
    when: Evolution step identifies killable agents
    then: Print kill recommendations (user confirms via tri dev kill)

  - name: mutate_best
    given: Top-performing agents identified
    when: Evolution step has kill slots to fill
    then: Suggest new spawn configs mutated from best (different model/role)

test_cases:
  - name: fitness_formula
    given: test_pass=1.0, spec=0.8, time=0.5, pr_merged=true
    when: Fitness computed
    then: score = 0.4*1.0 + 0.3*0.8 + 0.2*min(1,1/0.5) + 0.1*1.0 = 0.94

  - name: asha_halving
    given: 8 agents, rung kill_ratio=0.5
    when: Step executed
    then: 4 worst agents killed

  - name: find_current_rung
    given: Oldest agent running 1.5 hours
    when: Rung evaluated
    then: Rung 1 (1.0h threshold) is current, rung 2 (2.0h) not yet reached

  - name: kill_below_min_fitness
    given: Agent with fitness 0.15, rung min_fitness 0.2
    when: Step evaluates
    then: Agent marked for kill (below minimum)

  - name: empty_state_status
    given: No agents in state
    when: tri dev evolve status
    then: Show "No agents" message, no crash

exit_criteria:
  compiles: true
  fitness_formula_correct: true
  asha_kill_works: true

metadata:
  author: Trinity SWE Pipeline
  date: 2026-03-14
  phase: 1
  reuses:
    - src/tri/tri_farm_evolve.zig (ASHA+PBT pattern)
