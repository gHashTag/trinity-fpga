name: pipeline_executor
version: "5.1.0"
language: zig
module: pipeline_executor

description: |
  Pipeline Executor — Golden Chain Orchestration.
  v5.1: Parallel group execution, per-link checkpoint, model roulette.

  Executes the 26-link Golden Chain pipeline with:
  - TVC gate check (link 0)
  - Parallel link groups (links can run concurrently where safe)
  - Per-link checkpoint persistence
  - Model roulette for LLM selection
  - Vision LED test integration
  - Perplexity Scholar for research-assisted error fixing

dependencies:
  - golden_chain
  - tvc_gate
  - tvc_corpus
  - self_improving_pipeline
  - vision_led_test
  - perplexity_scholar

behaviors:
  - name: executePipeline
    given: Allocator and chain state
    when: Called by tri pipeline run
    then: Executes links 0-25 with checkpointing and parallel groups

export_functions:
  - executePipeline
