# ═══════════════════════════════════════════════════════════════════════════════
# smoke_test v1.0.0 - FPGA Synthesis Pipeline Smoke Tests
# ═══════════════════════════════════════════════════════════════════════════════
#
# Sacred formula: V = n × 3^k × π^m × φ^p × e^q
# Golden identity: φ² + 1/φ² = 3
#
# Critical path validation for Trinity v2.2.0 Phase 3 orchestration
#
# Purpose: Validate all critical paths in FPGA synthesis pipeline
# Scope: Minimal designs, fast execution (< 30 seconds each)
# Target: Catch regressions before full test suite
#
# ═══════════════════════════════════════════════════════════════════════════════

name: smoke_test
version: "1.0.0"
language: zig
module: smoke_test

# ═══════════════════════════════════════════════════════════════════════════════
# TYPES
# ═══════════════════════════════════════════════════════════════════════════════

types:
  # Smoke test result
  SmokeTestResult:
    fields:
      test_name: String
      passed: Bool
      duration_ms: UInt64
      error_message: Option<String>
      phase: String  # "yosys", "forge", "bitstream", "flash"

  # Critical path test configuration
  CriticalPathConfig:
    fields:
      name: String
      verilog_file: String
      top_module: String
      expected_phases: List<String>
      timeout_ms: UInt64
      required_tools: List<String>  # ["yosys", "forge", "fasm2frames"]

  # Tool availability check
  ToolCheck:
    fields:
      tool_name: String
      available: Bool
      version: Option<String>
      path: Option<String>

  # Smoke test suite summary
  SmokeTestSummary:
    fields:
      total_tests: UInt32
      passed_tests: UInt32
      failed_tests: UInt32
      skipped_tests: UInt32
      total_duration_ms: UInt64
      critical_path_passed: Bool
      regression_detected: Bool

# ═══════════════════════════════════════════════════════════════════════════════
# BEHAVIORS
# ═══════════════════════════════════════════════════════════════════════════════

behaviors:
  # ═══════════════════════════════════════════════════════════════════════════
  # TOOLCHAIN AVAILABILITY CHECKS
  # ═══════════════════════════════════════════════════════════════════════════

  - name: checkYosysAvailable
    given: Smoke test suite initialized
    when: Yosys availability checked
    then: Return ToolCheck with version and path, fail if missing

  - name: checkForgeAvailable
    given: Smoke test suite initialized
    when: FORGE binary availability checked
    then: Return ToolCheck, verify binary exists in zig-out/bin/

  - name: checkOpenXC7DockerAvailable
    given: Smoke test suite initialized
    when: Docker openXC7 image checked
    then: Return ToolCheck, verify docker pull regymm/openxc7 works

  - name: checkJTAGToolAvailable
    given: Smoke test suite initialized
    when: JTAG programming tool checked
    then: Verify fpga/tools/jtag_program exists and is executable

  # ═══════════════════════════════════════════════════════════════════════════
  # MINIMAL DESIGN TESTS (CRITICAL PATH)
  # ═══════════════════════════════════════════════════════════════════════════

  - name: testMinimalLED
    given: Simple LED blink design (d6_blink.v)
    when: Full synthesis pipeline executed
    then: Complete in < 30 seconds, all phases pass

  - name: testTernaryDot
    given: Ternary dot product design (ternary_dot.v)
    when: Full synthesis pipeline executed
    then: Complete in < 30 seconds, generate valid bitstream

  - name: testCombinatorialLogic
    given: Pure combinatorial design (no clock)
    when: Synthesis executed
    then: Complete without timing violations, valid bitstream

  - name: testSequentialLogic
    given: Design with flip-flops and clock
    when: Synthesis executed
    then: Complete with proper OLOGIC configuration

  # ═══════════════════════════════════════════════════════════════════════════
  # CONTRACT VALIDATION (Phase 3 Interfaces)
  # ═══════════════════════════════════════════════════════════════════════════

  - name: testIStrategistContract
    given: ForgeStrategist implementation
    when: IStrategist.verify() called at compile time
    then: Compile successfully with all required methods

  - name: testITriParserContract
    given: TriParser implementation
    when: ITriParser.verify() called at compile time
    then: Compile successfully with parse/generateVerilog/generateXDC

  - name: testIAutoFixEngineContract
    given: AutoFix implementation
    when: IAutoFixEngine.verify() called at compile time
    then: Compile successfully with analyzeFailure/autoFix methods

  - name: testIBatchExecutorContract
    given: BatchSynthRunner implementation
    when: IBatchExecutor.verify() called at compile time
    then: Compile successfully with submit/run/getStatus methods

  - name: testIConfigManagerContract
    given: ConfigManager implementation
    when: IConfigManager.verify() called at compile time
    then: Compile successfully with load/save/validate methods

  - name: testIPersistentStateContract
    given: SynthesisState implementation
    when: IPersistentState.verify() called at compile time
    then: Compile successfully with serialize/deserialize methods

  # ═══════════════════════════════════════════════════════════════════════════
  # ORCHESTRATION LAYER TESTS
  # ═══════════════════════════════════════════════════════════════════════════

  - name: testConfigLoadSave
    given: SynthesisConfig with default values
    when: Config saved to JSON and reloaded
    then: All values preserved, validation passes

  - name: testStatePersistence
    given: SynthesisState after successful synthesis
    when: State serialized and deserialized
    then: All fields preserved, checksum matches

  - name: testBatchSequentialMode
    given: 3 simple designs
    when: Batch executed in sequential mode
    then: All jobs complete, order preserved

  - name: testBatchParallelMode
    given: 3 simple designs
    when: Batch executed in parallel mode (max_concurrent=2)
    then: All jobs complete, parallel execution confirmed

  # ═══════════════════════════════════════════════════════════════════════════
  # ERROR HANDLING SMOKE TESTS
  # ═══════════════════════════════════════════════════════════════════════════

  - name: testInvalidVerilog
    given: Malformed Verilog file
    when: Yosys synthesis attempted
    then: Error caught gracefully, clear error message

  - name: testMissingTopModule
    given: Valid Verilog but wrong top module name
    when: Synthesis attempted
    then: Error caught, module name not found in design

  - name: testTimeoutHandling
    given: Design that exceeds timeout
    when: Synthesis timeout_ms set to 5000
    then: Timeout enforced, partial cleanup attempted

  - name: testInvalidConfig
    given: SynthesisConfig with max_fix_iterations = 11
    when: Config validation called
    then: Validation fails with clear error message

  # ═══════════════════════════════════════════════════════════════════════════
  # REPORTING
  # ═══════════════════════════════════════════════════════════════════════════

  - name: generateSmokeTestReport
    given: All SmokeTestResult objects
    when: Report generation requested
    then: Output markdown summary with pass/fail matrix

  - name: generateCriticalPathReport
    given: Smoke test results
    when: Critical path analysis requested
    then: Highlight which phases failed, suggest fixes

# ═══════════════════════════════════════════════════════════════════════════════
# TEST CASES
# ═══════════════════════════════════════════════════════════════════════════════

test_cases:
  - name: yosys_available_test
    given: Smoke test suite
    when: Yosys check executed
    then: ToolCheck.available = true, version detected

  - name: forge_available_test
    given: Smoke test suite
    when: FORGE check executed
    then: ToolCheck.available = true, path = zig-out/bin/forge

  - name: minimal_led_test
    given: d6_blink.v design
    when: Full pipeline executed
    then: SmokeTestResult.passed = true, duration_ms < 30000

  - name: contract_verification_test
    given: All Phase 3 interfaces
    when: Compile-time verification executed
    then: All interfaces compile without errors

  - name: config_persistence_test
    given: Default SynthesisConfig
    when: Save/load cycle executed
    then: All fields preserved, validation passes

  - name: batch_sequential_test
    given: 3 designs in sequential mode
    when: Batch execution completed
    then: All 3 jobs complete, order = 1,2,3

  - name: error_handling_test
    given: Invalid Verilog input
    when: Synthesis attempted
    then: Error caught gracefully, no crash

# ═══════════════════════════════════════════════════════════════════════════════
# CRITICAL PATHS
# ═══════════════════════════════════════════════════════════════════════════════

critical_paths:
  - name: YOSYS_SYNTHESIS
    description: "Yosys Verilog → JSON netlist"
    timeout_ms: 10000
    required: true

  - name: FORGE_PLACEMENT
    description: "FORGE JSON → Placed design"
    timeout_ms: 15000
    required: true

  - name: FORGE_ROUTING
    description: "FORGE Placed → Routed design"
    timeout_ms: 20000
    required: true

  - name: BITSTREAM_GEN
    description: "FORGE Routed → .bit file"
    timeout_ms: 5000
    required: true

  - name: CONTRACT_VALIDATION
    description: "Phase 3 interface verification"
    timeout_ms: 1000
    required: true

  - name: CONFIG_PERSISTENCE
    description: "Config save/load cycle"
    timeout_ms: 2000
    required: true

# ═══════════════════════════════════════════════════════════════════════════════
# EXIT CRITERIA
# ═══════════════════════════════════════════════════════════════════════════════

exit_criteria:
  all_tools_available: true
  all_critical_paths_passed: true
  all_contracts_verified: true
  no_regressions: true
  total_duration_s: < 60
  failed_tests: 0

# ═══════════════════════════════════════════════════════════════════════════════
# METADATA
# ═══════════════════════════════════════════════════════════════════════════════

metadata:
  author: Trinity SA-3 Phase 3
  date: 2026-03-08
  cycle: 118
  phase: 3
  status: SPEC_COMPLETE
  target: Validate critical paths before full test suite
  execution_time_seconds: 30-60
  run_frequency: "Every commit, before full test suite"
