# TEST_IMPLEMENTATION — Verify that implementation: field generates real code
# This spec tests Phase B of CODEGEN-001
# phi^2 + 1/phi^2 = 3

name: test_implementation
version: "1.0.0"
language: zig
module: test_implementation

constants:
  EPSILON: 0.0001

types:
  Vec3:
    fields:
      x: Float
      y: Float
      z: Float

behaviors:
  - name: vec3_add
    given: two Vec3 vectors
    when: adding vectors component-wise
    then: component-wise sum
    implementation: |
      pub fn vec3_add(a_x: f64, a_y: f64, a_z: f64, b_x: f64, b_y: f64, b_z: f64) struct { x: f64, y: f64, z: f64 } {
          return .{ .x = a_x + b_x, .y = a_y + b_y, .z = a_z + b_z };
      }

  - name: vec3_dot
    given: two Vec3 vectors
    when: computing dot product
    then: scalar result
    implementation: |
      pub fn vec3_dot(a_x: f64, a_y: f64, a_z: f64, b_x: f64, b_y: f64, b_z: f64) f64 {
          return a_x * b_x + a_y * b_y + a_z * b_z;
      }

  - name: vec3_length
    given: a Vec3 vector
    when: computing magnitude
    then: euclidean length
    implementation: |
      pub fn vec3_length(x: f64, y: f64, z: f64) f64 {
          return @sqrt(x * x + y * y + z * z);
      }

  - name: vec3_normalize
    given: a Vec3 vector
    when: normalizing to unit length
    then: unit vector
    implementation: |
      pub fn vec3_normalize(x: f64, y: f64, z: f64) struct { x: f64, y: f64, z: f64 } {
          const len = @sqrt(x * x + y * y + z * z);
          if (len == 0.0) return .{ .x = 0.0, .y = 0.0, .z = 0.0 };
          return .{ .x = x / len, .y = y / len, .z = z / len };
      }

  - name: ternary_quantize
    given: a float value and threshold
    when: quantizing to ternary
    then: -1, 0, or +1
    implementation: |
      pub fn ternary_quantize(value: f64, threshold: f64) i8 {
          if (value > threshold) return 1;
          if (value < -threshold) return -1;
          return 0;
      }
