# ═══════════════════════════════════════════════════════════════════════════════
# EXECUTION STRATEGIES (FULLY IMPLEMENTED)
# ═══════════════════════════════════════════════════════════════════════════════

execution_strategies:
  sequential:
    status: FULLY_IMPLEMENTED
    description: Execute steps in dependency order using topological sort
    features:
      - Kahn's algorithm for topological sorting
      - DFS-based visitor pattern
      - Proper error handling with continue_on_failure

  parallel:
    status: FULLY_IMPLEMENTED
    description: Execute independent steps concurrently using std.Thread
    features:
      - Level-based execution (Kahn's algorithm variant)
      - Thread-safe ParallelContext with Mutex and atomic counters
      - Maximum concurrency: min(CPU count, φ × 8 = 13)
      - Graceful thread joining and cleanup
      - Sacred score tracking across parallel steps

  conditional:
    status: FULLY_IMPLEMENTED
    description: Execute with conditional branching based on step conditions
    features:
      - AST-based condition parser
      - Logical operators: &&, ||, !
      - Comparison operators: >, >=, <, <=, ==, !=
      - String matching: contains operator
      - Sacred mathematics: phi(n) comparisons
      - Step field references: step('id').field

  adaptive:
    status: FULLY_IMPLEMENTED
    description: Auto-select execution strategy based on workflow analysis
    features:
      - Workflow analysis (conditions, parallelizable_ratio, complexity, sacred_alignment)
      - Decision matrix based on φ-sacred principles
      - Intelligent strategy selection
      - Runtime logging of decision reasoning

# ═══════════════════════════════════════════════════════════════════════════════
# SACRED CONSTANTS
# ═══════════════════════════════════════════════════════════════════════════════

sacred_constants:
  PHI: 1.618033988749895
  PHI_INV: 0.618033988749895
  PHI_SQ: 2.618033988749895
  TRINITY: 3.0
  MU: 0.0382
  CHI: 0.0618
  SACRED_THRESHOLD: 0.95

# ═══════════════════════════════════════════════════════════════════════════════
# CONDITION SYNTAX
# ═══════════════════════════════════════════════════════════════════════════════

condition_syntax:
  - success: Execute if previous step succeeded
  - failed: Execute if previous step failed
  - "sacred_score > 0.9": Execute if sacred score exceeds threshold
  - "output contains 'pattern'": Execute if output contains substring
  - "step('build').success": Execute if specific step succeeded
  - "phi(2) > 2.6": Execute if φ² exceeds threshold
  - "success && score > 0.8": Logical AND combination
  - "success || failed": Logical OR combination
  - "!success": Negation

