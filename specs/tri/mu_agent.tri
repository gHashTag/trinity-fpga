name: mu_agent
version: "1.0.0"
language: zig
module: mu_agent

description: >
  MU Agent — Memory Unit for the Trinity swarm. Detects error patterns from
  compile output, categorizes them, persists to JSONL storage, suggests fixes
  based on known patterns, and reports statistics. Supports auto-fix classification.

types:
  MuAgent:
    fields:
      allocator: "std.mem.Allocator"
      patterns: "ArrayList(ErrorPattern)"
      storage_path: "[]const u8"

  ErrorCategory:
    description: "Classification of detected errors"
    variants:
      - ast_fail
      - gen_fail
      - format_fail
      - type_mismatch
      - import_fail
      - unknown

  ErrorPattern:
    fields:
      id: "[]const u8"
      error_text: "[]const u8"
      category: ErrorCategory
      count: u32
      first_seen: i64
      last_seen: i64
      spec_file: "[]const u8"
      fix_suggestion: "[]const u8"
      auto_fixable: bool
      resolved: bool

  MuReport:
    fields:
      total_patterns: usize
      unresolved: usize
      auto_fixable: usize
      by_category: "[6]u32"
      top_patterns: "[]const ErrorPattern"

  DetectResult:
    fields:
      patterns: "[]ErrorPattern"
      new_count: usize
      updated_count: usize

behaviors:
  MuAgent.init:
    given: "allocator and storage_path string"
    when: "called"
    then: "returns zero-initialized MuAgent with empty patterns list"

  MuAgent.load:
    given: "existing storage JSONL file"
    when: "called"
    then: "parses each line into ErrorPattern and appends to patterns; ignores missing file"

  MuAgent.detect:
    given: "compile_output string and spec_file string"
    when: "called"
    then: "matches output against priority-ordered rules; creates new pattern or increments count on match; returns DetectResult"

  MuAgent.log:
    given: "ErrorPattern"
    when: "called"
    then: "appends a JSONL line to storage file with all pattern fields"

  MuAgent.suggest:
    given: "error_text string"
    when: "called"
    then: "searches stored patterns for a match; falls back to rule-based suggestions; returns fix string or null"

  MuAgent.stats:
    given: "accumulated patterns"
    when: "called"
    then: "returns MuReport with counts by category and lists of unresolved/auto-fixable patterns"

  MuAgent.save:
    given: "all patterns"
    when: "called"
    then: "rewrites storage file with all current patterns as JSONL"

  MuAgent.formatReport:
    given: "writer"
    when: "called"
    then: "prints formatted agent status report with per-category breakdown and top patterns"
