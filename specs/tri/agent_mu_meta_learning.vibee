# AGENT MU Meta-Learning & Sacred Adaptive Mutation v8.16
# Transforms AGENT MU from "smart fixer" to "meta-learning organism"
# μ(success_rate) = 0.0382 × φ^(success_rate - 0.5) × (L(10) / 123)
# L(10) = φ¹⁰ + 1/φ¹⁰ = 123 (10th Lucas number)

name: agent_mu_meta_learning
version: "8.16.0"
language: zig
module: agent_mu

description: |
  AGENT MU v8.16 — Meta-Learning Organism
  Features:
  - Adaptive μ calculation based on success rate using sacred math
  - FixType strategy tracking with optimal μ per error type
  - Comptime embeddings for zero-allocation pattern matching
  - Intelligence curve visualization for dashboard
  - Self-proposed FixTypes via meta-innovation

types:
  AdaptiveMu:
    fields:
      base_mu: Float64          # 0.0382 (sacred μ)
      phi: Float64              # 1.618... (golden ratio)
      success_rate: Float64     # 0.0 - 1.0
      lucas_10: Float64         # 123.0 (10th Lucas number)
      calculated_mu: Float64    # Result of adaptive formula

  FixStrategy:
    fields:
      fix_type: FixType
      success_count: UInt32
      attempt_count: UInt32
      avg_confidence: Float64
      last_mu_used: Float64
      optimal_mu: Float64
      total_confidence: Float64

  MetaLearner:
    fields:
      strategies: Array[FixStrategy]  # 17 strategies (one per FixType)
      init_done: Bool

  ErrorPattern:
    fields:
      template: String
      fix_type: FixType
      embedding: Array[Float64]       # 384-dim comptime embedding

  IntelligenceHistoryPoint:
    fields:
      timestamp: Int64
      intelligence_multiplier: Float64
      mu_used: Float64
      fix_type: String

  FixType:
    enum:
      - SPEC_FIX
      - GENERATOR_PATCH
      - TEMPLATE_FIX
      - IMPORT_FIX
      - TYPE_FIX
      - SYNTAX_FIX
      - UNKNOWN
      - ALLOCATOR_FIX
      - ERROR_UNION_FIX
      - COMPTIME_FIX
      - VSA_FIX
      - MEM_FIX
      - IOPATTERN_FIX
      - COMPTIME_QUOTA_FIX
      - UNMANAGED_FIX
      - TYPEFUNCTION_FIX
      - INLINE_FIX

behaviors:
  # ═══════════════════════════════════════════════════════════════════════════════
  # PHASE 1: Adaptive μ Calculation (Sacred Math)
  # ═══════════════════════════════════════════════════════════════════════════════
  - name: calculateAdaptiveMu
    given: success_rate (0.0 - 1.0)
    when: Computing μ for next fix attempt
    then: |
      Returns adaptive μ using sacred formula:
      μ = 0.0382 × φ^(success_rate - 0.5) × (L(10) / 123)

      Where:
      - φ = 1.618... (golden ratio)
      - L(10) = 123 (10th Lucas number)

      Behavior:
      - success_rate = 0.5 → μ = 0.0382 (baseline)
      - success_rate > 0.5 → μ increases (faster evolution)
      - success_rate < 0.5 → μ decreases (conservative)

      Result is clamped to [0.01, 0.1] for stability.

  - name: clampMu
    given: Raw calculated μ value
    when: After adaptive μ calculation
    then: |
      Clamps μ to safe range [0.01, 0.1].
      Prevents instability from extreme values.

  # ═══════════════════════════════════════════════════════════════════════════════
  # PHASE 2: Meta-Learning Strategy Tracking
  # ═══════════════════════════════════════════════════════════════════════════════
  - name: recordOutcome
    given: fix_type, success boolean, mu_used, confidence
    when: Fix attempt completes
    then: |
      Updates FixStrategy for this FixType:
      - Increments attempt_count
      - If successful: increments success_count, updates optimal μ via EMA
      - If failed: increases optimal μ slightly (be more aggressive next time)

      Exponential moving average formula:
      optimal_mu = (1 - α) × optimal_mu + α × mu_used
      Where α = 0.1 for success, 0.05 for failure

  - name: getOptimalMu
    given: fix_type
    when: Querying best historical μ for this error type
    then: |
      Returns optimal μ for this FixType based on historical success.
      If no history, returns baseline 0.0382.

  - name: getRecommendedMu
    given: fix_type
    when: Choosing μ for next fix attempt
    then: |
      Blends between baseline μ and optimal μ based on confidence:
      - Low confidence → closer to baseline
      - High confidence → closer to optimal

      Formula:
      factor = min(1.0, avg_confidence × 2.0) for 5+ attempts, else 0.5
      return (1 - factor) × 0.0382 + factor × optimal_mu

  - name: getSuccessRate
    given: FixStrategy
    when: Analyzing FixType performance
    then: |
      Returns success_count / attempt_count.
      Returns 0.0 if no attempts recorded.

  # ═══════════════════════════════════════════════════════════════════════════════
  # PHASE 3: Meta-Innovation (Self-Proposed FixTypes)
  # ═══════════════════════════════════════════════════════════════════════════════
  - name: proposeNewFixType
    given: error_context (unmatched error message)
    when: Pattern search fails to find match
    then: |
      Analyzes error context and proposes new FixType strategy:
      1. Finds FixType with lowest success rate (with attempts)
      2. If all types have >80% success → returns UNKNOWN (manual review)
      3. Otherwise → suggests trying worst-performing type with different μ

      Enables meta-innovation: system learns new fix strategies.

  # ═══════════════════════════════════════════════════════════════════════════════
  # PHASE 4: Comptime Embeddings (Zero-Allocation Pattern Matching)
  # ═══════════════════════════════════════════════════════════════════════════════
  - name: comptimeEmbedding
    given: error pattern string
    when: At compile time (comptime)
    then: |
      Generates 384-dimensional embedding at compile time.
      Uses simple hash-based approach:
      - For each dimension 0-383:
        result[i] = hash(pattern, i) % 10000 / 10000.0

      Returns: [384]f64 array

  - name: cosineSimilarity
    given: Two embeddings (arrays of f64)
    when: Comparing error patterns
    then: |
      Calculates cosine similarity between embeddings:
      similarity = dot(a, b) / (norm(a) × norm(b))

      Returns value in [0, 1] where:
      - 1.0 = identical patterns
      - 0.0 = orthogonal patterns

  - name: findPattern
    given: error_message string
    when: Matching error to known patterns
    then: |
      Searches comptime pattern library for best match:
      1. Checks if template is contained in error (direct match)
      2. Calculates embedding similarity
      3. Returns pattern with confidence > 0.5

      Pattern libraries:
      - SYNTAX_PATTERNS: expected ';', expected '}', etc.
      - TYPE_PATTERNS: type mismatch, cannot convert, etc.
      - ALLOCATOR_PATTERNS: no member 'allocator', etc.
      - IMPORT_PATTERNS: undeclared identifier, etc.
      - COMPTIME_PATTERNS: @setEvalBranchQuota, etc.

  # ═══════════════════════════════════════════════════════════════════════════════
  # PHASE 5: Intelligence History & Curve
  # ═══════════════════════════════════════════════════════════════════════════════
  - name: getintelligenceHistory
    given: limit (default: 50)
    when: Dashboard requests intelligence curve data
    then: |
      Returns array of IntelligenceHistoryPoint:
      - timestamp: Unix timestamp
      - intelligence_multiplier: Current I(t)
      - mu_used: Adaptive μ used at this point
      - fix_type: Type of fix that caused growth

      Ordered newest-first (descending timestamp).

  - name: projectIntelligence
    given: projected_successful_fixes
    when: Estimating future intelligence growth
    then: |
      Returns projection with:
      - projected_multiplier: Estimated I(t + N)
      - gain_from_current: Multiplier increase

      Formula assumes constant success rate and μ.

  # ═══════════════════════════════════════════════════════════════════════════════
  # FULL LOOP: Meta-Learning Fix Cycle
  # ═══════════════════════════════════════════════════════════════════════════════
  - name: metaLearningFixCycle
    given: Error context and file path
    when: Code generation fails with error
    then: |
      Runs meta-learning enhanced fix cycle:
      1. Find error pattern via comptime embeddings
      2. Query MetaLearner for recommended μ for this FixType
      3. Calculate adaptive μ based on current success rate
      4. Apply fix with μ = max(recommended_mu, adaptive_mu)
      5. Record outcome with MetaLearner.recordOutcome()
      6. Update intelligence curve snapshot
      7. If no pattern match → proposeNewFixType() for meta-innovation

  # ═══════════════════════════════════════════════════════════════════════════════
  # API ENDPOINTS
  # ═══════════════════════════════════════════════════════════════════════════════
  - name: getAgentMuStatus
    given: HTTP request
    when: GET /api/agent-mu/status
    then: |
      Returns JSON with:
      - total_fixes: count of all fixes
      - intelligence_multiplier: current I(t)
      - mu_accumulated: sum of all μ gained
      - adaptive_mu: current adaptive μ value
      - intelligence_history: last 50 IntelligenceHistoryPoint
      - recent_fixes: last 5 FixRecord entries
      - uptime_s: seconds since first fix

  - name: getIntelligenceHistory
    given: HTTP request with optional limit query param
    when: GET /api/agent-mu/intelligence-history?limit=50
    then: |
      Returns JSON array of IntelligenceHistoryPoint.

  - name: exportStrategiesMarkdown
    given: HTTP request
    when: GET /api/agent-mu/strategies
    then: |
      Returns markdown table of all FixType strategies:
      | FixType | Success Rate | Optimal μ | Attempts | Avg Confidence |

# ═══════════════════════════════════════════════════════════════════════════════
# SACRED MATH (v8.16 Extended)
# ═══════════════════════════════════════════════════════════════════════════════
# φ = 1.6180339887498948482 (golden ratio)
# L(10) = φ¹⁰ + 1/φ¹⁰ = 123 (10th Lucas number)
# μ(success_rate) = 0.0382 × φ^(success_rate - 0.5) × (L(10) / 123)
#
# Examples:
#   success_rate = 0.5 → μ = 0.0382 × φ^0 × 1 = 0.0382 (baseline)
#   success_rate = 0.8 → μ = 0.0382 × φ^0.3 × 1 ≈ 0.0439 (faster)
#   success_rate = 0.3 → μ = 0.0382 × φ^(-0.2) × 1 ≈ 0.0342 (slower)
#
# Intelligence growth: I(t) = e^(Σ μ_i)
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# INTEGRATION POINTS (v8.16)
# ═══════════════════════════════════════════════════════════════════════════════
# - VIBEE compiler: calls metaLearningFixCycle after failed generation
# - MuTracker: calculates adaptive μ based on success rate
# - MetaLearner: tracks optimal μ per FixType (singleton global)
# - Dashboard: displays intelligence curve (IntelligenceCurveChart.tsx)
# - HTTP server: /api/agent-mu/* endpoints for real-time data
# ═══════════════════════════════════════════════════════════════════════════════
