# ═══════════════════════════════════════════════════════════════════════════════
# dev_pipeline v1.0.0 — Dev-Specific Pipeline Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Extends Golden Chain pipeline for development agent use cases.
# Decomposes GitHub issues into pipeline link subsets.
#
# φ² + 1/φ² = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

name: dev_pipeline
version: "1.1.0"
language: zig
module: dev_pipeline

types:
  PipelineConfig:
    fields:
      issue_number: UInt32
      role: String               # planner, coder, reviewer, tester, integrator
      model: String              # claude-sonnet-4-20250514, glm-5
      links: List<UInt32>        # which Golden Chain links to execute
      timeout_minutes: UInt32    # max execution time
      max_retries: UInt32        # per-link retry count

  LinkSubset:
    enum:
      - full             # all 26 links
      - spec_only        # links 1-6 (spec creation)
      - code_only        # links 7-11 (code generation + fix)
      - test_only        # links 12-15 (testing)
      - review_only      # links 16-18 (review + verdict)
      - minimal          # links 6,7,11,17 (minimum viable)

  DevResult:
    fields:
      issue_number: UInt32
      links_executed: UInt32
      links_passed: UInt32
      links_failed: UInt32
      build_success: Bool
      test_pass_rate: Float32
      time_seconds: UInt32
      error_log: Option<String>

behaviors:
  - name: decompose_issue
    given: A GitHub issue body
    when: Pipeline receives issue for processing
    then: Extract task type, determine optimal LinkSubset

  - name: plan_links
    given: Issue type and agent role
    when: Pipeline planning phase
    then: Return ordered list of links to execute

  - name: execute_subset
    given: PipelineConfig with selected links
    when: Agent runs pipeline
    then: Execute links in order, report DevResult

  - name: report_results
    given: Completed pipeline execution
    when: All links finished or timeout
    then: Post results as GitHub issue comment, set Railway variables

  - name: parse_issue_json
    given: JSON output from `gh issue view --json number,title,labels`
    when: Agent reads issue from GitHub
    then: Extract number, title, and labels array into IssueInfo struct

  - name: find_closest_spec
    given: Issue title/body keywords
    when: Link 6 needs a .tri template
    then: Scan specs/tri/*.tri, find closest match by keyword overlap

  - name: estimate_cost
    given: PipelineConfig with model and expected token count
    when: Before execution starts
    then: Return estimated cost in USD based on model pricing

test_cases:
  - name: bug_fix_uses_minimal
    given: Issue titled "fix: compile error in X"
    when: Issue decomposed
    then: LinkSubset = minimal (6,7,11,17)

  - name: new_feature_uses_full
    given: Issue titled "feat: add new module Y"
    when: Issue decomposed
    then: LinkSubset = full (all 26 links)

  - name: docs_uses_review_only
    given: Issue titled "docs: update README"
    when: Issue decomposed
    then: LinkSubset = review_only (16-18)

  - name: refactor_uses_code_only
    given: Issue titled "refactor: extract common types"
    when: Issue decomposed
    then: LinkSubset = code_only (7-11)

  - name: test_issue_uses_test_only
    given: Issue titled "test: add coverage for vsa.zig"
    when: Issue decomposed
    then: LinkSubset = test_only (12-15)

  - name: chore_uses_minimal
    given: Issue titled "chore: update dependencies"
    when: Issue decomposed
    then: LinkSubset = minimal

  - name: parse_issue_json_valid
    given: JSON '{"number":42,"title":"fix: bug","labels":[{"name":"agent:dev"}]}'
    when: Parsed
    then: IssueInfo{number=42, title="fix: bug", labels=["agent:dev"]}

  - name: cost_estimate_sonnet
    given: model=claude-sonnet-4, tokens=50000
    when: Cost estimated
    then: ~$0.45 (input $3/M + output $15/M, assume 80/20 split)

exit_criteria:
  compiles: true
  link_subsets_valid: true
  role_routing_works: true

metadata:
  author: Trinity SWE Pipeline
  date: 2026-03-14
  phase: 1
  reuses:
    - src/tri/pipeline_executor.zig (Golden Chain execution)
    - src/tri/golden_chain.zig (link definitions)
