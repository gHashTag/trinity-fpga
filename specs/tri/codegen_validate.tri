# ═══════════════════════════════════════════════════════════════════════════════
# codegen_validate v1.0.0 — Post-Generation Compile Validation Loop
# ═══════════════════════════════════════════════════════════════════════════════
#
# Link 7 enhancement: after `tri gen` produces .zig, validate it compiles.
# Format → build → check errors → retry (max 3).
# Also: enhanced Link 17 toxic verdict with real scoring.
#
# phi^2 + 1/phi^2 = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

name: codegen_validate
version: "1.0.0"
language: zig
module: codegen_validate

types:
  ValidationResult:
    fields:
      formatted: Bool        # zig fmt succeeded
      compiled: Bool         # zig build succeeded
      error_count: UInt32    # number of compile errors
      error_preview: String  # first 500 chars of stderr
      attempts: UInt32       # how many tries it took
      fixed_errors: List<String>  # errors that were auto-fixed

  ToxicScore:
    fields:
      test_pass_rate: Float32      # tests_passed / tests_total
      spec_compliance: Float32     # spec behaviors covered / total
      compile_clean: Bool          # compiled without warnings
      time_seconds: UInt32         # total pipeline time
      overall: Float32             # weighted score 0.0-1.0
      verdict: String              # "PROD", "SHIP IT", "NEEDS WORK", "GARBAGE"

behaviors:
  - name: validate_generated_code
    given: Path to generated .zig file from tri gen
    when: Link 7 completes code generation
    then: |
      1. Run `zig fmt <file>` — if fails, file has syntax errors
      2. Run `zig build` — check for compile errors
      3. If compile fails:
         a. Parse error message (line number, error type)
         b. Attempt auto-fix for common patterns:
            - "unused variable" → prefix with _ or remove
            - "expected type" → check generated types match spec
            - "undeclared identifier" → add missing @import
         c. Retry from step 1 (max 3 attempts)
      4. Return ValidationResult with success/failure + attempts

  - name: auto_fix_common_errors
    given: Compile error stderr, path to file
    when: First compile attempt failed
    then: |
      Pattern matching on error messages:
      - "error: unused local variable 'X'" → read file, prefix X with _
      - "error: expected type 'X', found 'Y'" → log for manual fix
      - "error: use of undeclared identifier 'X'" → check if X is importable
      - "error: expected '}'" → likely missing closing brace, log
      Most errors are NOT auto-fixable — just log and report honestly

  - name: toxic_verdict_scoring
    given: Pipeline execution results (all link metrics)
    when: Link 17 toxic_verdict runs
    then: |
      1. Collect metrics: test results, compile status, time, coverage
      2. Score formula:
         overall = 0.4 * test_pass_rate
                 + 0.3 * spec_compliance
                 + 0.2 * (compile_clean ? 1.0 : 0.0)
                 + 0.1 * time_score (faster = better, cap at 1.0)
      3. Map to verdict:
         >= 0.9 → "PROD" (ship it, no caveats)
         >= 0.7 → "SHIP IT" (good enough, minor issues)
         >= 0.4 → "NEEDS WORK" (significant gaps)
         < 0.4  → "GARBAGE" (start over)
      4. Print verdict with real numbers, no sugar coating

test_cases:
  - name: format_success
    given: Valid .zig file
    when: zig fmt runs
    then: formatted = true, no error

  - name: format_failure
    given: Invalid syntax .zig file
    when: zig fmt runs
    then: formatted = false, error_preview contains syntax info

  - name: compile_success
    given: Valid .zig project
    when: zig build runs
    then: compiled = true, error_count = 0

  - name: compile_failure_unused_var
    given: .zig with unused variable
    when: Compiled
    then: error_preview contains "unused local variable"

  - name: toxic_score_perfect
    given: test_pass=1.0, spec_comp=1.0, compile_clean=true, time=10s
    when: Scored
    then: overall >= 0.9, verdict = "PROD"

  - name: toxic_score_garbage
    given: test_pass=0.0, spec_comp=0.0, compile_clean=false
    when: Scored
    then: overall < 0.4, verdict = "GARBAGE"

  - name: toxic_score_mid
    given: test_pass=0.8, spec_comp=0.5, compile_clean=true, time=60s
    when: Scored
    then: overall in [0.4, 0.9), verdict = "SHIP IT" or "NEEDS WORK"

exit_criteria:
  compiles: true
  validation_loop_works: true
  toxic_scoring_works: true
  error_parsing_works: true

metadata:
  author: Trinity SWE Pipeline
  date: 2026-03-14
  phase: 4
  pipeline_link: 7, 17
  reuses:
    - src/tri/pipeline_executor.zig (executeCodeGenerate, executeToxicVerdict)
    - src/tri/golden_chain.zig (deriveOutputPath)
