// TRI AGENT RUN — Full Autonomous Issue Cycle
// One command, full cycle: tri agent run <N>
// φ² + 1/φ² = 3 = TRINITY

spec tri_agent_run {
    import experience_hooks;
    import tri_experience;
    import github_commands;
    import tri_pipeline;
    import tri_commands;

    type RunStep {
        name: str = "",
        success: bool = false,
        detail: [256]u8,
        detail_len: usize = 0,

        behavior setDetail(msg: str) -> void;
        behavior getDetail() -> str;
    }

    // 8-step autonomous cycle
    behavior runAgentRunCommand(allocator: Allocator, args: []str) -> void {
        // Parse issue number from args[0]
        // Run runFullCycle(allocator, issue_num, issue_str)
    }

    behavior runFullCycle(allocator: Allocator, issue_num: u32, issue_str: str) -> void {
        // Step 1: issue view <N>        — get issue title/body
        // Step 2: experience recall     — check for related past episodes
        // Step 3: spec create <name>    — create .tri spec from issue
        // Step 4: gen <spec>            — generate Zig from spec
        // Step 5: verify               — run tests
        // Step 6: verdict              — toxic verdict
        // Step 7: experience save      — record episode
        // Step 8: git commit           — commit with issue ref
        // Print summary: OK/FAIL per step, PASS/PARTIAL final
    }

    test "RunStep default values" {
        step = RunStep{};
        assert(step.success == false);
        assert(step.detail_len == 0);
    }

    test "RunStep setDetail/getDetail" {
        step = RunStep{};
        step.setDetail("test detail");
        assert(step.getDetail() == "test detail");
    }
}
