# ═══════════════════════════════════════════════════════════════════════════════
# NEEDLE Phase 1: Safety & Correctness — Production-Grade Safety Gates
# ═══════════════════════════════════════════════════════════════════════════════
#
# Based on Research Report 2026-03-03
# φ² + 1/φ² = 3 | TRINITY
#
# ═══════════════════════════════════════════════════════════════════════════════

name: phase1_safety
version: "1.0.0"
language: zig
module: trinity.needle.phase1_safety

description: |
  Production-grade safety gates for NEEDLE Omega refactoring.
  Implements atomic rollback with 100% zero data loss guarantee.

# ═══════════════════════════════════════════════════════════════════════════════
# TYPES
# ═══════════════════════════════════════════════════════════════════════════════

types:
  SafetyGateType:
    description: "Individual safety check types"
    enum: [parse_check, compile_check, test_check, vsa_check, rollback_check]

  SafetyGate:
    description: "Configuration for a single safety gate"
    fields:
      name: SafetyGateType
      enabled: Boolean
      threshold: Float
      block_on_failure: Boolean
      timeout_ms: Int

  SafetyResult:
    description: "Result of running a safety gate"
    fields:
      gate: SafetyGateType
      passed: Boolean
      score: Float
      errors: List<String>
      warnings: List<String>
      duration_ms: Int

  ParseResult:
    description: "Result of parsing a source file"
    fields:
      valid: Boolean
      errors: List<String>
      error_locations: List[SourceLocation]
      ast_valid: Boolean

  CompileResult:
    description: "Result of compiling source code"
    fields:
      success: Boolean
      exit_code: Int
      stdout: String
      stderr: String
      compile_time_ms: Int

  TestResult:
    description: "Result of running test suite"
    fields:
      passed: Int
      failed: Int
      skipped: Int
      total: Int
      test_names: List<String>
      failure_output: String

  AtomicRefactor:
    description: "Atomic refactor with guaranteed rollback"
    fields:
      backups: Map<String, String>
      affected_files: List[String]
      original_state: String
      rollback_on_error: Boolean
      state: Enum[idle, backing_up, applying, committing, rolling_back]

  RefactorTransaction:
    description: "Complete refactor transaction with all phases"
    fields:
      atomic_refactor: AtomicRefactor
      safety_gates: List[SafetyGate]
      results: List[SafetyResult]
      final_state: Enum[committed, rolled_back, in_progress]

  SourceLocation:
    description: "Location in source code"
    fields:
      file: String
      line: Int
      column: Int
      offset: Int

# ═══════════════════════════════════════════════════════════════════════════════
# BEHAVIORS
# ═══════════════════════════════════════════════════════════════════════════════

behaviors:
  - name: production_safety_gates
    description: "Run all safety gates before and after edits"
    given: "source file to refactor"
    when: "any edit operation is requested"
    then: |
      1. Backup original file (AtomicRefactor.begin)
      2. Run parse_check (tree-sitter validation)
      3. Apply edit
      4. Run parse_check again
      5. Run compile_check (zig build)
      6. Run test_check (zig test)
      7. If any gate fails: rollback_all
      8. If all gates pass: commit (clear backups)
    implementation: "check.zig + safe_cross.zig"
    safety: "100% zero data loss guarantee"

  - name: atomic_rollback
    description: "Guaranteed rollback on any failure"
    given: "refactor operation that fails safety gates"
    when: "any safety gate returns error"
    then: |
      1. Stop further operations immediately
      2. Restore all files from backups
      3. Verify files restored correctly
      4. Report failure with detailed error info
    implementation: "safe_cross.zig AtomicRefactor"
    safety: "Atomic operation - all succeed or all fail"

  - name: parse_check_tree_sitter
    description: "Parse source using tree-sitter for validation"
    given: "source file path"
    when: "before and after edit"
    then: |
      1. Parse source with tree-sitter
      2. Check AST is valid (no error nodes)
      3. Extract error locations if invalid
      4. Return ParseResult with detailed errors
    implementation: "check.zig runParseCheck"

  - name: compile_check_zig
    description: "Compile check using zig build"
    given: "source file or project root"
    when: "after edit applied"
    then: |
      1. Run `zig build` as subprocess
      2. Capture exit code and output
      3. Parse errors from stderr
      4. Return CompileResult with error details
    implementation: "check.zig runCompileCheck"
    timeout: 30000

  - name: test_check_runner
    description: "Run test suite to verify no regressions"
    given: "project with tests"
    when: "after compile succeeds"
    then: |
      1. Run `zig test` as subprocess
      2. Parse test results
      3. Count passed/failed/skipped
      4. Return TestResult with failure details
    implementation: "check.zig runTestCheck"
    timeout: 60000

# ═══════════════════════════════════════════════════════════════════════════════
# ALGORITHMS
# ═══════════════════════════════════════════════════════════════════════════════

algorithms:
  - name: atomic_refactor_algorithm
    description: "Atomic refactor with guaranteed rollback"
    steps:
      - name: begin
        description: "Create backups of all affected files"
        implementation: |
          for file in affected_files:
              backups[file] = read_file(file)
          state = backing_up

      - name: apply_edit
        description: "Apply the edit operation"
        implementation: |
          try:
              apply_edit(edit_operation)
              state = applying
          catch Error:
              rollback()
              raise

      - name: run_gates
        description: "Run all enabled safety gates"
        implementation: |
          for gate in safety_gates:
              if gate.enabled:
                  result = run_gate(gate)
                  results.append(result)
                  if not result.passed and gate.block_on_failure:
                      rollback()
                      raise SafetyGateFailed(gate, result)

      - name: commit
        description: "Commit changes - clear backups"
        implementation: |
          for backup in backups.values():
              free(backup)
          backups.clear()
          state = committed

      - name: rollback
        description: "Rollback all changes from backups"
        implementation: |
          state = rolling_back
          for file, backup in backups:
              write_file(file, backup)
              verify_checksum(file, backup)
          state = rolled_back
    safety: "100% ACID properties"

  - name: safety_gate_pipeline
    description: "Sequential safety gate execution"
    steps:
      - name: pre_check
        gates: [parse_check]
      - name: apply
        action: "apply_edit"
      - name: post_check
        gates: [parse_check, compile_check, test_check]
      - name: decide
        condition: "all gates passed"
        true_action: "commit"
        false_action: "rollback"

# ═══════════════════════════════════════════════════════════════════════════════
# MCP TOOLS
# ═══════════════════════════════════════════════════════════════════════════════

mcp_tools:
  - name: needle_safety_gates_run
    description: "Run all safety gates on a file"
    input_schema:
      file_path:
        type: String
        required: true
      gates:
        type: List[String]
        description: "List of gates to run: parse, compile, test, vsa"
        default: ["parse", "compile", "test"]
    output_schema:
      results:
        type: List[SafetyResult]

  - name: needle_atomic_refactor
    description: "Apply atomic refactor with 100% rollback guarantee"
    input_schema:
      file_path:
        type: String
        required: true
      pattern_query:
        type: String
        required: true
      replacement:
        type: String
        required: true
      safety_gates:
        type: List[String]
        default: ["parse", "compile", "test"]
    output_schema:
      success:
        type: Boolean
      rolled_back:
        type: Boolean
      results:
        type: List[SafetyResult]
      duration_ms:
        type: Int

  - name: needle_parse_check
    description: "Parse check using tree-sitter"
    input_schema:
      file_path:
        type: String
        required: true
    output_schema:
      valid:
        type: Boolean
      errors:
        type: List[String]

  - name: needle_compile_check
    description: "Compile check using zig build"
    input_schema:
      file_path:
        type: String
        required: false
      project_root:
        type: String
        default: "."
    output_schema:
      success:
        type: Boolean
      exit_code:
        type: Int
      stderr:
        type: String

# ═══════════════════════════════════════════════════════════════════════════════
# INTEGRATION
# ═══════════════════════════════════════════════════════════════════════════════

integration:
  trinity_mcp:
    enabled: true
    tool_count: 4
    claude_only: true

  omega_analyze:
    enabled: true
    auto_call_after: "phase1_complete"
    description: "Omega will analyze safety patterns for Phase 2"

# ═══════════════════════════════════════════════════════════════════════════════
# EXIT CRITERIA
# ═══════════════════════════════════════════════════════════════════════════════

exit_criteria:
  - name: parse_check_functional
    description: "Parse check using tree-sitter works correctly"
    test: "zig test needle/parse_check_test"

  - name: compile_check_functional
    description: "Compile check detects real compilation errors"
    test: "zig test needle/compile_check_test"

  - name: test_check_functional
    description: "Test check runs and parses results"
    test: "zig test needle/test_check_test"

  - name: atomic_rollback_100_percent
    description: "Rollback tested on 100 scenarios, zero data loss"
    test: "zig test needle/atomic_rollback_test --test-count 100"

  - name: e2e_safety_verified
    description: "End-to-end safety verification passes"
    test: "zig build needle-safety-e2e"

  - name: mcp_tools_working
    description: "All 4 safety MCP tools respond correctly"
    test: "./zig-out/bin/trinity-mcp tools/call needle_parse_check"

success_signal:
  all_exit_criteria: true
  zero_data_loss: true
  tests_pass: true
  committed: true

# ═══════════════════════════════════════════════════════════════════════════════
# REFERENCES
# ═══════════════════════════════════════════════════════════════════════════════

references:
  - "Research Report 2026-03-03 - VSA Literature & SOTA Analysis"
  - "tree-sitter documentation - https://tree-sitter.github.io/tree-sitter/"
  - "Zig build system - https://ziglearn.org/chapter-1/"
  - "ACID properties - database transactions for rollback guarantee"
  - "SWE-Bench safety requirements"

# ═══════════════════════════════════════════════════════════════════════════════
# METADATA
# ═══════════════════════════════════════════════════════════════════════════════

metadata:
  created: "2026-03-03"
  phase: 1
  duration_weeks: 4
  priority: P0
  status: in_progress

