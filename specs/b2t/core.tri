[spec]
name = "b2t_core"
version = "1.0.0"
description = "Binary to ternary encoding and decoding"

[interface]
inputs = ["binary_data: []u8"]
outputs = ["ternary_data: []Trit"]

[invariants]
length = "len(output) == ceil(len(input) * 8 / log2(3))"
reversible = "decode(encode(x)) == x"
trit_values = "{-1, 0, +1}"

[architecture]
encoding = "balanced ternary representation"
chunk_size = "process 8 bits at a time"
