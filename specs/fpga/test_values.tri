# ═══════════════════════════════════════════════════════════════════════════════
# test_values - Parser values field test
# ═══════════════════════════════════════════════════════════════════════════════
#
# Tests parsing of {name, value} pairs in type definitions
# Expected Verilog output: localparam declarations
#
# φ² + 1/φ² = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

name: test_values
version: "1.0.0"
language: varlog
fpga_target: xilinx
target_frequency: 50

types:
  State:
    encoding: one_hot
    width: 3
    values:
      - name: IDLE
        value: 3'b001
      - name: RUNNING
        value: 3'b010
      - name: DONE
        value: 3'b100

  Command:
    width: 8
    values:
      - name: CMD_PING
        value: 8'hFF
      - name: CMD_MODE
        value: 8'h01

signals:
  - name: state
    width: 3
    direction: output
  - name: cmd
    width: 8
    direction: input

behaviors:
  - name: test_localparams
    given: State and Command types with values
    when: Type definitions are parsed
    then: localparam declarations generated in Verilog output
