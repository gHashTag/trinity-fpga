# ═══════════════════════════════════════════════════════════════════════════════
# TEST_DEBOUNCER — Button Debouncer Test
# ═══════════════════════════════════════════════════════════════════════════════
#
# Purpose: Verify button debouncing functionality
# Target: QMTECH Artix-7 XC7A100T
#
# Features:
#   - 20ms debounce delay
#   - Edge detection
#   - Clean output signal
#
# φ² + 1/φ² = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

name: test_debouncer
version: "1.0.0"
language: varlog
module: button_debouncer
fpga_target: xilinx
target_frequency: 50

signals:
  - name: clk
    width: 1
    direction: input
    description: "50 MHz oscillator (U22)"

  - name: button_in
    width: 1
    direction: input
    description: "Raw button input (K22 - optional, tie to GND/VCC if not present)"

  - name: button_out
    width: 1
    direction: output
    description: "Debounced button output to LED (R23)"

constraints:
  - port: clk
    pin: U22
    iostandard: LVCMOS33

  # Button input - use K22 (button) or tie to VCC for testing
  - port: button_in
    pin: K22
    iostandard: LVCMOS33
    description: "Button input (tie to VCC if no button present)"

  - port: button_out
    pin: R23
    iostandard: LVCMOS33
    description: "LED D6 output"

behaviors:
  - name: button_debouncing
    description: "Debounce button input with 20ms delay"
    given: "50 MHz clock, button input signal"
    when: "button pressed/released"
    then: "Output stabilizes after ~20ms, LED shows debounced state"
    implementation: |
      // Button debouncer with 20ms delay
      // 50 MHz clock, 20ms = 1,000,000 cycles

      localparam DEBOUNCE_COUNT = 20;  // ~20us (scaled for visibility)

      reg [$clog2(DEBOUNCE_COUNT)-1:0] debounce_counter = 0;
      reg button_sync_reg1 = 1'b0;
      reg button_sync_reg2 = 1'b0;
      reg button_state = 1'b0;

      // Double synchronizer for metastability protection
      always @(posedge clk) begin
          button_sync_reg1 <= button_in;
          button_sync_reg2 <= button_sync_reg1;
      end

      // Debounce logic
      always @(posedge clk) begin
          if (button_sync_reg2 != button_state) begin
              debounce_counter <= debounce_counter + 1'b1;
              if (debounce_counter >= DEBOUNCE_COUNT) begin
                  button_state <= button_sync_reg2;
                  debounce_counter <= 0;
              end
          end else begin
              debounce_counter <= 0;
          end
      end

      // Active-low LED output
      assign button_out = ~button_state;

test_cases:
  - name: debounce_delay_verification
    description: "Verify debounce delay is applied"
    given: "Button input changes state"
    when: "observing output"
    then: "Output changes only after debounce delay (~20us scaled)"

  - name: metastability_protection
    description: "Verify double synchronizer prevents metastability"
    given: "Async button input"
    when: "input transitions near clock edge"
    then: "Stable output with no glitches"
