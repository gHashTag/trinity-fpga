# Tier 3 — Semantic VSA (Vector Symbolic Architecture)
# NEEDLE Tier 3: Semantic-aware refactoring with VSA embeddings
# φ² + 1/φ² = 3 | TRINITY

name: tier3-vsa
version: "1.0.0"
module: trinity.needle.vsa
description: Semantic VSA embeddings for intent-aware code refactoring with cosine similarity search

# ═══════════════════════════════════════════════════════════════════════════════
# TYPES
# ═══════════════════════════════════════════════════════════════════════════════

types:
  SemanticVector:
    fields:
      symbol_id: String                        # Fully qualified symbol name
      embedding: List<Float>                   # 384-dim or 768-dim embedding
      context_hash: String                     # Hash of surrounding context
      symbol_type: Enum[function, struct, enum, const, variable]
      file: String
      line: Int
      metadata: Map<String, String]

  VSARule:
    fields:
      pattern_id: String
      semantic_pattern: String                 # Natural language description
      similarity_threshold: Float              # Default: 0.85
      safety_level: Enum[low, medium, high, critical]
      allowed_transforms: List<String]
      forbidden_transforms: List[String]

  VSAMatch:
    fields:
      symbol: Symbol
      similarity: Float                        # Cosine similarity [-1, 1]
      context_match: Float                     # Context similarity
      confidence: Float                        # Combined score

  SemanticIndex:
    fields:
      vectors: Map<String, SemanticVector>     # symbol_id -> SemanticVector
      vsa_rules: List[VSARule]
      embedding_dim: Int                       # 384 or 768
      index_type: Enum[flat, hnsw, ivf]        # Index structure

# ═══════════════════════════════════════════════════════════════════════════════
# BEHAVIORS
# ═══════════════════════════════════════════════════════════════════════════════

behaviors:
  # ─────────────────────────────────────────────────────────────────────────────
  # VSA EMBEDDING GENERATION
  # ─────────────────────────────────────────────────────────────────────────────
  - name: build_vsa_index
    given: "CallGraph + source code"
    when: "Tier 3 initialized or requested"
    then: |
      1. For each symbol in CallGraph:
         - Extract symbol signature and body
         - Extract surrounding context (5 lines before/after)
         - Generate embedding:
           a. Hash-based (baseline): φ-based hash of signature + context
           b. VSA operations: bind(symbol_name, context)
           c. Future: real embedding model (384-dim)
         - Store in SemanticIndex
      2. Build HNSW index for fast similarity search
      3. Return SemanticIndex
    complexity: "O(N log N) for HNSW build"
    safety: "Read-only, always safe"

  # ─────────────────────────────────────────────────────────────────────────────
  # SEMANTIC SEARCH
  # ─────────────────────────────────────────────────────────────────────────────
  - name: vsa_semantic_search
    given: "SemanticIndex + query symbol"
    when: "User requests semantic-aware refactor"
    then: |
      1. Generate embedding for query symbol
      2. Search HNSW index for top-K similar symbols
      3. Filter by:
         - similarity_threshold (default 0.85)
         - symbol_type compatibility
         - VSA rules
      4. Return ranked list of VSAMatch
    output: "List<VSAMatch> ranked by similarity"
    complexity: "O(log N) for HNSW search"

  - name: vsa_find_similar_code
    given: "Code snippet + SemanticIndex"
    when: "User wants to find similar patterns"
    then: |
      1. Parse code snippet to extract intent
      2. Generate embedding for snippet
      3. Search for similar symbols
      4. Return matches with similarity scores
    use_case: "Find all error handling patterns, all logging patterns, etc."

  # ─────────────────────────────────────────────────────────────────────────────
  # SEMANTIC REFACTOR
  # ─────────────────────────────────────────────────────────────────────────────
  - name: vsa_semantic_refactor
    given: "Symbol name + new intent + SemanticIndex + CallGraph"
    when: "User requests refactor by meaning (not just name)"
    then: |
      1. Find all semantically similar symbols (vsa_semantic_search)
      2. For each similar symbol above threshold:
         - Verify VSA rules allow transformation
         - Add to edit plan
      3. Compute topological order (Tier 2)
      4. Preview changes with semantic diff
      5. If confirmed, apply with rollback (Tier 2)
    output: "MultiFileEdit with semantic awareness"
    safety: "VSA rules + Tier 2 safety gates"

  - name: vsa_rename_by_intent
    given: "Old symbol name + new intent description"
    when: "User wants to rename based on meaning"
    then: |
      1. Generate new name from intent (future: LLM)
      2. Find all semantically related usages
      3. Apply rename with semantic verification
    example: |
      Input: "handle_error" -> intent: "should be called recover_from_failure"
      Result: Finds all error handling patterns, renames consistently

  # ─────────────────────────────────────────────────────────────────────────────
  # VSA RULES ENGINE
  # ─────────────────────────────────────────────────────────────────────────────
  - name: vsa_load_rules
    given: "Rules configuration file"
    when: "Tier 3 initialized"
    then: |
      1. Parse VSA rules from config
      2. Validate rules (syntax, semantic constraints)
      3. Load into SemanticIndex
    format: "YAML or JSON"

  - name: vsa_validate_refactor
    given: "Proposed edit + VSA rules"
    when: "Before applying refactor"
    then: |
      1. Check if transformation is allowed
      2. Check if transformation is forbidden
      3. Verify semantic similarity above threshold
      4. Return validation result
    safety: "Blocks unsafe transformations"

# ═══════════════════════════════════════════════════════════════════════════════
# ALGORITHMS
# ═══════════════════════════════════════════════════════════════════════════════

algorithms:
  - name: generate_embedding
    given: "Symbol signature + context"
    when: "Building VSA index"
    algorithm: |
      Hash-based embedding (baseline):
      1. Preprocess: normalize, tokenize
      2. For each dimension i in 0..embedding_dim-1:
         - hash_input = signature + context + str(i)
         - hash_val = φ_hash(hash_input)  # φ-based hash
         - embedding[i] = (hash_val % 10000) / 10000.0  # Normalize to [0,1]
         - Convert to [-1,1]: embedding[i] = 2 * embedding[i] - 1

      Future: Real embedding model
      1. Use pre-trained model (e.g., codebert, graphcodebert)
      2. Fine-tune on Trinity codebase
      3. Cache embeddings
    complexity: "O(D) where D = embedding_dim"

  - name: cosine_similarity
    given: "Two embeddings"
    algorithm: |
      cos_sim(a, b) = (a · b) / (||a|| * ||b||)

      Where:
      - a · b = Σ(a[i] * b[i])  # Dot product
      - ||a|| = sqrt(Σ(a[i]²))   # L2 norm

      Range: [-1, 1] where:
      - 1.0 = identical direction
      - 0.0 = orthogonal
      - -1.0 = opposite direction
    complexity: "O(D)"

  - name: hnsw_build
    given: "List of embeddings"
    algorithm: |
      Hierarchical Navigable Small World:
      1. Build layers of proximity graphs
      2. Higher layers: sparse, long-range connections
      3. Lowest layer: dense, all points
      4. Search: greedy descent from top layer
    complexity: "O(N log N) build, O(log N) search"

  - name: vsa_bind_unbind
    given: "Symbol + context"
    algorithm: |
      VSA operations from src/vsa.zig:
      1. bind(symbol_vec, context_vec) → combined_vec
      2. unbind(combined_vec, context_vec) → symbol_vec (approximate)
      3. Similarity check: cosine(unbind(bind(s,c),c), s) ≈ 1.0
    use_case: "Context-aware symbol matching"

# ═══════════════════════════════════════════════════════════════════════════════
# MCP TOOLS (Tier 3)
# ═══════════════════════════════════════════════════════════════════════════════

mcp_tools:
  - name: needle_graph_build
    description: "Build complete call graph with VSA embeddings for project"
    category: tier2
    safety_level: low
    args_schema:
      root_dir:
        type: string
        description: "Project root directory"
        default: "."
      enable_vsa:
        type: boolean
        description: "Enable VSA embedding generation"
        default: true

  - name: needle_graph_refactor
    description: "Rename symbol across entire project with semantic awareness"
    category: tier2
    safety_level: needle
    args_schema:
      symbol:
        type: string
        description: "Current symbol name"
        required: true
      new_name:
        type: string
        description: "New symbol name"
        required: true
      semantic_aware:
        type: boolean
        description: "Use VSA to find semantically similar symbols"
        default: true
      similarity_threshold:
        type: number
        description: "Minimum similarity for semantic matches"
        default: 0.85
      scope:
        type: string
        enum: [file, project]
        description: "Refactor scope"
      preview:
        type: boolean
        description: "Only preview changes"

  - name: needle_graph_vsa_search
    description: "Search for semantically similar symbols by code or intent"
    category: tier3
    safety_level: low
    args_schema:
      query:
        type: string
        description: "Code snippet or intent description"
        required: true
      top_k:
        type: integer
        description: "Number of results to return"
        default: 10
      min_similarity:
        type: number
        description: "Minimum similarity threshold"
        default: 0.75

  - name: needle_semantic_replace
    description: "Replace code by semantic meaning (not just pattern)"
    category: tier3
    safety_level: needle
    args_schema:
      intent:
        type: string
        description: "Intent description of what to replace"
        required: true
      replacement_intent:
        type: string
        description: "Intent description of replacement"
        required: true
      file:
        type: string
        description: "File to apply replacement"
      preview:
        type: boolean
        description: "Preview changes only"
        default: true

  - name: needle_graph_visualize
    description: "Generate graph visualization with VSA clustering (DOT/JSON)"
    category: tier2
    safety_level: low
    args_schema:
      format:
        type: string
        enum: [dot, json, json_html]
      focus:
        type: string
        description: "Symbol or file to focus on"
      show_vsa:
        type: boolean
        description: "Show VSA similarity clusters"

  - name: needle_graph_affected
    description: "Find all files affected by symbol change (with semantic impact)"
    category: tier2
    safety_level: low
    args_schema:
      symbol:
        type: string
        required: true
      include_transitive:
        type: boolean
        default: true
      semantic_impact:
        type: boolean
        description: "Include semantically related symbols"
        default: true

# ═══════════════════════════════════════════════════════════════════════════════
# INTEGRATION
# ═══════════════════════════════════════════════════════════════════════════════

integration:
  trinity_mcp: true
  tier2_bridge: "Uses Tier 2 call graph for dependency tracking"
  vsa_module: "src/vsa.zig for bind/unbind operations"
  needle_check: "After each file edit + VSA validation"
  rollback: "Automatic on parse failure or semantic mismatch"

# ═══════════════════════════════════════════════════════════════════════════════
# EXIT CRITERIA
# ═══════════════════════════════════════════════════════════════════════════════

exit_criteria:
  vsa_zig_compiles: true
  semantic_index_builds: true
  cosine_similarity_works: true
  vsa_semantic_search_passes: true
  vsa_rules_validate: true
  semantic_refactor_e2e_passes: true
  vsa_preview_works: true
  mcp_tools_registered: true
  committed: true

# ═══════════════════════════════════════════════════════════════════════════════
# TECHNOLOGY TREE POSITION
# ═══════════════════════════════════════════════════════════════════════════════

tech_tree:
  needle:
    tier_0: "Fuzzy text fallback — COMPLETE ✅"
    tier_1: "AST structural — COMPLETE ✅"
    tier_1_5: "MCP Bridge (Zig) — COMPLETE ✅"
    tier_1_6: "FULL TRI-MCP (35+ tools) — COMPLETE ✅"
    tier_2: "Graph multi-file — COMPLETE ✅"
    tier_3: "Semantic VSA — IN PROGRESS ← WE ARE HERE"
    tier_4: "Safe cross-file + VSA rules — PENDING"
    tier_5: "Omega (autonomy) — PENDING"

# ═══════════════════════════════════════════════════════════════════════════════
# SACRED CONSTANTS
# ═══════════════════════════════════════════════════════════════════════════════

sacred:
  phi: 1.618033988749895
  trinity_sum: 3.0  # φ² + 1/φ² = 3
  phoenix: 999
  vsa_dim: 384      # Default embedding dimension
  similarity_threshold: 0.85

# φ² + 1/φ² = 3 | TRINITY | TIER 3 SEMANTIC VSA
