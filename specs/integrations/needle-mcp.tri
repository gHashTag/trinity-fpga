# NEEDLE-MCP Integration Specification
# Model Context Protocol server for NEEDLE structural editor
# φ² + 1/φ² = 3 | TRINITY

name: needle-mcp-integration
version: "1.0.0"
language: zig
module: needle_mcp
description: Model Context Protocol server for NEEDLE structural editor with AST-aware code editing

types:
  McpServerConfig:
    fields:
      server_name: String                  # "needle-mcp"
      server_version: String               # "1.0.0"
      protocol_version: String             # "2024-11-05"
      transport: Enum[stdio, sse]          # stdio for Claude Code
      tri_binary_path: String              # Path to tri binary
      max_timeout_seconds: Int             # Default: 300

  McpTool:
    fields:
      name: String
      description: String
      input_schema: Map                    # JSON Schema

  McpResponse:
    fields:
      content: List[McpContent]
      is_error: Bool
      meta: Map                            # Metadata (duration, tier used)

  McpContent:
    fields:
      type: Enum[text, image, resource]
      text: String                         # For text type
      data: String                         # For resource type

behaviors:
  # ─────────────────────────────────────────────────────────────────────────────
  # MCP Protocol Handlers
  # ─────────────────────────────────────────────────────────────────────────────

  - name: handle_initialize
    given: "Initialize request from MCP client"
    when: "Client connects to server"
    then: |
      Returns server capabilities:
      - protocolVersion: "2024-11-05"
      - capabilities.tools: {}
      - serverInfo.name: "needle-mcp"
      - serverInfo.version: "1.0.0"

  - name: handle_tools_list
    given: "Tools list request"
    when: "Client requests available tools"
    then: |
      Returns array of 5 tools:
      1. needle_structural_replace
      2. needle_search
      3. needle_quality_gates
      4. needle_preview
      5. needle_batch_edit

  - name: handle_tools_call
    given: "Tool call request with name and arguments"
    when: "Client invokes a tool"
    then: |
      Routes to appropriate tool handler:
      1. Parse tool name and arguments
      2. Call tri needle command via subprocess
      3. Parse JSON output from tri
      4. Return formatted MCP response
      On error: return isError=true with error message

  # ─────────────────────────────────────────────────────────────────────────────
  # Tool: needle_structural_replace
  # ─────────────────────────────────────────────────────────────────────────────

  - name: tool_needle_structural_replace
    given: "file_path, pattern_query, replacement, safety_level, edit_mode"
    when: "User wants to apply structural edit"
    then: |
      Executes: tri needle --file <file> --query <pattern> --replace <code> --json-output
      Returns:
      - operations_applied: Int
      - files_modified: Int
      - parse_ok: Bool
      - violations: List[Violation]
      - duration_ms: Int
      On parse error: returns violation with severity=critical

  # ─────────────────────────────────────────────────────────────────────────────
  # Tool: needle_search
  # ─────────────────────────────────────────────────────────────────────────────

  - name: tool_needle_search
    given: "query, file_path (optional), confidence_threshold"
    when: "User searches codebase for pattern"
    then: |
      Executes: tri needle-search <query> [--file <path>] --json-output
      Returns:
      - matches: List[MatchResult]
      - total_count: Int
      Each match includes: line, column, confidence, matched_text

  # ─────────────────────────────────────────────────────────────────────────────
  # Tool: needle_quality_gates
  # ─────────────────────────────────────────────────────────────────────────────

  - name: tool_needle_quality_gates
    given: "file_path, check_level (basic, full)"
    when: "User runs quality check"
    then: |
      Executes: tri needle-check <file> --json-output
      Returns:
      - parse_ok: Bool
      - violations: List[Violation]
      - safety_score: Float (0.0-1.0)
      - has_critical: Bool

  # ─────────────────────────────────────────────────────────────────────────────
  # Tool: needle_preview
  # ─────────────────────────────────────────────────────────────────────────────

  - name: tool_needle_preview
    given: "file_path, pattern_query, replacement"
    when: "User wants diff without applying"
    then: |
      Executes: tri needle --file <file> --query <pattern> --replace <code> --preview --json-output
      Returns:
      - diff_hunk: String (unified diff format)
      - old_text: String
      - new_text: String
      - line_range: String (start:end)

  # ─────────────────────────────────────────────────────────────────────────────
  # Tool: needle_batch_edit
  # ─────────────────────────────────────────────────────────────────────────────

  - name: tool_needle_batch_edit
    given: "List of edit operations with file, query, replacement"
    when: "User applies multiple edits"
    then: |
      For each edit:
        1. Run tri needle with preview
        2. Accumulate results
        3. If all pass, apply sequentially
      Returns:
      - applied_count: Int
      - failed_count: Int
      - results: List[EditReport]

algorithms:
  # ─────────────────────────────────────────────────────────────────────────────
  # Subprocess Bridge Pattern
  # ─────────────────────────────────────────────────────────────────────────────

  - name: subprocess_bridge
    input: tri_command, args
    output: parsed_json_result
    steps:
      - name: build_command
        action: "Construct subprocess args: tri <command> <args> --json-output"
      - name: execute
        action: "Run subprocess with timeout (default 300s)"
      - name: capture_output
        action: "Capture stdout and stderr"
      - name: parse_json
        action: "Parse JSON response from tri"
      - name: handle_error
        action: "On failure, return MCP error response"
    formula: |
      response_time = end_time - start_time
      if exit_code != 0:
          return MCPErrorResponse(stderr)
      return MCPSuccessResponse(json.loads(stdout))

  # ─────────────────────────────────────────────────────────────────────────────
  # Self-Healing Safety
  # ─────────────────────────────────────────────────────────────────────────────

  - name: self_healing_check
    input: EditReport
    output: Bool (should_rollback)
    steps:
      - name: check_parse
        action: "If !parse_ok: rollback = true"
      - name: check_critical_violations
        action: "If any severity=critical: rollback = true"
      - name: check_safety_score
        action: "If safety_score < 0.5: rollback = true"
      - name: auto_rollback
        action: "Restore original file if rollback = true"
    formula: |
      rollback = (!parse_ok) or (critical_count > 0) or (safety_score < 0.5)

integration:
  tri_commands:
    - name: needle
      usage: "tri needle --file <path> --query <pattern> --replace <code> [--json-output]"
      mcp_tool: needle_structural_replace

    - name: needle-search
      usage: "tri needle-search <query> [--file <path>] [--json-output]"
      mcp_tool: needle_search

    - name: needle-check
      usage: "tri needle-check <file-path> [--json-output]"
      mcp_tool: needle_quality_gates

  mcp_servers:
    - name: needle-mcp
      command: "python3"
      args: ["tools/mcp/needle_mcp/server.py"]
      transport: "stdio"

  self_healing:
    enabled: true
    auto_rollback: true
    backup_suffix: ".needle_backup"

sacred_constants:
  phi: 1.618033988749895
  trinity_sum: 3.0  # φ² + 1/φ² = 3
  phoenix: 999
