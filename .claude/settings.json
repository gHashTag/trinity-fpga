{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(tri *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(gh issue*)",
      "Bash(zig build*)",
      "Bash(zig fmt*)",
      "Bash(zig ast-check*)",
      "mcp__zig-docs__*",
      "mcp__railway-mcp-server__*",
      "mcp__perplexity__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(python*)",
      "Bash(node*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "tri doctor enforce-check"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./zig-out/bin/ralph-hook post-edit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./zig-out/bin/ralph-hook stop"
          }
        ]
      }
    ]
  }
}
