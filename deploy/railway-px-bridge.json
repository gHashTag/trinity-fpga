{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.px-bridge"
  },
  "deploy": {
    "startCommand": "/usr/local/bin/tri-api --serve",
    "healthcheckPath": "/px/status",
    "healthcheckTimeout": 10,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
