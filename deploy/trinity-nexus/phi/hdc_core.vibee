  FloatAccumulator:
    description: "Float [CYR:I] for  withnotandI"
    fields:
      data: List<Float>
      dim: Int

  Prototype:
    description: "type class with [CYR:I]"
    fields:
      label: String
      accumulator: FloatAccumulator
      vector: HyperVector
      count: Int

  OnlineHDC:
    description: " HDC system"
