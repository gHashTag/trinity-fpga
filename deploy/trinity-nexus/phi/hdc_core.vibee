name: hdc_core
version: "1.0.0"
language: zig
module: hdc_core

description: |
  HDC Core - iny and and[CYR:y] inyandwithand
  with -and for withandwithI AI .
  
  onI [CYR:base]:
  - Kanerva (2009): Hyperdimensional Computing
  - BitNet b1.58 (2024): and[CYR:y] inwith {-1, 0, +1}
  - Setun (1958): withandinonI andonI system
  
  and:
  - Binding: a ⊗ b = element and
  - Bundling: and [CYR:go]withinand
  - Similarity: withandwith within
  - Online Update: P ← P + η(v - P),  infromandI

imports:
  - hybrid  # HybridBigInt, Vec32i8, SIMD_WIDTH

constants:
  DEFAULT_DIM: 10240
  LEARNING_RATE: 0.01
  SIMILARITY_THRESHOLD: 0.7
  QUANTIZE_POS: 0.5
  QUANTIZE_NEG: -0.5
  MAX_PROTOTYPES: 1000

types:
  Trit:
    description: "withandin[CYR:ny] and[CYR:ny] [CYR:I]"
    values:
      - Neg: -1
      - Zero: 0
      - Pos: 1

  HyperVector:
