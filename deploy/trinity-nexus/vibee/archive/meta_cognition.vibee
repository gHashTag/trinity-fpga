@spec detect_biases(
  chain: [ReasoningStep],
  evidence: [Evidence]
) → [Bias] {
  /// Detect cognitive biases in reasoning
  given: Chain and evidence
  when: Checking for biases
  then: Returns type {name} {
  items: List[Item],
  count: Int} biases
}

@impl {
  let biases = []

  // Check for confirmation bias
  let confirming = evidence.filter(fn(e) { e.relevance > 0.7 })
  let disconfirming = evidence.filter(fn(e) { e.relevance < 0.3 })
  let biases = case list.len(confirming) > list.len(disconfirming) * 3 {
    true → [ConfirmationBias, ..biases]
    false → biases
  }

  // Check for recency bias
  let recent = evidence.filter(fn(e) {
    current_timestamp_ms() - e.timestamp < 3600000  // 1 hour
  })
  let biases = case list.len(recent) > list.len(evidence) / 2 {
    true → [RecencyBias, ..biases]
    false → biases
  }

  // Check for overconfidence
  let avg_confidence = chain.fold(0.0, step · fn {
    acc +. step.confidence
  }) /. int.to_float(list.len(chain))
  let biases = case avg_confidence > 0.9 && list.len(evidence) < 3 {
    true → [OverconfidenceBias, ..biases]
    false → biases
  }

  # Auto-generated getters
fn approach(self) · self.approach

fn success_rate(self) · self.success_rate

fn completed_at(self) · self.completed_at


  biases
}

@spec identify_assumptions(chain: [ReasoningStep]) → [Assumption] {
  /// Identify assumptions in reasoning
  given: Reasoning chain
  when: Analyzing assumptions
  then: Returns type {name} {
  items: List[Item],
  count: Int} assumptions
}

@impl {
  // Look for implicit assumptions in reasoning steps
  chain.flat_map(fn(step) {
    extract_assumptions_from_step(step)
  })
}

// =============================================================================
// Explanation Generation
// =============================================================================

@spec explain_decision(decision: Decision) → Explanation {
  /// Explain a decision in human-readable form
  given: Decision
  when: Explaining to type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int}
  then: Returns explanation
}

@impl {
  Explanation(
    what: decision.action,
    why: decision.reasoning,
    alternatives_considered: decision.alternatives.map(fn(a) { a.approach }),
    confidence: decision.confidence,
    risks: decision.risks.map(fn(r) { r.description }),
    mitigation: decision.mitigation.map(fn(m) { m.strategy })
  )
}

struct Explanation {
  Explanation(
    what: str,
    why: str,
    alternatives_considered: [str],
    confidence: float,
    risks: [str],
    mitigation: [str]
  )
}

