struct EvidenceSource {
  CodeAnalysis
  PastExperience
  Documentation
  TestResults
  type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int}Feedback
  ExternalAPI
