    task_id: str,
    hypothesis: str,
    evidence: [Evidence],
    confidence: float,
    alternatives: [Alternative],
    decision: Decision,
    reasoning_chain: [ReasoningStep],
    thinking_time_ms: int,
    meta_analysis: MetaAnalysis
  )
}

