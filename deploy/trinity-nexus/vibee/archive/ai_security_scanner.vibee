      severity: "critical"
      cwe: "CWE-89"
      fix: "withl]in[CYR:ate] parameterfromin[CYR:nye] queryy"
      
    xss:
      pattern: 'html.render(user_input)'
      severity: "high"
      cwe: "CWE-79"
      fix: "andin[CYR:ate] HTML"
      
    path_traversal:
      pattern: 'file.read(user_input)'
      severity: "high"
      cwe: "CWE-22"
      fix: "andin[CYR:ate] and filein"
      
    weak_crypto:
      pattern: 'md5(password)'
      severity: "high"
      cwe: "CWE-327"
      fix: "withl]in[CYR:ate] bcrypt or argon2"
      
    hardcoded_secrets:
      pattern: 'api_key = "sk-..."'
      severity: "critical"
      cwe: "CWE-798"
      fix: "withl]in[CYR:ate] [CYR:nye] andI"

  AI_PROMPTS:
