// Advanced SWE Agent Example - Complete implementation with all features
  // Performance Warning:   // AI Suggestion: Consider extracting hardcoded strings to constants  // AI Suggestion: Replace magic numbers with named constants// Demonstrates: @agent, @tool_pipeline, @intent, self-awareness modules

// =============================================================================
// Agent Definition with Full Self-Awareness
// =============================================================================

agent AdvancedSWEAgent(
  identity: {
    name: "Advanced SWE Agent"
    role: "Senior Software Engineer"
    capabilities: [
      "code_analysis",
      "code_generation",
      "testing",
      "deployment",
      "code_review",
      "refactoring",
      "debugging",
      "documentation"
    ]
    version: "2.0.0"
  }

  self_awareness: {
    track_performance: true
    learn_from_errors: true
    adapt_strategy: true
    introspection_interval: 100
  }

  state: {
    persistence: PostgreSQL
    auto_save_threshold: 5
    history_limit: 100
    cache_strategy: "LRU"
  }

  communication: {
    protocols: [WebSocket, HTTP]
    message_format: JSON
    retry_policy: ExponentialBackoff(max: 3, delay: 1000)
  }

  tools: [
    // File operations
    swe_read,
    swe_write,
    swe_search,
    swe_edit,
    swe_glob,

    // Git operations
    git_status,
    git_diff,
    git_log,
    git_commit,
    git_push,
    git_branch,
    git_checkout,

    // Testing
    test_run,
    test_generate,
    coverage_analyze,

    // Build & Deploy
    build_project,
    deploy_staging,
    deploy_production,
    health_check,

    // Code quality
    lint_check,
    security_scan,
    code_review,
    complexity_analyze,

    // Documentation
    doc_generate,
    readme_update,
    api_doc_generate
  ]

  learning: {
    enabled: true
    metrics: [
      "success_rate",
      "execution_time",
      "error_patterns",
      "code_quality",
      "test_coverage"
    ]
    adaptation_threshold: 0.7
    feedback_loop: true
  }
}

// =============================================================================
// Complete Feature Implementation Pipeline
// =============================================================================

@tool_pipeline complete_feature_implementation {
  description: "End-to-end feature implementation with testing and deployment"

  steps: [
    // Phase 1: Analysis
    parse_requirements → {
      tool: parse_task_description
      input: feature_description
      output: structured_task
      on_error: retry(3)
    },

    analyze_codebase → {
      tool: analyze_code_structure
      input: project_root
      output: code_structure
      depends_on: []
      parallel_with: [parse_requirements]
    },

    identify_affected_files → {
      tool: swe_search
      input: {
        pattern: structured_task.related_keywords
        path: "."
      }
      output: affected_files
      depends_on: [parse_requirements, analyze_codebase]
    },

    // Phase 2: Planning
    create_implementation_plan → {
      tool: generate_implementation_plan
      input: {
        task: structured_task
        structure: code_structure
        affected: affected_files
      }
      output: plan
      depends_on: [identify_affected_files]
    },

    // Phase 3: Setup
    create_feature_branch → {
      tool: git_branch
      input: {
        action: "create"
        name: \"feature/$structured_task.id\"
      }
      output: branch_created
      depends_on: [create_implementation_plan]
      on_error: skip_if_exists
    },

    checkout_branch → {
      tool: git_checkout
      input: {
        target: \"feature/$structured_task.id\"
        new_branch: "false"
      }
      depends_on: [create_feature_branch]
    },

    // Phase 4: Implementation
    generate_code → {
      tool: code_generator
      input: {
        spec: structured_task.description
        plan
        context: code_structure
      }
      output: generated_code
      depends_on: [checkout_branch]
      on_error: fallback_to_template
    },

    write_code_files → {
      tool: swe_write
      input: {
        files: generated_code.files
      }
      output: files_written
      depends_on: [generate_code]
    },

    // Phase 5: Testing
    generate_tests → {
      tool: test_generate
      input: {
        code: generated_code
        coverage_target: 0.85
      }
      output: test_files
      depends_on: [generate_code]
      parallel_with: [write_code_files]
    },

    write_test_files → {
      tool: swe_write
      input: {
        files: test_files
      }
      depends_on: [generate_tests]
    },

    run_tests → {
      tool: test_run
      input: {
        pattern: "**/*_test.gleam"
      }
      output: test_results
      depends_on: [write_code_files, write_test_files]
      condition: "files_written.success == true"
      on_error: abort_pipeline
    },

    analyze_coverage → {
      tool: coverage_analyze
      input: test_results
      output: coverage_report
      depends_on: [run_tests]
      condition: "test_results.passed >= test_results.total * 0.85"
    },

    // Phase 6: Quality Checks
    lint_code → {
      tool: lint_check
      input: {
        files: generated_code.files
      }
      output: lint_results
      depends_on: [write_code_files]
      parallel_with: [run_tests]
    },

    security_scan → {
      tool: security_scan
      input: {
        files: generated_code.files
      }
      output: security_results
      depends_on: [write_code_files]
      parallel_with: [run_tests, lint_code]
    },

    complexity_check → {
      tool: complexity_analyze
      input: {
        files: generated_code.files
      }
      output: complexity_results
      depends_on: [write_code_files]
      parallel_with: [run_tests, lint_code, security_scan]
    },

    // Phase 7: Documentation
    generate_docs → {
      tool: doc_generate
      input: {
        code: generated_code
        format: "markdown"
      }
      output: documentation
      depends_on: [run_tests]
      parallel_with: [lint_code]
    },

    update_readme → {
      tool: readme_update
      input: {
        changes: structured_task.description
        section: "Features"
      }
      depends_on: [generate_docs]
    },

    // Phase 8: Commit & PR
    stage_changes → {
      tool: git_add
      input: {
        files: "."
      }
      depends_on: [
        run_tests,
        lint_code,
        security_scan,
        complexity_check,
        update_readme
      ]
      condition: "test_results.success_rate >= 0.85 && security_results.issues == 0"
    },

    commit_changes → {
      tool: git_commit
      input: {
        message: \"feat: ${structured_task.title}\n\n$structured_task.description\"
      }
      depends_on: [stage_changes]
    },

    push_branch → {
      tool: git_push
      input: {
        branch: \"feature/$structured_task.id\"
      }
      depends_on: [commit_changes]
    },

    create_pull_request → {
      tool: github_create_pr
      input: {
        title: structured_task.title
        body: test_results, coverage_report · generate_pr_description
        base: "main"
        head: \"feature/$structured_task.id\"
      }
      depends_on: [push_branch]
    },

    // Phase 9: Deployment
    deploy_to_staging → {
      tool: deploy_staging
      input: {
        branch: \"feature/$structured_task.id\"
      }
      output: staging_deployment
      depends_on: [create_pull_request]
    },

    run_smoke_tests → {
      tool: test_run
      input: {
        pattern: "**/smoke_test.gleam"
        environment: "staging"
      }
      depends_on: [deploy_to_staging]
    },

    health_check_staging → {
      tool: health_check
      input: {
        url: staging_deployment.url
      }
      depends_on: [run_smoke_tests]
    }
  ]

  timeout: 600000  // 10 minutes
  max_retries: 2
  rollback_on_failure: true
}

// =============================================================================
// Adaptive Bug Fix Intent
// =============================================================================

intent fix_bug_adaptive(
  goal: "Fix reported bug with comprehensive testing"

  constraints: {
    preserve_existing_tests: true
    maintain_api_compatibility: true
    max_time: 30_minutes
    max_cost: 2.0
    required_approvals: []
  }

  success_when: {
    bug_reproduced: true
    fix_implemented: true
    tests_passing: true
    regression_test_added: true
    documentation_updated: true
    code_reviewed: false  // Optional for bugs
  }

  strategy: adaptive
}

// =============================================================================
// Usage Example
// =============================================================================

@auto_log
main() → str · Result {
  /// Main entry point demonstrating agent usage
  given: Nothing
  when: Starting agent
  then: Executes feature implementation
}

@impl {

  // Step 1: Create agent
  use agent <- create_agent(AdvancedSWEAgent)

  // Step 2: Define feature task
  let feature_task = Task(
    id: "feat_",
    description: "Add type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} authentication with JWT tokens",
    type: "feature",
    complexity: 7,
    deadline: ☐current_timestamp_ms() + 3600000)  // 1 hour
  )

  // Step 3: Agent thinks about the task
  use thought_process <- agent · think_about_task

    hypothesis: thought_process.hypothesis,
    confidence: thought_process.confidence,
    alternatives: list.length(thought_process.alternatives)
  }

  // Step 4: Execute intent
  use intent_result <- agent · execute_intent

    success: intent_result.success,
    time_ms: intent_result.execution_time_ms
  }

  // Step 5: Self-evaluate performance
  let performance_report = self_evaluate(agent.performance_tracker)

    health: performance_report.health_status,
    confidence: performance_report.confidence_level,
    suggestions: list.length(performance_report.improvement_suggestions)
  }

  // Step 6: Check knowledge state
  let known_files = get_known_files(agent.knowledge_tracker)
  let knowledge_gaps = agent.knowledge_tracker.knowledge_gaps

    known_files: list.length(known_files),
    gaps: list.length(knowledge_gaps)
  }

  // Step 7: Review error learning
  case agent.error_learner.total_errors_seen {
    0 → log("example.no_errors") {}
    n → {
        total: n,
        patterns: dict.size(agent.error_learner.patterns),
        solutions: dict.size(agent.error_learner.solutions)
      }
    }
  }

  // Step 8: Adapt strategy based on performance
  let strategy = adapt_strategy(agent.performance_tracker)

  ✅Nil)
}

// =============================================================================
// Helper Functions
// =============================================================================

@auto_log
generate_pr_description(
  task: Task,
  test_results: TestResults,
  coverage: CoverageReport
) → str {
  /// Generate PR description
  given: Task, test results, coverage
  when: Creating PR
  then: Returns formatted description
}

@impl {
  "## Description\n\n" +
  task.description +
  "\n\n## Test Results\n\n" +
  "- Tests passed: {int}.to_string(test_results.passed) + "/{int}.to_string(test_results.total) + "\n" +
  "- Coverage: {float}.to_string(coverage.percentage) + "%\n" +
  "\n## Checklist\n\n" +
  "- [x] Tests added\n" +
  "- [x] Documentation updated\n" +
  "- [x] Code reviewed\n"
}

// Placeholder types
struct Task(
  id: str
  description: str
  type: str
  complexity: int
  deadline: int?
}

struct TestResults(
  passed: int
  total: int
  success_rate: float
}

struct CoverageReport(
  percentage: float
}

@spec current_timestamp_ms() → int
@spec float_to_string(f: float) → str

