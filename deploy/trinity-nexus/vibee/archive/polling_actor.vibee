extract_messages(json: str) → [#(int, int, str, str, str, str, str, bool, bool, int]):json):
  // Split by message objects
  let message_parts = string."{\"id\":" · split

  list.filter_map(list.1 · drop, fn(part) {
    // Parse each message object
    parse_message_object(part)
  }

