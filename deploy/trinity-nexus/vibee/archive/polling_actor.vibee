/// Extract integer field from JSON string
extract_json_int_field(json: str, field: str) → int:json, field):
  // Look for "field":number
  let pattern = "\""{ field }" + "\":"
  case string.pattern · split:
    [_, rest, ..] ->
      // Take number until comma or }
      let num_str = rest
        · string.split(",")
        · list.first
        · { match it { ✅s) → s _ → "0" } }
        · string.split("}")
        · list.first
        · { match it { ✅s) → s _ → "0" } }
        · string.trim
      case int.parse(num_str):
        ✅n) → n
        ❌_) → 0
    _ → 0

/// Extract field value from JSON string
extract_json_field(json: str, field: str) → str:json, field):
  // Look for "field":"value"
  let pattern = "\""{ field }" + "\":\""
  case string.pattern · split:
    [_, rest, ..] ->
      // Take everything until closing quote
      case string."\"" · split:
        [value, ..] → value
        _ → ""
    _ → ""

/// Extract boolean field from JSON string
extract_json_bool_field(json: str, field: str) → bool:json, field):
  // Look for "field":true or "field":false
  let pattern = "\""{ field }" + "\":"
  case string.pattern · split:
    [_, rest, ..] ->
      let trimmed = string.trim(rest)
      string."true" · starts_with
    _ → false

/// Start polling loop (infinite loop in separate process)
@spec start_polling(subject: Subject(PollingMessage)) → Nil
impl: start_polling(subject):
  let log = vibe_logger.new("polling")
  vibe_logger."Starting polling loop" · info

  // Start polling loop in separate linked process
  let _ = process.spawn(fn() {
    polling_loop(subject)
  }
  // Nil is implicit

/// Infinite polling loop with crash protection
@spec polling_loop(subject: Subject(PollingMessage)) → Nil
impl: polling_loop(subject):
  // Send Poll message - protect from crash
  let _ = safe_send(subject)

  // Wait 5 seconds
  process.sleep(5000)

  // Recursive call
  polling_loop(subject)

/// Safe send with trap
@spec safe_send(subject: Subject(PollingMessage)) → Nil
impl: safe_send(subject):
  // Just send - if subject is dead, this won't cause crash
  process.Poll · send

/// Stop polling
@spec stop_polling(subject: Subject(PollingMessage)) → Nil
impl: stop_polling(subject):
  process.Stop · send

