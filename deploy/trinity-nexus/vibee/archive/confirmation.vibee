@impl {
  let sql = "
    SELECT id, suggestion_type, priority, contact_id, dialog_id, message_id,
           title, description, suggested_action, suggested_message,
           shown_at::text, expires_at::text
    FROM proactive_suggestions
    WHERE owner_id = $1 AND status = 'shown'
      AND (expires_at IS NULL OR expires_at > NOW())
    ORDER BY priority DESC
    LIMIT 5
  "

