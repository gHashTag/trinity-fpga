@impl {
  let emoji = match suggestion.suggestion_type {
    LeadDetected → "money_bag"
    ReplyReminder → "speech_balloon"
    DealFollowUp → "handshake"
    ScheduleReminder → "calendar"
    ContactReactivation → "wave"
  }

  let action_text = match suggestion.suggested_message {
    ☐msg) → {
      "\n\nPredlagayu napisat':\n\"{msg}\""
    }
    ∅-> ""
  }

  "{emoji} {suggestion.title}\n\n{suggestion.description}\n\nTarget: {suggestion.suggested_action}{action_text}\n\nKhochesh' ya eto sdelayu? (da/net/svoy tekst)"
}

