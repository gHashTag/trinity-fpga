@spec expire_old_suggestions(pool: DbPool) → str · Result {
  /// Expire old suggestions
  given: Database pool
  when: Running periodic cleanup
  then: Returns count of expired suggestions or error
}

@impl {
  let sql = "
    UPDATE proactive_suggestions
    SET status = 'expired'
    WHERE status in ('pending', 'shown')
      AND (expires_at IS NOT NULL AND expires_at < NOW())
      OR (expires_at IS NULL AND created_at < NOW() - INTERVAL '24 hours')
  "

  match pog.query(sql)
    · pog.execute(pool)
  {
    ✅_ · Returned) → ✅count)
    ❌_) → ❌"Failed to expire suggestions")
  }
}

