  name: String,
  email: String,
  id: Int}'s decision
  then: Returns Approved, Rejected, Modified, or Ignored
}

@impl {
  let lower = string.lowercase(string.trim(text))

  match lower {
    "da" → Approved
    "yes" → Approved
    "ok" → Approved
    "davay" → Approved
    "go" → Approved
    "+" → Approved
    "thumbs_up" → Approved
    "net" → Rejected
    "no" → Rejected
    "ne nado" → Rejected
    "-" → Rejected
    "thumbs_down" → Rejected
    "otmena" → Rejected
    _ → {
      // If text is longer than simple yes/no, treat as modified response
      match len(lower) > 10 {
        true → Modified(text)
        false → Ignored
      }
    }
  }
}

