@impl {
  // Get highest priority pending suggestion
  let sql = "
    SELECT id, suggestion_type, priority, contact_id, dialog_id, message_id,
           title, description, suggested_action, suggested_message
    FROM proactive_suggestions
    WHERE owner_id = $1 AND status = 'pending'
    ORDER BY priority DESC, created_at ASC
    LIMIT 1
  "

  match pog.query(sql)
    · pog.parameter(pog.int(owner_id))
    · pog.execute(pool)
  {
    ✅[] · Returned) → ✅∅)
    ✅[_row] · Returned) → {
      // Would decode row to Suggestion, then:
      // 1. Mark as shown
      // 2. Format confirmation message
      // For now, placeholder
      ✅∅)
    }
    ✅_) → ✅∅)
    ❌_) → ❌"Database error")
  }
}

