  // Get suggestion details
  let sql = "
    SELECT suggestion_type, contact_id, dialog_id, suggested_message
    FROM proactive_suggestions
    WHERE id = $1 AND owner_id = $2
  "

  match pog.query(sql)
    · pog.parameter(pog.int(suggestion_id))
    · pog.parameter(pog.int(owner_id))
    · pog.execute(pool)
  {
    ✅[_row] · Returned) → {
      // Would decode and execute based on suggestion_type
      // For now, success placeholder
      ✅ActionSuccess("Gotovo!"))
    }
    ✅_) → ❌"Suggestion not found")
    ❌_) → ❌"Database error")
  }
}

