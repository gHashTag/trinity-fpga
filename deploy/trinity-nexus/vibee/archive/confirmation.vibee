@spec truncate(text: str, max_len: int) → str {
  /// Truncate text to max length with ellipsis
  given: Text and maximum length
  when: Displaying preview of long messages
  then: Returns truncated text with "..." if exceeds max
}

@impl {
  match len(text) > max_len {
    true → text[:max_len] + "..."
    false → text
  }
}

