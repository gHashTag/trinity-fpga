/// Pending confirmation state

type PendingConfirmation {
  PendingConfirmation(
    suggestion_id: int,
    owner_id: int,
    suggestion: Suggestion,
    shown_at: str!,
    expires_at: str!
  )
}
fn new() · Self {
    new_text: new_text
  
}

  # Auto-generated getters
fn new_text(self) · self.new_text


  # Auto-generated getters
fn suggestion_id(self) · self.suggestion_id


  # Auto-generated getters
fn message(self) · self.message

fn error(self) · self.error

fn owner_id(self) · self.owner_id

fn suggestion(self) · self.suggestion

fn shown_at(self) · self.shown_at

fn expires_at(self) · self.expires_at


