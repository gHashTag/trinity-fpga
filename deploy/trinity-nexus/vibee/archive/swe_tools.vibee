# SWE Agent - Software Engineering Agent
  // Performance Warning:   // AI Suggestion: Consider extracting hardcoded strings to constants# Full implementation in VIBEE DSL
  // AI Suggestion: Replace magic numbers with named constants# VIBEE - AGI Open Source Framework
  // AI Suggestion: Use pipeline operator for better readability
# =============================================================================
# CONSTANTS
# =============================================================================

let VERSION = const("0.1.0"
let AGENT_NAME = const("VIBEE SWE Agent"

# =============================================================================
# VERSION AND HELP
# =============================================================================

tool swe_version:
  desc: "Show SWE agent version"
  @Returns version: true → swe_version() → result contains "SWE"

  → {
    VERSION
  }

tool swe_help:
  desc: "Show SWE agent help and commands"
  @Returns help: true → swe_help() → result contains "/help"

  → {
    "/help - Show help\n/mode - Change mode\n/context - Show context\n/quit - Exit"
  }

# =============================================================================
# AGENT LIFECYCLE
# =============================================================================

tool swe_create:
  desc: "Create a new SWE agent instance"
  @Creates agent: true → swe_create() → result != ""

  → {
    { mode: "chat", files: [], history: [] }
  }

tool swe_init:
  desc: "Initialize SWE agent with configuration"
  @Initializes agent: true → swe_init() → result != ""

  mode: str = "chat"
  lang: str = "en"
  verbose: bool = false

  → {
    { mode, lang, verbose }
  }

tool swe_destroy:
  desc: "Destroy SWE agent and cleanup"
  @Destroys agent: true → swe_destroy() → result != ""

  → {
    "destroyed"
  }

# =============================================================================
# MODE MANAGEMENT
# =============================================================================

tool swe_get_mode:
  desc: "Get current agent mode"
  @Returns mode: true → swe_get_mode() → result != ""

  mode: str!

  → {
    mode
  }

tool swe_set_mode:
  desc: "Set agent mode (chat, code, architect, review, debug)"
  @Sets mode: true → swe_set_mode() → result != ""

  mode: str!

  → {
    mode
  }

tool swe_list_modes:
  desc: "list all available agent modes"
  @Returns modes: true → swe_list_modes() → result contains "chat"

  → {
    "chat, code, architect, review, debug"
  }

# =============================================================================
# CONTEXT MANAGEMENT
# =============================================================================

tool swe_context:
  desc: "Show current agent context"
  @Returns context: true → swe_context() → result != ""

  → {
    "context"
  }

tool swe_add_file:
  desc: "Add file to agent context"
  @Adds file: path != "" → result != ""

  path: str!

  → {
    path
  }

tool swe_drop_file:
  desc: "Remove file from agent context"
  @Drops file: path != "" → result != ""

  path: str!

  → {
    path
  }

tool swe_clear:
  desc: "Clear conversation history"
  @Clears history: true → swe_clear() → result != ""

  → {
    "cleared"
  }

# =============================================================================
# REPOSITORY MAP
# =============================================================================

tool swe_map:
  desc: "Generate and display repository map"
  @Returns map: true → swe_map() → result != ""

  → {
    ffi("os_ffi", "exec", "find . -name '*.vibee' -o -name '*.gleam' | head -50")
  }

tool swe_map_refresh:
  desc: "Refresh repository map"
  @Refreshes map: true → swe_map_refresh() → result != ""

  → {
    ffi("os_ffi", "exec", "find . -name '*.vibee' -o -name '*.gleam' | head -50")
  }

# =============================================================================
# SPEC COVERAGE
# =============================================================================

tool swe_spec:
  desc: "Check @spec coverage in codebase"
  @Returns coverage: true → swe_spec() → result != ""

  → {
    ffi("os_ffi", "exec", "grep -r '@spec' src/vibee/dsl/ | wc -l")
  }

tool swe_spec_file:
  desc: "Check @spec coverage for specific file"
  @Returns file coverage: path != "" → result != ""

  path: str!

  → {
    ffi("os_ffi", "exec", "grep '@spec' " + path + " | wc -l")
  }

# =============================================================================
# GIT INTEGRATION
# =============================================================================

tool swe_git_status:
  desc: "Show git status"
  @Returns status: true → swe_git_status() → result != ""

  → {
    ffi("os_ffi", "exec", "git status --short")
  }

tool swe_git_diff:
  desc: "Show uncommitted changes"
  @Returns diff: true → swe_git_diff() → result != ""

  → {
    ffi("os_ffi", "exec", "git diff --stat")
  }

tool swe_git_add:
  desc: "Stage files for commit"
  @Stages files: files != "" → result != ""

  files: str!

  → {
    ffi("os_ffi", "exec", "git add " + files)
  }

tool swe_git_commit:
  desc: "Create git commit with message"
  @Creates commit: message != "" → result != ""

  message: str!

  → {
    ffi("os_ffi", "exec", "git commit -m '" + message + "'")
  }

tool swe_git_commit_ai:
  desc: "Create git commit with AI-generated message"
  @Creates AI commit: true → swe_git_commit_ai() → result != ""

  → {
    "ai_commit_placeholder"
  }

# =============================================================================
# LLM INTEGRATION
# =============================================================================

tool swe_chat:
  desc: "Send message to LLM and get response"
  @Returns response: message != "" → result != ""

  message: str!

  → {
    ffi("llm_ffi", "chat", message)
  }

tool swe_chat_stream:
  desc: "Stream response from LLM"
  @Streams response: message != "" → result != ""

  message: str!

  → {
    ffi("llm_ffi", "chat_stream", message)
  }

tool swe_set_model:
  desc: "Set LLM model to use"
  @Sets model: model != "" → result != ""

  model: str!

  → {
    model
  }

# =============================================================================
# CODE CHANGES
# =============================================================================

tool swe_apply:
  desc: "Apply code changes from LLM response"
  @Applies changes: response != "" → result != ""

  response: str!

  → {
    "applied"
  }

tool swe_undo:
  desc: "Undo last code change"
  @Undoes change: true → swe_undo() → result != ""

  → {
    ffi("os_ffi", "exec", "git checkout -- .")
  }

tool swe_redo:
  desc: "Redo last undone change"
  @Redoes change: true → swe_redo() → result != ""

  → {
    ffi("os_ffi", "exec", "git stash pop")
  }

# =============================================================================
# REPL
# =============================================================================

tool swe_repl:
  desc: "Start interactive REPL"
  @Starts REPL: true → swe_repl() → result != ""

  → {
    "repl_started"
  }

tool swe_process:
  desc: "Process type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} input"
  @Processes input: input != "" → result != ""

  input: str!

  → {
    input
  }

tool swe_command:
  desc: "Execute slash command"
  @Executes command: command != "" → result != ""

  command: str!

  → {
    command
  }

# =============================================================================
# CONFIG
# =============================================================================

tool swe_config:
  desc: "Show agent configuration"
  @Returns config: true → swe_config() → result != ""

  → {
    "config"
  }

tool swe_config_set:
  desc: "Set configuration value"
  @Sets config: key != "" → result != ""

  key: str!
  value: str!

  → {
    value
  }

tool swe_config_get:
  desc: "Get configuration value"
  @Gets config: key != "" → result != ""

  key: str!

  → {
    key
  }

# =============================================================================
# SESSION
# =============================================================================

tool swe_save:
  desc: "Save conversation to file"
  @Saves session: path != "" → result != ""

  path: str!

  → {
    "saved"
  }

tool swe_load:
  desc: "Load conversation from file"
  @Loads session: path != "" → result != ""

  path: str!

  → {
    "loaded"
  }

tool swe_quit:
  desc: "Exit SWE agent"
  @Exits agent: true → swe_quit() → result != ""

  → {
    { exit_code: 0 }
  }

# =============================================================================
# FILE OPERATIONS (P1)
# =============================================================================

tool swe_read:
  desc: "Read file with line numbers"
  @Reads file: path != "" → result != ""

  path: str!
  from_line: int = 1
  to_line: int = 0

  → {
    ffi("file_ffi", "read_lines", path, from_line, to_line)
  }

tool swe_write:
  desc: "Write/update file content"
  @Writes file: path != "" → result != ""

  path: str!
  content: str!

  → {
    ffi("file_ffi", "write_file", path, content)
  }

tool swe_create_file:
  desc: "Create new file"
  @Creates file: path != "" → result != ""

  path: str!
  content: str = ""

  → {
    ffi("file_ffi", "create_file", path, content)
  }

tool swe_rename:
  desc: "Rename file"
  @Renames file: old_path != "" → result != ""

  old_path: str!
  new_path: str!

  → {
    ffi("file_ffi", "rename_file", old_path, new_path)
  }

tool swe_delete:
  desc: "Delete file"
  @Deletes file: path != "" → result != ""

  path: str!
  force: bool = false

  → {
    ffi("file_ffi", "delete_file", path)
  }

tool swe_view:
  desc: "View file with syntax highlighting"
  @Views file: path != "" → result != ""

  path: str!
  context: int = 10

  → {
    ffi("file_ffi", "view_file", path, context)
  }

# =============================================================================
# CODE SEARCH & NAVIGATION (P1)
# =============================================================================

tool swe_search:
  desc: "Search in codebase (ripgrep)"
  @Searches code: pattern != "" → result != ""

  pattern: str!
  path: str = "."
  extension: str = ""
  case_sensitive: bool = false

  → {
    ffi("os_ffi", "exec", "rg --line-number '" + pattern + "' " + path)
  }

tool swe_find_references:
  desc: "Find all references to symbol"
  @Finds references: symbol != "" → result != ""

  symbol: str!
  path: str = "."

  → {
    ffi("os_ffi", "exec", "rg --line-number '\\b" + symbol + "\\b' " + path)
  }

tool swe_find_definition:
  desc: "Find symbol definition"
  @Finds definition: symbol != "" → result != ""

  symbol: str!

  → {
    ffi("os_ffi", "exec", "rg --line-number '(fn |fn |type |type )" + symbol + "' src/")
  }

tool swe_find_usages:
  desc: "Find function usages"
  @Finds usages: function != "" → result != ""

  function: str!

  → {
    ffi("os_ffi", "exec", "rg --line-number '" + function + "\\(' src/")
  }

# =============================================================================
# CODE QUALITY (P1)
# =============================================================================

tool swe_format:
  desc: "Format code"
  @Formats code: true → swe_format() → result != ""

  path: str = "src"
  check_only: bool = false

  → {
    ffi("os_ffi", "exec", "gleam format " + path)
  }

tool swe_lint:
  desc: "Run linter (gleam build warnings)"
  @Runs linter: true → swe_lint() → result != ""

  path: str = "."

  → {
    ffi("os_ffi", "exec", "gleam build 2>&1 | grep -E '(warning|error)'")
  }

tool swe_fix_warnings:
  desc: "Auto-fix warnings"
  @Fixes warnings: true → swe_fix_warnings() → result != ""

  path: str = "."

  → {
    ffi("os_ffi", "exec", "gleam format " + path + " && gleam build")
  }

# =============================================================================
# TESTING (P2)
# =============================================================================

tool swe_test_run:
  desc: "Run tests with filter"
  @Runs tests: true → swe_test_run() → result != ""

  filter: str = ""
  module: str = ""
  verbose: bool = false

  → {
    ffi("os_ffi", "exec", "gleam test" + (module != "" ? " --module " + module : ""))
  }

tool swe_test_coverage:
  desc: "Show test coverage (spec count)"
  @Shows coverage: true → swe_test_coverage() → result != ""

  path: str = "."

  → {
    ffi("os_ffi", "exec", "echo 'Tests:' && gleam test 2>&1 | tail -1 && echo 'Specs:' && grep -r '@spec' src/ | wc -l")
  }

tool swe_test_watch:
  desc: "Watch mode for tests"
  @Starts watch: true → swe_test_watch() → result != ""

  module: str = ""

  → {
    "Watch mode not implemented yet. Use: watchexec -e gleam gleam test"
  }

tool swe_test_generate:
  desc: "Generate tests from spec(SDD)"
  @Generates tests: path != "" → result != ""

  path: str!

  → {
    "Test generation via SDD: vibee compile " + path + " --sdd"
  }

# =============================================================================
# CODE ANALYSIS (P2)
# =============================================================================

tool swe_analyze:
  desc: "Static code analysis"
  @Analyzes code: true → swe_analyze() → result != ""

  path: str = "."

  → {
    ffi("os_ffi", "exec", "echo 'Files:' && find " + path + " -name '*.gleam' | wc -l && echo 'Lines:' && find " + path + " -name '*.gleam' -exec cat {} + | wc -l && echo 'Functions:' && grep -r 'fn' " + path + " | wc -l")
  }

tool swe_type_check:
  desc: "Type checking (via gleam build)"
  @Checks types: true → swe_type_check() → result != ""

  path: str = "."

  → {
    ffi("os_ffi", "exec", "gleam build 2>&1 | grep -E '(Type mismatch|error:)'")
  }

tool swe_code_metrics:
  desc: "Code metrics (LOC, files, functions)"
  @Shows metrics: true → swe_code_metrics() → result != ""

  path: str = "src"

  → {
    ffi("os_ffi", "exec", "echo '=== Code Metrics ===' && echo 'Gleam files:' && find " + path + " -name '*.gleam' | wc -l && echo 'VIBEE files:' && find " + path + " -name '*.vibee' | wc -l && echo 'Total LOC:' && find " + path + " \\( -name '*.gleam' -o -name '*.vibee' \\) -exec cat {} + | wc -l && echo 'Public functions:' && grep -r 'fn' " + path + " | wc -l && echo '@spec coverage:' && grep -r '@spec' " + path + " | wc -l")
  }

tool swe_dependency_graph:
  desc: "Show module dependencies"
  @Shows deps: true → swe_dependency_graph() → result != ""

  module: str = ""

  → {
    ffi("os_ffi", "exec", "grep -r '^import ' src/ | sort | uniq -c | sort -rn | head -20")
  }

# =============================================================================
# BUILD & DEPLOYMENT (P2)
# =============================================================================

tool swe_build:
  desc: "Build project"
  @Builds project: true → swe_build() → result != ""

  target: str = "dev"

  → {
    ffi("os_ffi", "exec", "gleam build")
  }

tool swe_build_check:
  desc: "Check if build passes"
  @Checks build: true → swe_build_check() → result != ""

  → {
    ffi("os_ffi", "exec", "gleam build && echo 'Build OK' || echo 'Build FAILED'")
  }

tool swe_release:
  desc: "Create release with tag"
  @Creates release: version != "" → result != ""

  version: str!
  changelog: bool = true

  → {
    "Release " + version + ": git tag v" + version + " && git push --tags"
  }

# =============================================================================
# DEBUGGING (P3)
# =============================================================================

tool swe_debug:
  desc: "Start Erlang debugger"
  @Starts debugger: true → swe_debug() → result != ""

  module: str = ""

  → {
    "Debugger: Use :debugger.start() in Erlang shell"
  }

tool swe_trace:
  desc: "Trace function calls"
  @Traces calls: function != "" → result != ""

  function: str!
  depth: int = 10

  → {
    ffi("os_ffi", "exec", "echo 'Trace " + function + " with depth " + depth + "'")
  }

tool swe_breakpoint:
  desc: "Set/remove breakpoint"
  @Sets breakpoint: file != "" → result != ""

  file: str!
  line: int!
  remove: bool = false

  → {
    "Breakpoint at " + file + ":" + line
  }

tool swe_profile:
  desc: "Profile code execution"
  @Profiles code: true → swe_profile() → result != ""

  command: str = "gleam build"

  → {
    ffi("os_ffi", "exec", "time " + command)
  }

# =============================================================================
# DOCUMENTATION (P3)
# =============================================================================

tool swe_doc_generate:
  desc: "Generate documentation"
  @Generates docs: true → swe_doc_generate() → result != ""

  path: str = "src"
  format: str = "markdown"

  → {
    ffi("os_ffi", "exec", "echo '=== Documentation ===' && grep -r '@desc' " + path + " | head -30")
  }

tool swe_doc_check:
  desc: "Check documentation coverage"
  @Checks docs: true → swe_doc_check() → result != ""

  path: str = "src"

  → {
    ffi("os_ffi", "exec", "echo 'Functions:' && grep -r 'fn' " + path + " | wc -l && echo 'Documented (@desc):' && grep -r '@desc' " + path + " | wc -l")
  }

tool swe_doc_update:
  desc: "Update documentation from code"
  @Updates docs: true → swe_doc_update() → result != ""

  → {
    "Run: vibee doc-gen to update CLAUDE.md"
  }

# =============================================================================
# DEPENDENCIES (P3)
# =============================================================================

tool swe_deps_list:
  desc: "list project dependencies"
  @Lists deps: true → swe_deps_list() → result != ""

  → {
    ffi("os_ffi", "exec", "cat gleam.toml | grep -A 100 '\\[dependencies\\]' | head -30")
  }

tool swe_deps_update:
  desc: "Update dependencies"
  @Updates deps: true → swe_deps_update() → result != ""

  → {
    ffi("os_ffi", "exec", "gleam deps download && gleam build")
  }

tool swe_deps_audit:
  desc: "Audit dependencies for issues"
  @Audits deps: true → swe_deps_audit() → result != ""

  → {
    ffi("os_ffi", "exec", "echo 'Dependencies:' && cat gleam.toml | grep -E '^[a-z].*=' | wc -l && echo 'Lock file:' && cat manifest.toml | grep 'name' | wc -l")
  }

# =============================================================================
# AI CODE REVIEW
# =============================================================================

tool swe_explain:
  desc: "Explain code with AI"
  @Explains code: path != "" → result != ""

  path: str!

  → {
    ffi("llm_ffi", "chat", "Explain this code: " + path)
  }

tool swe_refactor:
  desc: "Suggest refactoring with AI"
  @Suggests refactor: path != "" → result != ""

  path: str!
  goal: str = "improve readability"

  → {
    ffi("llm_ffi", "chat", "Suggest refactoring for " + path + ". Goal: " + goal)
  }

tool swe_review:
  desc: "AI code review"
  @Reviews code: true → swe_review() → result != ""

  path: str = "."

  → {
    ffi("llm_ffi", "chat", "Review this code for bugs and improvements")
  }

tool swe_suggest_fix:
  desc: "Suggest fix for error"
  @Suggests fix: error != "" → result != ""

  error: str!

  → {
    ffi("llm_ffi", "chat", "How to fix this error: " + error)
  }

# =============================================================================
# GITHUB INTEGRATION
# =============================================================================

tool swe_pr_create:
  desc: "Create pull request"
  @Creates PR: title != "" → result != ""

  title: str!
  body: str = ""
  base: str = "main"

  → {
    ffi("os_ffi", "exec", "gh pr create --title '" + title + "' --body '" + body + "' --base " + base)
  }

tool swe_pr_list:
  desc: "list pull requests"
  @Lists PRs: true → swe_pr_list() → result != ""

  state: str = "open"

  → {
    ffi("os_ffi", "exec", "gh pr list --state " + state)
  }

tool swe_issue_create:
  desc: "Create GitHub issue"
  @Creates issue: title != "" → result != ""

  title: str!
  body: str = ""
  labels: str = ""

  → {
    ffi("os_ffi", "exec", "gh issue create --title '" + title + "' --body '" + body + "'")
  }

# =============================================================================
# SECURITY
# =============================================================================

tool swe_security_scan:
  desc: "Scan for security issues"
  @Scans security: true → swe_security_scan() → result != ""

  path: str = "."

  → {
    ffi("os_ffi", "exec", "echo '=== Security Scan ===' && echo 'Hardcoded secrets:' && grep -rn -E '(password|secret|api_key|token)\\s*=' " + path + " 2>/dev/null | grep -v test | head -10 || echo '∅found'")
  }

tool swe_secrets_check:
  desc: "Check for exposed secrets"
  @Checks secrets: true → swe_secrets_check() → result != ""

  → {
    ffi("os_ffi", "exec", "echo 'Checking .env files...' && find . -name '.env*' -type f 2>/dev/null && echo 'Checking for API keys...' && grep -rn 'API_KEY' src/ 2>/dev/null | head -5 || echo 'Clean'")
  }

# =============================================================================
# BENCHMARK & PERFORMANCE
# =============================================================================

tool swe_benchmark:
  desc: "Run benchmark"
  @Runs benchmark: command != "" → result != ""

  command: str!
  iterations: int = 3

  → {
    ffi("os_ffi", "exec", "echo 'Benchmark: " + command + "' && time " + command)
  }

tool swe_memory_profile:
  desc: "Profile memory usage"
  @Profiles memory: true → swe_memory_profile() → result != ""

  → {
    ffi("os_ffi", "exec", "echo 'BEAM Memory:' && erl -noshell -eval 'io:format(\"~p~n\", [erlang:memory()]), halt().' 2>/dev/null || echo 'Run in Erlang shell: erlang:memory()'")
  }

# =============================================================================
# MCP INTEGRATION
# =============================================================================

tool swe_mcp_list:
  desc: "list available MCP tools"
  @Lists MCP tools: true → swe_mcp_list() → result != ""

  → {
    ffi("os_ffi", "exec", "grep -r 'Tool(' src/vibee/infra/mcp/ | grep 'name:' | head -30")
  }

tool swe_mcp_call:
  desc: "Call MCP tool"
  @Calls MCP: tool != "" → result != ""

  tool: str!
  args: str = "{}"

  → {
    "MCP call: " + tool + " with args " + args
  }

tool swe_mcp_test:
  desc: "Test MCP tool"
  @Tests MCP: tool != "" → result != ""

  tool: str!

  → {
    ffi("os_ffi", "exec", "grep -A 20 'name: \"" + tool + "\"' src/vibee/infra/mcp/*.gleam | head -25")
  }

# =============================================================================
# SNIPPETS
# =============================================================================

tool swe_snippet_save:
  desc: "Save code snippet"
  @Saves snippet: name != "" → result != ""

  name: str!
  code: str!

  → {
    ffi("file_ffi", "write_file", ".snippets/" + name + ".txt", code)
  }

tool swe_snippet_list:
  desc: "list saved snippets"
  @Lists snippets: true → swe_snippet_list() → result != ""

  → {
    ffi("os_ffi", "exec", "ls -la .snippets/ 2>/dev/null || echo 'No snippets yet'")
  }

tool swe_snippet_apply:
  desc: "Apply snippet to file"
  @Applies snippet: name != "" → result != ""

  name: str!
  target: str!

  → {
    "Apply snippet " + name + " to " + target
  }

# =============================================================================
# GIT HISTORY
# =============================================================================

tool swe_history_show:
  desc: "Show file history"
  @Shows history: path != "" → result != ""

  path: str!
  limit: int = 10

  → {
    ffi("os_ffi", "exec", "git log --oneline -" + limit + " -- " + path)
  }

tool swe_history_diff:
  desc: "Show diff between commits"
  @Shows diff: commit1 != "" → result != ""

  commit1: str!
  commit2: str = "HEAD"

  → {
    ffi("os_ffi", "exec", "git diff " + commit1 + ".." + commit2 + " --stat")
  }

tool swe_blame:
  desc: "Show git blame for file"
  @Shows blame: path != "" → result != ""

  path: str!
  from_line: int = 1
  to_line: int = 50

  → {
    ffi("os_ffi", "exec", "git blame -L " + from_line + "," + to_line + " " + path)
  }

# =============================================================================
# WORKSPACE
# =============================================================================

tool swe_workspace_save:
  desc: "Save current workspace context"
  @Saves workspace: name != "" → result != ""

  name: str!

  → {
    ffi("os_ffi", "exec", "echo 'Saving workspace " + name + "' && git stash push -m 'workspace:" + name + "'")
  }

tool swe_workspace_load:
  desc: "Load workspace context"
  @Loads workspace: name != "" → result != ""

  name: str!

  → {
    ffi("os_ffi", "exec", "git stash list | grep 'workspace:" + name + "'")
  }

tool swe_workspace_list:
  desc: "list saved workspaces"
  @Lists workspaces: true → swe_workspace_list() → result != ""

  → {
    ffi("os_ffi", "exec", "git stash list | grep 'workspace:' || echo 'No workspaces saved'")
  }

