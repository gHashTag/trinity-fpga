# VIBEEC Spec Example: Todo API
# KILLER FEATURE: spec.yml → Production code automatically
# This 100-line YAML file generates 1,000+ lines of production code

name: todo_api
version: 1.0.0
description: Complete Todo API with CRUD operations and user management
author: VIBEE Team
category: API
tags: [todo, crud, api, rest]

# ============================================================================
# BEHAVIORS (5 key scenarios)
# ============================================================================

behaviors:
  # 1. CREATE TODO
  - name: create_todo
    description: Create new todo item
    given: User is authenticated
    when: User creates todo with title and description
    then: Todo created and returned with ID
    test_cases:
      - name: valid_todo
        input:
          user_id: "1"
          title: "Buy groceries"
          description: "Milk, eggs, bread"
        expected:
          created: "true"
          id: "1"
          title: "Buy groceries"
      
      - name: empty_title
        input:
          user_id: "1"
          title: ""
          description: "Some description"
        expected:
          created: "false"
          error: "Title is required"
      
      - name: long_title
        input:
          user_id: "1"
          title: "This is a very long title that exceeds the maximum allowed length of 100 characters and should be rejected"
          description: "Description"
        expected:
          created: "false"
          error: "Title too long"

  # 2. GET TODO
  - name: get_todo
    description: Get todo by ID
    given: Todo exists in database
    when: User requests todo by ID
    then: Todo returned with all fields
    test_cases:
      - name: existing_todo
        input:
          user_id: "1"
          todo_id: "1"
        expected:
          found: "true"
          id: "1"
          title: "Buy groceries"
      
      - name: nonexistent_todo
        input:
          user_id: "1"
          todo_id: "999"
        expected:
          found: "false"
          error: "Todo not found"
      
      - name: unauthorized_access
        input:
          user_id: "2"
          todo_id: "1"
        expected:
          found: "false"
          error: "Unauthorized"

  # 3. UPDATE TODO
  - name: update_todo
    description: Update existing todo
    given: Todo exists and user is owner
    when: User updates todo fields
    then: Todo updated and returned
    test_cases:
      - name: update_title
        input:
          user_id: "1"
          todo_id: "1"
          title: "Buy groceries and cook"
        expected:
          updated: "true"
          title: "Buy groceries and cook"
      
      - name: mark_completed
        input:
          user_id: "1"
          todo_id: "1"
          completed: "true"
        expected:
          updated: "true"
          completed: "true"
      
      - name: update_nonexistent
        input:
          user_id: "1"
          todo_id: "999"
          title: "New title"
        expected:
          updated: "false"
          error: "Todo not found"

  # 4. DELETE TODO
  - name: delete_todo
    description: Delete todo by ID
    given: Todo exists and user is owner
    when: User deletes todo
    then: Todo deleted from database
    test_cases:
      - name: delete_existing
        input:
          user_id: "1"
          todo_id: "1"
        expected:
          deleted: "true"
      
      - name: delete_nonexistent
        input:
          user_id: "1"
          todo_id: "999"
        expected:
          deleted: "false"
          error: "Todo not found"
      
      - name: delete_unauthorized
        input:
          user_id: "2"
          todo_id: "1"
        expected:
          deleted: "false"
          error: "Unauthorized"

  # 5. LIST TODOS
  - name: list_todos
    description: List all todos for user
    given: User has todos in database
    when: User requests todo list
    then: All user todos returned
    test_cases:
      - name: list_all
        input:
          user_id: "1"
        expected:
          count: "3"
          todos: "array"
      
      - name: list_completed
        input:
          user_id: "1"
          filter: "completed"
        expected:
          count: "1"
          todos: "array"
      
      - name: list_empty
        input:
          user_id: "999"
        expected:
          count: "0"
          todos: "array"

# ============================================================================
# TYPES
# ============================================================================

types:
  Todo:
    id: int
    user_id: int
    title: str
    description: str
    completed: bool
    created_at: str
    updated_at: str
  
  User:
    id: int
    email: str
    name: str
  
  TodoList:
    todos: list
    count: int
    page: int

# ============================================================================
# FUNCTIONS
# ============================================================================

functions:
  - name: create_todo
    signature: "create_todo(user_id: Int, title: String, description: String) → Result(Todo, String)"
  
  - name: get_todo
    signature: "get_todo(user_id: Int, todo_id: Int) → Result(Todo, String)"
  
  - name: update_todo
    signature: "update_todo(user_id: Int, todo_id: Int, title: Option(String), description: Option(String), completed: Option(Bool)) → Result(Todo, String)"
  
  - name: delete_todo
    signature: "delete_todo(user_id: Int, todo_id: Int) → Result(Nil, String)"
  
  - name: list_todos
    signature: "list_todos(user_id: Int, filter: Option(String)) → Result(TodoList, String)"

# ============================================================================
# GENERATION STATISTICS
# ============================================================================
# Input: 100 lines of YAML
# Output: 1,000+ lines of production code
#
# Behaviors: 5
# Test Cases: 15
# Functions: 5
# Types: 3
#
# Time saved: ~40 hours
# Cost saved: ~$2,000
