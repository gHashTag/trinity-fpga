# Agent Interaction Specification
# Spec-driven development: This spec is the SINGLE SOURCE OF TRUTH
# All code, tests, and documentation are GENERATED from this spec

metadata:
  name: agent_interaction
  version: 1.0.0
  description: Agent interaction patterns - channels, shared state, and reactive streams
  author: VIBEE Team
  license: MIT
  generated_from: spec
  manual_code_forbidden: true

# Type definitions
types:
  - name: Channel
    description: Communication channel between agents
    fields:
      - name: id
        type: String
        description: Channel ID
        required: true
      - name: name
        type: String
        description: Channel name
        required: true
      - name: capacity
        type: Int
        description: Channel buffer capacity
        default: 100
      - name: message_count
        type: Int
        description: Current message count
        default: 0
      - name: subscribers
        type: List<String>
        description: Subscribed agent IDs
        default: []
      - name: closed
        type: Bool
        description: Whether channel is closed
        default: false

  - name: SharedState
    description: Shared state between agents
    fields:
      - name: id
        type: String
        description: State ID
        required: true
      - name: name
        type: String
        description: State name
        required: true
      - name: data
        type: Map<String, String>
        description: State data
        default: {}
      - name: version
        type: Int
        description: State version
        default: 0
      - name: locked_by
        type: String
        description: Agent ID holding lock
        required: false
      - name: watchers
        type: List<String>
        description: Agent IDs watching state
        default: []

  - name: Stream
    description: Reactive data stream
    fields:
      - name: id
        type: String
        description: Stream ID
        required: true
      - name: name
        type: String
        description: Stream name
        required: true
      - name: type
        type: String
        description: Stream type (hot, cold)
        required: true
      - name: buffer_size
        type: Int
        description: Buffer size
        default: 10
      - name: subscribers
        type: List<String>
        description: Subscribed agent IDs
        default: []
      - name: active
        type: Bool
        description: Whether stream is active
        default: true

  - name: Event
    description: Event in stream
    fields:
      - name: id
        type: String
        description: Event ID
        required: true
      - name: stream_id
        type: String
        description: Stream ID
        required: true
      - name: type
        type: String
        description: Event type
        required: true
      - name: data
        type: Map<String, String>
        description: Event data
        default: {}
      - name: timestamp
        type: String
        description: Event timestamp
        required: true

  - name: Lock
    description: Distributed lock
    fields:
      - name: id
        type: String
        description: Lock ID
        required: true
      - name: resource
        type: String
        description: Resource name
        required: true
      - name: holder
        type: String
        description: Agent ID holding lock
        required: true
      - name: acquired_at
        type: String
        description: Lock acquisition timestamp
        required: true
      - name: expires_at
        type: String
        description: Lock expiration timestamp
        required: true

# Behavior specifications with test cases
behaviors:
  - name: channel_operations
    description: Channel communication operations
    functions:
      - name: create_channel
        description: Create a new channel
        params:
          - name: name
            type: String
          - name: capacity
            type: Int
        returns: Result<Channel, String>
        test_cases:
          - input:
              name: "data-channel"
              capacity: 100
            expected:
              Ok:
                id: "channel-123"
                name: "data-channel"
                capacity: 100
                message_count: 0
                subscribers: []
                closed: false

      - name: subscribe_channel
        description: Subscribe agent to channel
        params:
          - name: channel_id
            type: String
          - name: agent_id
            type: String
        returns: Result<Channel, String>
        test_cases:
          - input:
              channel_id: "channel-123"
              agent_id: "agent-456"
            expected:
              Ok:
                id: "channel-123"
                subscribers: ["agent-456"]

      - name: publish_to_channel
        description: Publish message to channel
        params:
          - name: channel_id
            type: String
          - name: message
            type: Map<String, String>
        returns: Result<Bool, String>
        test_cases:
          - input:
              channel_id: "channel-123"
              message: {type: "data", content: "test"}
            expected:
              Ok: true

      - name: receive_from_channel
        description: Receive message from channel
        params:
          - name: channel_id
            type: String
          - name: agent_id
            type: String
        returns: Result<Map<String, String>, String>
        test_cases:
          - input:
              channel_id: "channel-123"
              agent_id: "agent-456"
            expected:
              Ok: {type: "data", content: "test"}

      - name: close_channel
        description: Close channel
        params:
          - name: channel_id
            type: String
        returns: Result<Channel, String>
        test_cases:
          - input:
              channel_id: "channel-123"
            expected:
              Ok:
                id: "channel-123"
                closed: true

  - name: shared_state_operations
    description: Shared state operations
    functions:
      - name: create_shared_state
        description: Create shared state
        params:
          - name: name
            type: String
          - name: initial_data
            type: Map<String, String>
        returns: Result<SharedState, String>
        test_cases:
          - input:
              name: "config"
              initial_data: {key1: "value1", key2: "value2"}
            expected:
              Ok:
                id: "state-123"
                name: "config"
                data: {key1: "value1", key2: "value2"}
                version: 0

      - name: read_shared_state
        description: Read shared state
        params:
          - name: state_id
            type: String
        returns: Result<SharedState, String>
        test_cases:
          - input:
              state_id: "state-123"
            expected:
              Ok:
                id: "state-123"
                data: {key1: "value1", key2: "value2"}
                version: 0

      - name: update_shared_state
        description: Update shared state
        params:
          - name: state_id
            type: String
          - name: updates
            type: Map<String, String>
        returns: Result<SharedState, String>
        test_cases:
          - input:
              state_id: "state-123"
              updates: {key1: "new_value"}
            expected:
              Ok:
                id: "state-123"
                data: {key1: "new_value", key2: "value2"}
                version: 1

      - name: watch_shared_state
        description: Watch shared state for changes
        params:
          - name: state_id
            type: String
          - name: agent_id
            type: String
        returns: Result<SharedState, String>
        test_cases:
          - input:
              state_id: "state-123"
              agent_id: "agent-456"
            expected:
              Ok:
                id: "state-123"
                watchers: ["agent-456"]

  - name: stream_operations
    description: Reactive stream operations
    functions:
      - name: create_stream
        description: Create reactive stream
        params:
          - name: name
            type: String
          - name: stream_type
            type: String
          - name: buffer_size
            type: Int
        returns: Result<Stream, String>
        test_cases:
          - input:
              name: "events"
              stream_type: "hot"
              buffer_size: 10
            expected:
              Ok:
                id: "stream-123"
                name: "events"
                type: "hot"
                buffer_size: 10
                active: true

      - name: subscribe_stream
        description: Subscribe to stream
        params:
          - name: stream_id
            type: String
          - name: agent_id
            type: String
        returns: Result<Stream, String>
        test_cases:
          - input:
              stream_id: "stream-123"
              agent_id: "agent-456"
            expected:
              Ok:
                id: "stream-123"
                subscribers: ["agent-456"]

      - name: emit_event
        description: Emit event to stream
        params:
          - name: stream_id
            type: String
          - name: event_type
            type: String
          - name: data
            type: Map<String, String>
        returns: Result<Event, String>
        test_cases:
          - input:
              stream_id: "stream-123"
              event_type: "user_action"
              data: {action: "click", target: "button"}
            expected:
              Ok:
                id: "event-789"
                stream_id: "stream-123"
                type: "user_action"
                data: {action: "click", target: "button"}

      - name: close_stream
        description: Close stream
        params:
          - name: stream_id
            type: String
        returns: Result<Stream, String>
        test_cases:
          - input:
              stream_id: "stream-123"
            expected:
              Ok:
                id: "stream-123"
                active: false

  - name: lock_operations
    description: Distributed lock operations
    functions:
      - name: acquire_lock
        description: Acquire distributed lock
        params:
          - name: resource
            type: String
          - name: agent_id
            type: String
          - name: timeout_ms
            type: Int
        returns: Result<Lock, String>
        test_cases:
          - input:
              resource: "database"
              agent_id: "agent-456"
              timeout_ms: 5000
            expected:
              Ok:
                id: "lock-123"
                resource: "database"
                holder: "agent-456"

      - name: release_lock
        description: Release distributed lock
        params:
          - name: lock_id
            type: String
        returns: Result<Bool, String>
        test_cases:
          - input:
              lock_id: "lock-123"
            expected:
              Ok: true

      - name: check_lock
        description: Check lock status
        params:
          - name: resource
            type: String
        returns: Result<Lock, String>
        test_cases:
          - input:
              resource: "database"
            expected:
              Ok:
                id: "lock-123"
                resource: "database"
                holder: "agent-456"

# Function declarations
functions:
  # Channel operations
  - name: create_channel
    params: [name: String, capacity: Int]
    returns: Result<Channel, String>
    behavior: channel_operations

  - name: subscribe_channel
    params: [channel_id: String, agent_id: String]
    returns: Result<Channel, String>
    behavior: channel_operations

  - name: publish_to_channel
    params: [channel_id: String, message: Map<String, String>]
    returns: Result<Bool, String>
    behavior: channel_operations

  - name: receive_from_channel
    params: [channel_id: String, agent_id: String]
    returns: Result<Map<String, String>, String>
    behavior: channel_operations

  - name: close_channel
    params: [channel_id: String]
    returns: Result<Channel, String>
    behavior: channel_operations

  # Shared state operations
  - name: create_shared_state
    params: [name: String, initial_data: Map<String, String>]
    returns: Result<SharedState, String>
    behavior: shared_state_operations

  - name: read_shared_state
    params: [state_id: String]
    returns: Result<SharedState, String>
    behavior: shared_state_operations

  - name: update_shared_state
    params: [state_id: String, updates: Map<String, String>]
    returns: Result<SharedState, String>
    behavior: shared_state_operations

  - name: watch_shared_state
    params: [state_id: String, agent_id: String]
    returns: Result<SharedState, String>
    behavior: shared_state_operations

  # Stream operations
  - name: create_stream
    params: [name: String, stream_type: String, buffer_size: Int]
    returns: Result<Stream, String>
    behavior: stream_operations

  - name: subscribe_stream
    params: [stream_id: String, agent_id: String]
    returns: Result<Stream, String>
    behavior: stream_operations

  - name: emit_event
    params: [stream_id: String, event_type: String, data: Map<String, String>]
    returns: Result<Event, String>
    behavior: stream_operations

  - name: close_stream
    params: [stream_id: String]
    returns: Result<Stream, String>
    behavior: stream_operations

  # Lock operations
  - name: acquire_lock
    params: [resource: String, agent_id: String, timeout_ms: Int]
    returns: Result<Lock, String>
    behavior: lock_operations

  - name: release_lock
    params: [lock_id: String]
    returns: Result<Bool, String>
    behavior: lock_operations

  - name: check_lock
    params: [resource: String]
    returns: Result<Lock, String>
    behavior: lock_operations

# Documentation
documentation:
  overview: |
    # Agent Interaction System
    
    Agent interaction patterns for channels, shared state, and reactive streams.
    
    ## Features
    - Channel operations (create, subscribe, publish, receive, close)
    - Shared state (create, read, update, watch)
    - Reactive streams (create, subscribe, emit, close)
    - Distributed locks (acquire, release, check)
    
  examples:
    - title: Channel Communication
      code: |
        let result = create_channel("data-channel", 100)
        case result {
          Ok(channel) -> {
            subscribe_channel(channel.id, "agent-1")
            subscribe_channel(channel.id, "agent-2")
            
            let msg = map.from_list([
              #("type", "data"),
              #("content", "test")
            ])
            publish_to_channel(channel.id, msg)
          }
          Error(err) -> io.println("Error: " <> err)
        }
    
    - title: Shared State
      code: |
        let initial = map.from_list([
          #("key1", "value1"),
          #("key2", "value2")
        ])
        let result = create_shared_state("config", initial)
        case result {
          Ok(state) -> {
            watch_shared_state(state.id, "agent-1")
            
            let updates = map.from_list([#("key1", "new_value")])
            update_shared_state(state.id, updates)
          }
          Error(err) -> io.println("Error: " <> err)
        }
    
    - title: Reactive Stream
      code: |
        let result = create_stream("events", "hot", 10)
        case result {
          Ok(stream) -> {
            subscribe_stream(stream.id, "agent-1")
            
            let data = map.from_list([
              #("action", "click"),
              #("target", "button")
            ])
            emit_event(stream.id, "user_action", data)
          }
          Error(err) -> io.println("Error: " <> err)
        }

# Generation metadata
generation:
  target_language: gleam
  output_path: src/agent_interaction.gleam
  test_path: test/agent_interaction_test.gleam
  generate_docs: true
  generate_tests: true
  generate_helpers: true
