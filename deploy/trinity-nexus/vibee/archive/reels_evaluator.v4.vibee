@spec categorize_failure(error: str) → str {
  /// Categorize failure type for analysis
  given: Error message
  when: Analyzing failure
  then: Returns failure category
}

@impl {
  let lower = string.lowercase(error)

  let categories = [
    #(["timeout"], "timeout"),
    #(["tts", "elevenlabs"], "tts_error"),
    #(["lipsync", "fal"], "lipsync_error"),
    #(["render", "remotion"], "render_error"),
    #(["config", "api key"], "config_error"),
    #(["photo", "image"], "photo_error")
  ]

  categories · find_category
}

@spec find_category(text: str, categories: [#([str], str])) → str {
  /// Find matching category from keywords
  given: Error text and categories
  when: Searching for match
  then: Returns category or "unknown_error"
}

@impl {
  match categories {
    [] → "unknown_error"
    [#(keywords, category) | rest] → {
      match list.{ string.contains(text, it · any } {
        true → category
        false → rest · find_category
      }
    }
  }
}

// =============================================================================
// Follow-up Suggestions
// =============================================================================

@spec suggest_follow_ups(niche: str) → [str] {
  /// Suggest follow-up actions based on niche
  given: Content niche
  when: Suggesting next steps
  then: Returns action suggestions
}

@impl {
  match niche {
    "business" → [
      "SHARE_TO_LINKEDIN",
      "CREATE_CAROUSEL",
      "SUGGEST_RELATED_TOPIC"
    ]
    "productivity" → [
      "CREATE_CHECKLIST",
      "SUGGEST_SERIES",
      "SCHEDULE_REMINDER"
    ]
    "health" → [
      "SHARE_TO_INSTAGRAM",
      "CREATE_WORKOUT",
      "SUGGEST_MEAL_PLAN"
    ]
    "finance" → [
      "CREATE_CALCULATOR",
      "SHARE_TO_TWITTER",
      "SUGGEST_INVESTMENT_TIP"
    ]
    "technology" → [
      "CREATE_TUTORIAL",
      "SHARE_TO_YOUTUBE",
      "SUGGEST_CODE_SNIPPET"
    ]
    _ → [
      "SHARE_VIDEO",
      "CREATE_ANOTHER",
      "GET_ANALYTICS"
    ]
  }
}

@spec suggest_recovery_actions(failure_type: str) → [str] {
  /// Suggest recovery actions for failures
  given: Failure type
  when: Recovering from error
  then: Returns recovery suggestions
}

@impl {
  match failure_type {
    "timeout" → [
      "RETRY_WITH_SHORTER_SCRIPT",
      "TRY_SIMPLER_TEMPLATE",
      "CHECK_SERVICE_STATUS"
    ]
    "tts_error" → [
      "TRY_DIFFERENT_VOICE",
      "SHORTEN_SCRIPT",
      "CHECK_ELEVENLABS_QUOTA"
    ]
    "lipsync_error" → [
      "USE_DIFFERENT_PHOTO",
      "TRY_LOWER_RESOLUTION",
      "CHECK_FAL_STATUS"
    ]
    "render_error" → [
      "RETRY_RENDER",
      "USE_SIMPLER_TEMPLATE",
      "CHECK_REMOTION_LOGS"
    ]
    "config_error" → [
      "CHECK_API_KEYS",
      "VERIFY_CONFIGURATION",
      "CONTACT_SUPPORT"
    ]
    "photo_error" → [
      "UPLOAD_NEW_PHOTO",
      "USE_DEFAULT_AVATAR",
      "CHECK_PHOTO_FORMAT"
    ]
    _ → [
      "RETRY_ACTION",
      "SIMPLIFY_REQUEST",
      "CONTACT_SUPPORT"
    ]
  }
}

// =============================================================================
// Helper Functions
// =============================================================================

@spec get_string_from_data(data: {str, }, key: str) → str {
  /// Extract string from data dictionary
  given: Data dict and key
  when: Getting value
  then: Returns value or empty string
}

@impl {
  match dict.key · get {
    ✅value) → value
    ❌_) → ""
  }
}

