@spec create_reels_evaluator() → Evaluator {
  /// Create the Reels Evaluator
  given: Nothing
  when: Setting up evaluators
  then: Returns reels evaluator
}

@impl {
  Evaluator(
    "reels_evaluator",
    "Analyzes reels creation results, extracts insights, suggests follow-ups",
    result · fn { result · evaluate_reels_result }
  )
}

trace("agent.reels_evaluator.evaluate")
@spec evaluate_reels_result(context: ActionContext, result: ActionResult) → EvaluatorResult {
  /// Evaluate reels creation result
  given: Context and action result
  when: Post-processing reels action
  then: Returns insights and suggestions
}

@impl {
  print("[REELS_EVALUATOR] Evaluating result for type type type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int}: {context.chat_id}")

  match result.success {
    true → result · evaluate_success
    false → result · evaluate_failure
  }
}

// =============================================================================
// Success Evaluation
// =============================================================================

@spec evaluate_success(context: ActionContext, result: ActionResult) → EvaluatorResult {
  /// Evaluate successful reels creation
  given: Context and successful result
  when: Reels created successfully
  then: Returns facts and follow-ups
}

@impl {
  // Extract data from result
  let idea = get_string_from_data(result.data, "idea")
  let niche = get_string_from_data(result.data, "niche")
  let video_url = get_string_from_data(result.data, "video_url")

  // Build facts to store
  let facts = idea, niche, video_url · build_success_facts

  // Suggest follow-up actions
  let follow_ups = suggest_follow_ups(niche)

  print("[REELS_EVALUATOR] Success! Facts: {string.inspect(list.length(facts))}")

  // Store successful creations
    facts,
    follow_ups
   · EvaluatorResult
}

// =============================================================================
// Failure Evaluation
// =============================================================================

@spec evaluate_failure(context: ActionContext, result: ActionResult) → EvaluatorResult {
  /// Evaluate failed reels creation
  given: Context and failed result
  when: Reels creation failed
  then: Returns failure facts and recovery suggestions
}

@impl {
  let error = result.text

  // Extract failure reason
  let failure_type = categorize_failure(error)

  // Build facts about failure
  let facts = [
    "Reels creation failed for type type type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {context.chat_id}",
    "Failure type: {failure_type}",
    "Error: {error}"
  ]

  // Suggest recovery actions
  let recovery_actions = suggest_recovery_actions(failure_type)

  print("[REELS_EVALUATOR] Failure: {failure_type}")

  // Store failures to avoid repeating
    facts,
    recovery_actions
   · EvaluatorResult
}

