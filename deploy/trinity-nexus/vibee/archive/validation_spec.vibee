# Validation Utilities Specification
# Input validation and data sanitization

name: validation
version: 1.0.0
description: |
  Validation utilities for input checking and data sanitization.
  Demonstrates spec-driven development with validation logic.

# ============================================================================
# TYPES
# ============================================================================

types:
  - name: ValidationResult
    description: Result of validation
    fields:
      - name: valid
        type: Bool
        description: Whether input is valid
      - name: errors
        type: List(String)
        description: List of validation errors
      - name: sanitized
        type: String
        description: Sanitized input value
  
  - name: EmailValidation
    description: Email validation result
    fields:
      - name: valid
        type: Bool
        description: Whether email is valid
      - name: domain
        type: String
        description: Email domain
      - name: local_part
        type: String
        description: Local part of email

# ============================================================================
# BEHAVIORS
# ============================================================================

behaviors:
  - name: validate_email
    description: Validate email address
    given: An email string
    when: validate_email is called
    then: Email validity is checked
    test_cases:
      - name: valid_email
        input:
          email: "user@example.com"
        expected:
          valid: "true"
          domain: "example.com"
      
      - name: invalid_email_no_at
        input:
          email: "userexample.com"
        expected:
          valid: "false"
          error: "Missing @ symbol"
      
      - name: invalid_email_no_domain
        input:
          email: "user@"
        expected:
          valid: "false"
          error: "Missing domain"
  
  - name: validate_url
    description: Validate URL
    given: A URL string
    when: validate_url is called
    then: URL validity is checked
    test_cases:
      - name: valid_https_url
        input:
          url: "https://example.com"
        expected:
          valid: "true"
          protocol: "https"
      
      - name: valid_http_url
        input:
          url: "http://example.com"
        expected:
          valid: "true"
          protocol: "http"
      
      - name: invalid_url_no_protocol
        input:
          url: "example.com"
        expected:
          valid: "false"
          error: "Missing protocol"
  
  - name: validate_phone
    description: Validate phone number
    given: A phone number string
    when: validate_phone is called
    then: Phone validity is checked
    test_cases:
      - name: valid_us_phone
        input:
          phone: "+1-555-123-4567"
        expected:
          valid: "true"
          country: "US"
      
      - name: valid_international
        input:
          phone: "+44-20-1234-5678"
        expected:
          valid: "true"
          country: "UK"
  
  - name: sanitize_html
    description: Sanitize HTML input
    given: HTML string with potential XSS
    when: sanitize_html is called
    then: Dangerous tags are removed
    test_cases:
      - name: remove_script_tags
        input:
          html: "<p>Hello</p><script>alert('xss')</script>"
        expected:
          sanitized: "<p>Hello</p>"
      
      - name: remove_onclick
        input:
          html: "<div onclick='alert()'>Click</div>"
        expected:
          sanitized: "<div>Click</div>"
  
  - name: validate_password
    description: Validate password strength
    given: A password string
    when: validate_password is called
    then: Password strength is checked
    test_cases:
      - name: strong_password
        input:
          password: "MyP@ssw0rd123"
        expected:
          valid: "true"
          strength: "strong"
      
      - name: weak_password
        input:
          password: "password"
        expected:
          valid: "false"
          strength: "weak"
          errors: "[\"No uppercase\", \"No numbers\", \"No special chars\"]"

# ============================================================================
# FUNCTIONS
# ============================================================================

functions:
  - name: validate_email
    signature: "validate_email(email: String) -> Result(EmailValidation, String)"
    description: Validate email address format
    examples:
      - "validate_email(\"user@example.com\")"
  
  - name: validate_url
    signature: "validate_url(url: String) -> Result(Bool, String)"
    description: Validate URL format
    examples:
      - "validate_url(\"https://example.com\")"
  
  - name: validate_phone
    signature: "validate_phone(phone: String) -> Result(Bool, String)"
    description: Validate phone number format
    examples:
      - "validate_phone(\"+1-555-123-4567\")"
  
  - name: sanitize_html
    signature: "sanitize_html(html: String) -> String"
    description: Remove dangerous HTML tags and attributes
    examples:
      - "sanitize_html(\"<script>alert()</script>\")"
  
  - name: validate_password
    signature: "validate_password(password: String) -> ValidationResult"
    description: Check password strength
    examples:
      - "validate_password(\"MyP@ssw0rd123\")"
  
  - name: is_alphanumeric
    signature: "is_alphanumeric(text: String) -> Bool"
    description: Check if string contains only letters and numbers
    examples:
      - "is_alphanumeric(\"abc123\")"
  
  - name: is_numeric
    signature: "is_numeric(text: String) -> Bool"
    description: Check if string contains only numbers
    examples:
      - "is_numeric(\"12345\")"

dependencies:
  - gleam_stdlib

metadata:
  author: VIBEE Team
  license: MIT
  category: security
  tags:
    - validation
    - security
    - sanitization
  
  security_features:
    - XSS prevention
    - SQL injection prevention
    - Email validation
    - URL validation
    - Password strength checking
