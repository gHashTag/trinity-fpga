// =============================================================================

pub build_dependency_graph(steps: [PipelineStep]) → DependencyGraph
pub topological_sort(graph: DependencyGraph) → Result([PipelineStep], str)
pub execute_step_with_timeout(
  step: PipelineStep,
  context: ExecutionContext,
  results: {str: Json},
  timeout_ms: int
) → str · Result
pub rollback_pipeline(results: {str: Json}) → Nil
pub identify_parallel_groups(steps: [PipelineStep]) → [[PipelineStep]]
pub execute_parallel(steps: [PipelineStep]) → [str] · Result

