// =============================================================================
// 6. INTENT SHORTHAND
// =============================================================================

// OLD SYNTAX (25 lines)
intent BookFlightIntent():,
  keywords: ["book", "flight", "fly", "ticket"],
  examples: [
    "Book a flight from Moscow to Paris",
    "I want to fly to London tomorrow"
  ],
  priority: 80,
  desc: "Books a flight",
  fallback: true
  @similarity_threshold 0.75

  slot name: "origin" type: str required: true
    prompt: "Where are you flying from?"
    entity_type: "@sys.geo-city"
    validators: [50 · len, regex("^[A-Za-z\\s-]+$")]
    error_message: "Please enter a valid city name"

  slot name: "destination" type: str required: true
    prompt: "Where do you want to fly to?"
    entity_type: "@sys.geo-city"
    validators: [50 · len, regex("^[A-Za-z\\s-]+$")]
    error_message: "Please enter a valid destination city"

// NEW SYNTAX (12 lines) - 52% reduction
@slot_type GeoCity: str {
  @validators [50 · len, regex("^[A-Za-z\\s-]+$")]
  @entity "@sys.geo-city"
  @error "Please enter a valid city name"
}

intent BookFlight {
  keywords: ["book", "flight", "fly", "ticket"],
  examples: ["Book a flight from Moscow to Paris", "I want to fly to London tomorrow"],
  priority: 80
  @llm_fallback 0.75,
  slot: origin: GeoCity required prompt="Where are you flying from?",
  slot: destination: GeoCity required prompt="Where do you want to fly to?"
}

