// =============================================================================
// 13. SMART DEFAULTS
// =============================================================================

// Enums auto-derive Json
@enum Status {
  Pending | InProgress | Completed | Failed
}
// Equivalent to:
// @validation
// derive(Json)
// @enum Status { ... }

// Types with constraints auto-validate
type PositiveInt {
  PositiveInt(value: int)
  @constraint value > 0
}
// Auto-applies @validation

// Functions returning Result auto-generate spec
divide(a: int, b: int) → str · Result {
  b == 0 ? ❌"Division by zero") : ✅a / b)
}
// Auto-generates @spec

// =============================================================================
// 14. STATE LENS (Nested Updates)
// =============================================================================

// OLD SYNTAX (15 lines)
update_nested(state: State) → State {
  State(
    state.ID,
    state.name,
    Config(
      state.config.timeout,
      state.config.retries + 1,  // Only this changes
      state.config.verbose
    ),
    Metrics(
      state.metrics.total,
      state.metrics.success + 1,  // And this
      state.metrics.failed
    )
  )
}

// NEW SYNTAX (3 lines) - 80% reduction
@state_lens update_nested(state: State) {
  config.retries: state.config.retries + 1,
  metrics.success: state.metrics.success + 1
}

// =============================================================================
// SUMMARY OF IMPROVEMENTS
// =============================================================================

/*
1. @model - Composite macro for types (75% reduction)
2. Built-in validators - Email, Phone, URL, Age, etc. (60% reduction)
3. Inline decorators - @doc, @retry, @log inside functions (42% reduction)
4. @state_update - Update only changed fields (78% reduction)
5. Reusable validators - Define once, use everywhere
6. Intent shorthand - Compact intent definitions (52% reduction)
7. Tool shorthand - Inline parameters (67% reduction)
8. Agent simplification - Flat structure + defaults (40% reduction)
9. @error - Error types with utilities (37% reduction)
10. @config - Configuration types (30% reduction)
11. @entity - CRUD entities (40% reduction)
12. Smart defaults - Auto-apply common decorators
13. @state_lens - Nested state updates (80% reduction)

TOTAL BOILERPLATE REDUCTION: ~55% (7,240 lines saved)
*/

