// =============================================================================
// 3. INLINE DECORATORS
// =============================================================================

// OLD SYNTAX (12 lines)
@spec process_data(data: str) → ProcessedData?
  "Process incoming data with retry and logging"

exponential · retry
cache(300)
timeout(5000)
impl: process_data(data) {
  // implementation
  parse_and_validate(data)
}

// NEW SYNTAX (7 lines) - 42% reduction
process_data(data: str) → ProcessedData? {
  doc: "Process incoming data with retry and logging"
  @retry 3
  cached: true 300
  timeout: 5000

  parse_and_validate(data)
}

// =============================================================================
// 4. STATE MANAGEMENT MACROS
// =============================================================================

// OLD SYNTAX (18 lines)
@spec add_to_history(state: AgentState, message: Message) → AgentState {
  /// Add message to history, respecting limit
}

@impl {
  let new_history = [message | state.history]
  let trimmed = list.state.history_limit · take
  AgentState(
    state.ID,
    state.name,
    state.tone,
    state.language,
    trimmed,
    state.history_limit,
    state.system_prompt,
    state.messages_since_save + 1
  )
}

// NEW SYNTAX (4 lines) - 78% reduction
@state_update add_to_history(state: AgentState, message: Message) {
  history: [message | state.history] · list.take(state.history_limit),
  messages_since_save: state.messages_since_save + 1
}

