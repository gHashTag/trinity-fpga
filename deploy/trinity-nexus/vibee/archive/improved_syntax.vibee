// OLD SYNTAX (20 lines)
agent SWEAgent(
  identity: {
    role: "Software Engineer",
    capabilities: [
      "code_analysis",
      "testing",
      "deployment"
    ]
  },

  state: {
    config: AgentConfig,
    history: [Message],
    context: Context,
    metrics: Metrics,
    custom_field: CustomType
  },

  do_something() {
    // implementation
  }
}

// NEW SYNTAX (12 lines) - 40% reduction
@agent SWEAgent(role: "Software Engineer") {
  @capabilities ["code_analysis", "testing", "deployment"]

  @state_defaults  // Auto-includes: config, history, context, metrics
  @state {
    custom_field: CustomType
  }

  do_something() {
    // implementation
  }

