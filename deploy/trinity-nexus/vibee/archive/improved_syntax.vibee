// OLD SYNTAX (8 lines)

derive(Json)
type DbError {
  DbConnection❌message: str)
  DbQuery❌message: str)
  DbNotFound
  DbTimeout
}

// NEW SYNTAX (5 lines) - 37% reduction
@error DbError {
  Connection❌message: str),
  Query❌message: str),
  NotFound,
  Timeout
}
