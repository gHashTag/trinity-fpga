  verbose: bool! = false
  log_level: str! = "info"

// NEW SYNTAX (7 lines) - 30% reduction
@config ServerConfig {
  host: str = "localhost",
  port: int = 3000,
  timeout: int = 30,
  retries: int = 3,
  verbose: bool = false,
  log_level: str = "info"
}

