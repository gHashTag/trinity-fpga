# Calculator with Auto-Generated Tests
# VIBEE = VibeCoding + Bee (Swarm Intelligence)

name: calculator
version: 1.0.0
description: Calculator with automatic test generation

types:
  - name: Operation
    description: Mathematical operation
    fields:
      - name: operator
        type: String
        description: Operation type (+, -, *, /)
      - name: a
        type: Float
        description: First operand
      - name: b
        type: Float
        description: Second operand

functions:
  - name: add
    description: Add two numbers
    params:
      - name: a
        type: Float
      - name: b
        type: Float
    return_type: Float
    properties:
      - commutative: "add(a, b) == add(b, a)"
      - associative: "add(add(a, b), c) == add(a, add(b, c))"
      - identity: "add(a, 0.0) == a"
    test_cases:
      - name: add_positive
        inputs: {a: 5.0, b: 3.0}
        expected: 8.0
      - name: add_negative
        inputs: {a: -5.0, b: -3.0}
        expected: -8.0
      - name: add_zero
        inputs: {a: 5.0, b: 0.0}
        expected: 5.0
  
  - name: subtract
    description: Subtract two numbers
    params:
      - name: a
        type: Float
      - name: b
        type: Float
    return_type: Float
    properties:
      - inverse: "add(subtract(a, b), b) == a"
    test_cases:
      - name: subtract_positive
        inputs: {a: 5.0, b: 3.0}
        expected: 2.0
  
  - name: multiply
    description: Multiply two numbers
    params:
      - name: a
        type: Float
      - name: b
        type: Float
    return_type: Float
    properties:
      - commutative: "multiply(a, b) == multiply(b, a)"
      - associative: "multiply(multiply(a, b), c) == multiply(a, multiply(b, c))"
      - identity: "multiply(a, 1.0) == a"
      - zero: "multiply(a, 0.0) == 0.0"
    test_cases:
      - name: multiply_positive
        inputs: {a: 5.0, b: 3.0}
        expected: 15.0
  
  - name: divide
    description: Divide two numbers
    params:
      - name: a
        type: Float
      - name: b
        type: Float
    return_type: Result(Float, String)
    properties:
      - inverse: "multiply(divide(a, b), b) == a"
      - error_on_zero: "divide(a, 0.0) == Error('Division by zero')"
    test_cases:
      - name: divide_positive
        inputs: {a: 6.0, b: 3.0}
        expected: Ok(2.0)
      - name: divide_by_zero
        inputs: {a: 5.0, b: 0.0}
        expected: Error("Division by zero")

# Test Generation Configuration
test_generation:
  enabled: true
  property_tests:
    num_cases: 100  # Generate 100 random test cases per property
    shrinking: true  # Enable automatic shrinking
  edge_cases:
    enabled: true
    values:
      - 0.0
      - 1.0
      - -1.0
      - 0.0000001  # Very small
      - 1000000.0  # Very large
  symbolic_execution:
    enabled: false  # Disabled for now (complex)
  coverage_target: 95  # Target 95% code coverage
