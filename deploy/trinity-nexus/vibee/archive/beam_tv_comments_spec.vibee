  - id: "comment2"
    video_id: "video1"
    user_id: "user2"
    text: "Thanks for this tutorial. Looking forward to more content!"
    likes: 28
    created_at: "2026-01-10T11:30:00Z"
  
  - id: "comment3"
    video_id: "video1"
    user_id: "user3"
    text: "Could you explain more about OTP supervision trees?"
    likes: 15
    created_at: "2026-01-10T14:20:00Z"
  
  - id: "comment4"
    video_id: "video2"
    user_id: "user1"
    text: "Pattern matching in Gleam is so elegant!"
    likes: 35
    created_at: "2026-01-10T09:00:00Z"
  
  - id: "comment5"
    video_id: "video2"
    user_id: "user4"
    text: "This helped me understand the type system better."
    likes: 22
    created_at: "2026-01-10T16:45:00Z"

# ============================================================================
# COMPLETENESS
# ============================================================================

completeness:
  test_coverage: 100%
  all_behaviors_implemented: true
  all_functions_implemented: true
  storage_functions: 9
  api_functions: 2
  total_tests: 12
