    given: orin[CYR:ny] code and TVC IR
    when: Aonfrom withandwithand andwithand
    then: in[CYR:acts] list Distortion with andIand and severity
    implementation: |
                    pub fn detect_distortions(code: []const u8, ir: anytype) []const Distortion {
                        _ = code;
                        _ = ir;
                        return &[_]Distortion{};
                    }
            
            
      
      

