Output trinity_math_sacred.gif
Set Shell "zsh"
Set Theme "Crystal Violet"
Set FontSize 20
Set FontFamily "JetBrains Mono, Fira Code, monospace"
Set Width 1280
Set Height 720
Set Padding 40
Set Margin 20
Set Framerate 30
Set TypingSpeed 100ms
Set CursorBlink false

Type "clear"
Enter
Sleep 500ms

Type "tri math sacred"
Enter
Sleep 8s
