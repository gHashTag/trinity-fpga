# Docker ignore for Railway build deployment
# Need source files for zig build, exclude large unnecessary files

# Large data
data/
*.tar.gz
*.zip
*.jsonl

# Git and CI
.git/
.github/

# Documentation
docs/
docsite/
website/

# Node modules
node_modules/

# Build artifacts from previous builds
zig-out/
*.o
*.a

# Claude/Ralph state (optional - can exclude)
.claude/
.ralph/
.trinity/

# Dev scripts
scripts/
archive/

# Test/benchmark data
*.vcd
*.bin
*.elf

# Keep .zig-cache for build dependencies
# Keep src/ for source code
# Keep build.zig and build.zig.zon for build config
