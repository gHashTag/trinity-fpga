{
  "permissions": {
    "allow": [
      "bash(zig build *)",
      "bash(zig fmt *)",
      "bash(zig test *)",
      "bash(gh *)",
      "bash(git status)",
      "bash(git diff *)",
      "bash(git log *)",
      "bash(git add *)",
      "bash(git commit *)",
      "bash(git push)",
      "bash(git branch *)",
      "bash(ls *)",
      "bash(find *)",
      "bash(grep *)",
      "bash(wc *)",
      "bash(cat *)",
      "bash(head *)",
      "bash(tail *)",
      "read_file(*)",
      "grep(*)"
    ],
    "deny": [
      "bash(rm -rf /)",
      "bash(rm -rf ~)",
      "bash(rm -rf /*)",
      "bash(git push --force *)",
      "write_file(.env)",
      "write_file(*secret*)",
      "write_file(*credential*)"
    ]
  }
}
