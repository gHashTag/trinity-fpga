name: b2t_llm_assist
version: "1.0.0"
language: zig

types:
  DistortionType:
  Distortion:
    fields:
      type: DistortionType
      location: Int
      line_number: Int
      severity: Float
      description: String
      suggested_fix: Option<String>
      confidence: Float
  DataFlowNode:
    fields:
      variable_id: Int
      definition_site: Int
      use_sites: List<Int>
      type_hint: Option<String>
      is_parameter: Bool
      is_return_value: Bool
  CallGraphNode:
    fields:
      function_address: Int
      function_name: Option<String>
      callers: List<Int>
      callees: List<Int>
      is_library: Bool
      signature_hint: Option<String>
  SemanticContext:
    fields:
      data_flow: List<DataFlowNode>
      call_graph: List<CallGraphNode>
      string_references: List<String>
      import_hints: List<String>
      struct_hints: List<String>
  CodeEmbedding:
    fields:
      code_hash: String
      embedding: List<Float>
      source_type: String
      metadata: Map<String, String>
  SimilarCode:
    fields:
      code: String
      similarity: Float
      source: String
      context: String
  RAGDatabase:
    fields:
      embeddings: List<CodeEmbedding>
      index_type: String
      dimension: Int
  PromptTemplate:
    fields:
      name: String
      template: String
      variables: List<String>
      distortion_aware: Bool
      examples_count: Int
  DecompilationPrompt:
    fields:
      template: PromptTemplate
      decompiled_code: String
      detected_distortions: List<Distortion>
      semantic_context: SemanticContext
      similar_examples: List<SimilarCode>
      target_quality: String
  CorrectedCode:
    fields:
      original: String
      corrected: String
      changes: List<CodeChange>
      confidence: Float
      reasoning: String
  CodeChange:
    fields:
      line_start: Int
      line_end: Int
      old_code: String
      new_code: String
      change_type: String
      rationale: String
  DecompilationResult:
    fields:
      function_name: String
      original_address: Int
      decompiled_code: String
      corrected_code: String
      distortions_found: List<Distortion>
      distortions_fixed: List<Distortion>
      fix_rate: Float
      re_executable: Bool
      tokens_used: Int

behaviors:
  - name: detect_distortions
    given: [CYR:Декомп]orроin[CYR:анный] code and TVC IR
    when: Аonлfrom with[CYR:емант]andчеwithкandх andwith[CYR:кажен]andй
    then: [CYR:Воз]in[CYR:ращает] list Distortion with [CYR:локац]andямand and severity
    implementation: |
                    pub fn detect_distortions(code: []const u8, ir: anytype) []const Distortion {
                        _ = code;
                        _ = ir;
                        return &[_]Distortion{};
                    }
            
            
      
      

  - name: compute_semantic_intensity
    given: [CYR:Строка] [CYR:декомп]orроin[CYR:анного] codeа
    when: [CYR:Выч]andwith[CYR:лен]andе "with[CYR:емант]andчеwith[CYR:кой] and[CYR:нтен]withandinноwithтand" (по FidelityGPT)
    then: [CYR:Воз]in[CYR:ращает] Float score for прandорandтfromацandand andwith[CYR:пра]in[CYR:лен]andй
    implementation: |
                    pub fn compute_semantic_intensity(code: []const u8) f32 {
                        _ = code;
                        return 0.5;
                    }
            
            
      
      

  - name: analyze_variable_dependencies
    given: Спandwithок [CYR:переменных] with andwith[CYR:кажен]andямand
    when: Поwith[CYR:троен]andе [CYR:графа] заinandwithandмоwith[CYR:тей]
    then: [CYR:Воз]in[CYR:ращает] [CYR:упорядоченный] list for andwith[CYR:пра]in[CYR:лен]andя
    implementation: |
                    pub fn analyze_variable_dependencies(variables: []const []const u8) []const []const u8 {
                        _ = variables;
                        return &[_][]const u8{};
                    }
            
            
      
      

  - name: extract_data_flow
    given: TVC IR [CYR:функц]andand
    when: Аonлfrom def-use chains
    then: [CYR:Воз]in[CYR:ращает] List<DataFlowNode>

  - name: extract_call_graph
    given: TVC IR [CYR:модуля]
    when: Поwith[CYR:троен]andе [CYR:графа] in[CYR:ызо]inоin
    then: [CYR:Воз]in[CYR:ращает] List<CallGraphNode>
    implementation: |
                    pub fn extract_call_graph(ir: anytype) []const CallGraphNode {
                        _ = ir;
                        return &[_]CallGraphNode{};
                    }
            
            
      
      

  - name: build_semantic_context
    given: TVC IR and resultы дfromаwithwith[CYR:ембл]andроinанandя
    when: [CYR:Агрегац]andя inwith[CYR:его] [CYR:контек]withта
    then: [CYR:Воз]in[CYR:ращает] SemanticContext
    implementation: |
                    pub fn build_semantic_context(ir: anytype, disasm: anytype) SemanticContext {
                        _ = ir;
                        _ = disasm;
                        return SemanticContext{};
                    }
            
            
      
      

  - name: embed_code
    given: [CYR:Фрагмент] codeа
    when: Геnot[CYR:рац]andя [CYR:эмбедд]and[CYR:нга] [CYR:через] LLM
    then: [CYR:Воз]in[CYR:ращает] CodeEmbedding
    implementation: |
                    pub fn embed_code(code: []const u8) CodeEmbedding {
                        _ = code;
                        return CodeEmbedding{};
                    }
            
            
      
      

  - name: search_similar
    given: CodeEmbedding and RAGDatabase
    when: Поandwithк k блand[CYR:жайш]andх withоwith[CYR:едей]
    then: [CYR:Воз]in[CYR:ращает] List<SimilarCode> отwith[CYR:орт]andроin[CYR:анный] по similarity
    implementation: |
                    pub fn search_similar(embedding: CodeEmbedding, db: anytype) []const SimilarCode {
                        _ = embedding;
                        _ = db;
                        return &[_]SimilarCode{};
                    }
            
            
      
      

  - name: retrieve_examples
    given: [CYR:Декомп]orроin[CYR:анный] code and type andwith[CYR:кажен]andя
    when: Поandwithк [CYR:реле]in[CYR:антных] exampleоin for ICL
    then: [CYR:Воз]in[CYR:ращает] List<SimilarCode> for [CYR:промпта]
    implementation: |
                    pub fn retrieve_examples(code: []const u8, dist_type: DistortionType) []const SimilarCode {
                        _ = code;
                        _ = dist_type;
                        return &[_]SimilarCode{};
                    }
            
            
      
      

  - name: select_template
    given: Тandп andwith[CYR:кажен]andя and [CYR:целе]inое [CYR:каче]withтinо
    when: [CYR:Выбор] [CYR:опт]and[CYR:мального] [CYR:шабло]on [CYR:промпта]
    then: [CYR:Воз]in[CYR:ращает] PromptTemplate
    implementation: |
                    pub fn select_template(dist_type: DistortionType, quality: []const u8) PromptTemplate {
                        _ = dist_type;
                        _ = quality;
                        return PromptTemplate{};
                    }
            
            
      
      

  - name: build_prompt
    given: Вwithе componentы [CYR:контек]withта
    when: [CYR:Сборка] фandon[CYR:льного] [CYR:промпта]
    then: [CYR:Воз]in[CYR:ращает] DecompilationPrompt
    implementation: |
                    pub fn build_prompt(context: anytype) DecompilationPrompt {
                        _ = context;
                        return DecompilationPrompt{};
                    }
            
            
      
      

  - name: format_icl_examples
    given: List<SimilarCode>
    when: [CYR:Формат]andроinанandе exampleоin for in-context learning
    then: [CYR:Воз]in[CYR:ращает] String with exampleамand in [CYR:формате] few-shot
    implementation: |
                    pub fn format_icl_examples(examples: []const SimilarCode) []const u8 {
