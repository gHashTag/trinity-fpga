name: b2t_llm_lifter
version: "1.0.0"
language: zig

types:
  EnhancedTVCFunction:
    fields:
      base: LiftedFunction
      semantic_name: String
      semantic_signature: String
      variable_names: Map<Int, String>
      type_annotations: Map<Int, String>
      struct_definitions: List<StructDef>
      comments: List<CodeComment>
      confidence: Float
  StructDef:
    fields:
      name: String
      fields: List<StructField>
      size: Int
      alignment: Int
      source_evidence: List<String>
  StructField:
    fields:
      name: String
      field_type: String
      offset: Int
      size: Int
  CodeComment:
    fields:
      line: Int
      comment: String
      comment_type: CommentType
  CommentType:
  LiftingStage:
  LiftingProgress:
    fields:
      current_stage: LiftingStage
      stages_completed: List<LiftingStage>
      errors: List<LiftingError>
      llm_calls: Int
      tokens_used: Int
      time_elapsed_ms: Int
  LiftingError:
    fields:
      stage: LiftingStage
      message: String
      recoverable: Bool
      fallback_used: Bool
  LLMLiftingConfig:
    fields:
      enable_name_recovery: Bool
      enable_type_inference: Bool
      enable_struct_recovery: Bool
      enable_pattern_recognition: Bool
      enable_comments: Bool
      max_llm_calls_per_function: Int
      confidence_threshold: Float
      use_rag: Bool
      rag_examples_count: Int
      fallback_on_error: Bool
  LiftedFunction:
    fields:
      name: String
      instructions: List<IRInstruction>
      variables: Map<Int, Variable>
  DisassemblyResult:
    fields:
      functions: List<LiftedFunction>
      entry_points: List<String>
  BasicBlock:
    fields:
      instructions: List<IRInstruction>
      successors: List<Int>
  IRInstruction:
    fields:
      opcode: String
      operands: List<String>
      result: String
  Variable:
    fields:
      id: Int
      type: String
      name: String
  SemanticContext:
    fields:
      strings: List<String>
      calls: List<String>
      globals: List<String>
  CallGraph:
    fields:
      nodes: List<CallGraphNode>
      edges: List<CallGraphEdge>
  CallGraphNode:
    fields:
      function_id: Int
      function_name: String
  CallGraphEdge:
    fields:
      from: Int
      to: Int
  DataFlow:
    fields:
      def_use_chains: Map<Int, List<Int>>
      types: Map<Int, String>
  CallSite:
    fields:
      function_id: Int
      arguments: List<String>
  CallingConvention:
  StructAccessPattern:
    fields:
      base_offset: Int
      accesses: List<MemoryAccess>
  MemoryAccess:
    fields:
      offset: Int
      size: Int
      type: String
  RecognizedIdiom:
    fields:
      idiom_name: String
      confidence: Float
  AlgorithmMatch:
    fields:
      algorithm_name: String
      confidence: Float
  RecognizedPattern:
    fields:
      pattern_name: String
      pattern_type: String
  Issue:
    fields:
      severity: String
      message: String
  ValidationIssue:
    fields:
      issue_type: String
      description: String
  ImprovementMetrics:
    fields:
      name_recovery_improvement: Float
      type_inference_improvement: Float
      overall_quality_score: Float

behaviors:
  - name: lift_with_llm
    given: b2t_disasm.DisassemblyResult and LLMLiftingConfig
    when: [CYR:ny]  lifting with LLM
    then: in[CYR:acts] List<EnhancedTVCFunction>
    implementation: |
                    pub fn lift_with_llm(dasm_result: DisassemblyResult, config: LLMLiftingConfig) []const EnhancedTVCFunction {
                        _ = dasm_result;
                        _ = config;
                        return &[_]EnhancedTVCFunction{};
                    }
            
            
      
      

  - name: lift_function_with_llm
    given: b2t_disasm.BasicBlock[] and LLMLiftingConfig
    when: Lifting  and with LLM-andIand
    then: in[CYR:acts] EnhancedTVCFunction
    implementation: |
                    pub fn lift_function_with_llm(blocks: []const BasicBlock, config: LLMLiftingConfig) EnhancedTVCFunction {
                        _ = blocks;
                        _ = config;
                        return EnhancedTVCFunction{};
                    }
            
            
      
      

  - name: get_lifting_progress
    given: and with lifting
    when: [CYR:pro]with [CYR:pro]with
    then: in[CYR:acts] LiftingProgress
    implementation: |
                    pub fn get_lifting_progress(context: anytype) LiftingProgress {
                        _ = context;
                        return LiftingProgress{};
                    }
            
            
      
      

  - name: recover_function_name
    given: LiftedFunction and SemanticContext
    when: withinand and[CYR:me]and and  LLM
    then: in[CYR:acts] String andI and Float confidence
    implementation: |
                    pub fn recover_function_name(lifted: LiftedFunction, context: SemanticContext) struct { name: []const u8, confidence: f32 } {
                        _ = lifted;
                        _ = context;
                        return .{ .name = "function_name", .confidence = 0.7 };
                    }
            
            
      
      

  - name: recover_variable_names
    given: LiftedFunction and SemanticContext
    when: withinand and [CYR:mey]  LLM
    then: in[CYR:acts] Map<Int, String>
    implementation: |
                    pub fn recover_variable_names(lifted: LiftedFunction, context: SemanticContext) std.AutoHashMap(usize, []const u8) {
                        _ = lifted;
                        _ = context;
                        const map = std.AutoHashMap(usize, []const u8).init(std.heap.page_allocator);
                        return map;
                    }
            
            
      
      

  - name: recover_parameter_names
    given: LiftedFunction and call graph context
    when: withinand and parameterin
    then: in[CYR:acts] List<String>
    implementation: |
                    pub fn recover_parameter_names(lifted: LiftedFunction, call_graph: CallGraph) []const []const u8 {
                        _ = lifted;
                        _ = call_graph;
                        return &[_][]const u8{};
                    }
            
            
      
      

  - name: infer_types_with_llm
    given: LiftedFunction and data flow
    when: [CYR:ny] inyin typein  LLM
    then: in[CYR:acts] Map<Int, String> typein
    implementation: |
                    pub fn infer_types_with_llm(lifted: LiftedFunction, data_flow: DataFlow) std.AutoHashMap(usize, []const u8) {
                        _ = lifted;
                        _ = data_flow;
                        const map = std.AutoHashMap(usize, []const u8).init(std.heap.page_allocator);
                        return map;
                    }
            
            
      
      

  - name: infer_return_type
    given: LiftedFunction and call sites
    when: Vyin type inin
    then: in[CYR:acts] String type
    implementation: |
                    pub fn infer_return_type(lifted: LiftedFunction, call_sites: []const CallSite) []const u8 {
                        _ = lifted;
                        _ = call_sites;
                        return "i64";
                    }
            
            
      
      

  - name: infer_parameter_types
    given: LiftedFunction and calling convention
    when: Vyin typein parameterin
    then: in[CYR:acts] List<String> typein
    implementation: |
                    pub fn infer_parameter_types(lifted: LiftedFunction, calling_conv: CallingConvention) []const []const u8 {
                        _ = lifted;
                        _ = calling_conv;
                        return &[_][]const u8{};
                    }
            
            
      
      

  - name: detect_struct_access
    given: TVC IR with memory operations
    when: andwith in with  with
    then: in[CYR:acts] List<StructAccessPattern>
    implementation: |
                    pub fn detect_struct_access(ir: []const IRInstruction) []const StructAccessPattern {
                        _ = ir;
                        return &[_]StructAccessPattern{};
                    }
            
            
      
      

  - name: recover_struct_definition
    given: List<StructAccessPattern>
    when: withinand andI withy]  LLM
    then: in[CYR:acts] StructDef
    implementation: |
                    pub fn recover_struct_definition(patterns: []StructAccessPattern) StructDef {
                        _ = patterns;
                        return StructDef{};
                    }
            
            
      
      

  - name: apply_struct_types
    given: LiftedFunction and List<StructDef>
    when: andnotand withy] typein  IR
    then: in[CYR:I] type annotations
    implementation: |
                    pub fn apply_struct_types(lifted: *LiftedFunction, structs: []const StructDef) void {
                        _ = lifted;
                        _ = structs;
                    }
            
            
      
      

  - name: recognize_idioms
    given: TVC IR block
    when: withoninand and (malloc/free, strlen, memcpy)
    then: in[CYR:acts] List<RecognizedIdiom>
    implementation: |
                    pub fn recognize_idioms(ir_block: []const IRInstruction) []const RecognizedIdiom {
                        _ = ir_block;
                        return &[_]RecognizedIdiom{};
                    }
            
            
      
      

  - name: recognize_algorithms
    given: LiftedFunction
    when: withoninand [CYR:algorithm]andin (sort, search, hash)
    then: in[CYR:acts] Option<AlgorithmMatch>
    implementation: |
                    pub fn recognize_algorithms(lifted: LiftedFunction) ?AlgorithmMatch {
                        _ = lifted;
                        return AlgorithmMatch{};
                    }
            
            
      
      

  - name: apply_pattern_knowledge
    given: LiftedFunction and recognized patterns
    when: andnotand onand  on
    then: [CYR:acts] andon and [CYR:me]and
    implementation: |
                    pub fn apply_pattern_knowledge(lifted: *EnhancedTVCFunction, patterns: []const RecognizedPattern) void {
                        _ = lifted;
                        _ = patterns;
                    }
            
            
      
      

  - name: generate_function_comment
    given: EnhancedTVCFunction
    when: notandI [CYR:me]and[CYR:go] [CYR:me]andI
    then: in[CYR:acts] CodeComment
    implementation: |
                    pub fn generate_function_comment(func: EnhancedTVCFunction) CodeComment {
                        _ = func;
                        return CodeComment{};
                    }
            
            
      
      

  - name: generate_inline_comments
    given: EnhancedTVCFunction
    when: notandI inline [CYR:me]andin for withy] within
    then: in[CYR:acts] List<CodeComment>
    implementation: |
                    pub fn generate_inline_comments(func: EnhancedTVCFunction) []CodeComment {
                        _ = func;
                        return &[_]CodeComment{};
                    }
            
            
      
      

  - name: generate_warning_comments
    given: EnhancedTVCFunction and detected issues
    when: notandI and
    then: in[CYR:acts] List<CodeComment>
    implementation: |
                    pub fn generate_warning_comments(func: EnhancedTVCFunction, issues: []const Issue) []const CodeComment {
                        _ = func;
                        _ = issues;
                        return &[_]CodeComment{};
                    }
            
            
      
      

  - name: validate_enhanced_ir
    given: EnhancedTVCFunction
    when: in withand and
    then: in[CYR:acts] Bool and List<ValidationIssue>
    implementation: |
                    pub fn validate_enhanced_ir(func: EnhancedTVCFunction) struct { valid: bool, issues: []ValidationIssue } {
                        _ = func;
                        return .{ .valid = true, .issues = &[_]ValidationIssue{} };
                    }
            
            
      
      

  - name: compare_with_baseline
    given: EnhancedTVCFunction and iny LiftedFunction
    when: innotand with baseline
    then: in[CYR:acts] ImprovementMetrics
    implementation: |
                    pub fn compare_with_baseline(enhanced: EnhancedTVCFunction, baseline: LiftedFunction) ImprovementMetrics {
                        _ = enhanced;
                        _ = baseline;
                        return ImprovementMetrics{};
                    }
            
            
      
      

  - name: rollback_to_baseline
    given: EnhancedTVCFunction with errorand
    when:   in IR
    then: in[CYR:acts] LiftedFunction
    implementation: |
                    pub fn rollback_to_baseline(enhanced: EnhancedTVCFunction) LiftedFunction {
                        _ = enhanced;
                        return LiftedFunction{};
                    }
            
            
      
      

