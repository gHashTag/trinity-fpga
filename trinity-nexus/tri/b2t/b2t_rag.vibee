  - name: detect_chunk_type
    given: [CYR:Фрагмент] codeа
    when: [CYR:Кла]withwithandфand[CYR:кац]andя typeа [CYR:чанка]
    then: [CYR:Воз]in[CYR:ращает] ChunkType
    implementation: |
                    pub fn detect_chunk_type(chunk: CodeChunk) ChunkType {
