name: b2t_prompts
version: "1.0.0"
language: zig

types:
  PromptRole:
  PromptSection:
    fields:
      role: PromptRole
      content: String
      priority: Int
      required: Bool
      max_tokens: Option<Int>
  PromptConfig:
    fields:
      max_total_tokens: Int
      temperature: Float
      top_p: Float
      presence_penalty: Float
      frequency_penalty: Float
  DistortionTemplate:
    fields:
      distortion_type: String
      detection_prompt: String
      correction_prompt: String
      validation_prompt: String
      examples: List<DistortionExample>
  DistortionExample:
    fields:
      distorted_code: String
      corrected_code: String
      explanation: String
      distortion_markers: List<String>
  ReasoningStep:
    fields:
      step_number: Int
      description: String
      expected_output: String
  ChainOfThought:
    fields:
      task: String
      steps: List<ReasoningStep>
      final_instruction: String
  CoTParseResult:
    fields:
      steps: List<ReasoningStep>
      final_answer: String
      reasoning: String

behaviors:
  - name: build_system_prompt
    given: [CYR:[EN]l] [CYR:agent[EN]] and [CYR:[TRANSLATED]]and[CYR:[TRANSLATED]]andI
    when: [CYR:[TRANSLATED]]and[EN] withandwith[CYR:[TRANSLATED]go] [CYR:pro[TRANSLATED]]
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] PromptSection with role=system
    implementation: |
                    pub fn build_system_prompt(role: []const u8, constraints: []const u8) PromptSection {
                        _ = role;
                        _ = constraints;
                        return PromptSection{};
                    }
            
            
      
      

  - name: build_context_section
    given: SemanticContext from b2t_llm_assist
    when: [CYR:[TRANSLATED]]and[EN]in[EN]and[EN] [CYR:[TRANSLATED]]with[EN]
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] PromptSection with role=context
    implementation: |
                    pub fn build_context_section(context: anytype) PromptSection {
                        _ = context;
                        return PromptSection{};
                    }
            
            
      
      

  - name: build_icl_examples
    given: List<SimilarCode> and max_examples
    when: [CYR:[TRANSLATED]]and[EN]in[EN]and[EN] example[EN]in for ICL
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] PromptSection with role=example
    implementation: |
                    pub fn build_icl_examples(examples: anytype, max_examples: usize) PromptSection {
                        _ = examples;
                        _ = max_examples;
                        return PromptSection{};
                    }
            
            
      
      

  - name: build_query
    given: [CYR:[TRANSLATED]]or[EN]in[CYR:[EN]ny] code and task
    when: [CYR:[TRANSLATED]]and[EN]in[EN]and[EN] query[EN]
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] PromptSection with role=query
    implementation: |
                    pub fn build_query(code: []const u8, task: []const u8) PromptSection {
                        _ = code;
                        _ = task;
                        return PromptSection{};
                    }
            
            
      
      

  - name: assemble_prompt
    given: List<PromptSection> and PromptConfig
    when: [CYR:[TRANSLATED]] [EN]andon[CYR:lnogo] [CYR:pro[TRANSLATED]] with [CYR:[TRANSLATED]] [EN]and[EN]and[EN]in
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] String [CYR:pro[TRANSLATED]]
    implementation: |
                    pub fn assemble_prompt(sections: []const PromptSection, config: PromptConfig) []const u8 {
                        _ = sections;
                        _ = config;
                        return "";
                    }
            
            
      
      

  - name: get_distortion_template
    given: DistortionType
    when: [CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]on for [CYR:[TRANSLATED]go] andwith[CYR:[TRANSLATED]]andI
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] DistortionTemplate
    implementation: |
                    pub fn get_distortion_template(dist_type: anytype) DistortionTemplate {
                        _ = dist_type;
                        return DistortionTemplate{};
                    }
            
            
      
      

  - name: format_detection_prompt
    given: [CYR:Code] and DistortionTemplate
    when: [CYR:[TRANSLATED]]and[EN] [CYR:pro[TRANSLATED]] for [CYR:[TRANSLATED]]andand andwith[CYR:[TRANSLATED]]and[EN]
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] String [CYR:pro[TRANSLATED]]
    implementation: |
                    pub fn format_detection_prompt(code: []const u8, template: anytype) []const u8 {
                        _ = code;
                        _ = template;
                        return "";
                    }
            
            
      
      

  - name: format_correction_prompt
    given: [CYR:Code], andwith[CYR:[TRANSLATED]]andI and DistortionTemplate
    when: [CYR:[TRANSLATED]]and[EN] [CYR:pro[TRANSLATED]] for andwith[CYR:law]in[CYR:[TRANSLATED]]andI
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] String [CYR:pro[TRANSLATED]]
    implementation: |
                    pub fn format_correction_prompt(code: []const u8, distortions: anytype, template: anytype) []const u8 {
                        _ = code;
                        _ = distortions;
                        _ = template;
                        return "";
                    }
            
            
      
      

  - name: format_validation_prompt
    given: [EN]and[EN]andon[EN], fix and DistortionTemplate
    when: [CYR:[TRANSLATED]]and[EN] [CYR:pro[TRANSLATED]] for in[EN]and[CYR:[TRANSLATED]]andand
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] String [CYR:pro[TRANSLATED]]
    implementation: |
                    pub fn format_validation_prompt(original: []const u8, corrected: []const u8, template: anytype) []const u8 {
                        _ = original;
                        _ = corrected;
                        _ = template;
                        return "";
                    }
            
            
      
      

  - name: create_cot_prompt
    given: [CYR:[TRANSLATED]] and ChainOfThought
    when: [CYR:[TRANSLATED]]and[EN] [CYR:pro[TRANSLATED]] with [EN]step[EN]iny[EN] [EN]withwith[CYR:[TRANSLATED]]and[EN]
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] String [CYR:pro[TRANSLATED]]
    implementation: |
                    pub fn create_cot_prompt(task: []const u8, cot: anytype) []const u8 {
                        _ = task;
                        _ = cot;
                        return "";
                    }
            
            
      
      

  - name: parse_cot_response
    given: [EN]in[EN] LLM with [EN]withwith[CYR:[TRANSLATED]]andI[EN]and
    when: [EN]in[CYR:[EN]chen]and[EN] step[EN]in and [EN]andon[CYR:lnogo] response[EN]
    then: [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]acts] with[CYR:[TRANSLATED]]and[EN]in[CYR:[EN]ny] result
    implementation: |
                    pub fn parse_cot_response(response: []const u8) CoTParseResult {
                        _ = response;
                        return CoTParseResult{};
                    }
            
            
      
      

