name: b2t_prompts
version: "1.0.0"
language: zig

types:
  PromptRole:
  PromptSection:
    fields:
      role: PromptRole
      content: String
      priority: Int
      required: Bool
      max_tokens: Option<Int>
  PromptConfig:
    fields:
      max_total_tokens: Int
      temperature: Float
      top_p: Float
      presence_penalty: Float
      frequency_penalty: Float
  DistortionTemplate:
    fields:
      distortion_type: String
      detection_prompt: String
      correction_prompt: String
      validation_prompt: String
      examples: List<DistortionExample>
  DistortionExample:
    fields:
      distorted_code: String
      corrected_code: String
      explanation: String
      distortion_markers: List<String>
  ReasoningStep:
    fields:
      step_number: Int
      description: String
      expected_output: String
  ChainOfThought:
    fields:
      task: String
      steps: List<ReasoningStep>
      final_instruction: String
  CoTParseResult:
    fields:
      steps: List<ReasoningStep>
      final_answer: String
      reasoning: String

behaviors:
  - name: build_system_prompt
    given: [CYR:Роль] [CYR:агента] and [CYR:огран]and[CYR:чен]andя
    when: [CYR:Создан]andе withandwith[CYR:темного] [CYR:промпта]
    then: [CYR:Воз]in[CYR:ращает] PromptSection with role=system
    implementation: |
                    pub fn build_system_prompt(role: []const u8, constraints: []const u8) PromptSection {
                        _ = role;
                        _ = constraints;
                        return PromptSection{};
                    }
            
            
      
      

  - name: build_context_section
    given: SemanticContext from b2t_llm_assist
    when: [CYR:Формат]andроinанandе [CYR:контек]withта
    then: [CYR:Воз]in[CYR:ращает] PromptSection with role=context
    implementation: |
                    pub fn build_context_section(context: anytype) PromptSection {
                        _ = context;
                        return PromptSection{};
                    }
            
            
      
      

  - name: build_icl_examples
    given: List<SimilarCode> and max_examples
    when: [CYR:Формат]andроinанandе exampleоin for ICL
    then: [CYR:Воз]in[CYR:ращает] PromptSection with role=example
    implementation: |
                    pub fn build_icl_examples(examples: anytype, max_examples: usize) PromptSection {
                        _ = examples;
                        _ = max_examples;
                        return PromptSection{};
                    }
            
            
      
      

  - name: build_query
    given: [CYR:Декомп]orроin[CYR:анный] code and task
    when: [CYR:Форм]andроinанandе queryа
    then: [CYR:Воз]in[CYR:ращает] PromptSection with role=query
    implementation: |
                    pub fn build_query(code: []const u8, task: []const u8) PromptSection {
                        _ = code;
                        _ = task;
                        return PromptSection{};
                    }
            
            
      
      

  - name: assemble_prompt
    given: List<PromptSection> and PromptConfig
    when: [CYR:Сборка] фandon[CYR:льного] [CYR:промпта] with [CYR:учётом] лandмandтоin
    then: [CYR:Воз]in[CYR:ращает] String [CYR:промпт]
    implementation: |
                    pub fn assemble_prompt(sections: []const PromptSection, config: PromptConfig) []const u8 {
                        _ = sections;
                        _ = config;
                        return "";
                    }
            
            
      
      

  - name: get_distortion_template
    given: DistortionType
    when: [CYR:Получен]andе [CYR:шабло]on for [CYR:конкретного] andwith[CYR:кажен]andя
    then: [CYR:Воз]in[CYR:ращает] DistortionTemplate
    implementation: |
                    pub fn get_distortion_template(dist_type: anytype) DistortionTemplate {
                        _ = dist_type;
                        return DistortionTemplate{};
                    }
            
            
      
      

  - name: format_detection_prompt
    given: [CYR:Код] and DistortionTemplate
    when: [CYR:Создан]andе [CYR:промпта] for [CYR:детекц]andand andwith[CYR:кажен]andй
    then: [CYR:Воз]in[CYR:ращает] String [CYR:промпт]
    implementation: |
                    pub fn format_detection_prompt(code: []const u8, template: anytype) []const u8 {
                        _ = code;
                        _ = template;
                        return "";
                    }
            
            
      
      

  - name: format_correction_prompt
    given: [CYR:Код], andwith[CYR:кажен]andя and DistortionTemplate
    when: [CYR:Создан]andе [CYR:промпта] for andwith[CYR:пра]in[CYR:лен]andя
    then: [CYR:Воз]in[CYR:ращает] String [CYR:промпт]
    implementation: |
                    pub fn format_correction_prompt(code: []const u8, distortions: anytype, template: anytype) []const u8 {
                        _ = code;
                        _ = distortions;
                        _ = template;
                        return "";
                    }
            
            
      
      

  - name: format_validation_prompt
    given: Орandгandonл, fix and DistortionTemplate
    when: [CYR:Создан]andе [CYR:промпта] for inалand[CYR:дац]andand
    then: [CYR:Воз]in[CYR:ращает] String [CYR:промпт]
    implementation: |
                    pub fn format_validation_prompt(original: []const u8, corrected: []const u8, template: anytype) []const u8 {
                        _ = original;
                        _ = corrected;
                        _ = template;
                        return "";
                    }
            
            
      
      

  - name: create_cot_prompt
    given: [CYR:Задача] and ChainOfThought
    when: [CYR:Создан]andе [CYR:промпта] with поstepоinым раwithwith[CYR:ужден]andем
    then: [CYR:Воз]in[CYR:ращает] String [CYR:промпт]
    implementation: |
                    pub fn create_cot_prompt(task: []const u8, cot: anytype) []const u8 {
                        _ = task;
                        _ = cot;
                        return "";
                    }
            
            
      
      

  - name: parse_cot_response
    given: Отinет LLM with раwithwith[CYR:ужден]andямand
    when: Изin[CYR:лечен]andе stepоin and фandon[CYR:льного] responseа
    then: [CYR:Воз]in[CYR:ращает] with[CYR:труктур]andроin[CYR:анный] result
    implementation: |
                    pub fn parse_cot_response(response: []const u8) CoTParseResult {
                        _ = response;
                        return CoTParseResult{};
                    }
            
            
      
      

