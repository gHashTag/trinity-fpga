name: hdc_golden_chain_quark_gluon_v1_2
version: "1.2.0"
language: zig
module: golden_chain_quark_gluon

description: |
  Quark-Gluon Ultra-Granular Provenance for Golden Chain v1.2.
  Adds 32+ quark sub-step records per query (3-6 per pipeline node)
  with gluon entanglement creating a DAG overlay on the linear hash chain.
  v1.1 provenance chain remains intact (backward compatible).
  Combined: 8 provenance + 32 quarks = 40 immutable records per query.
  phi^2 + 1/phi^2 = 3 = TRINITY

constants:
  QUARK_HASH_SIZE: 32
  MAX_QUARK_RECORDS: 48
  MAX_ENTANGLE_REFS: 2
  QUARK_CONTENT_DIGEST_LEN: 48

types:
  QuarkType:
    description: "16 sub-step types covering all pipeline micro-operations"
    variants:
      - input_capture      # Capture raw user input
      - goal_classify      # Classify intent type
      - task_decompose     # Break into subtasks
      - dependency_check   # Check subtask dependencies
      - schedule_plan      # Plan execution order
      - route_decision     # Choose execution backend
      - api_call           # Invoke LLM/tool
      - tvc_cross_check    # TVC corpus verification
      - vsa_bind           # VSA bind/unbind operation
      - quality_gate       # Quality threshold check
      - adapt_decision     # Adaptation decision
      - merge_result       # Merge subtask outputs
      - format_output      # Format final response
      - chain_integrity    # Full chain integrity check
      - hash_verify        # SHA256 hash verification sub-step
      - gluon_verify       # Gluon entanglement verification sub-step

  QuarkRecord:
    description: "Single quark in the ultra-granular provenance layer"
    fields:
      quark_index: Int
      quark_type: QuarkType
      parent_node: ChainNode
      content_digest: List<Int>
      digest_len: Int
      confidence: Float
      timestamp_us: Int
      prev_quark_hash: List<Int>
      current_quark_hash: List<Int>
      entangled_indices: List<Int>
      entangle_count: Int

  ChainMessageType_v1_2:
    description: "Extended message types (v1.2 additions)"
    variants:
      - QuarkStep          # Quark sub-step record
      - GluonEntangle      # Gluon entanglement notification

behaviors:
  - name: computeQuarkHash
    given: Previous quark hash, quark type, parent node, content, confidence, timestamp, entangled indices
    when: A quark sub-step is recorded
    then: |
      SHA256(prev_quark_hash ++ quark_type_label ++ node_label ++ content ++ confidence_bytes ++ timestamp_bytes ++ entangled_indices[0..count])
      Entanglement indices included in hash make DAG topology tamper-evident.

  - name: recordQuark
    given: Quark type, parent node, content, confidence, two optional entanglement indices
    when: During node execution, for each sub-step
    then: |
      1. Get prev_hash from previous quark (or all-zeros for genesis)
      2. Build entanglement array (validate backward references only)
      3. Compute SHA256 quark hash (includes entanglement in hash)
      4. Store QuarkRecord
      5. Emit QuarkStep chat message: "Q[hex8] NODE.QUARK_TYPE | conf% | ent:N"
      6. If gluon_verify with entanglements, also emit GluonEntangle message

  - name: verifyQuarkChain
    given: Complete quark chain after DELIVER node
    when: Final integrity check
    then: |
      Phase A (Linear):
        1. Check genesis record has all-zero prev_quark_hash
        2. For each quark: recompute hash and verify it matches stored hash
        3. For each quark[i>0]: verify prev_quark_hash == quarks[i-1].current_quark_hash
      Phase B (DAG):
        1. entangle_count in [0, MAX_ENTANGLE_REFS]
        2. All entangled_indices point backward (< current index)
        3. Genesis quark has entangle_count == 0
        4. gluon_verify quarks (except genesis) must have entangle_count > 0

  - name: formatQuarkLine
    given: A QuarkRecord
    when: Rendering to canvas chat
    then: |
      Format: "Q[<8-char-hex-prefix>] <NODE_LABEL>.<QUARK_TYPE_LABEL> | <conf>% | ent:<count>"
      quark_step color: light steel blue (#9999BB)
      gluon_entangle color: magenta (#CC44FF)

test_cases:
  - name: quark_type_16_variants
    given: "All 16 QuarkType values"
    expected: "All accessible and distinct"

  - name: quark_type_labels_unique
    given: "All QuarkType labels"
    expected: "No duplicates across 16"

  - name: quark_hash_deterministic
    given: "Same inputs twice"
    expected: "Identical hashes"

  - name: quark_hash_varies_with_type
    given: "Same content, different quark_type"
    expected: "Different hashes"

  - name: quark_hash_varies_with_entanglement
    given: "Same content, different entangled_indices"
    expected: "Different hashes"

  - name: quark_format_line
    given: "QuarkRecord with known values"
    expected: "Contains NODE, QUARK_TYPE, ent:N"

  - name: chain_msg_type_quark_gluon
    given: "QuarkStep and GluonEntangle enum values"
    expected: "Distinct from all existing types"

  - name: quark_type_verification_classification
    given: "14 work + 2 verification quarks"
    expected: "isWorkQuark and isVerificationQuark correct for all"
