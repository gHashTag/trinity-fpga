# Browser Extension Popup UI Specification
# Generates popup interface for [CYR:[EN]A[EN]] [CYR:[TRANSLATED]A]
# φ² + 1/φ² = 3 = TRINITY

name: firebird_popup
version: "1.0.0"
language: zig
module: popup_ui

description: |
  Popup UI for browser extension.
  [CYR:[TRANSLATED]acts] evasion [CYR:[TRANSLATED]]and[EN]and, control [CYR:pro[EN]]and[CYR:[EN]I[EN]]and, $TRI rewards.

# ═══════════════════════════════════════════════════════════════════════════════
# UI [CYR:[TRANSLATED]]
# ═══════════════════════════════════════════════════════════════════════════════

components:
  Header:
    description: "[CYR:[EN]go[EN]]in[EN] with [CYR:[EN]go]type[EN] and with[CYR:[TRANSLATED]]with[EN]"
    elements:
      - logo: "[CYR:[EN]A[EN]] [CYR:[TRANSLATED]A] 🔥"
      - status_indicator: NodeStatus
      - version: "v1.0.0"

  EvasionPanel:
    description: "[EN]notl [CYR:[EN]law]in[CYR:[TRANSLATED]]andI evasion"
    elements:
      - toggle_enabled: Bool
      - similarity_display: Float
      - similarity_target: Float
      - progress_bar: Float
      - detection_risk: String

  ProfileSelector:
    description: "[CYR:Vy[TRANSLATED]] and control [CYR:pro[EN]]and[CYR:[EN]I[EN]]and"
    elements:
      - current_profile: String
      - profile_list: List<ProfileItem>
      - generate_button: Button
      - delete_button: Button

  NavigationPanel:
    description: "[EN]and[CYR:[TRANSLATED]l]onI oninand[CYR:[TRANSLATED]]andI"
    elements:
      - steps_completed: Int
      - current_similarity: Float
      - navigate_button: Button
      - reset_button: Button

  DePINPanel:
    description: "DePIN and $TRI rewards"
    elements:
      - wallet_address: String
      - pending_tri: Float
      - total_earned: Float
      - claim_button: Button
      - stake_button: Button

  FingerprintDetails:
    description: "[CYR:[TRANSLATED]]and [CYR:[TRANSLATED]go] fingerprint"
    elements:
      - canvas_hash: String
      - webgl_hash: String
      - audio_hash: String
      - screen_resolution: String
      - timezone: String
      - language: String

# ═══════════════════════════════════════════════════════════════════════════════
# LAYOUT
# ═══════════════════════════════════════════════════════════════════════════════

layout:
  width: 400
  height: 600
  sections:
    - Header (fixed top)
    - EvasionPanel
    - ProfileSelector
    - NavigationPanel (collapsible)
    - DePINPanel
    - FingerprintDetails (collapsible)

# ═══════════════════════════════════════════════════════════════════════════════
# [CYR:[TRANSLATED]] (for [EN]not[CYR:[TRANSLATED]]andand CSS)
# ═══════════════════════════════════════════════════════════════════════════════

styles:
  colors:
    primary: "#FF6B35"      # [EN]not[CYR:[EN]ny] [CYR:[TRANSLATED]]iny[EN] ([CYR:[TRANSLATED]]-[EN]and[EN])
    secondary: "#1A1A2E"    # [CYR:[TRANSLATED]ny] [CYR:foundation]
    accent: "#FFD700"       # [CYR:[TRANSLATED]] ($TRI)
    success: "#00FF88"      # [CYR:[TRANSLATED]ny] (evasion OK)
    warning: "#FFB800"      # [CYR:[TRANSLATED]y[EN]] (risk)
    danger: "#FF4444"       # [CYR:[TRANSLATED]]with[CYR:ny] (detected)
