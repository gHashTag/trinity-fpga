    sm: 8
    md: 16
    lg: 24
    xl: 32

# ═══════════════════════════════════════════════════════════════════════════════
# [CYR:[TRANSLATED]]
# ═══════════════════════════════════════════════════════════════════════════════

events:
  on_popup_open:
    - load_config
    - load_current_profile
    - update_metrics
    - sync_depin_status

  on_toggle_evasion:
    - save_config
    - notify_content_script
    - record_depin_operation

  on_generate_profile:
    - call_wasm_create_profile
    - save_profile
    - update_ui

  on_navigate_step:
    - call_wasm_navigate_step
    - update_similarity
    - record_depin_reward

  on_claim_rewards:
    - call_wasm_claim_rewards
    - update_balance
    - show_notification

