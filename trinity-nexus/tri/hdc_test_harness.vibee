name: hdc_test_harness
version: "1.0.0"
language: zig
module: hdc_test_harness

description: |
  HDC Test Harness — Level 10A.18: Concrete Test Runner for Integration Tests.
  Defines the exact test file structure that exercises all 5 integration
  criteria from v2.26 using the wiring from v2.27.

  === WHY THIS SPEC EXISTS ===
  v2.26 defined 5 integration tests. v2.27 defined the API wiring.
  Neither produced executable tests. This spec defines the TEST FILE
  that should exist at src/tests/hdc_integration_test.zig.

  === THE 5 TESTS (Concrete Zig test blocks) ===

  TEST 1: FORWARD PASS EXECUTES
  ```zig
  test "forward pass produces valid output" {
      const alloc = std.testing.allocator;
      var codebook = sdk.Codebook.init(alloc, 256);
      defer codebook.deinit();

      // Encode "To be or "
      const text = "To be or";
      var hvs: [8]sdk.Hypervector = undefined;
      for (text, 0..) |c, i| {
          hvs[i] = (try codebook.encode(&[_]u8{c})).clone();
      }

      // Position + single-head attention + FFN + decode
      var roles = initRoles(256, 42);
      var output = forwardPass(&hvs, &roles, &codebook);
      const predicted = codebook.decode(&output);

      try std.testing.expect(predicted != null);
      try std.testing.expect(output.density() > 0.0);
  }
  ```

  TEST 2: TRAINING REDUCES LOSS
  ```zig
  test "training reduces loss over epochs" {
      // ... init codebook, roles, samples ...
      const loss_before = evaluateLoss(&test_samples, &roles, &codebook);

      // Train 5 epochs
      for (0..5) |_| {
          for (train_samples) |sample| {
              var output = forwardPass(&sample.context, &roles, &codebook);
              var target_hv = (try codebook.encode(sample.target)).clone();
              var error = computeError(&output, &target_hv);
              var sparse = sparsifyError(&error, 0.2);
              updateRoles(&roles, &sparse);
          }
      }

      const loss_after = evaluateLoss(&test_samples, &roles, &codebook);
      try std.testing.expect(loss_after < loss_before);
  }
  ```

  TEST 3: PACKED TRIT ROUND-TRIP
  ```zig
  test "pack and unpack trits is lossless" {
      var hv = sdk.Hypervector.random(256, 12345);
      var packed = packTrits(&hv);       // 52 bytes
      var unpacked = unpackTrits(&packed); // 256 trits

      // Every trit must match
      for (0..256) |i| {
          try std.testing.expectEqual(hv.get(i), unpacked.get(i));
      }
      // Cosine similarity must be exactly 1.0
      try std.testing.expectApproxEqAbs(hv.similarity(&unpacked), 1.0, 1e-10);
  }
  ```

  TEST 4: ROLE ORTHOGONALITY
  ```zig
  test "role vectors remain approximately orthogonal" {
      var roles = initRoles(256, 42);
      // Check all 55 pairs of 11 roles
      var max_sim: f64 = 0;
      for (0..11) |i| {
          for (i+1..11) |j| {
              const sim = @abs(roles.all[i].similarity(&roles.all[j]));
              if (sim > max_sim) max_sim = sim;
          }
      }
      // Random 256D vectors: expected |cos| < 0.15
      try std.testing.expect(max_sim < 0.3);
  }
  ```

  TEST 5: SWARM MAJORITY VOTE
  ```zig
  test "majority vote rejects minority Byzantine" {
      const alloc = std.testing.allocator;
      // 8 honest random vectors, 2 adversarial
      var honest: [8]sdk.Hypervector = undefined;
      for (0..8) |i| { honest[i] = sdk.Hypervector.random(256, i + 1000); }

      var adversarial: [2]sdk.Hypervector = undefined;
      adversarial[0] = sdk.Hypervector.random(256, 99999);
      adversarial[1] = sdk.Hypervector.random(256, 99998);

      // Bundle honest only
      var honest_agg = honest[0];
      for (1..8) |i| { honest_agg = honest_agg.bundle(&honest[i]); }

      // Bundle all 10 (8 honest + 2 adversarial)
      var all_agg = honest[0];
      for (1..8) |i| { all_agg = all_agg.bundle(&honest[i]); }
      all_agg = all_agg.bundle(&adversarial[0]);
      all_agg = all_agg.bundle(&adversarial[1]);

      // Majority vote should preserve honest aggregate
      const similarity = honest_agg.similarity(&all_agg);
      try std.testing.expect(similarity > 0.5);
  }
  ```

  === HELPER FUNCTIONS NEEDED ===

  The test file needs these helper functions (each ~10-20 lines):

  1. initRoles(dim, seed) -> RoleSet
     Create 11 random Hypervectors (Q/K/V per head * 3 + FF1 + FF2)

  2. forwardPass(context_hvs, roles, codebook) -> Hypervector
     The minimal forward pass from hdc_minimal_demo

  3. evaluateLoss(samples, roles, codebook) -> f64
     Forward each sample, compute avg(1 - similarity(output, target))

  4. computeError(output, target) -> Hypervector
     target.bundle(&output.negate())

  5. sparsifyError(error, lr) -> Hypervector
     Zero out (1-lr) fraction of trits

  6. updateRoles(roles, sparse_error) -> void
     role = role.bundle(&sparse_error) for each

  7. packTrits(hv) -> [52]u8
     Base-3 encoding: 5 trits per byte

  8. unpackTrits(packed) -> Hypervector
     Reverse of packTrits

  === TOTAL: ~200 lines of test code ===
  5 tests + 8 helpers = ~200 lines of real, executable Zig code.
  This is the minimal test harness that validates the entire Level 10A stack.

  Trinity Identity: phi^2 + 1/phi^2 = 3

types:
  RoleSet:
    fields:
      q_roles: List<String>
      k_roles: List<String>
      v_roles: List<String>
      ff1_role: String
      ff2_role: String
      all: List<String>

  TestResult:
    fields:
      test_name: String
      passed: Bool
      message: String
      elapsed_ns: usize

  HarnessReport:
    fields:
      tests_run: usize
      tests_passed: usize
      tests_failed: usize
      results: List<TestResult>
      all_passed: Bool
      total_time_ms: Float

behaviors:
  - name: initRoles
    given: Dimension and seed
    when: |
      For h in 0..3:
        q_roles[h] = Hypervector.random(dim, seed + h*3 + 0)
        k_roles[h] = Hypervector.random(dim, seed + h*3 + 1)
        v_roles[h] = Hypervector.random(dim, seed + h*3 + 2)
      ff1 = Hypervector.random(dim, seed + 9)
      ff2 = Hypervector.random(dim, seed + 10)
      all = concatenate(q_roles, k_roles, v_roles, [ff1, ff2])
    then: RoleSet with 11 vectors

  - name: forwardPass
    given: 8 context Hypervectors, RoleSet, Codebook
    when: |
      Position: pos[i] = ctx[i].permute(i)
      Attention (1 head for minimal): bind Q/K/V, scores, bundle top-2
      FFN: bind(ff1), bundle(residual)
    then: Output Hypervector

  - name: evaluateLoss
    given: List of (context, target) samples
    when: Forward each, loss = 1 - similarity(output, target_hv), average
    then: Average loss (float)

  - name: computeError
    given: Output and target Hypervectors
    when: error = target.bundle(&output.negate())
    then: Error Hypervector

  - name: sparsifyError
    given: Error Hypervector and learning rate
    when: Zero out (1-lr) fraction of trits randomly
    then: Sparse error Hypervector

  - name: updateRoles
    given: RoleSet and sparse error
    when: Each role = role.bundle(&sparse_error)
    then: All roles updated

  - name: packTrits
    given: Hypervector (256 trits)
    when: |
      For groups of 5: byte = (t0+1) + (t1+1)*3 + (t2+1)*9 + (t3+1)*27 + (t4+1)*81
    then: 52-byte packed array

  - name: unpackTrits
    given: 52-byte packed array
    when: |
      For each byte: t0 = (byte%3)-1, t1 = ((byte/3)%3)-1, ...
    then: Hypervector with 256 trits

  - name: runHarness
    given: All 5 test functions
    when: Run each test, collect pass/fail, compute summary
    then: HarnessReport with overall verdict

test_cases:
  - name: forward_test_passes
    description: Forward pass produces non-null decoded output
    expected: predicted != null and density > 0

  - name: training_reduces_loss
    description: 5 epochs of training reduce eval loss
    expected: loss_after < loss_before

  - name: pack_unpack_lossless
    description: 256 trits survive pack/unpack cycle
    expected: all 256 trits identical after round-trip

  - name: roles_orthogonal
    description: No role pair has |cosine| > 0.3
    expected: max_similarity < 0.3

  - name: bft_preserves_honest
    description: 2/10 adversaries don't corrupt majority vote
    expected: honest_vs_all similarity > 0.5
