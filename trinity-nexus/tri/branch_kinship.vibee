name: branch_kinship
version: "1.0.0"
language: zig
module: branch_kinship
description: "Level 11.18 â€” Branch Kinship (Cross-Relation Composition). Extends CLUTRR from linear parent chains to uncle, cousin, nephew, grandparent queries using per-LEVEL indexed memories. 3 families Ă— 6 people = 18 people. parent_l0 (childrenâ†’parents), parent_l1 (parentsâ†’grandparent), child_l0 (parentsâ†’children), child_l1 (grandparentâ†’parents), sibling_mems (bidirectional). Result: 30/30 (100%)."

constants:
  DIM: 1024
  FAMILIES: 3
  PEOPLE_PER_FAMILY: 6

types:
  FamilyTree:
    fields:
      grandparent: Int
      parent_a: Int
      parent_b: Int
      child_a1: Int
      child_a2: Int
      child_b1: Int
      description: "A 3-generation family with grandparent, two parents, and three children."
  KinshipQuery:
    fields:
      relation: String
      subject: Int
      expected: Int
      description: "A kinship query: given subject, find expected via relation (uncle, cousin, nephew, grandparent)."

behaviors:
  - name: perLevelIndexedMemories
    given: 3 families each with 6 people across 3 generations. Flat per-family memories cause cross-generation interference (child_of(parent_b) returns grandparent instead of child_b1).
    when: Split into per-level memories â€” parent_l0 (3 pairs, childrenâ†’parents), parent_l1 (2 pairs, parentsâ†’grandparent), child_l0 (3 pairs, parentsâ†’children), child_l1 (2 pairs, grandparentâ†’parents), sibling_mems (4 bidirectional pairs)
    then: Per-level indexing eliminates cross-generation interference. Each memory has only 2-3 pairs, well within VSA capacity. All queries use correct level for each hop.

  - name: uncleQuery
    given: Uncle = sibling of parent. Subject is a child.
    when: parent_l0(subject) â†’ parent, then sibling_mems(parent) â†’ uncle
    then: 9/9 uncle queries correct (3 families Ă— 3 children)

  - name: cousinQuery
    given: Cousin = child of uncle. Subject is a child.
    when: parent_l0(subject) â†’ parent, sibling_mems(parent) â†’ uncle, child_l0(uncle) â†’ cousin
    then: 6/6 cousin queries correct (3 families Ă— 2 children with cousins)

  - name: nephewQuery
    given: Nephew = child of sibling. Subject is a parent.
    when: sibling_mems(subject) â†’ sibling, child_l0(sibling) â†’ nephew
    then: 6/6 nephew queries correct (3 families Ă— 2 parents)

  - name: grandparentQuery
    given: Grandparent = parent of parent. Subject is a child.
    when: parent_l0(subject) â†’ parent, parent_l1(parent) â†’ grandparent. Uses L0 then L1 for correct level progression.
    then: 9/9 grandparent queries correct (3 families Ă— 3 children)

test_cases:
  - name: test_uncle_9_9
    input: "Query uncle for all 9 children across 3 families"
    expected: "9/9 (100%)"

  - name: test_cousin_6_6
    input: "Query cousin for 6 children with cousins"
    expected: "6/6 (100%)"

  - name: test_nephew_6_6
    input: "Query nephew for 6 parents across 3 families"
    expected: "6/6 (100%)"

  - name: test_grandparent_9_9
    input: "Query grandparent for all 9 children"
    expected: "9/9 (100%)"

  - name: test_combined_30_30
    input: "Combined branch kinship accuracy"
    expected: "30/30 (100%)"

  - name: test_per_level_vs_flat
    input: "Compare per-level indexed memories vs flat per-family memories"
    expected: "Per-level: 30/30 (100%), Flat: ~16/30 (~53%) due to cross-generation interference"
