name: trinity_canvas_v2_1
version: "2.1.0"
language: zig
module: photon_trinity_canvas

# Trinity Canvas v2.1 — Mirror of Three Worlds
# Live dashboard: 3 columns (Razum/Materiya/Dukh) + scrolling log strip.
# Shift+9 = Mirror mode. All data live from WaveState + HybridConfig + std.fs.
#
# Technology Tree:
#   v2.0 (Live data in each mode)
#   -> v2.1 (Mirror of Three Worlds dashboard) <- CURRENT
#   -> v2.2 (Interactive mirror with keyboard input)
#
# phi^2 + 1/phi^2 = 3 = TRINITY | KOSCHEI IS ENERGY IMMORTAL

types:
  MirrorColumn:
    description: "One of three vertical columns, one per realm"
    fields:
      realm: RealmId
      title: String
      color_r: u8
      color_g: u8
      color_b: u8

  LiveLogEntry:
    description: "Single log entry with timestamp, source, and text"
    fields:
      text: "[128]u8"
      text_len: usize
      source_hue: f32
      timestamp: i64

behaviors:
  - name: add_mirror_mode_to_enum
    given: "WaveMode enum"
    when: "v2.1 upgrade"
    then: >
      Add .mirror variant to WaveMode enum.
      getLabel returns "MIRROR".
      getHue returns 45.0 (gold, trinity color).
      Shift+9 maps to .mirror, Shift+0 maps to .idle.

  - name: add_live_log_buffer
    given: "Global state"
    when: "v2.1 init"
    then: >
      Add g_live_log[16] ring buffer of LiveLogEntry.
      addLiveLog(text, source_hue) appends entry with timestamp.
      Called from chat response handler after addChatLogMessage.

  - name: render_mirror_razum
    given: "g_wave_mode == .mirror, left column"
    when: "Canvas render loop"
    then: >
      RAZUM column (gold, x=0..sw/3):
      - Title "RAZUM" with gold realm color
      - Subtitle: "Mind / AI / Chat"
      - Last chat response (truncated)
      - Source: @tagName(ws.routing)
      - Confidence: ws.confidence as percentage
      - Total queries: g_hybrid_engine.total_queries
      - Groq health: groq_health.getSuccessRate()
      - Claude health: claude_health.getSuccessRate()
      Realm border glow on left edge.

  - name: render_mirror_materiya
    given: "g_wave_mode == .mirror, center column"
    when: "Canvas render loop"
    then: >
      MATERIYA column (cyan, x=sw/3..2*sw/3):
      - Title "MATERIYA" with cyan realm color
      - Subtitle: "Matter / System / Files"
      - CWD file count from g_finder_count
      - Engine: "IglaHybridChat v2.4" or "FluentChat"
      - Tools: enabled/disabled from config
      - Memory entries: ws.memory_load as percentage
      - TVC corpus: max entries count
      - FPS: live GetFPS()
      Realm border glow on edges.

  - name: render_mirror_dukh
    given: "g_wave_mode == .mirror, right column"
    when: "Canvas render loop"
    then: >
      DUKH column (purple, x=2*sw/3..sw):
      - Title "DUKH" with purple realm color
      - Subtitle: "Spirit / Knowledge / Reflection"
      - Routing decision: @tagName(ws.routing)
      - Source hue: ws.source_hue (color bar)
      - Reflection: last reflection status name
      - Learning: ws.is_learning (green dot or gray)
      - Provider health: ws.provider_health_avg as bar
      - Similarity: ws.similarity as percentage
      Self-reflection pulsing ring.

  - name: render_mirror_log_strip
    given: "g_wave_mode == .mirror, bottom 20% of screen"
    when: "Canvas render loop"
    then: >
      Scrolling log strip showing last N log entries.
      Each entry: [HH:MM:SS] [source_icon colored by hue] text
      Source icons: different colors per routing decision.
      Auto-scroll to latest. Dark background bar.

  - name: render_mirror_trinity_ring
    given: "g_wave_mode == .mirror, center intersection"
    when: "Canvas render loop"
    then: >
      At the vertical center where 3 columns meet:
      Three overlapping circles (gold/cyan/purple) pulsing,
      representing the Trinity identity phi^2 + 1/phi^2 = 3.
      Size modulated by ws.confidence.

# Architecture:
#
# ┌─────────────┬─────────────┬─────────────┐
# │  RAZUM      │ MATERIYA    │  DUKH       │
# │  (Gold)     │  (Cyan)     │  (Purple)   │
# │  Chat/AI    │  System     │  Knowledge  │
# │             │             │             │
# │  response   │  files      │  routing    │
# │  source     │  engine     │  reflection │
# │  confidence │  tools      │  learning   │
# │  queries    │  FPS        │  health     │
# │  health     │  memory     │  similarity │
# ├─────────────┴─────────────┴─────────────┤
# │  LIVE LOG: [ts] [src] message...        │
# └─────────────────────────────────────────┘
#
# Shift+9 = Mirror | ESC = idle
