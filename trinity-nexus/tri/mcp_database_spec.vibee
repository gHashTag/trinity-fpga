name: mcp_database
version: "1.0.0"
language: zig
module: mcp_database
description: Database operations MCP tools

types:
  DatabaseConfig:
    fields:
      driver: String
      host: String
      database: String

  QueryResult:
    fields:
      rows: List<String>
      row_count: Int

behaviors:
  - name: query_operations
  - name: execute_query
  - name: config
  - name: sql
  - name: execute_query
