name: trinity_canvas_v2_4
version: "2.4.0"
language: typescript
module: trinity_canvas

description: |
  Trinity Canvas v2.4 — Mirror of Three Worlds: Interactive Dashboard
  Three columns with real functionality: RAZUM (chat), MATERIYA (finder), DUKH (tools).
  Real-time polling every 2 seconds from /health endpoint.
  Inline chat, file search, tool execution — no empty design.
  phi^2 + 1/phi^2 = 3 = TRINITY | KOSCHEI IS IMMORTAL

# =============================================================================
# TRINITY CANVAS v2.4 — MIRROR OF THREE WORLDS: INTERACTIVE
# Upgrade from passive dashboard to real interactive functionality.
# RAZUM: chat input + response. MATERIYA: file search + open. DUKH: tool exec.
# Live logs + query path + provider health — all functional.
# =============================================================================

types:
  CanvasLayer:
    description: "9 canvas layers as wave states"
    values:
      - petals
      - chat
      - editor
      - finder
      - vision
      - voice
      - tools     # display: [CYR:[TRANSLATED]A[EN]] (Mirror of Three Worlds)
      - settings
      - viz

  MirrorRazum:
    description: "RAZUM (Mind) — VSA engine intelligence metrics"
    fields:
      symbolic_hits: Int
      symbolic_hit_rate: Float
      memory_entries: Int
      memory_hit_rate: Float
      memory_evictions: Int
      llm_loaded: Bool
      last_routing: String

  MirrorMateriya:
    description: "MATERIYA (Matter) — TVC corpus physical storage metrics"
    fields:
      tvc_enabled: Bool
      tvc_corpus_size: Int
      tvc_hits: Int
      tvc_hit_rate: Float
      cache_hit_rate: Float

  MirrorDukh:
    description: "DUKH (Spirit) — Chat pipeline energy and provider metrics"
    fields:
      total_queries: Int
      energy_saved_wh: Float
      groq_calls: Int
      claude_calls: Int
      tool_hits: Int
      vision_calls: Int
      whisper_calls: Int
      groq_success_rate: Float
      claude_success_rate: Float
      context_enabled: Bool
      context_messages: Int
      context_key_facts: Int

  MirrorLogEntry:
    description: "Single query log entry from ring buffer"
    fields:
      ts: Int
      src: String
      q: String
      conf: Float
      lat: Int
      learned: Option<Bool>

  MirrorStatus:
    description: "Combined health response with three world sections + logs"
    fields:
      status: String
      uptime_s: Option<Int>
      razum: Option<MirrorRazum>
      materiya: Option<MirrorMateriya>
      dukh: Option<MirrorDukh>
      logs: Option<List<MirrorLogEntry>>

  MirrorChatState:
    description: "v2.4 — inline chat state for RAZUM column"
    fields:
      input: String
      reply_text: Option<String>
      reply_source: Option<String>
      reply_confidence: Option<Float>
      reply_latency: Option<Int>
      sending: Bool

  MirrorFinderState:
    description: "v2.4 — inline file search state for MATERIYA column"
    fields:
      query: String
      results: List<FinderFile>

  MirrorToolState:
    description: "v2.4 — inline tool execution state for DUKH column"
    fields:
      output: String

constants:
  PHI: 1.618033988749895
  PI: 3.141592653589793
  E: 2.718281828459045
  TRINITY_CONSTANT: 3.0
  MIRROR_POLL_INTERVAL_MS: 2000
  HEALTH_TIMEOUT_MS: 3000
  LOG_RING_SIZE: 20
  LOG_FRONTEND_MAX: 50

behaviors:
  - name: mirror_auto_poll
    given: User switches to Mirror layer (key 7)
    when: Layer becomes 'tools' (display [CYR:[TRANSLATED]A[EN]])
    then: |
      Immediately fetch /health endpoint.
      Parse JSON into MirrorStatus with razum/materiya/dukh + logs.
      Start polling every 2 seconds.
      Merge new log entries by timestamp deduplication.
      Accumulate up to 50 log entries on frontend.
      Auto-scroll log panel to bottom.
      Stop polling when layer changes.

  - name: mirror_razum_chat
    given: User is on Mirror layer
    when: User types in RAZUM chat input and submits
    then: |
      Send message to /chat API via sendMessage().
      Show response with source, confidence, latency.
      Trigger wave animation at 45 degrees.
      Refresh mirror status after 500ms delay.
      Clear input on success. Show error on failure.

  - name: mirror_materiya_finder
    given: User is on Mirror layer
    when: User types in MATERIYA search input
    then: |
      Filter FILE_INDEX by path or category match (case-insensitive).
      Show up to 8 results with icon, path, category.
      Click result → set finderQuery, select file, switch to Finder layer.
      Show top 8 files when search is empty.

  - name: mirror_dukh_tools
    given: User is on Mirror layer
    when: User clicks Build, Test, or Health button in DUKH column
    then: |
      Send tool command to /chat API:
        Build → "zig build status"
        Test → "zig build test summary"
        Health → "system health check"
      Show output with source, confidence, latency.
      Trigger wave animation at 280 degrees.
      Refresh mirror status after 500ms.

  - name: mirror_three_columns
    given: MirrorStatus data available
    when: Rendering Mirror layer
    then: |
      Display three glass-morphism columns:
        RAZUM (gold, left)
          — Chat input form + response display
          — Query path: Symbolic → TVC → LLM (active highlighted)
          — Metrics row (hits, memory, routing)
          — Live log: symbolic/memory entries
        MATERIYA (cyan, center)
          — File search input + clickable results
          — Corpus metrics (TVC, corpus size, cache rate)
          — Compact energy pipeline (4 levels)
          — Live log: TVC/learned entries
        DUKH (purple, right)
          — Tool buttons (Build/Test/Health)
          — Tool output display
          — Provider health (Groq/Claude %)
          — Metrics row (queries, energy, context)
          — Live log: all events

  - name: query_path_visualization
    given: RAZUM column has last_routing data
    when: Rendering query path
    then: |
      Show: ⚡ Symbolic → 💎 TVC → 🧠 LLM
      Active step highlighted (opacity 1.0), inactive dimmed (0.3).
      Based on last_routing field.

  - name: energy_pipeline_display
    given: MATERIYA column rendering
    when: Rendering energy pipeline
    then: |
      Show compact cost hierarchy:
        Symbolic: 0.1 mWh, TVC: 1 mWh, LLM: 50 mWh, Cloud: 100 mWh

  - name: provider_health_display
    given: DUKH column has provider data
    when: Rendering provider health
    then: |
      Show Groq and Claude success rates as percentage numbers.
      Color: green (>80%), yellow (>50%), red (<50%).
      Show call count below each.

  - name: mirror_offline_state
    given: Backend unreachable
    when: fetchMirrorStatus returns status='offline'
    then: |
      Show "Start backend: zig build tri -- serve --chat --port 8080".
      Connection indicator shows red dot + OFFLINE label.
      Continue polling (backend may come online).

  - name: log_ring_buffer
    given: Chat request processed by backend
    when: Response sent to client
    then: |
      Record LogEntry to ring buffer (size 20):
        timestamp, source name, query preview (64 chars),
        confidence, latency_us, learned flag.
      Ring buffer overwrites oldest entry when full.
