name: hdc_igla_hybrid_v2_0
version: "2.0.0"
language: zig
module: igla_hybrid_chat

# IglaHybridChat v2.0 — VSA Persistent Memory + Dynamic Semantic Routing + Wave State
# Extends v2.4 (ReflectionStatus, tool_name, multi-modal, context)
# 7 Sub-Agents: VSAMemoryManager, SemanticRouter, WaveStateExporter,
#               FallbackEngine, APIKeyManager, BenchmarkHarness, ContextBinder
# phi^2 + 1/phi^2 = 3 = TRINITY | KOSCHEI IS ENERGY IMMORTAL
#
# Technology Tree:
#   v1.9 (Canvas Wave UI + basic fallback)
#   → v2.0 (VSA memory + semantic routing + wave state) ← CURRENT
#   → v3.0 (Phi-Engine quantum visualization + ouroboros self-repair)
#   → v4.0 (immortal hybrid agent)

types:
  # ── Sub-Agent 1: VSAMemoryManager ──
  VSAMemoryEntry:
    description: "Persistent memory entry with confidence weighting and usage tracking"
    fields:
      query_vec: HybridBigInt       # VSA-encoded query vector (1000 trits)
      response_text: String          # Original response text (max 512 bytes)
      confidence: Float              # 0.0-1.0 confidence at creation
      usage_count: Int               # Times retrieved (popularity)
      last_accessed: Int             # Timestamp of last retrieval
      source_tag: ResponseSource     # Which layer produced this (Symbolic/TVC/LLM)
      quality_score: Float           # Weighted: confidence * log(usage_count + 1)

  VSAMemoryStats:
    description: "Memory subsystem statistics"
    fields:
      total_entries: Int
      cache_hits: Int
      cache_misses: Int
      hit_rate: Float                # hits / (hits + misses)
      avg_confidence: Float
      avg_latency_us: Int
      eviction_count: Int            # LRU evictions performed

  # ── Sub-Agent 2: SemanticRouter ──
  RoutingDecision:
    description: "Dynamic routing decision based on query embedding similarity"
    variants:
      - RouteSymbolic          # High similarity to known patterns → symbolic
      - RouteTVC               # Medium similarity → TVC corpus lookup
      - RouteLocalLLM          # Low similarity + local model available
      - RouteGroq              # Low similarity + Groq API key set
      - RouteClaude            # Complex query + Claude API key set
      - RouteFallback          # All providers failed → fallback chain

  ProviderHealth:
    description: "Health status of an LLM provider"
    fields:
      name: String
      is_available: Bool             # API key set and not rate-limited
      success_count: Int
      failure_count: Int
      avg_latency_us: Int
      last_error_time: Int           # 0 = no errors
      success_rate: Float            # success / (success + failure)

  # ── Sub-Agent 3: WaveStateExporter ──
  WaveState:
    description: "Reasoning state exported for canvas wave visualization"
    fields:
      similarity: Float              # Cosine similarity of best TVC match
      source_hue: Float              # Color hue based on source (0-360)
      confidence: Float              # Response confidence 0.0-1.0
      latency_normalized: Float      # Latency / max_expected_latency (0-1)
      memory_load: Float             # entries / max_entries (0-1)
      is_learning: Bool              # true when response saved to TVC
      routing_path: RoutingDecision  # Which route was taken
      provider_health: Float         # Average health of all providers (0-1)

  # ── Sub-Agent 4: FallbackEngine ──
  FallbackResult:
    description: "Result from fallback chain with provider tracking"
    fields:
      response: String
      provider_used: String          # "groq", "claude", "local", "symbolic"
      attempts: Int                  # Number of providers tried
      total_latency_us: Int

  # ── Sub-Agent 5: APIKeyManager ──
  APIKeyStatus:
    description: "Status of all API keys from environment"
    fields:
      anthropic_set: Bool
      groq_set: Bool
      openai_set: Bool
      any_cloud_available: Bool      # OR of all above
      provider_count: Int            # Number of available providers

  # ── Sub-Agent 6: BenchmarkHarness ──
  BenchmarkResult:
    description: "Single benchmark measurement"
    fields:
      test_name: String
      v19_latency_us: Int            # v1.9 baseline
      v20_latency_us: Int            # v2.0 measurement
      improvement_ratio: Float       # v19/v20 (>1.0 = faster)
      context_retained: Bool         # Did response use context?
      coherence_score: Float         # 0-1 self-consistency

  # ── Sub-Agent 7: ContextBinder ──
  BoundContext:
    description: "Context compressed via VSA bind/bundle operations"
    fields:
      context_vec: HybridBigInt      # Bundled summary of conversation
      turn_count: Int                # Number of turns encoded
      key_facts_vec: HybridBigInt    # Bound key facts
      topic_vec: HybridBigInt        # Current topic embedding

  # ── Extended HybridResponse v2.0 ──
  HybridResponseV20:
    description: "Full v2.0 response with memory, routing, and wave state"
    fields:
      response: String
      source: ResponseSource
      language: Language
      confidence: Float
      latency_us: Int
      tvc_similarity: Float
      tool_name: Option<String>
      reflection: ReflectionStatus
      # v2.0 new fields:
      routing: RoutingDecision       # Which route was taken
      wave_state: WaveState          # Exported for canvas visualization
      memory_hit: Bool               # True if served from VSA memory
      provider_health: Float         # Current provider health score
      context_similarity: Float      # How related to conversation context

  # ── Extended Config v2.0 ──
  HybridConfigV20:
    description: "Configuration with memory and routing settings"
    fields:
      # Existing v2.4 config (inherited)
      symbolic_confidence_threshold: Float    # default: 0.3
      tvc_similarity_threshold: Float         # default: 0.55
      max_tokens: Int                         # default: 32
      temperature: Float                      # default: 0.7
      enable_reflection: Bool                 # default: true
      enable_context: Bool                    # default: true
      system_prompt: String
      # API keys (from env)
      groq_api_key: Option<String>
      claude_api_key: Option<String>
      openai_api_key: Option<String>
      # v2.0 new settings
      memory_max_entries: Int                 # default: 256 (lightweight)
      memory_eviction_threshold: Float        # default: 0.3 (evict below)
      routing_learn_rate: Float               # default: 0.1
      wave_export_enabled: Bool               # default: true
      context_bind_enabled: Bool              # default: true
      fallback_max_retries: Int               # default: 2
      provider_timeout_ms: Int                # default: 10000

behaviors:
  # ── VSAMemoryManager behaviors ──
  - name: memory_store
    given: "Query text + response text + confidence + source"
    when: "Response passes quality filters (reflection == Saved)"
    then: "Encode query via VSA encodeText(), create VSAMemoryEntry, store with quality_score = confidence * log(usage+1). If at capacity, evict lowest quality_score entry."

  - name: memory_search
    given: "Query text"
    when: "Checking VSA memory before TVC and LLM"
    then: "Encode query to vector, compute cosineSimilarity against all entries. Return best match if similarity >= tvc_similarity_threshold. Increment usage_count and update last_accessed."

  - name: memory_evict_lru
    given: "Memory at capacity (entries >= memory_max_entries)"
    when: "New entry needs to be stored"
    then: "Find entry with lowest quality_score (confidence * log(usage+1)). If quality_score < memory_eviction_threshold, evict it. Update eviction_count stat."

  - name: memory_get_stats
    given: "Request for memory statistics"
    when: "getStats() called"
    then: "Return VSAMemoryStats with hit_rate, avg_confidence, eviction_count"

  # ── SemanticRouter behaviors ──
  - name: route_query
    given: "User query + API key status + provider health"
    when: "Determining which layer to try first"
    then: "1. Encode query to vector. 2. Check similarity against symbolic patterns (if >= 0.7 → RouteSymbolic). 3. Check TVC memory (if >= 0.55 → RouteTVC). 4. Check provider health → pick best available cloud LLM. 5. If no providers → RouteFallback."

  - name: update_provider_health
    given: "Provider name + success/failure + latency"
    when: "After each LLM call completes or fails"
    then: "Update ProviderHealth: increment success/failure count, update avg_latency, compute success_rate. If 3+ consecutive failures, mark is_available = false for 60 seconds."

  - name: get_best_provider
    given: "All ProviderHealth states"
    when: "Selecting cloud LLM provider"
    then: "Score = success_rate * (1.0 / (avg_latency_us / 1_000_000 + 0.1)). Pick highest scoring available provider."

  # ── WaveStateExporter behaviors ──
  - name: export_wave_state
    given: "HybridResponse after respond() completes"
    when: "wave_export_enabled = true"
    then: "Compute WaveState: source_hue from source enum (Symbolic=60, TVC=120, Groq=210, Claude=270, Tool=30, Error=0). latency_normalized = latency_us / 5_000_000. memory_load = memory_entries / memory_max_entries. Store in global g_last_wave_state for canvas to read."

  - name: wave_state_to_grid_params
    given: "WaveState from last response"
    when: "Canvas reads wave state for visualization"
    then: "Map: similarity → wave amplitude (0-1). source_hue → photon hue. confidence → wave frequency. is_learning → green pulse. routing_path → wave pattern shape."

  # ── FallbackEngine behaviors ──
  - name: cascade_with_fallback
    given: "Query text + ordered list of providers"
    when: "Primary LLM call fails (timeout, error, empty response)"
    then: "Try next provider in order. Track attempts. If all cloud providers fail, fall back to symbolic response. Return FallbackResult with provider_used and attempts."

  - name: detect_empty_response
    given: "LLM response text"
    when: "Checking if response is meaningful"
    then: "Return true if response is empty, or only whitespace, or shorter than 3 chars, or starts with common error prefixes (Error:, Sorry, I can't)"

  # ── APIKeyManager behaviors ──
  - name: check_api_keys
    given: "Environment variables"
    when: "Initializing hybrid chat engine"
    then: "Read ANTHROPIC_API_KEY, GROQ_API_KEY, OPENAI_API_KEY from env. Set APIKeyStatus booleans. Log which providers are available."

  # ── ContextBinder behaviors ──
  - name: bind_context_turn
    given: "New user query + assistant response"
    when: "Context tracking enabled"
    then: "1. Encode query and response to vectors. 2. bound_turn = bind(query_vec, response_vec). 3. context_vec = bundle2(context_vec, permute(bound_turn, turn_count)). 4. Increment turn_count."

  - name: get_context_similarity
    given: "New query + current context_vec"
    when: "Checking if query relates to conversation"
    then: "Encode query. Return cosineSimilarity(query_vec, context_vec). High similarity = related to conversation. Low = new topic."

  # ── Extended respond() v2.0 ──
  - name: respond_v20
    given: "User query"
    when: "respond() called on IglaHybridChat"
    then: >
      1. Check API key status (APIKeyManager).
      2. Route query (SemanticRouter → RoutingDecision).
      3. If RouteSymbolic: try symbolic, if miss → continue.
      4. Check VSA memory (VSAMemoryManager.memory_search).
      5. If memory hit: return with memory_hit=true.
      6. Check TVC corpus (existing search).
      7. If TVC hit: return.
      8. LLM cascade with fallback (FallbackEngine).
      9. Self-reflection: save to TVC if quality passes (existing).
      10. Save to VSA memory (memory_store) if reflection == Saved.
      11. Bind context (ContextBinder.bind_context_turn).
      12. Export wave state (WaveStateExporter).
      13. Return HybridResponseV20.

  # ── Benchmark behaviors ──
  - name: benchmark_latency
    given: "Test query + number of iterations"
    when: "Running benchmark suite"
    then: "Time respond() over N iterations. Report: min, max, avg, p50, p99 latency_us."

  - name: benchmark_context_retention
    given: "Sequence of related queries"
    when: "Testing context binding"
    then: "Send 5 related queries. Check if response to query 5 references info from query 1. Score: context_similarity between first and last turns."

  - name: benchmark_fallback_rate
    given: "100 random queries with varied API availability"
    when: "Testing fallback chain robustness"
    then: "Count: successful responses, fallback activations, total failures. Target: 99.9% success."

# Architecture v2.0: VSA Memory + Semantic Routing + Wave State
#
# USER QUERY
#     |
#     v
# [APIKeyManager] → check env keys → APIKeyStatus
#     |
#     v
# [SemanticRouter] → encode query → RoutingDecision
#     |
#     +--→ RouteSymbolic ──→ [Symbolic Matcher] → response
#     |
#     +--→ RouteTVC ──→ [VSAMemoryManager] → memory_search
#     |                        |
#     |                 (miss) v
#     |                 [TVC Corpus] → search
#     |
#     +--→ RouteGroq/Claude ──→ [FallbackEngine] → cascade
#     |
#     v
# [Self-Reflection] → saveToTVCFiltered → ReflectionStatus
#     |
#     v (if Saved)
# [VSAMemoryManager] → memory_store (confidence-weighted)
#     |
#     v
# [ContextBinder] → bind_context_turn (VSA bind+bundle)
#     |
#     v
# [WaveStateExporter] → export_wave_state → g_last_wave_state
#     |
#     v
# HybridResponseV20 {
#     response, source, routing, wave_state,
#     memory_hit, provider_health, context_similarity
# }
#     |
#     v
# [Trinity Canvas v1.9] → reads g_last_wave_state → wave visualization
