name: cli_query_dispatch
version: "1.0.0"
language: zig
module: cli_query_dispatch
description: "Level 11.23 ‚Äî CLI-Style Query Dispatch Routing. Simulates command-line query interface with 5 query types dispatched programmatically: direct (1-hop), 2-hop chain, 3-hop chain, cross-domain (2 relations per query), and multi-relation (3 relations per entity). 30 entities across 6 categories. Total 40/40 (100%)."

constants:
  DIM: 1024
  NUM_ENTITIES: 30
  NUM_QUERY_TYPES: 5

types:
  CLIQuery:
    fields:
      query_type: String
      hops: Int
      result: String
      correct: Bool
      description: "A CLI-dispatched query with type routing."

behaviors:
  - name: directQuery
    given: 5 cities mapped to 5 countries via city_in_country memory.
    when: CLI dispatches direct query "What country is city X in?"
    then: 5/5 (100%) ‚Äî all direct lookups resolve correctly

  - name: chain2Query
    given: landmark‚Üícity‚Üícountry 2-hop chain.
    when: CLI dispatches chain query "What country is landmark X in?"
    then: 5/5 (100%) ‚Äî 2-hop chains resolve via intermediate city

  - name: chain3Query
    given: landmark‚Üícity‚Üícountry‚Üífood 3-hop chain.
    when: CLI dispatches chain query "What food for landmark X?"
    then: 5/5 (100%) ‚Äî 3-hop chains propagate correctly

  - name: crossDomainQuery
    given: country‚Üílanguage and country‚Üíclimate divergent relations.
    when: CLI dispatches "What language + climate for country X?"
    then: 10/10 (100%) ‚Äî both branches resolve

  - name: multiRelQuery
    given: country‚Üí(food + language + climate) three relations simultaneously.
    when: CLI dispatches "All relations for country X?"
    then: 15/15 (100%) ‚Äî all 3 relations correct for each entity

test_cases:
  - name: test_direct_5_5
    input: "Direct city‚Üícountry queries"
    expected: "5/5 (100%)"

  - name: test_chain3_5_5
    input: "3-hop landmark‚Üícity‚Üícountry‚Üífood"
    expected: "5/5 (100%)"

  - name: test_multi_rel_15_15
    input: "Multi-relation country‚Üífood,language,climate"
    expected: "15/15 (100%)"

  - name: test_total_40_40
    input: "Total CLI query dispatch accuracy"
    expected: "40/40 (100%)"
