  - name: execute_clean
    given: CleanMode
    when: User runs tri clean
    then: Clean build artifacts and cache
    implementation: |
      pub fn execute_clean(_: anytype) !void {
          std.debug.print("\\x1b[36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\\x1b[0m\\n", .{});
          std.debug.print("\\x1b[36mв•‘           Cleaning Build Artifacts                       в•‘\\x1b[0m\\n", .{});
          std.debug.print("\\x1b[36mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\\x1b[0m\\n", .{});

          const paths_to_clean = [_][]const u8{
              "zig-cache",
              "zig-out",
              ".zig-cache",
          };

          for (paths_to_clean) |path| {
              if (std.fs.cwd().deleteTree(path)) {
                  std.debug.print("  \\x1b[32mвњ“\\x1b[0m Removed {s}/\\n", .{path});
              } else |_| {
                  std.debug.print("  \\x1b[90m- {s}/ (not found)\\x1b[0m\\n", .{path});
              }
          }

          std.debug.print("\\n\\x1b[32mвњ“ Clean complete!\\x1b[0m\\n", .{});
      }

  - name: execute_doctor
    given: DoctorMode
    when: User runs tri doctor
    then: Run system diagnostics
    implementation: |
      pub fn execute_doctor(_: anytype) !void {
          std.debug.print("\\x1b[36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\\x1b[0m\\n", .{});
          std.debug.print("\\x1b[36mв•‘           TRINITY System Diagnostics                    в•‘\\x1b[0m\\n", .{});
          std.debug.print("\\x1b[36mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\\x1b[0m\\n", .{});

          // Check Zig version
          std.debug.print("\\n\\x1b[33m[Zig Compiler]\\x1b[0m\\n", .{});
          const zig_version = @import("builtin").zig_version;
          std.debug.print("  Version: {}\\n", .{zig_version});

          if (zig_version.major >= 0 and zig_version.minor >= 15) {
              std.debug.print("  \\x1b[32mвњ“ Compatible (>= 0.15)\\x1b[0m\\n", .{});
          } else {
              std.debug.print("  \\x1b[31mвњ— Requires Zig >= 0.15\\x1b[0m\\n", .{});
          }

          // Check directories
          std.debug.print("\\n\\x1b[33m[Project Structure]\\x1b[0m\\n", .{});
          const dirs = [_][]const u8{
              "trinity-nexus/tri",
              "trinity-nexus/output",
              "trinity-nexus/lang/src",
          };

          for (dirs) |dir| {
              if (std.fs.cwd().openDir(dir, .{})) |_| {
                  std.debug.print("  \\x1b[32mвњ“ {s}/\\x1b[0m\\n", .{dir});
              } else |_| {
                  std.debug.print("  \\x1b[31mвњ— {s}/ (missing)\\x1b[0m\\n", .{dir});
              }
          }

          // Check VIBEE compiler
          std.debug.print("\\n\\x1b[33m[VIBEE Compiler]\\x1b[0m\\n", .{});
          if (std.fs.cwd().openDir("src/vibeec", .{})) |_| {
              std.debug.print("  \\x1b[32mвњ“ VIBEE compiler source present\\x1b[0m\\n", .{});
          } else |_| {
              std.debug.print("  \\x1b[31mвњ— VIBEE compiler missing\\x1b[0m\\n", .{});
          }

          std.debug.print("\\n\\x1b[36mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\\x1b[0m\\n", .{});
          std.debug.print("\\x1b[32mSystem check complete!\\x1b[0m\\n", .{});
      }

  - name: execute_update
    given: UpdateMode
    when: User runs tri update
    then: Update dependencies

