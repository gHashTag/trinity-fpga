  - name: execute_knowledge_build
    given: KnowledgeBuildMode
    when: User runs tri knowledge build
    then: Build knowledge base from specifications
    implementation: |
      pub fn execute_knowledge_build(options: anytype) !void {
          const fs = std.fs;
          const allocator = std.heap.page_allocator;

          const specs_path = if (options.specs_path) |p| p else "trinity-nexus/tri";

          std.debug.print("\\x1b[36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\\x1b[0m\\n", .{});
          std.debug.print("\\x1b[36mв•‘           Knowledge Base Builder                           в•‘\\x1b[0m\\n", .{});
          std.debug.print("\\x1b[36mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\\x1b[0m\\n", .{});
          std.debug.print("Scanning: {s}/\\n\\n", .{specs_path});

          var dir = fs.cwd().openDir(specs_path, .{ .iterate = true }) catch |err| {
              std.debug.print("\\x1b[31mError opening directory: {any}\\x1b[0m\\n", .{err});
              return err;
          };
          defer dir.close();

          var count: usize = 0;
          var walker = try dir.walk(allocator);
          defer walker.deinit();

          while (try walker.next()) |entry| {
              if (entry.kind == .file and std.mem.endsWith(u8, entry.path, ".vibee")) {
                  std.debug.print("  \\x1b[32mвњ“\\x1b[0m {s}\\n", .{entry.path});
                  count += 1;
              }
          }

          std.debug.print("\\n\\x1b[36mIndexed {} specification(s)\\x1b[0m\\n", .{count});
          std.debug.print("\\nKnowledge base ready for queries!\\n", .{});
      }

