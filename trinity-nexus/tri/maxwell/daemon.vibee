name: maxwell_daemon
version: "1.0.0"
language: zig
module: maxwell_daemon

# ═══════════════════════════════════════════════════════════════════════════════
# MAXWELL DAEMON - Ain[CYR:[TRANSLATED]ny] [CYR:A[TRANSLATED]]-[CYR:[TRANSLATED]]andwith[EN]
# "[CYR:[TRANSLATED]], which with[CYR:[TRANSLATED]]and[CYR:[TRANSLATED]] code [EN] [CYR:[TRANSLATED]]andand"
# ═══════════════════════════════════════════════════════════════════════════════
#
# [CYR:[TRANSLATED]] [CYR:[TRANSLATED]]within[CYR:[TRANSLATED]] in [CYR:[TRANSLATED]]andon[EN]and[EN] - [EN]and[CYR:[TRANSLATED]]and[EN]with[CYR:[TRANSLATED]] with[CYR:[TRANSLATED]]with[EN]in[EN], with[EN]with[CYR:[TRANSLATED]]
# with[CYR:[TRANSLATED]]and[EN]in[CYR:ate] [CYR:[TRANSLATED]y] [EN] with[CYR:[TRANSLATED]]with[EN]and, [CYR:[EN]me[TRANSLATED]I] [CYR:[TRANSLATED]]and[EN] withandwith[CYR:[TRANSLATED]y].
#
# Maxwell Daemon in [CYR:pro[TRANSLATED]]and[EN]in[EN]andand - [EN]in[CYR:[TRANSLATED]ny] [CYR:agent], with[EN]with[CYR:[EN]ny]:
# - Aon[EN]fromand[EN]in[CYR:ate] code and on[CYR:[TRANSLATED]]and[EN] [CYR:pro[TRANSLATED]y] (inywith[CYR:[TRANSLATED]I] [CYR:[TRANSLATED]]andI)
# - [EN]not[EN]and[EN]in[CYR:ate] [CYR:[TRANSLATED]]andI [CYR:[TRANSLATED]] .vibee with[CYR:[TRANSLATED]]and[EN]and[CYR:[TRANSLATED]]andand
# - [EN]with[EN]and[EN]in[CYR:ate] and improve code ([CYR:[EN]me[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]andand)
# - [EN]and[EN]withI on within[EN]and[EN] error[EN]
#
# φ² + 1/φ² = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

types:
  # [EN]with[CYR:[EN]I[EN]]and[EN] demoon
  DaemonState:
    fields:
      status: String          # "idle", "working", "error", "stopped"
      current_task: Option<Task>
      tasks_completed: Int
      tasks_failed: Int
      uptime_seconds: Int
      memory_usage_mb: Float

  # [CYR:[TRANSLATED]] for [CYR:agent[EN]]
  Task:
    fields:
      id: String
      description: String
      priority: Int           # 1-10, where 10 - [CYR:[TRANSLATED]]withand[CYR:[EN]al]
      task_type: String       # "feature", "bugfix", "refactor", "test", "optimize"
      target_files: List<String>
      constraints: List<String>
      deadline: Option<Int>   # Unix timestamp
      status: String          # "pending", "in_progress", "completed", "failed"
      result: Option<TaskResult>

  # [CYR:[TRANSLATED]l[TRANSLATED]] in[CYR:y[TRANSLATED]]not[EN]andI [CYR:[TRANSLATED]]and
  TaskResult:
    fields:
      success: Bool
      files_created: List<String>
      files_modified: List<String>
      tests_passed: Int
      tests_failed: Int
      error_message: Option<String>
      duration_ms: Int
      metrics: Metrics

  # [CYR:[TRANSLATED]]and[EN]and [CYR:pro]fromin[EN]and[CYR:[EN]lno]with[EN]and
  Metrics:
    fields:
      lines_of_code: Int
      cyclomatic_complexity: Float
      test_coverage: Float
      performance_delta: Float  # % change [CYR:pro]fromin[EN]and[CYR:[EN]lno]with[EN]and

  # [CYR:[TRANSLATED]I[EN]] [CYR:agent[EN]]
  Memory:
    fields:
      experiences: List<Experience>
      learned_patterns: List<Pattern>
      error_history: List<ErrorRecord>

  # [CYR:[EN]y[EN]] (for [CYR:[TRANSLATED]]andI)
  Experience:
    fields:
      task_type: String
      approach: String
      outcome: String         # "success", "partial", "failure"
      lessons: List<String>
      timestamp: Int

  # [CYR:[TRANSLATED]] (in[CYR:y[TRANSLATED]ny])
  Pattern:
    fields:
      name: String
      trigger: String         # [CYR:[TRANSLATED]] [EN]and[CYR:meI[EN]]
      solution: String        # [CYR:[TRANSLATED]] [CYR:[TRANSLATED]ate]
      confidence: Float       # 0.0 - 1.0
      usage_count: Int

  # [CYR:[TRANSLATED]]andwith[EN] [EN] [EN]and[CYR:[TRANSLATED]]
  ErrorRecord:
    fields:
      error_type: String
      context: String
      solution_attempted: String
      resolved: Bool
      timestamp: Int

  # [CYR:[TRANSLATED]]and[CYR:[TRANSLATED]]andI demoon
  DaemonConfig:
    fields:
      llm_api_key: String
      llm_model: String       # "claude-3-opus", "gpt-4", etc.
      max_concurrent_tasks: Int
      auto_commit: Bool
      safety_mode: String     # "strict", "normal", "permissive"
      working_directory: String
      log_level: String       # "debug", "info", "warn", "error"

  # [CYR:[TRANSLATED]]and[EN] for LLM
  LLMMessage:
    fields:
      role: String            # "system", "user", "assistant"
      content: String

  # [EN]in[EN] [EN] LLM
  LLMResponse:
    fields:
      content: String
      tokens_used: Int
      model: String
      finish_reason: String

behaviors:
  # ═══════════════════════════════════════════════════════════════════════════
  # LIFECYCLE
  # ═══════════════════════════════════════════════════════════════════════════

  - name: daemon_start
    given: DaemonConfig
    when: User starts the daemon
    then: Daemon initializes and enters idle state

  - name: daemon_stop
    given: Running daemon
    when: User stops the daemon
    then: Daemon gracefully shuts down, saves state

  - name: daemon_status
    given: Running daemon
    when: User queries status
    then: Returns DaemonState with current metrics

  # ═══════════════════════════════════════════════════════════════════════════
  # TASK MANAGEMENT
  # ═══════════════════════════════════════════════════════════════════════════

  - name: task_submit
    given: Task description
    when: User submits a new task
    then: Task is added to queue with priority

  - name: task_process
    given: Task from queue
    when: Daemon picks up task
    then: Task is decomposed and executed

  - name: task_complete
    given: Executed task
    when: All subtasks complete
    then: TaskResult is generated and stored

  # ═══════════════════════════════════════════════════════════════════════════
  # CODE GENERATION
  # ═══════════════════════════════════════════════════════════════════════════

  - name: analyze_codebase
    given: Target files
    when: Daemon needs context
    then: Returns code structure and patterns

  - name: generate_spec
    given: Task and analysis
    when: Daemon plans implementation
    then: Creates .vibee specification

  - name: generate_code
    given: .vibee specification
    when: Daemon executes plan
    then: Runs vibee gen, creates code

  - name: run_tests
    given: Generated code
    when: Daemon verifies implementation
    then: Returns test results

  # ═══════════════════════════════════════════════════════════════════════════
  # LEARNING
  # ═══════════════════════════════════════════════════════════════════════════

  - name: learn_from_success
    given: Successful TaskResult
    when: Task completes successfully
    then: Pattern is extracted and stored

  - name: learn_from_failure
    given: Failed TaskResult
    when: Task fails
    then: Error is analyzed, lessons learned

  - name: apply_pattern
    given: Similar task
    when: Pattern matches
    then: Use learned approach

  # ═══════════════════════════════════════════════════════════════════════════
  # LLM INTEGRATION
  # ═══════════════════════════════════════════════════════════════════════════

  - name: llm_reason
    given: Context and question
    when: Daemon needs reasoning
    then: LLM provides analysis

  - name: llm_generate_spec
    given: Task description
    when: Daemon needs .vibee
    then: LLM generates specification

  - name: llm_fix_error
    given: Error message and context
    when: Code fails tests
    then: LLM suggests fix

  # ═══════════════════════════════════════════════════════════════════════════
  # SAFETY
  # ═══════════════════════════════════════════════════════════════════════════

  - name: safety_check
    given: Proposed action
    when: Before any file modification
    then: Validates action is safe

  - name: safety_rollback
    given: Failed or dangerous action
    when: Safety violation detected
    then: Reverts all changes

  - name: safety_audit
    given: Completed task
    when: After task completion
    then: Logs all actions for review
