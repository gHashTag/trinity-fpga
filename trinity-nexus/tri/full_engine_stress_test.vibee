name: full_engine_stress_test
version: "1.0.0"
language: zig
module: full_engine_stress_test
description: "Level 11.20 â€” Full Engine Stress Test. Integrates 50 entities across 8 categories (Departments, Employees, Skills, Projects, Clients, Locations, Tools, Ratings) with 7 relation types. Uses 4-way split memories (4 sub-memories Ă— 3 pairs) for 12-pair relations. Tests 1-hop department and skill lookups, 2-hop chains (employeeâ†’departmentâ†’location, employeeâ†’departmentâ†’tool), and 2-hop chains (employeeâ†’projectâ†’client). Total 60/60 (100%)."

constants:
  DIM: 1024
  NUM_ENTITIES: 50
  NUM_CATEGORIES: 8
  NUM_RELATIONS: 7
  PAIRS_PER_SUBMEM: 3
  NUM_SUBMEMS: 4

types:
  StressQuery:
    fields:
      hop_depth: Int
      relation_chain: String
      result: String
      correct: Bool
      description: "A stress test query across the full engine with multiple relation types."

behaviors:
  - name: departmentLookup
    given: 12 employees across 6 departments. belongs_to relation split into 4 sub-memories of 3 pairs each.
    when: Query belongs_to(employee) for all 12 employees using querySplit4
    then: 12/12 (100%) â€” 4-way split with querySplit4 resolves all employees to correct departments

  - name: employeeToDeptToLocation
    given: Same 12 employees, 6 departments at 6 locations. Two-hop chain via dept_at relation.
    when: For each employee, chain belongs_to â†’ dept_at to find their floor location
    then: 12/12 (100%) â€” 2-hop chains through 4-way split + bundled memories all correct

  - name: employeeToProjectToClient
    given: 12 employees on 6 projects for 6 clients. works_on split 4Ă—3, project_for bundled 6 pairs.
    when: For each employee, chain works_on â†’ project_for to find their client
    then: 12/12 (100%) â€” 2-hop chains all resolve correctly

  - name: employeeToDeptToTool
    given: 6 departments each using a primary tool. Two-hop via belongs_to â†’ dept_uses.
    when: For each employee, chain belongs_to â†’ dept_uses to find their department's tool
    then: 12/12 (100%) â€” all department-tool associations retrieved correctly

  - name: skillLookup
    given: 12 employees with assigned skills. has_skill relation split 4Ă—3.
    when: Query has_skill(employee) for all 12 employees using querySplit4
    then: 12/12 (100%) â€” 4-way split skill memories resolve all correctly

test_cases:
  - name: test_dept_12_12
    input: "Query department for all 12 employees"
    expected: "12/12 (100%)"

  - name: test_location_12_12
    input: "2-hop employeeâ†’departmentâ†’location for 12 employees"
    expected: "12/12 (100%)"

  - name: test_client_12_12
    input: "2-hop employeeâ†’projectâ†’client for 12 employees"
    expected: "12/12 (100%)"

  - name: test_tool_12_12
    input: "2-hop employeeâ†’departmentâ†’tool for 12 employees"
    expected: "12/12 (100%)"

  - name: test_skill_12_12
    input: "Query skill for all 12 employees"
    expected: "12/12 (100%)"

  - name: test_total_60_60
    input: "Total full engine stress test accuracy"
    expected: "60/60 (100%)"
