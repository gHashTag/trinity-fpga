name: trinity_canvas_v2_0
version: "2.0.0"
language: zig
module: photon_trinity_canvas

# Trinity Canvas v2.0 — Real Logic Integration
# Replace all hardcoded data with live system queries.
# Chat already works. Now: code, tools, settings, finder, vision, voice, docs.
#
# Technology Tree:
#   v1.9 (Hardcoded wave mode UIs)
#   → v2.0 (Live data in every mode) ← CURRENT
#   → v2.1 (Interactive editing + file open)
#
# φ² + 1/φ² = 3 = TRINITY | KOSCHEI IS ENERGY IMMORTAL

types:
  LiveCodeLine:
    description: "Code mode line with label + live value formatted as Zig const"
    fields:
      label: String
      value_fn: "fn() []const u8"

  LiveSettingEntry:
    description: "Settings mode entry read from HybridConfig"
    fields:
      key: String
      value: String
      is_masked: Bool

  FinderEntry:
    description: "Real filesystem entry from std.fs.Dir.iterate()"
    fields:
      name: String
      kind: "std.fs.Dir.Entry.Kind"
      depth: Int

behaviors:
  - name: render_code_mode_live
    given: "g_wave_mode == .code"
    when: "Canvas render loop"
    then: >
      Display LIVE system data as scrolling code lines:
      - Line 1: const fps = GetFPS()
      - Line 2: const timestamp = std.time.timestamp()
      - Line 3: const canvas_version = "v2.0"
      - Line 4: const chat_engine = if hybrid != null "IglaHybridChat v2.4" else "FluentChat"
      - Line 5: const total_queries = g_hybrid_engine.total_queries
      - Line 6: const wave_routing = @tagName(g_last_wave_state.routing)
      - Line 7: const wave_confidence = g_last_wave_state.confidence
      - Line 8: const wave_learning = g_last_wave_state.is_learning
      - Line 9: const memory_load = g_last_wave_state.memory_load
      - Line 10: const provider_health = g_last_wave_state.provider_health_avg
      - Line 11: const groq_health = g_hybrid_engine.groq_health.getSuccessRate()
      - Line 12: const claude_health = g_hybrid_engine.claude_health.getSuccessRate()
      All values formatted at runtime via bufPrint into sentinel buffers.
      Wave animation per line preserved.

  - name: render_tools_mode_live
    given: "g_wave_mode == .tools"
    when: "Canvas render loop"
    then: >
      Display 7 tools in radial wheel with REAL status:
      - Status dot color: green if tool is enabled (config.enable_tools), gray if disabled
      - Center text: total tool invocations from energy.tool_calls
      - Subtitle: last routing decision from g_last_wave_state.routing
      Tool names from ChatTool.getName().

  - name: render_settings_mode_live
    given: "g_wave_mode == .settings"
    when: "Canvas render loop"
    then: >
      Read REAL values from g_hybrid_engine.?.config:
      - symbolic_confidence_threshold (f32 → bufPrint)
      - tvc_similarity_threshold (f64 → bufPrint)
      - max_tokens (u32 → bufPrint)
      - temperature (f32 → bufPrint)
      - enable_reflection (bool → "true"/"false")
      - enable_context (bool)
      - groq_model ([]const u8, truncated)
      - claude_model ([]const u8, truncated)
      - GROQ_API_KEY (masked to "****" if present, "not set" if null)
      - ANTHROPIC_API_KEY (masked)
      - wave_export ("enabled")
      - total_queries (u64 → bufPrint)
      Falls back to hardcoded defaults if g_hybrid_engine is null.

  - name: render_finder_mode_live
    given: "g_wave_mode == .finder"
    when: "Canvas render loop, once per 2 seconds"
    then: >
      Use std.fs.cwd().openDir(".", .{.iterate=true}) to read REAL directory listing.
      Cache result in global g_finder_entries[64] array, refresh every 2s.
      Display with tree structure, file/dir color coding.
      Show actual file count and current working directory.

  - name: render_vision_mode_info
    given: "g_wave_mode == .vision"
    when: "Canvas render loop"
    then: >
      Show vision status:
      - Whether Claude API key is available (from config)
      - respondWithImage() method exists
      - Instruction: type "vision: /path/to/image" in chat mode
      - Supported formats from actual code
      Expanding rings + eye icon preserved.

  - name: render_voice_mode_live
    given: "g_wave_mode == .voice"
    when: "Canvas render loop"
    then: >
      Modulate 64-bar waveform using LIVE wave state:
      - Base amplitude from g_last_wave_state.confidence
      - Frequency shift from g_last_wave_state.source_hue
      - Color intensity from provider_health_avg
      - If is_learning: green glow pulse
      Status shows real Whisper model from config.

  - name: render_docs_mode_full
    given: "g_wave_mode == .docs"
    when: "Canvas render loop"
    then: >
      Extend from 19 to full 27 sacred worlds.
      Use sacred_worlds.WORLDS[27] array directly.
      Show world domain (ai_chat, ai_code, etc.) as third column.

# Architecture:
#
# [ESC] ──→ IDLE (27 petals)
#              │
#   Shift+1 ──→ CHAT   (IglaHybridChat v2.4 — already real)
#   Shift+2 ──→ CODE   (LIVE: FPS, timestamp, wave state, engine stats)
#   Shift+3 ──→ TOOLS  (LIVE: tool counts, routing, health)
#   Shift+4 ──→ SETTINGS (LIVE: HybridConfig values, API key status)
#   Shift+5 ──→ VISION (info: API status, instructions)
#   Shift+6 ──→ VOICE  (LIVE: wave state modulated waveform)
#   Shift+7 ──→ FINDER (LIVE: std.fs directory listing)
#   Shift+8 ──→ DOCS   (LIVE: all 27 sacred worlds)
