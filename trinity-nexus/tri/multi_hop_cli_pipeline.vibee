name: multi_hop_cli_pipeline
version: "1.0.0"
language: zig
module: multi_hop_cli_pipeline
description: "Level 11.24 â€” Multi-Hop CLI Pipeline. Full end-to-end pipeline from string entity name through multi-hop chain to string result. Tests 2-hop chains (landmarkâ†’cityâ†’country), 3-hop chains (landmarkâ†’cityâ†’countryâ†’cuisine), cross-domain divergent queries (countryâ†’language+climate), and deterministic consistency. Total 30/30 (100%)."

constants:
  DIM: 1024
  NUM_ENTITIES: 30
  MAX_HOPS: 3

types:
  ChainResult:
    fields:
      start_entity: String
      chain: List<String>
      final_result: String
      correct: Bool
      description: "Result of a multi-hop chain query through the CLI pipeline."

behaviors:
  - name: twoHopChains
    given: 5 landmarks, each mapped to a city via landmark_in, then to a country via capital_of.
    when: Chain landmarkâ†’cityâ†’country using string-based lookup at each hop
    then: 5/5 (100%) â€” Eiffelâ†’Parisâ†’France, Fujiâ†’Tokyoâ†’Japan, etc.

  - name: threeHopChains
    given: landmarkâ†’cityâ†’countryâ†’cuisine chain (3 hops).
    when: For each of 5 landmarks, chain 3 hops to find associated cuisine
    then: 5/5 (100%) â€” Eiffelâ†’Parisâ†’Franceâ†’Croissant, etc.

  - name: crossDomainQueries
    given: For each country, query both language_of and climate_of.
    when: Execute 2 queries per country (5 countries Ă— 2 relations)
    then: 10/10 (100%) â€” both branches resolve correctly

  - name: deterministicConsistency
    given: 10 queries executed twice each.
    when: Compare results of two identical query runs
    then: 10/10 (100%) â€” deterministic execution verified

test_cases:
  - name: test_2hop_5_5
    input: "5 two-hop landmarkâ†’cityâ†’country chains"
    expected: "5/5 (100%)"

  - name: test_3hop_5_5
    input: "5 three-hop landmarkâ†’cityâ†’countryâ†’cuisine chains"
    expected: "5/5 (100%)"

  - name: test_crossdomain_10_10
    input: "10 cross-domain countryâ†’(language+climate) queries"
    expected: "10/10 (100%)"

  - name: test_total_30_30
    input: "Total multi-hop CLI pipeline accuracy"
    expected: "30/30 (100%)"
