name: ai_code_suggestions
version: 1.0.0
description: AI-powered code suggestions for VIBEE - [CYR:[TRANSLATED]y[EN]] [CYR:[TRANSLATED]]with[CYR:[TRANSLATED]]and in [CYR:[TRANSLATED]lno[EN]] in[CYR:[EN]me]and

metadata:
  author: VIBEE Team
  category: ai_integration
  tags: [ai, llm, code-completion, suggestions, openrouter]
  created: 2024-01-10

types:
  CodeContext:
    file_path: string
    cursor_position: Position
    current_line: string
    previous_lines: list<string>
    next_lines: list<string>
    imports: list<string>
    functions: list<string>
    types: list<string>
    
  Position:
    line: number
    column: number
    
  Suggestion:
    id: string
    text: string
    type: string  # completion, refactoring, fix, optimization
    confidence: number
    explanation: string
    code_snippet: string
    apply_automatically: boolean
    
  AIModel:
    provider: string  # openrouter, anthropic, openai
    model: string
    temperature: number
    max_tokens: number
    
  SuggestionRequest:
    context: CodeContext
    trigger: string  # typing, save, request
    preferences: UserPreferences
    
  UserPreferences:
    auto_apply_high_confidence: boolean
    show_explanations: boolean
    preferred_style: string
    max_suggestions: number

constants:
  AI_MODELS:
    - provider: "openrouter"
      model: "anthropic/claude-3.5-sonnet"
      temperature: 0.3
      max_tokens: 2000
      use_case: "code_completion"
      
    - provider: "openrouter"
      model: "anthropic/claude-3-opus"
      temperature: 0.2
      max_tokens: 4000
      use_case: "refactoring"
      
    - provider: "openrouter"
      model: "google/gemini-pro-1.5"
      temperature: 0.1
      max_tokens: 1000
      use_case: "quick_fixes"

  SUGGESTION_TYPES:
    completion:
      description: "Ain[CYR:[TRANSLATED]]not[EN]and[EN] code[EN]"
      confidence_threshold: 0.7
      auto_apply: true
      
    refactoring:
      description: "[CYR:[TRANSLATED]]andI [EN] [CYR:[EN]factor]and[CYR:[TRANSLATED]]"
      confidence_threshold: 0.8
      auto_apply: false
      
    fix:
      description: "[EN]with[CYR:law]in[CYR:[TRANSLATED]]and[EN] [EN]and[CYR:[TRANSLATED]]"
      confidence_threshold: 0.9
      auto_apply: false
      
    optimization:
      description: "[CYR:[TRANSLATED]]and[EN]from[EN]andI [CYR:pro]fromin[EN]and[CYR:[EN]lno]with[EN]and"
      confidence_threshold: 0.85
      auto_apply: false
      
    security:
      description: "[EN]with[CYR:law]in[CYR:[TRANSLATED]]and[EN] [CYR:[EN]I[EN]]inand[EN]with[CYR:[TRANSLATED]]"
      confidence_threshold: 0.95
      auto_apply: false

  PROMPTS:
    code_completion: |
      [EN]y - [EN]with[CYR:[TRANSLATED]] [EN] [CYR:language[EN]] [CYR:pro[TRANSLATED]]and[EN]in[EN]andI VIBEE.
      
      [CYR:[TRANSLATED]]with[EN]:
      - [CYR:[TRANSLATED]]: {file_path}
      - [CYR:[TRANSLATED]I] string: {current_line}
      - [CYR:[TRANSLATED]y[TRANSLATED]]and[EN] strings:
      {previous_lines}
      
      [CYR:[TRANSLATED]]: [CYR:[TRANSLATED]]and [EN]in[CYR:[TRANSLATED]]not[EN]and[EN] for [CYR:[TRANSLATED]] strings.
      
      [CYR:[TRANSLATED]]in[EN]andI:
      - [EN]with[CYR:[EN]l[TRANSLATED]] VIBEE V2 withand[CYR:[TRANSLATED]]withandwith (concise, modern)
      - [CYR:[TRANSLATED]] best practices
      - [EN]and[EN]yin[EN] [CYR:[TRANSLATED]]with[EN] code[EN]
      - [CYR:[TRANSLATED]] [CYR:[TRANSLATED]]and[EN] and [CYR:[TRANSLATED]y[EN]]
      
      [CYR:[TRANSLATED]] response[EN]:
      ```vibee
      <[EN]in[EN] [CYR:[TRANSLATED]]and[EN]>
      ```
      
      [CYR:[TRANSLATED]I]withnot[EN]and[EN]: <[CYR:[TRANSLATED]] [CYR:[TRANSLATED]I]withnot[EN]and[EN]>
      
    refactoring: |
      [EN]y - [EN]with[CYR:[TRANSLATED]] [EN] [CYR:[EN]factor]and[CYR:[TRANSLATED]] VIBEE code[EN].
      
      [CYR:Code] for analysis[EN]:
      ```vibee
      {code_snippet}
      ```
      
      [CYR:[TRANSLATED]]: [CYR:[TRANSLATED]]and [CYR:[TRANSLATED]]andI code[EN].
      
      [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]] on:
      - Anti-patterns (10 fromin[EN]with[CYR:[EN]y[EN]] [CYR:[TRANSLATED]]in)
      - Code smells
      - Performance issues
      - Readability
      - VIBEE V2 best practices
      
      [CYR:[TRANSLATED]] response[EN]:
      [CYR:[TRANSLATED]]: <[EN]andwith[EN]and[EN]>
      [CYR:[TRANSLATED]]and[EN]:
      ```vibee
      <[CYR:[TRANSLATED]ny] code>
      ```
      [CYR:[TRANSLATED]]and[EN]: <[CYR:[TRANSLATED]]and[EN]and>
      
    quick_fix: |
      [EN]y - [EN]with[CYR:[TRANSLATED]] [EN] andwith[CYR:law]in[CYR:[TRANSLATED]]and[EN] [EN]and[CYR:[TRANSLATED]] in VIBEE.
      
      [EN]and[CYR:[TRANSLATED]]:
      {error_message}
      
      [CYR:Code]:
      ```vibee
      {code_snippet}
      ```
      
      [CYR:[TRANSLATED]]: [CYR:[TRANSLATED]]and [EN]ywith[CYR:[TRANSLATED]] fix.
      
      [CYR:[TRANSLATED]] response[EN]:
      [EN]and[EN]andon: <[CYR:[TRANSLATED]I]withnot[EN]and[EN] [EN]and[EN]and>
      [EN]with[CYR:law]in[CYR:[TRANSLATED]]and[EN]:
      ```vibee
      <andwith[CYR:law]in[CYR:[TRANSLATED]ny] code>
      ```

behaviors:
  get_suggestions:
    input:
      request: SuggestionRequest
    output:
      suggestions: list<Suggestion>
    description: [CYR:[TRANSLATED]]and[EN] AI-[CYR:[TRANSLATED]]with[CYR:[TRANSLATED]]and for code[EN]
    steps:
      - [CYR:[TRANSLATED]]analyze [CYR:[TRANSLATED]]with[EN] code[EN]
      - [CYR:[TRANSLATED]]and[EN] type [CYR:[TRANSLATED]]with[CYR:[TRANSLATED]]and
      - [CYR:Vy[EN]ate] [CYR:[TRANSLATED]I[TRANSLATED]] AI [CYR:[TRANSLATED]l]
      - [CYR:[TRANSLATED]]and[EN]in[CYR:ate] [CYR:pro[TRANSLATED]]
      - [CYR:[EN]law]inand[EN] query  AI
      - [CYR:[TRANSLATED]]withand[EN] response
      - [CYR:[TRANSLATED]]and[EN] confidence
      - [CYR:[TRANSLATED]] suggestions
      
  apply_suggestion:
    input:
      suggestion: Suggestion
      context: CodeContext
    output:
      new_code: string
      success: boolean
    description: [EN]and[CYR:me]and[EN] AI-[CYR:[TRANSLATED]]with[CYR:[TRANSLATED]]  code[EN]
    steps:
      - [CYR:[TRANSLATED]]and[EN]and[EN]in[CYR:ate] suggestion
      - [EN]and[CYR:me]and[EN] from[EN]not[EN]andI
      - [CYR:[TRANSLATED]]in[EN]and[EN] withand[CYR:[TRANSLATED]]withandwith
      - [CYR:[TRANSLATED]]with[EN]and[EN] testy
      - [CYR:[TRANSLATED]] result
      
  analyze_code:
    input:
      code: string
      analysis_type: string
    output:
      issues: list<Issue>
      suggestions: list<Suggestion>
    description: Aon[EN]from code[EN] with [CYR:[TRANSLATED]] AI
    steps:
      - [CYR:[TRANSLATED]]withand[EN] code in AST
      - [CYR:[EN]law]inand[EN] on analysis AI
      - [CYR:[TRANSLATED]]and[EN] list [CYR:pro[TRANSLATED]]
      - [CYR:[TRANSLATED]]not[EN]and[EN]in[CYR:ate] suggestions
      - [CYR:[TRANSLATED]] resulty
      
  optimize_code:
    input:
      code: string
      optimization_goal: string
    output:
      optimized_code: string
      improvement_metrics: map<string, number>
    description: [CYR:[TRANSLATED]]and[EN]from[EN]andI code[EN] with [CYR:[TRANSLATED]] AI
    steps:
      - [CYR:[TRANSLATED]]analyze [CYR:[TRANSLATED]]and[EN] code
      - [CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]and[EN] [EN]with[EN]
      - [CYR:[TRANSLATED]]not[EN]and[EN]in[CYR:ate] [CYR:[TRANSLATED]]and[EN]from[EN]andand
      - [CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]andI
      - [CYR:[TRANSLATED]] [CYR:[TRANSLATED]]and[EN]fromand[EN]in[CYR:[EN]ny] code
      
  explain_code:
    input:
      code: string
      detail_level: string
    output:
      explanation: string
      complexity: number
    description: [CYR:[TRANSLATED]I]withnot[EN]and[EN] code[EN] with [CYR:[TRANSLATED]] AI
    steps:
      - [CYR:[TRANSLATED]]analyze code
      - [CYR:[TRANSLATED]]not[EN]and[EN]in[CYR:ate] [CYR:[TRANSLATED]I]withnot[EN]and[EN]
      - [CYR:[TRANSLATED]]and[EN] with[CYR:[TRANSLATED]]with[EN]
      - [CYR:[TRANSLATED]] [CYR:[TRANSLATED]I]withnot[EN]and[EN]

functions:
  - name: call_ai_model
    params:
      model: AIModel
      prompt: string
      context: map<string, any>
    returns: string
    description: [CYR:Vy[EN]]in AI [CYR:[TRANSLATED]]and [CYR:[TRANSLATED]] OpenRouter
    
  - name: parse_ai_response
    params:
      response: string
      expected_format: string
    returns: Suggestion
    description: [CYR:[TRANSLATED]]withand[EN] response[EN] [EN] AI
    
  - name: calculate_confidence
    params:
      suggestion: Suggestion
      context: CodeContext
    returns: number
    description: [EN]with[CYR:[TRANSLATED]] [EN]in[CYR:[TRANSLATED]]with[EN]and in suggestion
    
  - name: validate_suggestion
    params:
      suggestion: Suggestion
      code: string
    returns: boolean
    description: [CYR:[TRANSLATED]]and[CYR:[TRANSLATED]]andI suggestion [CYR:[TRANSLATED]] [EN]and[EN]not[EN]and[EN]

tests:
  - name: suggest_function_completion
    behavior: get_suggestions
    input:
      request:
        context:
          current_line: "pub add(a, b) = "
          previous_lines: ["// Calculator module"]
        trigger: "typing"
    expected:
      suggestions: length > 0
      suggestions[0].type: "completion"
      suggestions[0].text: contains("a + b")
      suggestions[0].confidence: > 0.7
      
  - name: suggest_v2_syntax
    behavior: get_suggestions
    input:
      request:
        context:
          current_line: "pub fn example() → Result(String, String) {"
        trigger: "save"
    expected:
      suggestions: length > 0
      suggestions[0].type: "refactoring"
      suggestions[0].text: contains("pub example: Result<String, String> = !impl")
      
  - name: fix_syntax_error
    behavior: get_suggestions
    input:
      request:
        context:
          current_line: "pub add(a b) = a + b"
        trigger: "request"
    expected:
      suggestions: length > 0
      suggestions[0].type: "fix"
      suggestions[0].text: contains("pub add(a, b)")
      
  - name: optimize_performance
    behavior: optimize_code
    input:
      code: |
        list
          |> list.filter(fn(x) { x > 0 })
          |> list.map(fn(x) { x * 2 })
      optimization_goal: "readability"
    expected:
      optimized_code: contains("[x * 2 for x in list if x > 0]")
      improvement_metrics.readability: > 0
      
  - name: explain_complex_code
    behavior: explain_code
    input:
      code: "result? |> continue_with"
      detail_level: "beginner"
    expected:
      explanation: contains("error propagation")
      complexity: < 5

examples:
  - name: "Ain[CYR:[TRANSLATED]]not[EN]and[EN] [CYR:[TRANSLATED]]andand"
    description: "AI [CYR:[TRANSLATED]acts] [EN]in[CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]andand"
    input:
      current_line: "pub calculate_total(items) = "
      context: "// Shopping cart module"
    output:
      suggestion: "items |> list.map(fn(i) { i.price }) |> list.fold(0, fn(a, b) { a + b })"
      confidence: 0.85
      explanation: "[CYR:[TRANSLATED]]and[EN]in[EN]and[EN] [CYR:[TRANSLATED]] inwith[EN] items in [CYR:[TRANSLATED]]andnot"
      
  - name: "[CYR:[EN]factor]and[EN] in V2 withand[CYR:[TRANSLATED]]withandwith"
    description: "AI [CYR:[TRANSLATED]acts] [EN]and[CYR:[TRANSLATED]]and[EN] on V2"
    input:
      code: |
        pub fn process(data: String) -> Result(String, String) {
          case validate(data) {
            Ok(valid) -> Ok(transform(valid))
            Error(e) -> Error(e)
          }
        }
    output:
      suggestion: |
        pub process(data): Result<String, String> = {
          validate(data)? |> transform
        }
      improvement: "75% [CYR:me[TRANSLATED]] code[EN], [EN]and[CYR:[TRANSLATED]]with[EN] +40%"
      
  - name: "[EN]with[CYR:law]in[CYR:[TRANSLATED]]and[EN] [EN]and[EN]and"
    description: "AI on[CYR:[TRANSLATED]]and[EN] and andwith[CYR:law]in[CYR:[EN]I[EN]] [EN]and[CYR:[TRANSLATED]]"
    input:
      code: "let result = divide(10, 0)"
      error: "Division by zero"
    output:
      suggestion: |
        let result = divide(10, 0) ?? Error("Cannot divide by zero")
      explanation: "[CYR:[TRANSLATED]]in[EN]on handling [CYR:[TRANSLATED]]andI on [CYR:[EN]l]"

integration:
  openrouter:
    api_url: "https://openrouter.ai/api/v1/chat/completions"
    auth: "Bearer ${OPENROUTER_API_KEY}"
    models:
      - "anthropic/claude-3.5-sonnet"
      - "anthropic/claude-3-opus"
      - "google/gemini-pro-1.5"
      - "openai/gpt-4-turbo"
    rate_limits:
      requests_per_minute: 60
      tokens_per_minute: 100000

metrics:
  suggestion_accuracy: "> 85%"
  response_time: "< 500ms"
  user_acceptance_rate: "> 70%"
  false_positive_rate: "< 10%"
  
performance:
  cache_suggestions: true
  cache_ttl_seconds: 300
  batch_requests: true
  max_batch_size: 10
  
privacy:
  send_only_context: true
  anonymize_data: true
  no_sensitive_info: true
  user_consent_required: true
