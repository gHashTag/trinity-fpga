name: ai_code_suggestions
version: 1.0.0
description: AI-powered code suggestions for VIBEE - [CYR:умные] [CYR:под]with[CYR:казк]and in [CYR:реальном] in[CYR:ремен]and

metadata:
  author: VIBEE Team
  category: ai_integration
  tags: [ai, llm, code-completion, suggestions, openrouter]
  created: 2024-01-10

types:
  CodeContext:
    file_path: string
    cursor_position: Position
    current_line: string
    previous_lines: list<string>
    next_lines: list<string>
    imports: list<string>
    functions: list<string>
    types: list<string>
    
  Position:
    line: number
    column: number
    
  Suggestion:
    id: string
    text: string
    type: string  # completion, refactoring, fix, optimization
    confidence: number
    explanation: string
    code_snippet: string
    apply_automatically: boolean
    
  AIModel:
    provider: string  # openrouter, anthropic, openai
    model: string
    temperature: number
    max_tokens: number
    
  SuggestionRequest:
    context: CodeContext
    trigger: string  # typing, save, request
    preferences: UserPreferences
    
  UserPreferences:
    auto_apply_high_confidence: boolean
    show_explanations: boolean
    preferred_style: string
    max_suggestions: number

constants:
  AI_MODELS:
    - provider: "openrouter"
      model: "anthropic/claude-3.5-sonnet"
      temperature: 0.3
      max_tokens: 2000
      use_case: "code_completion"
      
    - provider: "openrouter"
      model: "anthropic/claude-3-opus"
      temperature: 0.2
      max_tokens: 4000
      use_case: "refactoring"
      
    - provider: "openrouter"
      model: "google/gemini-pro-1.5"
      temperature: 0.1
      max_tokens: 1000
      use_case: "quick_fixes"

  SUGGESTION_TYPES:
    completion:
      description: "Аin[CYR:тодопол]notнandе codeа"
      confidence_threshold: 0.7
      auto_apply: true
      
    refactoring:
      description: "[CYR:Предложен]andя по [CYR:рефактор]and[CYR:нгу]"
      confidence_threshold: 0.8
      auto_apply: false
      
    fix:
      description: "Иwith[CYR:пра]in[CYR:лен]andе ошand[CYR:бок]"
      confidence_threshold: 0.9
      auto_apply: false
      
    optimization:
      description: "[CYR:Опт]andмfromацandя [CYR:про]frominодand[CYR:тельно]withтand"
      confidence_threshold: 0.85
      auto_apply: false
      
    security:
      description: "Иwith[CYR:пра]in[CYR:лен]andе [CYR:уяз]inandмоwith[CYR:тей]"
      confidence_threshold: 0.95
      auto_apply: false

  PROMPTS:
    code_completion: |
      Ты - экwith[CYR:перт] по [CYR:языку] [CYR:программ]andроinанandя VIBEE.
      
      [CYR:Контек]withт:
      - [CYR:Файл]: {file_path}
      - [CYR:Текущая] string: {current_line}
      - [CYR:Предыдущ]andе strings:
      {previous_lines}
      
      [CYR:Задача]: [CYR:Предлож]and аin[CYR:тодопол]notнandе for [CYR:текущей] strings.
      
      [CYR:Требо]inанandя:
      - Иwith[CYR:пользуй] VIBEE V2 withand[CYR:нтак]withandwith (concise, modern)
      - [CYR:Следуй] best practices
      - Учandтыinай [CYR:контек]withт codeа
      - [CYR:Будь] [CYR:кратк]andм and [CYR:точным]
      
      [CYR:Формат] responseа:
      ```vibee
      <тinое [CYR:предложен]andе>
      ```
      
      [CYR:Объя]withnotнandе: <[CYR:краткое] [CYR:объя]withnotнandе>
      
    refactoring: |
      Ты - экwith[CYR:перт] по [CYR:рефактор]and[CYR:нгу] VIBEE codeа.
      
      [CYR:Код] for analysisа:
      ```vibee
      {code_snippet}
      ```
      
      [CYR:Задача]: [CYR:Предлож]and [CYR:улучшен]andя codeа.
      
      [CYR:Про]in[CYR:ерь] on:
      - Anti-patterns (10 frominеwith[CYR:тных] [CYR:паттерно]in)
      - Code smells
      - Performance issues
      - Readability
      - VIBEE V2 best practices
      
      [CYR:Формат] responseа:
      [CYR:Проблема]: <опandwithанandе>
      [CYR:Решен]andе:
      ```vibee
      <[CYR:улучшенный] code>
      ```
      [CYR:Улучшен]andе: <[CYR:метр]andкand>
      
    quick_fix: |
      Ты - экwith[CYR:перт] по andwith[CYR:пра]in[CYR:лен]andю ошand[CYR:бок] in VIBEE.
      
      Ошand[CYR:бка]:
      {error_message}
      
      [CYR:Код]:
      ```vibee
      {code_snippet}
      ```
      
      [CYR:Задача]: [CYR:Предлож]and быwith[CYR:трое] fix.
      
      [CYR:Формат] responseа:
      Прandчandon: <[CYR:объя]withnotнandе ошandбкand>
      Иwith[CYR:пра]in[CYR:лен]andе:
      ```vibee
      <andwith[CYR:пра]in[CYR:ленный] code>
      ```

behaviors:
  get_suggestions:
    input:
      request: SuggestionRequest
    output:
      suggestions: list<Suggestion>
    description: [CYR:Получ]andть AI-[CYR:под]with[CYR:казк]and for codeа
    steps:
      - [CYR:Про]analyze [CYR:контек]withт codeа
      - [CYR:Определ]andть type [CYR:под]with[CYR:казк]and
      - [CYR:Выбрать] [CYR:подходящую] AI [CYR:модель]
      - [CYR:Сформ]andроin[CYR:ать] [CYR:промпт]
      - [CYR:Отпра]inandть query к AI
      - [CYR:Пар]withandть response
      - [CYR:Оцен]andть confidence
      - [CYR:Вернуть] suggestions
      
  apply_suggestion:
    input:
      suggestion: Suggestion
      context: CodeContext
    output:
      new_code: string
      success: boolean
    description: Прand[CYR:мен]andть AI-[CYR:под]with[CYR:казку] к codeу
    steps:
      - [CYR:Вал]andдandроin[CYR:ать] suggestion
      - Прand[CYR:мен]andть fromмеnotнandя
      - [CYR:Про]inерandть withand[CYR:нтак]withandwith
      - [CYR:Запу]withтandть testы
      - [CYR:Вернуть] result
      
  analyze_code:
    input:
      code: string
      analysis_type: string
    output:
      issues: list<Issue>
      suggestions: list<Suggestion>
    description: Аonлfrom codeа with [CYR:помощью] AI
    steps:
      - [CYR:Пар]withandть code in AST
      - [CYR:Отпра]inandть on analysis AI
      - [CYR:Получ]andть list [CYR:проблем]
      - [CYR:Сге]notрandроin[CYR:ать] suggestions
      - [CYR:Вернуть] resultы
      
  optimize_code:
    input:
      code: string
      optimization_goal: string
    output:
      optimized_code: string
      improvement_metrics: map<string, number>
    description: [CYR:Опт]andмfromацandя codeа with [CYR:помощью] AI
    steps:
      - [CYR:Про]analyze [CYR:текущ]andй code
      - [CYR:Определ]andть [CYR:узк]andе меwithта
      - [CYR:Сге]notрandроin[CYR:ать] [CYR:опт]andмfromацandand
      - [CYR:Измер]andть [CYR:улучшен]andя
      - [CYR:Вернуть] [CYR:опт]andмfromandроin[CYR:анный] code
      
  explain_code:
    input:
      code: string
      detail_level: string
    output:
      explanation: string
      complexity: number
    description: [CYR:Объя]withnotнandе codeа with [CYR:помощью] AI
    steps:
      - [CYR:Про]analyze code
      - [CYR:Сге]notрandроin[CYR:ать] [CYR:объя]withnotнandе
      - [CYR:Оцен]andть with[CYR:ложно]withть
      - [CYR:Вернуть] [CYR:объя]withnotнandе

functions:
  - name: call_ai_model
    params:
      model: AIModel
      prompt: string
      context: map<string, any>
    returns: string
    description: [CYR:Вызо]in AI [CYR:модел]and [CYR:через] OpenRouter
    
  - name: parse_ai_response
    params:
      response: string
      expected_format: string
    returns: Suggestion
    description: [CYR:Пар]withandнг responseа от AI
    
  - name: calculate_confidence
    params:
      suggestion: Suggestion
      context: CodeContext
    returns: number
    description: Раwith[CYR:чет] уin[CYR:еренно]withтand in suggestion
    
  - name: validate_suggestion
    params:
      suggestion: Suggestion
      code: string
    returns: boolean
    description: [CYR:Вал]and[CYR:дац]andя suggestion [CYR:перед] прandмеnotнandем

tests:
  - name: suggest_function_completion
    behavior: get_suggestions
    input:
      request:
        context:
          current_line: "pub add(a, b) = "
          previous_lines: ["// Calculator module"]
        trigger: "typing"
    expected:
      suggestions: length > 0
      suggestions[0].type: "completion"
      suggestions[0].text: contains("a + b")
      suggestions[0].confidence: > 0.7
      
  - name: suggest_v2_syntax
    behavior: get_suggestions
    input:
      request:
        context:
          current_line: "pub fn example() → Result(String, String) {"
        trigger: "save"
    expected:
      suggestions: length > 0
      suggestions[0].type: "refactoring"
      suggestions[0].text: contains("pub example: Result<String, String> = !impl")
      
  - name: fix_syntax_error
    behavior: get_suggestions
    input:
      request:
        context:
          current_line: "pub add(a b) = a + b"
        trigger: "request"
    expected:
      suggestions: length > 0
      suggestions[0].type: "fix"
      suggestions[0].text: contains("pub add(a, b)")
      
  - name: optimize_performance
    behavior: optimize_code
    input:
      code: |
        list
          |> list.filter(fn(x) { x > 0 })
          |> list.map(fn(x) { x * 2 })
      optimization_goal: "readability"
    expected:
      optimized_code: contains("[x * 2 for x in list if x > 0]")
      improvement_metrics.readability: > 0
      
  - name: explain_complex_code
    behavior: explain_code
    input:
      code: "result? |> continue_with"
      detail_level: "beginner"
    expected:
      explanation: contains("error propagation")
      complexity: < 5

examples:
  - name: "Аin[CYR:тодопол]notнandе [CYR:функц]andand"
    description: "AI [CYR:предлагает] заin[CYR:ершен]andе [CYR:функц]andand"
    input:
      current_line: "pub calculate_total(items) = "
      context: "// Shopping cart module"
    output:
      suggestion: "items |> list.map(fn(i) { i.price }) |> list.fold(0, fn(a, b) { a + b })"
      confidence: 0.85
      explanation: "[CYR:Сумм]andроinанandе [CYR:цен] inwithех items in [CYR:корз]andnot"
      
  - name: "[CYR:Рефактор]andнг in V2 withand[CYR:нтак]withandwith"
    description: "AI [CYR:предлагает] мand[CYR:грац]andю on V2"
    input:
      code: |
        pub fn process(data: String) -> Result(String, String) {
          case validate(data) {
            Ok(valid) -> Ok(transform(valid))
            Error(e) -> Error(e)
          }
        }
    output:
      suggestion: |
        pub process(data): Result<String, String> = {
          validate(data)? |> transform
        }
      improvement: "75% [CYR:меньше] codeа, чand[CYR:таемо]withть +40%"
      
  - name: "Иwith[CYR:пра]in[CYR:лен]andе ошandбкand"
    description: "AI on[CYR:ход]andт and andwith[CYR:пра]in[CYR:ляет] ошand[CYR:бку]"
    input:
      code: "let result = divide(10, 0)"
      error: "Division by zero"
    output:
      suggestion: |
        let result = divide(10, 0) ?? Error("Cannot divide by zero")
      explanation: "[CYR:Доба]inлеon handling [CYR:делен]andя on [CYR:ноль]"

integration:
  openrouter:
    api_url: "https://openrouter.ai/api/v1/chat/completions"
    auth: "Bearer ${OPENROUTER_API_KEY}"
    models:
      - "anthropic/claude-3.5-sonnet"
      - "anthropic/claude-3-opus"
      - "google/gemini-pro-1.5"
      - "openai/gpt-4-turbo"
    rate_limits:
      requests_per_minute: 60
      tokens_per_minute: 100000

metrics:
  suggestion_accuracy: "> 85%"
  response_time: "< 500ms"
  user_acceptance_rate: "> 70%"
  false_positive_rate: "< 10%"
  
performance:
  cache_suggestions: true
  cache_ttl_seconds: 300
  batch_requests: true
  max_batch_size: 10
  
privacy:
  send_only_context: true
  anonymize_data: true
  no_sensitive_info: true
  user_consent_required: true
