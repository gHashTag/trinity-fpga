// Reels Creation Action (ElizaOS Architecture)
  // Performance Warning:   // AI Suggestion: Replace magic numbers with named constants  // AI Suggestion: Consider extracting hardcoded strings to constants// Converted from infra/agent/actions/reels_action.gleam → dsl/infra/agent/actions/reels_action.vibee
//
// NO COMMANDS! This action triggers based on conversation context.
// validate() detects intent through NLP patterns, not /reels command.
//
// Trigger patterns (similes):
// - "with[CYR:оздай] рandлwith", "with[CYR:делай] inand[CYR:део] for рandлwith"
// - "[CYR:хочу] inand[CYR:део] for andнwith[CYR:таграм]"
// - "[CYR:нужен] [CYR:контент] for withоцwith[CYR:етей]"
// - "геnotрand[CYR:руй] reels", "make a reel"

import "../eliza.vibee" as eliza

// =============================================================================
// Types
// =============================================================================

struct RenderStatus(
  RenderStatus(
    completed: bool,
    video_url: str?,
    error: str?
  )
}

// =============================================================================
// Reels Action Definition
// =============================================================================

@spec create_reels_action() → Action {
  /// Create the Reels Action
  given: Nothing
  when: Setting up action registry
  then: Returns reels creation action
}

@impl {
  Action(
    "CREATE_REELS",
    "Creates Instagram-style reels video with AI-generated content. Uses type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int}'s photo for avatar, generates script, TTS, lipsync, and B-roll.",
    // Similes for NLP matching
    [
      "with[CYR:оздай] рandлwith", "with[CYR:делай] рandлwith", "рandлwith inand[CYR:део]",
      "with[CYR:оздай] inand[CYR:део] for andнwith[CYR:таграм]", "inand[CYR:део] for andнwithты",
      "make a reel", "create reels", "instagram video",
      "withгеnotрand[CYR:руй] inand[CYR:део]", "[CYR:хочу] рandлwith", "[CYR:нужен] рandлwith",
      "[CYR:контент] for reels", "reels creator"
    ],
    // Example messages
    [
      "[CYR:Создай] рandлwith [CYR:про] [CYR:продукт]andinноwithть",
      "[CYR:Хочу] inand[CYR:део] for andнwith[CYR:таграма] о бfromnotwithе",
      "[CYR:Сделай] мnot reels on [CYR:тему] [CYR:заработка]",
      "Make a reel about productivity tips",
      "[CYR:Нужен] рandлwith for [CYR:моего] [CYR:продукта]"
    ],
    { validate_reels_request(it) },
    { handle_reels_creation(it) }
  )
}

// =============================================================================
// Validate Function
// =============================================================================

trace("agent.reels_action.validate")
@spec validate_reels_request(context: ActionContext) → bool {
  /// Validate if message context indicates reels creation intent
  /// Returns true if ANY of the similes match in message
  given: Action context
  when: Checking for reels intent
  then: Returns true if should handle
}

@impl {
  let message = string.lowercase(context.message)

  // Check for explicit reels keywords
  let reels_keywords = [
    "рandлwith", "reels", "рandлз",
    "inand[CYR:део] for andнwithта", "video for insta",
    "inand[CYR:део] for withоцwithет", "social media video"
  ]

  // Check for creation intent
  let creation_intent = [
    "with[CYR:оздай]", "with[CYR:делай]", "withгеnotрand[CYR:руй]", "[CYR:хочу]",
    "create", "make", "generate", "need"
  ]

  // Must have BOTH: reels keyword AND creation intent
  let has_reels = list.fn(kw · any {
    string.kw · contains
  }

  let has_intent = list.fn(intent · any {
    string.intent · contains
  }

  has_reels && has_intent
}

