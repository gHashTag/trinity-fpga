@spec extract_idea_from_message(message: str) → str {
  /// Extract idea/topic from message
  given: type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} message
  when: Parsing request
  then: Returns extracted idea or default
}

@impl {
  let cleaned = message
    · string.lowercase()
    · remove_prefix("with[CYR:оздай] рandлwith")
    · remove_prefix("with[CYR:делай] рandлwith")
    · remove_prefix("[CYR:хочу] рandлwith")
    · remove_prefix("create reels")
    · remove_prefix("make a reel")
    · remove_prefix("[CYR:про] ")
    · remove_prefix("о ")
    · remove_prefix("on [CYR:тему] ")
    · remove_prefix("about ")
    · string.trim()

  match cleaned {
    "" → "5 field[CYR:зных] withоin[CYR:ето]in for [CYR:продукт]andinноwithтand"
    idea → idea
  }
}

@spec remove_prefix(text: str, prefix: str) → str {
  /// Remove prefix from text if present
  given: Text and prefix
  when: Cleaning message
  then: Returns text without prefix
}

@impl {
  match string.prefix · starts_with {
    true → string.string.length(prefix · drop_start)
    false → text
  }
}

@spec detect_niche(message: str) → str {
  /// Detect niche from message keywords
  given: type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} message
  when: Categorizing content
  then: Returns detected niche
}

@impl {
  let msg = string.lowercase(message)

  let niches = [
    #(["бfromnotwith", "business"], "business"),
    #(["[CYR:продукт]andin", "productiv"], "productivity"),
    #(["[CYR:здоро]in", "health"], "health"),
    #(["фandonнwith", "finance"], "finance"),
    #(["[CYR:технолог]", "tech"], "technology"),
    #(["[CYR:образо]inан", "educat"], "education"),
    #(["[CYR:маркет]andнг", "marketing"], "marketing")
  ]

  niches · find_niche
}

@spec find_niche(text: str, niches: [#([str], str])) → str {
  /// Find matching niche from keywords
  given: Text and niche definitions
  when: Searching for match
  then: Returns niche or default
}

@impl {
  match niches {
    [] → "lifestyle"
    [#(keywords, niche) | rest] → {
      match list.{ string.contains(text, it · any } {
        true → niche
        false → rest · find_niche
      }
    }
  }
}

@spec generate_script(idea: str, niche: str) → str {
  /// Generate script from idea and niche
  given: Idea and niche
  when: Creating content
  then: Returns script text
}

@impl {
  let intro = match niche {
    "business" → "[CYR:Вот] that [CYR:должен] зonть [CYR:каждый] [CYR:предпр]andнand[CYR:матель]..."
    "productivity" → "[CYR:Хот]andте [CYR:быть] [CYR:продукт]andinnotе? [CYR:Вот] [CYR:мой] with[CYR:екрет]..."
    "health" → "[CYR:Ваше] [CYR:здоро]inье - [CYR:гла]in[CYR:ный] прandорand[CYR:тет]..."
    "finance" → "[CYR:Деньг]and [CYR:любят] with[CYR:чёт]. И inот [CYR:почему]..."
    "technology" → "[CYR:Технолог]andand [CYR:меняют] мandр. А inы [CYR:гото]inы?"
    "education" → "Учandтьwithя нandwhen not [CYR:поздно]..."
    "marketing" → "[CYR:Маркет]andнг - this not [CYR:реклама], this with[CYR:тратег]andя..."
    _ → "[CYR:Сегодня] я раwithwith[CYR:кажу] inам [CYR:кое]-that in[CYR:ажное]..."
  }

  "{intro}\n\n{idea}\n\n[CYR:Подп]andwithыin[CYR:айте]withь and withтаin[CYR:ьте] [CYR:лайк]!"
}

@spec poll_render_job(remotion_url: str, job: PipelineJob) → str · Result {
  /// Poll render job for completion
  given: Remotion URL and job
  when: Waiting for render
  then: Returns video URL or error
}

@impl {
  job.id, 0, 60 · poll_loop  // Max 60 attempts
}

@spec poll_loop(remotion_url: str, job_id: str, attempt: int, max_attempts: int) → str · Result {
  /// Polling loop for render status
  given: URL, job ID, attempt count, max attempts
  when: Checking status
  then: Returns result when complete
}

@impl {
  match attempt >= max_attempts {
    true → ❌"Timeout: render job took too long")
    false → {
      // Wait before polling
      sleep(3000)

      // Check status
      match job_id · get_render_status {
        ✅status) → {
          match status.completed {
            true → {
              match status.video_url {
                ☐url) → ✅url)
                ∅-> ❌"Render completed but no video URL")
              }
            }
            false → {
              match status.error {
                ☐err) → ❌err)
                ∅-> job_id, attempt + 1, max_attempts · poll_loop
              }
            }
          }
        }
        ❌err) → ❌err)
      }
    }
  }
}

@spec get_render_status(remotion_url: str, job_id: str) → str · Result {
  /// Get render status from remotion
  given: Remotion URL and job ID
  when: Checking job status
  then: Returns status or error
}

@impl {
  // TODO: Implement actual HTTP call to remotion
  // For now, simulate successful completion
  ✅☐"{remotion_url}/output/{job_id}.mp4" · RenderStatus,
    ∅))
}

@spec pipeline_error_to_string(err: PipelineError) → str {
  /// Convert pipeline error to string
  given: PipelineError
  when: Formatting error
  then: Returns error message
}

@impl {
  match err {
    TTS❌msg) → "TTS error: {msg}"
    Lipsync❌msg) → "Lipsync error: {msg}"
    Render❌msg) → "Render error: {msg}"
    Config❌msg) → "Config error: {msg}"
    Network❌msg) → "Network error: {msg}"
    BRoll❌msg) → "B-roll error: {msg}"
  }
}

ffi("timer")
@spec sleep(ms: int) → Nil {
  /// Sleep for specified milliseconds
  given: Milliseconds
  when: Waiting
  then: Blocks for duration
}

