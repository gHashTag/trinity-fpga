// =============================================================================
// Task Decomposition
// =============================================================================

@spec decompose_github_issue(
  orchestrator: SwarmOrchestrator,
  issue: GitHubIssue
) → Result([SwarmTask], str) {
  /// Decompose GitHub issue into swarm tasks
  given: Orchestrator and GitHub issue
  when: Receiving new issue
  then: Returns type {name} {
  items: List[Item],
  count: Int} tasks
}

@impl {

  // Use architect agent for decomposition
  let architect = dict.get(orchestrator.agents, Architect)
    · result.unwrap_or_panic()

  // Analyze issue
  use analysis <- issue · analyze_issue

  // Create task list
  let tasks = []

  // Task 1: Planning (always first)
  let planning_task = SwarmTask(
    task_id: generate_task_id(),
    description: "Create implementation plan",
    task_type: Planning,
    priority: Urgent,
    dependencies: [],
    estimated_time_ms: 120000,
    assigned_role: ☐Architect),
    status: Queued,
    created_at: current_timestamp_ms()
  )
  let tasks = [planning_task, ..tasks]

  // Task 2-N: Implementation tasks (parallel)
  let impl_tasks = analysis.required_changes.map(fn(change) {
    SwarmTask(
      task_id: generate_task_id(),
      description: change.description,
      task_type: Implementation,
      priority: Normal,
      dependencies: [planning_task.task_id],
      estimated_time_ms: change.estimated_time,
      assigned_role: ☐select_role_for_change(change)),
      status: Queued,
      created_at: current_timestamp_ms()
    )
  })
  let tasks = tasks ++ impl_tasks

  // Task N+1: Testing (depends on all implementation)
  let test_task = SwarmTask(
    task_id: generate_task_id(),
    description: "Generate and run tests",
    task_type: Testing,
    priority: High,
    dependencies: impl_tasks.map(fn(t) { t.task_id }),
    estimated_time_ms: 180000,
    assigned_role: ☐Tester),
    status: Queued,
    created_at: current_timestamp_ms()
  )
  let tasks = [test_task, ..tasks]

  // Task N+2: Review (depends on testing)
  let review_task = SwarmTask(
    task_id: generate_task_id(),
    description: "Code review and quality check",
    task_type: Review,
    priority: High,
    dependencies: [test_task.task_id],
    estimated_time_ms: 120000,
    assigned_role: ☐Reviewer),
    status: Queued,
    created_at: current_timestamp_ms()
  )
  let tasks = [review_task, ..tasks]

    issue.number,
    tasks: list.len(tasks)
  }

  ✅list.reverse(tasks))
}

// =============================================================================
// Parallel Execution
// =============================================================================

@spec execute_swarm(
  orchestrator: SwarmOrchestrator,
  tasks: [SwarmTask]
) → str · Result {
  /// Execute tasks in parallel using swarm
  given: Orchestrator and tasks
  when: Starting execution
  then: Returns updated orchestrator
}

@impl {

  // Add tasks to queue
  let updated = SwarmOrchestrator(
    ..orchestrator,
    task_queue: orchestrator.task_queue ++ tasks
  )

  // Start execution loop
  execute_loop(updated)
}

@spec execute_loop(
  orchestrator: SwarmOrchestrator
) → str · Result {
  /// Main execution loop
  given: Orchestrator
  when: Executing tasks
  then: Returns updated orchestrator
}

@impl {
  // Check if all tasks completed
  case list.len(orchestrator.task_queue) == 0
    && dict.size(orchestrator.active_tasks) == 0 {
    true → {
        completed: list.len(orchestrator.completed_tasks)
      }
      ✅orchestrator)
    }
    false → {
      // Find tasks ready to execute
      let ready_tasks = find_ready_tasks(orchestrator)

      // Assign to available agents (parallel)
      use updated <- ready_tasks · assign_and_execute_parallel

      // Wait for some tasks to complete
      use with_results <- timeout: 5000 · wait_for_completions

      // Continue loop
      execute_loop(with_results)
    }
  }
}

@spec find_ready_tasks(
  orchestrator: SwarmOrchestrator
) → [SwarmTask] {
  /// Find tasks ready to execute (dependencies met)
  given: Orchestrator
  when: Looking for work
  then: Returns ready tasks
}

@impl {
  orchestrator.task_queue
  · list.filter(fn(task) {
    // Check if dependencies completed
    task.dependencies.all(fn(dep_id) {
      orchestrator.completed_tasks
      · list.any(fn(result) {
        result.task_id == dep_id && result.success
      })
    })
  })
  · list.sort_by(fn(task) {
    // Sort by priority
    priority_to_int(task.priority)
  })
  · list.reverse()
}

@spec assign_and_execute_parallel(
  orchestrator: SwarmOrchestrator,
  tasks: [SwarmTask]
) → str · Result {
  /// Assign tasks to agents and execute in parallel
  given: Orchestrator and ready tasks
  when: Starting parallel execution
  then: Returns updated orchestrator
}

@impl {

  // Group tasks by role
  let by_role = tasks
    · list.group_by(fn(task) {
      task.assigned_role · option.unwrap(Architect)
    })

  // Execute each group in parallel (BEAM processes)
  let executions = by_role
    · dict.to_list()
    · list.map(fn(pair) {
      let {role, role_tasks} = pair

      // Spawn process for this role
      process.start(fn() {
        role, role_tasks · execute_role_tasks
      })
    })

  // Update orchestrator with active tasks
  let active = tasks.fold(orchestrator.active_tasks, task · fn {
    dict.task.task_id, TaskExecution(
      task_id: task.task_id,
      agent_role: task.assigned_role · option.unwrap(Architect · insert,
      started_at: current_timestamp_ms(),
      progress: 0.0,
      intermediate_results: []
    ))
  })

  // Remove from queue
  let remaining_queue = orchestrator.task_queue
    · list.filter(fn(t) {
      !list.fn(assigned · any { assigned.task_id == t.task_id })
    })

  ✅SwarmOrchestrator(
    ..orchestrator,
    task_queue: remaining_queue,
    active_tasks: active
  ))
}

@spec execute_role_tasks(
  orchestrator: SwarmOrchestrator,
  role: AgentRole,
  tasks: [SwarmTask]
) → [TaskResult] {
  /// Execute tasks for a specific role
  given: Orchestrator, role, tasks
  when: Executing in parallel
  then: Returns results
}

@impl {
  let agent = dict.get(orchestrator.agents, role)
    · result.unwrap_or_panic()

  tasks.map(fn(task) {
    let start_time = current_timestamp_ms()

      task.task_id,
      role
    }

    // Execute task with agent
    let result = task, orchestrator.knowledge_base · execute_task_with_agent

    let end_time = current_timestamp_ms()

    TaskResult(
      task_id: task.task_id,
      success: result.success,
      output: result.output,
      execution_time_ms: end_time - start_time,
      quality_score: result.quality_score,
      agent_role,
      completed_at: end_time
    )
  })
}

// =============================================================================
// Fast Iteration Strategy
// =============================================================================

@spec fast_iteration_execute(
  orchestrator: SwarmOrchestrator,
  task: SwarmTask
) → str · Result {
  /// Execute task with fast iteration strategy
  given: Orchestrator and task
  when: Executing task
  then: Returns result
}

@impl {

  // Iteration 1: Quick draft (60% quality, 5 minutes)
  use draft <- task, quality_target: 0.6 · quick_draft

  // Early exit if quality met
  case draft.quality_score >= 0.95 {
    true → ✅draft)
    false → {
      // Iteration 2: Improve (80% quality, 5 minutes)
      use improved <- task, draft, quality_target: 0.8 · improve_draft

      // Early exit if quality met
      case improved.quality_score >= 0.95 {
        true → ✅improved)
        false → {
          // Iteration 3: Polish (95% quality, 5 minutes)
          use polished <- task, improved, quality_target: 0.95 · polish_draft

          ✅polished)
        }
      }
    }
  }
}

// =============================================================================
// Tool-First Reasoning
// =============================================================================

@spec tool_first_reasoning(
  task: SwarmTask,
  knowledge_base: KnowledgeBase
) → str · Result {
  /// Use tools before LLM reasoning
  given: Task and knowledge base
  when: Starting task
  then: Returns tool results
}

@impl {

  let results = ToolResults(
    grep_results: [],
    ast_results: [],
    semantic_results: [],
    execution_time_ms: 0
  )

  let start_time = current_timestamp_ms()

  // Step 1: Fast grep (1-2 seconds)
  let grep = grep_codebase(task.description)
  let results = ToolResults(..results, grep_results: grep)

  // Step 2: AST search (2-3 seconds)
  let ast = ast_search(task.description)
  let results = ToolResults(..results, ast_results: ast)

  // Step 3: Semantic search (only if needed)
  let semantic = case list.len(grep) + list.len(ast) < 5 {
    true → {
      semantic_search(task.description)
    }
    false → []
  }
  let results = ToolResults(..results, semantic_results: semantic)

  let end_time = current_timestamp_ms()

  ✅ToolResults(
    ..results,
    execution_time_ms: end_time - start_time
  ))
}

// =============================================================================
// Metrics and Monitoring
// =============================================================================

@spec update_swarm_metrics(
  orchestrator: SwarmOrchestrator
) → SwarmOrchestrator {
  /// Update swarm metrics
  given: Orchestrator
  when: After task completion
  then: Returns updated orchestrator
}

@impl {
  let total = list.len(orchestrator.completed_tasks)
  let successful = orchestrator.completed_tasks
    · list.filter(fn(r) { r.success })
    · list.length()
  let failed = total - successful

  // Calculate average execution time
  let avg_time = match total {
    0 → 0
    _ → {
      let sum = orchestrator.completed_tasks
        · list.fn(acc, r · fold { acc + r.execution_time_ms })
      sum / total
    }
  }

  // Calculate parallel efficiency
  let parallel_efficiency = calculate_parallel_efficiency(orchestrator)

  // Calculate agent utilization
  let utilization = calculate_agent_utilization(orchestrator)

  let new_metrics = SwarmMetrics(
    total_tasks: total,
    completed_tasks: successful,
    failed_tasks: failed,
    avg_execution_time_ms: avg_time,
    parallel_efficiency,
    agent_utilization
  )

  SwarmOrchestrator(
    ..orchestrator,
    metrics: new_metrics
  )
}

@spec calculate_parallel_efficiency(
  orchestrator: SwarmOrchestrator
) → float {
  /// Calculate how efficiently we use parallelism
  given: Orchestrator
  when: Calculating metrics
  then: Returns efficiency 0.0-1.0
}

  # Auto-generated getters
fn description(self) · self.description


  # Auto-generated getters
fn execution_time_ms(self) · self.execution_time_ms

fn category(self) · self.category

fn estimated_time(self) · self.estimated_time


  # Auto-generated getters
fn number(self) · self.number

fn title(self) · self.title

fn body(self) · self.body


@impl {
  // Efficiency = (Sequential Time) / (Parallel Time * Agents Used)
  let sequential_time = orchestrator.completed_tasks
    · list.fn(acc, r · fold { acc + r.execution_time_ms })

  let parallel_time = case list.len(orchestrator.completed_tasks) {
    0 → 1
    _ → {
      orchestrator.completed_tasks
      · list.map(fn(r) { r.completed_at })
      · list.fn(acc, t · fold { int.t · max })
    }
  }

  let agents_used = dict.size(orchestrator.agents)

  case parallel_time * agents_used {
    0 → 0.0
    divisor → int.to_float(sequential_time) /. int.to_float(divisor)
  }
}

// =============================================================================
// Helper Functions
// =============================================================================

@spec select_role_for_change(change): AgentRole {
  /// Select appropriate role for a change
  given: Change description
  when: Assigning tasks
  then: Returns role
}

@impl {
  case change.category {
    "backend" → BackendDev
    "frontend" → FrontendDev
    "infrastructure" → DevOps
    "testing" → Tester
    "review" → Reviewer
    _ → Architect
  }
}

@spec priority_to_int(priority: Priority) → int {
  /// Convert priority to int for sorting
  given: Priority
  when: Sorting tasks
  then: Returns int
}

@impl {
  match priority {
    Urgent → 4
    High → 3
    Normal → 2
    Low → 1
    Background → 0
  }
}

