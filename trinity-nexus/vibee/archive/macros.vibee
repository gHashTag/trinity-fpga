@spec create_intent_plan(intent: IntentDefinition, agent: Agent) → str · Result {
  /// Create execution plan from intent
  given: Intent and agent
  when: Planning execution
  then: Returns plan or error
}

@impl {
  // Use agent's knowledge and capabilities to create plan
  let available_tools = agent.definition.tools
  let capabilities = agent.definition.identity.capabilities

  // Analyze goal and decompose into steps
  use steps <- decompose_goal(intent.goal, available_tools)

  // Apply constraints
  let constrained_steps = intent.constraints · apply_constraints

  // Optimize based on strategy
  let optimized = intent.strategy · optimize_plan

  ✅Plan(
    intent.name,
    steps: optimized,
    estimated_time: estimate_time(optimized),
    risk_level: intent.constraints · assess_risk
  ))
}

// =============================================================================
// Helper Functions
// =============================================================================

@spec generate_agent_id(name: str) → str {
  /// Generate unique agent ID
  given: Agent name
  when: Creating agent
  then: Returns unique ID
}

@impl {
  let timestamp = current_timestamp_ms()
  let random = generate_random_string(8)
  "{name.lowercase().replace(" ", "_")}_ {timestamp$()}_ {random}"
}

@spec register_tools(tool_names: [str]) → ToolRegistry {
  /// Register tools for agent
  given: type {name} {
  items: List[Item],
  count: Int} tool names
  when: Initializing agent
  then: Returns tool registry
}

@impl {
  tool_names.fold(ToolRegistry.new(), tool_name · fn {
    case lookup_tool(tool_name) {
      ☐tool) → registry.tool · register
      ∅-> registry
    }
  })
}

@spec current_timestamp_ms() → int {
  /// Get current timestamp in milliseconds
  given: Nothing
  when: Timing operations
  then: Returns timestamp
}

@impl {
  // FFI call to Erlang
  erlang_timestamp_ms()
}

ffi("erlang")
erlang_timestamp_ms() → int

@spec generate_random_string(length: int) → str {
  /// Generate random alphanumeric string
  given: Desired length
  when: Creating IDs
  then: Returns random string
}

@impl {
  // FFI call to generate random string
  erlang_random_string(length)
}

ffi("vibee_random_ffi")
erlang_random_string(length: int) → str

// =============================================================================
// Type Definitions for Agent State
// =============================================================================

struct AgentState {
  AgentState(
    id: str,
    name: str,
    role: str,
    capabilities: [str],
    version: str,
    performance_tracker: PerformanceTracker?,
    error_learner: ErrorLearner?,
    strategy_adapter: StrategyAdapter?,
    introspection_interval: int,
    persistence: PersistenceType,
    auto_save_threshold: int,
    history_limit: int,
    cache_strategy: str,
    history: [Message],
    messages_since_save: int,
    protocols: [Protocol],
    message_format: MessageFormat,
    retry_policy: RetryPolicy,
    available_tools: [str],
    tool_registry: ToolRegistry,
    learning_enabled: bool,
    learning_metrics: [str],
    adaptation_threshold: float,
    feedback_loop: bool,
    experiences: [Experience]
  )
}

struct Agent {
  Agent(
    id: str,
    subject: Subject,
    definition: AgentDefinition
  )
}

