// =============================================================================
// @agent MACRO - Declarative Agent Definition
// =============================================================================

/// Define an agent with declarative configuration
///
/// Example:
/// ```vibee
/// agent SWEAgent(
///   identity: {
///     name: "SWE Agent"
///     role: "Software Engineer"
///     capabilities: ["code_analysis", "testing", "deployment"]
///     version: "2.0"
///   }
///
///   self_awareness: {
///     track_performance: true
///     learn_from_errors: true
///     adapt_strategy: true
///     introspection_interval: 100
///   }
///
///   state: {
///     persistence: PostgreSQL
///     auto_save_threshold: 5
///     history_limit: 50
///     cache_strategy: "LRU"
///   }
///
///   tools: [swe_read, swe_write, git_commit]
/// }
/// ```

struct AgentIdentity {
  AgentIdentity(
    name: str,
    role: str,
    capabilities: [str],
    version: str
  )
}

struct SelfAwarenessConfig {
  SelfAwarenessConfig(
    track_performance: bool,
    learn_from_errors: bool,
    adapt_strategy: bool,
    introspection_interval: int
  )
}
fn new() · Self {
    name: name,
    role: role,
    version: version
  
}

  # Auto-generated getters
fn name(self) · self.name


  # Auto-generated getters
fn track_performance(self) · self.track_performance


  # Auto-generated getters
fn persistence(self) · self.persistence

fn auto_save_threshold(self) · self.auto_save_threshold

fn history_limit(self) · self.history_limit

fn cache_strategy(self) · self.cache_strategy


  # Auto-generated getters
fn message_format(self) · self.message_format

fn retry_policy(self) · self.retry_policy

fn learn_from_errors(self) · self.learn_from_errors


  # Auto-generated getters
fn max_attempts(self) · self.max_attempts

fn initial_delay_ms(self) · self.initial_delay_ms

fn max_attempts(self) · self.max_attempts


  # Auto-generated getters
fn enabled(self) · self.enabled

fn adaptation_threshold(self) · self.adaptation_threshold

fn feedback_loop(self) · self.feedback_loop


  # Auto-generated getters
fn identity(self) · self.identity

fn self_awareness(self) · self.self_awareness

fn state(self) · self.state

fn communication(self) · self.communication

fn learning(self) · self.learning

