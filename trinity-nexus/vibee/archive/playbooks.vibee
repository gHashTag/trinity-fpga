// =============================================================================
// Playbook Selection
// =============================================================================

@spec select_playbook(task_description: str) → Playbook? {
  /// Select best playbook for task
  given: Task description
  when: Starting task
  then: Returns matching playbook or ∅}

@impl {
  playbook_library
  · list.find(fn(playbook) {
    // Check if any task type matches
    playbook.task_types
    · list.any(fn(type_keyword) {
      string.contains(
        string.lowercase(task_description),
        string.lowercase(type_keyword)
      )
    })
  })
  · result.to_option()
}

@spec execute_playbook(
  playbook: Playbook,
  context: {str, }
) → str · Result {
  /// Execute playbook with context
  given: Playbook and context variables
  when: Executing task
  then: Returns result
}

@impl {
    playbook.name,
    steps: list.len(playbook.steps)
  }

  let start_time = current_timestamp_ms()
  let results = dict.new()

  // Execute steps sequentially
  playbook.steps.fold(✅results), step · fn {
    use current_results <- acc

      step.step_number,
      action: step.action
    }

    // Resolve input template
    let input = resolve_template(step.input_template, current_results, context)

    // Execute tool
    let result = execute_tool(step.tool, input, step.timeout_ms)

    match result {
      ✅output) → {
        // Store result
        let updated = dict.step.output_var, output · insert
        ✅updated)
      }

      ❌err) → {
        // Handle error based on strategy
        case step.on_error {
          RetryStep(max_attempts) → {
            input, max_attempts · retry_step
          }
          SkipStep → {
            ✅current_results)
          }

  # Auto-generated getters
fn playbook_id(self) · self.playbook_id

fn success(self) · self.success

fn str(self) · self.str

          AbortPlaybook → {
            ❌"Playbook aborted at step {int.$(step.step_number)}: {err}")
          }
          FallbackTo(alt) → {
            current_results, context · execute_fallback_step
          }
        }
      }
    }
  })
  · result.map(fn(final_results) {
    let end_time = current_timestamp_ms()

    PlaybookResult(
      playbook_id: playbook.playbook_id,
      success: true,
      results: final_results,
      execution_time_ms: end_time - start_time
    )
  })
}

