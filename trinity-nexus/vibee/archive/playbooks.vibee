// Playbook Library - Proven patterns for common tasks
  // Performance Warning:   // AI Suggestion: Replace magic numbers with named constants  // AI Suggestion: Consider extracting hardcoded strings to constants// Fast, reliable solutions based on experience

// =============================================================================
// Playbook Types
// =============================================================================

struct Playbook {
  Playbook(
    playbook_id: str,
    name: str,
    description: str,
    task_types: [str],
    estimated_time_ms: int,
    success_rate: float,
    steps: [PlaybookStep],
    templates: {str, },
    tools: [str],
    prerequisites: [str]
  )
}
fn new() · Self {
    playbook_id: playbook_id,
    name: name,
    description: description,
    estimated_time_ms: estimated_time_ms,
    success_rate: success_rate,
    str: str
  
}

  # Auto-generated getters
fn playbook_id(self) · self.playbook_id

fn name(self) · self.name

fn description(self) · self.description

fn estimated_time_ms(self) · self.estimated_time_ms


  # Auto-generated getters
fn step_number(self) · self.step_number

fn action(self) · self.action


  # Auto-generated getters
fn max_attempts(self) · self.max_attempts

fn alternative_step(self) · self.alternative_step

fn tool(self) · self.tool

fn input_template(self) · self.input_template

fn output_var(self) · self.output_var

fn timeout_ms(self) · self.timeout_ms

fn on_error(self) · self.on_error

fn success_rate(self) · self.success_rate

fn str(self) · self.str


struct PlaybookStep {
  PlaybookStep(
    step_number: int,
    action: str,
    tool: str,
    input_template: str,
    output_var: str,
    timeout_ms: int,
    on_error: ErrorStrategy
  )
}

struct ErrorStrategy {
  RetryStep(max_attempts: int)
  SkipStep
  AbortPlaybook
  FallbackTo(alternative_step: str)
}

// =============================================================================
// Playbook Library
// =============================================================================

/// Add API Endpoint Playbook
let add_api_endpoint = const(Playbook(
  playbook_id: "add_api_endpoint_v1",
  name: "Add API Endpoint",
  description: "Add new REST API endpoint with tests",
  task_types: ["api", "endpoint", "rest"],
  estimated_time_ms: 180000,
  success_rate: 0.95,

  steps: [
    // Step 1: Find similar endpoint (10s)
    PlaybookStep(
      step_number: 1,
      action: "Find similar endpoint as template",
      tool: "grep",
      input_template: \"fn.*handler.*$endpoint_pattern\",
      output_var: "similar_endpoint",
      timeout_ms: 10000,
      on_error: FallbackTo("create_from_scratch")
    ),

    // Step 2: Copy template (5s)
    PlaybookStep(
      step_number: 2,
      action: "Copy endpoint as template",
      tool: "copy_file",
      input_template: \"$similar_endpoint\",
      output_var: "template_file",
      timeout_ms: 5000,
      on_error: AbortPlaybook
    ),

    // Step 3: Modify for new endpoint (60s)
    PlaybookStep(
      step_number: 3,
      action: "Modify template for new endpoint",
      tool: "llm_edit",
      input_template: \"file: ${template_file}, requirements: $requirements\",
      output_var: "new_endpoint_code",
      timeout_ms: 60000,
      on_error: RetryStep(max_attempts: 2)
    ),

    // Step 4: Generate tests (30s)
    PlaybookStep(
      step_number: 4,
      action: "Generate endpoint tests",
      tool: "test_generator",
      input_template: "code: ${new_endpoint_code}, coverage: 0.9",
      output_var: "test_code",
      timeout_ms: 30000,
      on_error: RetryStep(max_attempts: 2)
    ),

    // Step 5: Run tests (30s)
    PlaybookStep(
      step_number: 5,
      action: "Run tests to verify",
      tool: "test_runner",
      input_template: \"tests: $test_code\",
      output_var: "test_results",
      timeout_ms: 30000,
      on_error: AbortPlaybook
    ),

    // Step 6: Update API docs (15s)
    PlaybookStep(
      step_number: 6,
      action: "Update API documentation",
      tool: "doc_generator",
      input_template: \"endpoint: $new_endpoint_code\",
      output_var: "docs",
      timeout_ms: 15000,
      on_error: SkipStep
    )
  ],

  templates: {\`handler: "templates/api_handler.gleam", \`docs: "templates/api_docs.md"},

  tools: [
    "grep",
    "copy_file",
    "llm_edit",
    "test_generator",
    "test_runner",
    "doc_generator"
  ],

  prerequisites: [
    "API framework initialized",
    "Test framework available"
  ]
)

/// Fix Bug Playbook
let fix_bug = const(Playbook(
  playbook_id: "fix_bug_v1",
  name: "Fix Bug",
  description: "Reproduce, fix, and test bug",
  task_types: ["bug", "fix", "error"],
  estimated_time_ms: 300000,
  success_rate: 0.92,

  steps: [
    // Step 1: Reproduce bug (60s)
    PlaybookStep(
      step_number: 1,
      action: "Reproduce bug with test",
      tool: "test_runner",
      input_template: \"test_case: $bug_description\",
      output_var: "bug_reproduced",
      timeout_ms: 60000,
      on_error: AbortPlaybook
    ),

    // Step 2: Find root cause (60s)
    PlaybookStep(
      step_number: 2,
      action: "Analyze stack trace and find root cause",
      tool: "debugger",
      input_template: \"error: ${bug_reproduced.error}, stack: $bug_reproduced.stack_trace\",
      output_var: "root_cause",
      timeout_ms: 60000,
      on_error: RetryStep(max_attempts: 2)
    ),

    // Step 3: Search similar fixes (10s)
    PlaybookStep(
      step_number: 3,
      action: "Search for similar bug fixes",
      tool: "error_pattern_search",
      input_template: \"error_type: $root_cause.error_type\",
      output_var: "similar_fixes",
      timeout_ms: 10000,
      on_error: SkipStep
    ),

    // Step 4: Generate fix (90s)
    PlaybookStep(
      step_number: 4,
      action: "Generate bug fix",
      tool: "bug_fixer",
      input_template: \"root_cause: ${root_cause}, similar: $similar_fixes\",
      output_var: "proposed_fix",
      timeout_ms: 90000,
      on_error: RetryStep(max_attempts: 2)
    ),

    // Step 5: Apply fix (10s)
    PlaybookStep(
      step_number: 5,
      action: "Apply fix to codebase",
      tool: "code_patcher",
      input_template: \"fix: $proposed_fix\",
      output_var: "fix_applied",
      timeout_ms: 10000,
      on_error: AbortPlaybook
    ),

    // Step 6: Run all tests (60s)
    PlaybookStep(
      step_number: 6,
      action: "Run all tests to verify fix",
      tool: "test_runner",
      input_template: "all_tests: true",
      output_var: "test_results",
      timeout_ms: 60000,
      on_error: AbortPlaybook
    ),

    // Step 7: Add regression test (30s)
    PlaybookStep(
      step_number: 7,
      action: "Add regression test",
      tool: "test_generator",
      input_template: \"bug: ${bug_description}, fix: $proposed_fix\",
      output_var: "regression_test",
      timeout_ms: 30000,
      on_error: SkipStep
    )
  ],

  templates: {\`bug_fix: "templates/bug_fix.gleam", \`regression_test: "templates/regression_test.gleam"},

  tools: [
    "test_runner",
    "debugger",
    "error_pattern_search",
    "bug_fixer",
    "code_patcher",
    "test_generator"
  ],

  prerequisites: [
    "Bug description available",
    "Test framework available"
  ]
)

/// Refactor Code Playbook
let refactor_code = const(Playbook(
  playbook_id: "refactor_code_v1",
  name: "Refactor Code",
  description: "Improve code quality while maintaining behavior",
  task_types: ["refactor", "cleanup", "improve"],
  estimated_time_ms: 420000,
  success_rate: 0.88,

  steps: [
    // Step 1: Run linter (15s)
    PlaybookStep(
      step_number: 1,
      action: "Run linter to find issues",
      tool: "linter",
      input_template: \"files: $target_files\",
      output_var: "lint_issues",
      timeout_ms: 15000,
      on_error: SkipStep
    ),

    // Step 2: Analyze complexity (30s)
    PlaybookStep(
      step_number: 2,
      action: "Analyze code complexity",
      tool: "complexity_analyzer",
      input_template: \"files: $target_files\",
      output_var: "complexity_report",
      timeout_ms: 30000,
      on_error: SkipStep
    ),

    // Step 3: Find patterns (45s)
    PlaybookStep(
      step_number: 3,
      action: "Find common patterns to extract",
      tool: "pattern_finder",
      input_template: \"files: $target_files\",
      output_var: "common_patterns",
      timeout_ms: 45000,
      on_error: SkipStep
    ),

    // Step 4: Generate refactoring plan (60s)
    PlaybookStep(
      step_number: 4,
      action: "Generate refactoring plan",
      tool: "refactoring_planner",
      input_template: \"lint: ${lint_issues}, complexity: ${complexity_report}, patterns: $common_patterns\",
      output_var: "refactoring_plan",
      timeout_ms: 60000,
      on_error: RetryStep(max_attempts: 2)
    ),

    // Step 5: Apply refactoring (180s)
    PlaybookStep(
      step_number: 5,
      action: "Apply refactoring changes",
      tool: "refactorer",
      input_template: \"plan: $refactoring_plan\",
      output_var: "refactored_code",
      timeout_ms: 180000,
      on_error: RetryStep(max_attempts: 2)
    ),

    // Step 6: Run tests (60s)
    PlaybookStep(
      step_number: 6,
      action: "Verify tests still pass",
      tool: "test_runner",
      input_template: "all_tests: true",
      output_var: "test_results",
      timeout_ms: 60000,
      on_error: AbortPlaybook
    ),

    // Step 7: Update docs (30s)
    PlaybookStep(
      step_number: 7,
      action: "Update documentation",
      tool: "doc_updater",
      input_template: \"changes: $refactored_code\",
      output_var: "updated_docs",
      timeout_ms: 30000,
      on_error: SkipStep
    )
  ],

  templates: {\`refactoring: "templates/refactoring.gleam", \`: },

  tools: [
    "linter",
    "complexity_analyzer",
    "pattern_finder",
    "refactoring_planner",
    "refactorer",
    "test_runner",
    "doc_updater"
  ],

  prerequisites: [
    "Tests exist",
    "Code compiles"
  ]
)

/// Add Feature Playbook
let add_feature = const(Playbook(
  playbook_id: "add_feature_v1",
  name: "Add Feature",
  description: "Implement new feature with tests and docs",
  task_types: ["feature", "enhancement", "new"],
  estimated_time_ms: 600000,
  success_rate: 0.90,

  steps: [
    // Step 1: Analyze requirements (60s)
    PlaybookStep(
      step_number: 1,
      action: "Analyze feature requirements",
      tool: "requirement_analyzer",
      input_template: \"description: $feature_description\",
      output_var: "requirements",
      timeout_ms: 60000,
      on_error: RetryStep(max_attempts: 2)
    ),

    // Step 2: Design solution (90s)
    PlaybookStep(
      step_number: 2,
      action: "Design solution architecture",
      tool: "solution_designer",
      input_template: \"requirements: $requirements\",
      output_var: "design",
      timeout_ms: 90000,
      on_error: RetryStep(max_attempts: 2)
    ),

    // Step 3: Generate code (240s)
    PlaybookStep(
      step_number: 3,
      action: "Generate feature code",
      tool: "code_generator",
      input_template: \"design: $design\",
      output_var: "feature_code",
      timeout_ms: 240000,
      on_error: RetryStep(max_attempts: 2)
    ),

    // Step 4: Generate tests (120s)
    PlaybookStep(
      step_number: 4,
      action: "Generate comprehensive tests",
      tool: "test_generator",
      input_template: "code: ${feature_code}, coverage: 0.9",
      output_var: "test_code",
      timeout_ms: 120000,
      on_error: RetryStep(max_attempts: 2)
    ),

    // Step 5: Run tests (60s)
    PlaybookStep(
      step_number: 5,
      action: "Run tests",
      tool: "test_runner",
      input_template: \"tests: $test_code\",
      output_var: "test_results",
      timeout_ms: 60000,
      on_error: AbortPlaybook
    ),

    // Step 6: Generate docs (30s)
    PlaybookStep(
      step_number: 6,
      action: "Generate documentation",
      tool: "doc_generator",
      input_template: \"feature: $feature_code\",
      output_var: "documentation",
      timeout_ms: 30000,
      on_error: SkipStep
    )
  ],

  templates: {\`feature: "templates/feature.gleam", \`docs: "templates/feature_docs.md"},

  tools: [
    "requirement_analyzer",
    "solution_designer",
    "code_generator",
    "test_generator",
    "test_runner",
    "doc_generator"
  ],

  prerequisites: [
    "Feature description available",
    "Architecture defined"
  ]
)

/// Deploy to Production Playbook
let deploy_production = const(Playbook(
  playbook_id: "deploy_production_v1",
  name: "Deploy to Production",
  description: "Safe production deployment with rollback",
  task_types: ["deploy", "release", "production"],
  estimated_time_ms: 300000,
  success_rate: 0.98,

  steps: [
    // Step 1: Run all tests (60s)
    PlaybookStep(
      step_number: 1,
      action: "Run full test suite",
      tool: "test_runner",
      input_template: "all_tests: true, coverage: true",
      output_var: "test_results",
      timeout_ms: 60000,
      on_error: AbortPlaybook
    ),

    // Step 2: Security scan (30s)
    PlaybookStep(
      step_number: 2,
      action: "Run security scan",
      tool: "security_scanner",
      input_template: "full_scan: true",
      output_var: "security_report",
      timeout_ms: 30000,
      on_error: AbortPlaybook
    ),

    // Step 3: Build production (60s)
    PlaybookStep(
      step_number: 3,
      action: "Build production bundle",
      tool: "builder",
      input_template: "env: production, optimize: true",
      output_var: "build_artifact",
      timeout_ms: 60000,
      on_error: AbortPlaybook
    ),

    // Step 4: Deploy to staging (30s)
    PlaybookStep(
      step_number: 4,
      action: "Deploy to staging first",
      tool: "deployer",
      input_template: "artifact: ${build_artifact}, env: staging",
      output_var: "staging_deployment",
      timeout_ms: 30000,
      on_error: AbortPlaybook
    ),

    // Step 5: Smoke tests on staging (30s)
    PlaybookStep(
      step_number: 5,
      action: "Run smoke tests on staging",
      tool: "smoke_tester",
      input_template: \"url: $staging_deployment.url\",
      output_var: "smoke_results",
      timeout_ms: 30000,
      on_error: AbortPlaybook
    ),

    // Step 6: Deploy to production (30s)
    PlaybookStep(
      step_number: 6,
      action: "Deploy to production",
      tool: "deployer",
      input_template: "artifact: ${build_artifact}, env: production",
      output_var: "production_deployment",
      timeout_ms: 30000,
      on_error: AbortPlaybook
    ),

    // Step 7: Health check (30s)
    PlaybookStep(
      step_number: 7,
      action: "Verify production health",
      tool: "health_checker",
      input_template: \"url: $production_deployment.url\",
      output_var: "health_status",
      timeout_ms: 30000,
      on_error: FallbackTo("rollback")
    ),

    // Step 8: Monitor (30s)
    PlaybookStep(
      step_number: 8,
      action: "Monitor for errors",
      tool: "monitor",
      input_template: "deployment: ${production_deployment}, duration: 30s",
      output_var: "monitoring_results",
      timeout_ms: 30000,
      on_error: FallbackTo("rollback")
    )
  ],

  templates: dict.new(),

  tools: [
    "test_runner",
    "security_scanner",
    "builder",
    "deployer",
    "smoke_tester",
    "health_checker",
    "monitor"
  ],

  prerequisites: [
    "All tests passing",
    "No security vulnerabilities",
    "Deployment credentials configured"
  ]
)

