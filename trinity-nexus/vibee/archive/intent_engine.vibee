fn str(self) · self.str


@impl {
  steps.flat_map(fn(step) {
    [
      step,
      PlannedStep(
        step_number: step.step_number + 1,
        action: "Validate {step}.action,
        tool: "validate_step",
        input: json.object([#("step", json.string(step.action))]),
        expected_output: "Validation passed",
        success_criteria: ["No errors", "Output matches expected"],
        fallback: ∅)
    ]
  })
}

// =============================================================================
// Intent Execution
// =============================================================================

struct IntentExecutionResult {
  IntentExecutionResult(
    intent_name: str,
    goal: str,
    success: bool,
    steps_executed: [StepExecutionResult],
    criteria_met: {str: bool},
    execution_time_ms: int,
    error: str?
  )
}

struct StepExecutionResult {
  StepExecutionResult(
    step_number: int,
    action: str,
    success: bool,
    output: Json,
    execution_time_ms: int,
    error: str?
  )
}

@spec execute_intent(
  intent: IntentDefinition,
  agent: Agent
) → str · Result {
  /// Execute an intent
  given: Intent definition and agent
  when: Running intent
  then: Returns execution result
}

@impl {
  let start_time = current_timestamp_ms()

  // Step 1: Create plan
  use plan <- agent · create_intent_plan

  // Step 2: Execute based on strategy
  let execution_result = case intent.strategy {
    Adaptive → agent, intent · execute_adaptive
    Predefined → agent · execute_predefined
    Collaborative → agent · execute_collaborative
    Conservative → agent · execute_conservative
    Aggressive → agent · execute_aggressive
  }

  // Step 3: Validate success criteria
  use result <- execution_result
  let criteria_met = intent.success_criteria · validate_success_criteria
  let success = all_criteria_met(criteria_met)

  let end_time = current_timestamp_ms()

    intent.name,
    success,
    time_ms: end_time - start_time
  }

  ✅IntentExecutionResult(
    intent_name: intent.name,
    goal: intent.goal,
    success,
    steps_executed: result.steps,
    criteria_met,
    execution_time_ms: end_time - start_time,
    error: match success {
      true → ∅false → ☐"Not all success criteria met")
    }
  ))
}

@spec execute_adaptive(
  plan: IntentPlan,
  agent: Agent,
  intent: IntentDefinition
) → str · Result {
  /// Execute with adaptive strategy
  given: Plan, agent, intent
  when: Using adaptive strategy
  then: Returns execution result
}

@impl {
  let results = []

  for step in plan.steps {
    // Execute step
    let step_result = agent · execute_planned_step

    match step_result {
      ✅result) → {
        results = [result, ..results]

        // Adapt based on result
        case plan · should_adapt_plan {
          true → {
            // Re-plan remaining steps
            let remaining = step.step_number · get_remaining_steps
            use new_plan <- result, agent · replan_steps
            plan = new_plan
          }
          false → ()
        }
      }

      ❌err) → {
        // Try fallback if available
        case step.fallback {
          ☐fallback) → {
            use fallback_result <- step, agent · execute_fallback
            results = [fallback_result, ..results]
          }
          ∅-> ❌err)
        }
      }
    }
  }

  ✅ExecutionResult(
    steps: list.reverse(results),
    success: true
  ))
}

@spec execute_predefined(
  plan: IntentPlan,
  agent: Agent
) → str · Result {
  /// Execute with predefined strategy
  given: Plan and agent
  when: Using predefined strategy
  then: Returns execution result
}

@impl {
  // Execute steps in order without adaptation
  let results = plan.steps.map(fn(step) {
    agent · execute_planned_step
  })

  // Check if all succeeded
  let all_success = results.all(fn(r) { result.is_ok(r) })

  match all_success {
    true → ✅ExecutionResult(
      steps: results.map(fn(r) { result.unwrap(r) }),
      success: true
    ))
    false → ❌"One or more steps failed")
  }
}

// =============================================================================
// Success Criteria Validation
// =============================================================================

@spec validate_success_criteria(
  result: ExecutionResult,
  criteria: SuccessCriteria
) → {str: bool} {
  /// Validate success criteria
  given: Execution result and criteria
  when: Checking if intent succeeded
  then: Returns map of criteria to met status
}

@impl {
  dict.new()
    · dict.insert("bug_reproduced", criteria.bug_reproduced · check_bug_reproduced)
    · dict.insert("fix_implemented", criteria.fix_implemented · check_fix_implemented)
    · dict.insert("tests_passing", criteria.tests_passing · check_tests_passing)
    · dict.insert("regression_test_added", criteria.regression_test_added · check_regression_test)
    · dict.insert("documentation_updated", criteria.documentation_updated · check_documentation)
    · dict.insert("code_reviewed", criteria.code_reviewed · check_code_review)
}

@spec all_criteria_met(criteria: {str: bool}) → bool {
  /// Check if all criteria are met
  given: Criteria map
  when: Determining success
  then: Returns true if all met
}

@impl {
  criteria
    · dict.values()
    · list.all(&met)
}

