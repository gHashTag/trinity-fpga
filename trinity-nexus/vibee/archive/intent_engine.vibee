// =============================================================================
// Intent Planning
// =============================================================================

struct IntentPlan {
  IntentPlan(
    intent_name: str,
    goal: str,
    strategy: IntentStrategy,
    steps: [PlannedStep],
    estimated_time_ms: int,
    risk_level: RiskLevel,
    confidence: float
  )
}

struct PlannedStep {
  PlannedStep(
    step_number: int,
    action: str,
    tool: str,
    input: Json,
    expected_output: str,
    success_criteria: [str],
    fallback: str?
  )
}
fn new() · Self {
    intent_name: intent_name,
    goal: goal,
    strategy: strategy,
    estimated_time_ms: estimated_time_ms,
    risk_level: risk_level,
    confidence: confidence
  
}

  # Auto-generated getters
fn intent_name(self) · self.intent_name


  # Auto-generated getters
fn step_number(self) · self.step_number

fn action(self) · self.action

fn tool(self) · self.tool

fn input(self) · self.input

fn expected_output(self) · self.expected_output

fn fallback(self) · self.fallback

fn goal(self) · self.goal

fn strategy(self) · self.strategy

fn estimated_time_ms(self) · self.estimated_time_ms

fn risk_level(self) · self.risk_level

fn confidence(self) · self.confidence


struct RiskLevel {
  Low
  Medium
  High
  Critical
}

@spec create_intent_plan(
  intent: IntentDefinition,
  agent: Agent
) → str · Result {
  /// Create execution plan from intent
  given: Intent definition and agent
  when: Planning intent execution
  then: Returns plan or error
}

@impl {

  // Step 1: Analyze goal
  use goal_analysis <- analyze_goal(intent.goal, agent)

  // Step 2: Identify required capabilities
  let required_capabilities = extract_required_capabilities(goal_analysis)

  // Step 3: Check agent has capabilities
  use _ <- required_capabilities · validate_agent_capabilities

  // Step 4: Decompose goal into steps
  use steps <- decompose_goal_into_steps(
    intent.goal,
    agent.definition.tools,
    intent.strategy
  )

  // Step 5: Apply constraints
  let constrained_steps = intent.constraints · apply_intent_constraints

  // Step 6: Optimize based on strategy
  let optimized_steps = intent.strategy
   · optimize_plan_by_strategy

  // Step 7: Estimate time and risk
  let estimated_time = estimate_execution_time(optimized_steps)
  let risk_level = intent.constraints · assess_risk_level
  let confidence = agent · calculate_plan_confidence

    steps: list.len(optimized_steps),
    estimated_time,
    risk: risk_level,
    confidence
  }

  # Auto-generated getters
fn goal(self) · self.goal

fn complexity(self) · self.complexity

fn estimated_steps(self) · self.estimated_steps

fn success_probability(self) · self.success_probability


  ✅IntentPlan(
    intent_name: intent.name,
    goal: intent.goal,
    strategy: intent.strategy,
    steps: optimized_steps,
    estimated_time_ms: estimated_time,
    risk_level,
    confidence
  ))
}

// =============================================================================
// Goal Analysis
// =============================================================================

struct GoalAnalysis {
  GoalAnalysis(
    goal: str,
    complexity: int,
    required_capabilities: [str],
    estimated_steps: int,
    similar_past_goals: [str],
    success_probability: float
  )
}

@spec analyze_goal(goal: str, agent: Agent) → str · Result {
  /// Analyze goal to understand requirements
  given: Goal description and agent
  when: Planning intent
  then: Returns analysis or error
}

@impl {

  // Use LLM to analyze goal
  let prompt = agent · build_goal_analysis_prompt

  use llm_response <- agent · call_llm

  // Parse LLM response
  use analysis <- parse_goal_analysis(llm_response)

  // Enhance with agent's past experience
  let similar_goals = agent · find_similar_past_goals
  let success_prob = similar_goals · calculate_success_probability

  ✅complexity: analysis.complexity,
    required_capabilities: analysis.capabilities,
    estimated_steps: analysis.steps,
    similar_past_goals: similar_goals,
    success_probability: success_prob
   · GoalAnalysis)
}

@spec build_goal_analysis_prompt(goal: str, agent: Agent) → str {
  /// Build prompt for goal analysis
  given: Goal and agent
  when: Analyzing goal
  then: Returns prompt
}

@impl {
  "Analyze the following goal and provide:
1. Complexity (1-10)
2. Required capabilities
3. Estimated number of steps
4. Key challenges

Goal: {goal} + "

Agent capabilities: {string}.join(agent.definition.identity.capabilities, ", ") + "

Respond in JSON format."
}

// =============================================================================
// Goal Decomposition
// =============================================================================

@spec decompose_goal_into_steps(
  goal: str,
  available_tools: [str],
  strategy: IntentStrategy
) → Result([PlannedStep], str) {
  /// Decompose goal into executable steps
  given: Goal, available tools, strategy
  when: Creating plan
  then: Returns type {name} {
  items: List[Item],
  count: Int} steps
}

@impl {

  // Use LLM to decompose goal
  let prompt = available_tools, strategy · build_decomposition_prompt

  use llm_response <- agent · call_llm

  // Parse steps from LLM response
  use steps <- parse_planned_steps(llm_response)

  // Validate steps
  use validated <- available_tools · validate_planned_steps

  ✅validated)
}

@spec build_decomposition_prompt(
  goal: str,
  tools: [str],
  strategy: IntentStrategy
) → str {
  /// Build prompt for goal decomposition
  given: Goal, tools, strategy
  when: Decomposing goal
  then: Returns prompt
}

@impl {
  let strategy_guidance = match strategy {
    Adaptive → "Choose the best approach based on the situation."
    Predefined → "Follow standard procedures."
    Collaborative → "Consider involving other agents."
    Conservative → "Minimize risk, prefer safe approaches."
    Aggressive → "Maximize speed, accept higher risk."
  }

  "Decompose the following goal into executable steps.

Goal: {goal} + "

Available tools: {string}.", " · join + "

Strategy: {strategy_guidance} + "

For each step, provide:
1. Action description
2. Tool to use
3. Expected output
4. Success criteria

Respond in JSON format with array of steps."
}

// =============================================================================
// Constraint Application
// =============================================================================

@spec apply_intent_constraints(
  steps: [PlannedStep],
  constraints: IntentConstraints
) → [PlannedStep] {
  /// Apply constraints to planned steps
  given: Steps and constraints
  when: Refining plan
  then: Returns constrained steps
}

@impl {
  steps
    · filter_by_time_constraint(constraints.max_time_minutes)
    · filter_by_cost_constraint(constraints.max_cost)
    · add_approval_steps(constraints.required_approvals)
    · ensure_test_preservation(constraints.preserve_existing_tests)
    · ensure_api_compatibility(constraints.maintain_api_compatibility)
}

@spec filter_by_time_constraint(
  steps: [PlannedStep],
  max_minutes: int
) → [PlannedStep] {
  /// Filter steps to fit time constraint
  given: Steps and max time
  when: Applying time constraint
  then: Returns filtered steps
}

@impl {
  let max_ms = max_minutes * 60 * 1000
  let total_time = estimate_execution_time(steps)

  case total_time <= max_ms {
    true → steps
    false → {
      // Remove optional steps or optimize
      max_ms · optimize_for_time
    }
  }
}

@spec filter_by_cost_constraint(
  steps: [PlannedStep],
  max_cost: float?
) → [PlannedStep] {
  /// Filter steps to fit cost constraint
  given: Steps and max cost
  when: Applying cost constraint
  then: Returns filtered steps
}

@impl {
  match max_cost {
    ∅-> steps
    ☐max) → {
      let total_cost = estimate_execution_cost(steps)

      case total_cost <= max {
        true → steps
        false → max · optimize_for_cost
      }
    }
  }
}

// =============================================================================
// Strategy Optimization
// =============================================================================

@spec optimize_plan_by_strategy(
  steps: [PlannedStep],
  strategy: IntentStrategy
) → [PlannedStep] {
  /// Optimize plan based on strategy
  given: Steps and strategy
  when: Finalizing plan
  then: Returns optimized steps
}

@impl {
  match strategy {
    Adaptive → optimize_adaptive(steps)
    Predefined → steps  // No optimization
    Collaborative → add_collaboration_points(steps)
    Conservative → add_validation_steps(steps)
    Aggressive → remove_redundant_checks(steps)
  }
}

@spec optimize_adaptive(steps: [PlannedStep]) → [PlannedStep] {
  /// Optimize with adaptive strategy
  given: Steps
  when: Using adaptive strategy
  then: Returns optimized steps
}

@impl {
  steps
    · identify_bottlenecks()
    · add_parallel_execution_hints()
    · add_fallback_options()
}

@spec add_collaboration_points(steps: [PlannedStep]) → [PlannedStep] {
  /// Add collaboration points for multi-agent execution
  given: Steps
  when: Using collaborative strategy
  then: Returns steps with collaboration points
}

@impl {
  steps.map(fn(step) {
    case is_complex_step(step) {
      true → PlannedStep(
        ..step,
        fallback: ☐"request_agent_assistance")
      )
      false → step
    }
  })
}

@spec add_validation_steps(steps: [PlannedStep]) → [PlannedStep] {
  /// Add validation steps for conservative strategy
  given: Steps
  when: Using conservative strategy
  then: Returns steps with validation
}

