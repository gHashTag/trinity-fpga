# VIBEEC v3.0 Compiler - Self-Hosting Spec
# DOGFOODING: Using VIBEEC to build VIBEEC!
# Generated with AI Assistant + Manual refinement

name: vibeec_v3_compiler
version: 3.0.0
description: Next-generation VIBEEC compiler with self-hosting capabilities
author: VIBEEC Team
category: Compiler
tags: [compiler, self-hosting, meta, ai-powered, production]

# ============================================================================
# BEHAVIORS - Complete Compilation Pipeline
# ============================================================================

behaviors:
  # 1. LEXICAL ANALYSIS
  - name: tokenize_source
    description: Convert source code to token stream
    given: Valid VIBEEC source code
    when: Lexer processes input
    then: Token stream generated with positions
    test_cases:
      - name: simple_function
        input: {code: "pub fn hello() { print(\"Hi\") }"}
        expected: {tokens: "10", valid: "true"}
      
      - name: with_types
        input: {code: "type User { name: String, age: Int }"}
        expected: {tokens: "12", valid: "true"}
      
      - name: invalid_syntax
        input: {code: "pub fn { }"}
        expected: {tokens: "0", error: "Unexpected token"}

  # 2. SYNTAX ANALYSIS
  - name: parse_tokens
    description: Build Abstract Syntax Tree from tokens
    given: Valid token stream
    when: Parser processes tokens
    then: AST generated with type information
    test_cases:
      - name: function_definition
        input: {tokens: "[pub, fn, hello, (, ), {, }]"}
        expected: {ast_nodes: "3", valid: "true"}
      
      - name: type_definition
        input: {tokens: "[type, User, {, name, :, String, }]"}
        expected: {ast_nodes: "2", valid: "true"}
      
      - name: syntax_error
        input: {tokens: "[pub, fn, {, }]"}
        expected: {ast_nodes: "0", error: "Missing identifier"}

  # 3. SEMANTIC ANALYSIS
  - name: analyze_semantics
    description: Type checking and semantic validation
    given: Valid AST
    when: Semantic analyzer processes AST
    then: Type-checked AST with annotations
    test_cases:
      - name: valid_types
        input: {ast: "fn add(a: Int, b: Int) -> Int"}
        expected: {valid: "true", type: "Int"}
      
      - name: type_mismatch
        input: {ast: "fn add(a: Int, b: String) -> Int"}
        expected: {valid: "false", error: "Type mismatch"}
      
      - name: undefined_type
        input: {ast: "fn process(x: Unknown) -> Int"}
        expected: {valid: "false", error: "Undefined type"}

  # 4. OPTIMIZATION
  - name: optimize_ast
    description: Apply optimization passes to AST
    given: Type-checked AST
    when: Optimizer processes AST
    then: Optimized AST with better performance
    test_cases:
      - name: constant_folding
        input: {ast: "let x = 2 + 3"}
        expected: {optimized: "true", result: "let x = 5"}
      
      - name: dead_code_elimination
        input: {ast: "if false { unreachable() }"}
        expected: {optimized: "true", removed: "1"}
      
      - name: tail_call_optimization
        input: {ast: "fn factorial(n) { factorial(n-1) }"}
        expected: {optimized: "true", tail_call: "true"}

  # 5. CODE GENERATION
  - name: generate_erlang
    description: Generate Erlang code from optimized AST
    given: Optimized AST
    when: Code generator processes AST
    then: Erlang code generated
    test_cases:
      - name: simple_function
        input: {ast: "pub fn hello() { print(\"Hi\") }"}
        expected: {generated: "true", lines: "5"}
      
      - name: with_pattern_matching
        input: {ast: "case x { Ok(v) -> v, Error(e) -> 0 }"}
        expected: {generated: "true", lines: "8"}
      
      - name: with_types
        input: {ast: "type User { name: String }"}
        expected: {generated: "true", lines: "3"}

  # 6. SPEC PARSING (KILLER FEATURE)
  - name: parse_spec_yaml
    description: Parse spec.yml to internal representation
    given: Valid spec.yml file
    when: Spec parser processes YAML
    then: Spec structure with behaviors and types
    test_cases:
      - name: valid_spec
        input: {yaml: "name: test\nversion: 1.0.0\nbehaviors: []"}
        expected: {parsed: "true", behaviors: "0"}
      
      - name: with_behaviors
        input: {yaml: "behaviors:\n  - name: test"}
        expected: {parsed: "true", behaviors: "1"}
      
      - name: invalid_yaml
        input: {yaml: "name: [invalid"}
        expected: {parsed: "false", error: "Invalid YAML"}

  # 7. SPEC VALIDATION
  - name: validate_spec
    description: Validate spec structure and content
    given: Parsed spec structure
    when: Validator checks spec
    then: Validation result with errors
    test_cases:
      - name: valid_spec
        input: {spec: "name: test, version: 1.0.0"}
        expected: {valid: "true", errors: "0"}
      
      - name: missing_name
        input: {spec: "version: 1.0.0"}
        expected: {valid: "false", errors: "1"}
      
      - name: invalid_version
        input: {spec: "name: test, version: abc"}
        expected: {valid: "false", errors: "1"}

  # 8. SPEC CODE GENERATION
  - name: generate_from_spec
    description: Generate code from validated spec
    given: Valid spec with behaviors
    when: Spec code generator processes spec
    then: Complete code with tests and docs
    test_cases:
      - name: simple_spec
        input: {spec: "behaviors: 1, types: 1"}
        expected: {generated: "true", lines: "100"}
      
      - name: complex_spec
        input: {spec: "behaviors: 5, types: 3"}
        expected: {generated: "true", lines: "500"}
      
      - name: with_imports
        input: {spec: "import: [base.spec.yml]"}
        expected: {generated: "true", imports: "1"}

  # 9. AI ASSISTANT (NEW!)
  - name: ai_generate_spec
    description: Generate spec from natural language
    given: Natural language prompt
    when: AI assistant processes prompt
    then: Complete spec.yml generated
    test_cases:
      - name: simple_prompt
        input: {prompt: "Create a todo API"}
        expected: {generated: "true", confidence: "0.95"}
      
      - name: complex_prompt
        input: {prompt: "Build user auth with JWT"}
        expected: {generated: "true", confidence: "0.90"}
      
      - name: ambiguous_prompt
        input: {prompt: "Make something"}
        expected: {generated: "false", confidence: "0.30"}

  # 10. HOT RELOAD
  - name: watch_and_reload
    description: Watch files and auto-regenerate
    given: Spec file being watched
    when: File changes detected
    then: Code regenerated automatically
    test_cases:
      - name: file_changed
        input: {file: "test.spec.yml", changed: "true"}
        expected: {regenerated: "true", time_ms: "150"}
      
      - name: no_changes
        input: {file: "test.spec.yml", changed: "false"}
        expected: {regenerated: "false"}
      
      - name: invalid_change
        input: {file: "test.spec.yml", valid: "false"}
        expected: {regenerated: "false", error: "Validation failed"}

# ============================================================================
# TYPES - Compiler Data Structures
# ============================================================================

types:
  Token:
    type: str
    value: str
    line: int
    column: int
  
  ASTNode:
    type: str
    children: list
    metadata: dict
  
  Spec:
    name: str
    version: str
    behaviors: list
    types: list
    functions: list
  
  Behavior:
    name: str
    description: str
    test_cases: list
  
  CompilerOptions:
    optimize: bool
    target: str
    output_dir: str
  
  ValidationError:
    message: str
    line: int
    column: int
  
  AIResponse:
    spec_yaml: str
    confidence: float
    suggestions: list

# ============================================================================
# FUNCTIONS - Compiler API
# ============================================================================

functions:
  # Core compilation
  - name: tokenize_source
    signature: "tokenize_source(source: String) → Result(List(Token), String)"
  
  - name: parse_tokens
    signature: "parse_tokens(tokens: List(Token)) → Result(ASTNode, String)"
  
  - name: analyze_semantics
    signature: "analyze_semantics(ast: ASTNode) → Result(ASTNode, String)"
  
  - name: optimize_ast
    signature: "optimize_ast(ast: ASTNode, options: CompilerOptions) → Result(ASTNode, String)"
  
  - name: generate_erlang
    signature: "generate_erlang(ast: ASTNode) → Result(String, String)"
  
  # Spec-driven
  - name: parse_spec_yaml
    signature: "parse_spec_yaml(yaml: String) → Result(Spec, String)"
  
  - name: validate_spec
    signature: "validate_spec(spec: Spec) → Result(Nil, List(ValidationError))"
  
  - name: generate_from_spec
    signature: "generate_from_spec(spec: Spec) → Result(String, String)"
  
  # AI-powered
  - name: ai_generate_spec
    signature: "ai_generate_spec(prompt: String) → Result(AIResponse, String)"
  
  # Hot reload
  - name: watch_and_reload
    signature: "watch_and_reload(file: String, callback: Function) → Result(Nil, String)"

