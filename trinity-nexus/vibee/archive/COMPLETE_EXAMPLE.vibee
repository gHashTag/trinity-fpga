# ============================================================================
# Real Working Examples
# ============================================================================

# Fibonacci
pub fn fibonacci(n) {
  case n {
    0 -> 0
    1 -> 1
    n -> fibonacci(n - 1) + fibonacci(n - 2)
  }
}

# List operations
pub fn sum_list(list) {
  case list {
    [] -> 0
    [head, ..tail] -> head + sum_list(tail)
  }
}

# String operations
pub fn repeat_string(str, n) {
  case n {
    0 -> ""
    n -> str <> repeat_string(str, n - 1)
  }
}

# Complex pattern matching
pub fn classify(value) {
  case value {
    0 -> "zero"
    1 -> "one"
    2 -> "two"
    n when n > 0 -> "many"
    _ -> "negative"
  }
}

# Higher-order functions
pub fn apply_twice(f, x) {
  f(f(x))
}

pub fn compose(f, g, x) {
  f(g(x))
}

# Tests for all features
test fibonacci_test {
  fibonacci(5) == 5
}

test sum_list_test {
  sum_list([1, 2, 3, 4, 5]) == 15
}

test classify_test {
  classify(5) == "many"
}

test apply_twice_test {
  double = fn(x) { x * 2 }
  apply_twice(double, 3) == 12
}

