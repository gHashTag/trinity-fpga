# 1. [CYR:Функц]andand
pub fn greet(name) {
  print("Hello, {name}!")
}

# 2. Прandin[CYR:атные] [CYR:функц]andand
fn internal_helper(x) {
  x * 2
}

# 3. [CYR:Параметры] and inозin[CYR:рат] зon[CYR:чен]andй
pub fn add(x, y) {
  x + y
}

# 4. Guards
pub fn divide(x, y) {
  guard y != 0 else "Division by zero"
  x / y
}

# 5. String interpolation
pub fn format_user(name, age) {
  "User: {name}, Age: {age}"
}

# 6. Print shorthand
pub fn log_message(msg) {
  print("LOG: {msg}")
}

# 7. Tests
test add_test {
  result = add(2, 3)
  result == 5
}

test divide_test {
  result = divide(10, 2)
  result == 5
}

# ============================================================================
# Phase 2: Advanced Features
# ============================================================================

# 8. Pattern Matching
pub fn factorial(n) {
  case n {
    0 -> 1
    1 -> 1
    n -> n * factorial(n - 1)
  }
}

# 9. Case with Guards
pub fn describe_number(n) {
  case n {
    0 -> "zero"
    1 -> "one"
    n when n > 0 -> "positive"
    n when n < 0 -> "negative"
    _ -> "unknown"
  }
}

# 10. Pipe Operator
pub fn process_data(data) {
  data
  |> validate
  |> transform
  |> save
}

pub fn validate(x) { x }
pub fn transform(x) { x * 2 }
pub fn save(x) { x }

# 11. Lambda Functions
pub fn map_double(list) {
  list.map(list, fn(x) { x * 2 })
}

pub fn filter_positive(list) {
  list.filter(list, fn(x) { x > 0 })
}

# 12. Lists
pub fn list_example() {
  numbers = [1, 2, 3, 4, 5]
  doubled = list.map(numbers, fn(x) { x * 2 })
  doubled
}

# 13. Tuples
pub fn tuple_example() {
  point = {10, 20}
  person = {"John", 30, "john@example.com"}
  point
}

# 14. Records/Maps
pub fn record_example() {
  user = #{
    name => "John",
    age => 30,
    email => "john@example.com"
  }
  user
}

