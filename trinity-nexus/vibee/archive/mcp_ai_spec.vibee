# MCP AI Tools Specification
# AI service integrations (FLUX, Kling, ElevenLabs, GPT)

name: mcp_ai
version: 1.0.0
description: |
  MCP tools for AI service integrations.
  Provides image generation, video generation, text-to-speech, and chat.

# ============================================================================
# TYPES
# ============================================================================

types:
  - name: ImageGenerationRequest
    description: Request for image generation
    fields:
      - name: prompt
        type: String
        description: Text prompt for image
      - name: width
        type: Int
        description: Image width in pixels
      - name: height
        type: Int
        description: Image height in pixels
      - name: model
        type: String
        description: Model to use (flux-pro, flux-dev, flux-schnell)
  
  - name: ImageGenerationResult
    description: Result of image generation
    fields:
      - name: image_url
        type: String
        description: URL of generated image
      - name: seed
        type: Int
        description: Seed used for generation
      - name: model
        type: String
        description: Model used
      - name: generation_time_ms
        type: Int
        description: Time taken to generate
  
  - name: VideoGenerationRequest
    description: Request for video generation
    fields:
      - name: prompt
        type: String
        description: Text prompt for video
      - name: duration
        type: Int
        description: Video duration in seconds
      - name: fps
        type: Int
        description: Frames per second
      - name: model
        type: String
        description: Model to use (kling-v1, kling-v1.5)
  
  - name: TTSRequest
    description: Text-to-speech request
    fields:
      - name: text
        type: String
        description: Text to convert to speech
      - name: voice
        type: String
        description: Voice ID (rachel, adam, etc.)
      - name: model
        type: String
        description: Model to use (eleven_multilingual_v2)
  
  - name: ChatRequest
    description: Chat completion request
    fields:
      - name: messages
        type: List(ChatMessage)
        description: Conversation messages
      - name: model
        type: String
        description: Model to use (gpt-4, gpt-3.5-turbo)
      - name: temperature
        type: Float
        description: Sampling temperature
  
  - name: ChatMessage
    description: Single chat message
    fields:
      - name: role
        type: String
        description: Message role (system, user, assistant)
      - name: content
        type: String
        description: Message content

# ============================================================================
# BEHAVIORS
# ============================================================================

behaviors:
  - name: flux_generate
    description: Generate image with FLUX
    given: A text prompt and image dimensions
    when: flux_generate is called
    then: Image is generated and URL is returned
    test_cases:
      - name: generate_simple_image
        input:
          prompt: "A beautiful sunset over mountains"
          width: "1024"
          height: "1024"
        expected:
          image_url: "https://..."
          model: "flux-pro"
      
      - name: generate_with_custom_size
        input:
          prompt: "A cat sitting on a chair"
          width: "512"
          height: "768"
        expected:
          image_url: "https://..."
  
  - name: kling_video
    description: Generate video with Kling
    given: A text prompt and duration
    when: kling_video is called
    then: Video is generated and URL is returned
    test_cases:
      - name: generate_short_video
        input:
          prompt: "A bird flying through clouds"
          duration: "5"
        expected:
          video_url: "https://..."
          duration: "5"
  
  - name: elevenlabs_tts
    description: Convert text to speech
    given: Text and voice ID
    when: elevenlabs_tts is called
    then: Audio is generated and URL is returned
    test_cases:
      - name: generate_speech
        input:
          text: "Hello, how are you today?"
          voice: "rachel"
        expected:
          audio_url: "https://..."
          voice: "rachel"
  
  - name: gpt_chat
    description: Chat with GPT
    given: Conversation messages
    when: gpt_chat is called
    then: AI response is returned
    test_cases:
      - name: simple_chat
        input:
          messages: "[{role: 'user', content: 'Hello'}]"
          model: "gpt-4"
        expected:
          response: "Hello! How can I help you today?"
          model: "gpt-4"

# ============================================================================
# FUNCTIONS
# ============================================================================

functions:
  - name: flux_generate
    signature: "flux_generate(prompt: String, width: Int, height: Int) -> Result(ImageGenerationResult, String)"
    description: Generate image with FLUX AI
    examples:
      - "flux_generate(\"sunset\", 1024, 1024)"
  
  - name: flux_generate_with_model
    signature: "flux_generate_with_model(request: ImageGenerationRequest) -> Result(ImageGenerationResult, String)"
    description: Generate image with specific model
    examples:
      - "flux_generate_with_model(request)"
  
  - name: kling_video
    signature: "kling_video(prompt: String, duration: Int) -> Result(String, String)"
    description: Generate video with Kling AI
    examples:
      - "kling_video(\"flying bird\", 5)"
  
  - name: kling_video_with_options
    signature: "kling_video_with_options(request: VideoGenerationRequest) -> Result(String, String)"
    description: Generate video with options
    examples:
      - "kling_video_with_options(request)"
  
  - name: elevenlabs_tts
    signature: "elevenlabs_tts(text: String, voice: String) -> Result(String, String)"
    description: Convert text to speech
    examples:
      - "elevenlabs_tts(\"Hello\", \"rachel\")"
  
  - name: elevenlabs_tts_with_model
    signature: "elevenlabs_tts_with_model(request: TTSRequest) -> Result(String, String)"
    description: TTS with specific model
    examples:
      - "elevenlabs_tts_with_model(request)"
  
  - name: gpt_chat
    signature: "gpt_chat(messages: List(ChatMessage), model: String) -> Result(String, String)"
    description: Chat with GPT
    examples:
      - "gpt_chat(messages, \"gpt-4\")"
  
  - name: gpt_chat_with_options
    signature: "gpt_chat_with_options(request: ChatRequest) -> Result(String, String)"
    description: Chat with options
    examples:
      - "gpt_chat_with_options(request)"

# ============================================================================
# DEPENDENCIES
# ============================================================================

dependencies:
  - gleam_stdlib
  - gleam_http
  - gleam_httpc
  - gleam_json

# ============================================================================
# METADATA
# ============================================================================

metadata:
  author: VIBEE Team
  license: MIT
  category: ai
  tags:
    - ai
    - image-generation
    - video-generation
    - text-to-speech
    - chat
  
  api_keys_required:
    - FLUX_API_KEY
    - KLING_API_KEY
    - ELEVENLABS_API_KEY
    - OPENAI_API_KEY
  
  rate_limits:
    flux: "100 requests/hour"
    kling: "50 requests/hour"
    elevenlabs: "1000 characters/day"
    gpt: "10000 tokens/minute"
  
  pricing:
    flux_pro: "$0.05 per image"
    kling_v1: "$0.10 per second"
    elevenlabs: "$0.30 per 1000 characters"
    gpt4: "$0.03 per 1000 tokens"
