# VIBEE SWE Agent - Full Implementation
  // Performance Warning:   // AI Suggestion: Consider extracting hardcoded strings to constants# Written in VIBEE DSL - Dogfooding!
# Claude Code style Agent Loop: Stream → Tool → Execute → Repeat

# =============================================================================
# IMPORTS
# =============================================================================

import cli_ui/cli as cli
import agent/swe_tools as tools

# =============================================================================
# CONSTANTS
# =============================================================================

let VERSION = const("0.1.0"
let AGENT_NAME = const("VIBEE SWE Agent"
let MAX_TURNS = const(10

# =============================================================================
# AGENT STATE
# =============================================================================

struct AgentState:
  mode: str = "chat"
  model: str = "sonnet"
  provider: str = "claude-code"
  files: list[str] = []
  history: list[Message] = []
  session_id: str = ""
  verbose: bool = false
end

struct Message:
  role: str       # "type type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int}" | "assistant" | "system"
  content: str
  model: str = ""
end

struct AgentConfig:
  max_turns: int = 10
  model: str = "sonnet"
  provider: str = "claude-code"
  show_thinking: bool = false
  verbose: bool = false
end

# =============================================================================
# AGENT LIFECYCLE
# =============================================================================

tool agent_create:,
  desc: "Create new SWE agent instance"
  @Creates agent: true → agent_create() → result.session_id != ""

  → {
    session_id = ffi("session_ffi", "generate_id")
    cwd = ffi("os_ffi", "cwd")

    AgentState(
      mode: "chat",
      model: "sonnet",
      provider: "claude-code",
      files: [],
      history: [],
      session_id,
      verbose: false
    )
  }

tool agent_init:,
  desc: "Initialize agent with config"
  @Initializes agent: config != _ → result != _

  config: AgentConfig!

  → {
    state = agent_create()
    AgentState(
      ..state,
      model: config.model,
      provider: config.provider,
      verbose: config.verbose
    )
  }

# =============================================================================
# AGENT LOOP (Claude Code Style)
# =============================================================================

tool agent_run:,
  desc: "Run agent loop until completion"
  @Runs agent: state != _, prompt != "" → result != _

  state: AgentState!
  prompt: str!
  config: AgentConfig = AgentConfig()

  → {
    # Add type type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} message to history
    new_history = state.history + [Message(role: "type type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int}", content: prompt)]
    state = AgentState(..state, history: new_history)

    # Start agent loop
    config, 0 · agent_turn
  }

tool agent_turn:,
  desc: "Single agent turn (call LLM, process response, execute tools)"
  @Executes turn: state != _ → result != _

  state: AgentState!
  config: AgentConfig!
  turn: int!

  → {
    # Check max turns
    if turn >= config.max_turns:
      cli.cli_warning("Max turns reached (" + config.max_turns + ")")
      state
    end

    # Show spinner while calling LLM
    spinner_ref = cli.cli_spinner_start()

    # Call LLM
    response = config · call_llm

    # Stop spinner
    cli.cli_spinner_stop(spinner_ref)

    # Process response
    state = response, config · process_response

    # Check stop reason
    match response.stop_reason:
      "tool_use" ->
        # Execute pending tools
        state = config · execute_pending_tools
        # Continue loop
        config, turn + 1 · agent_turn

      "end_turn" ->
        # Normal completion
        turn + 1 · show_final_result
        state

      "max_tokens" ->
        # Hit token limit - compact and continue
        cli.cli_warning("Token limit reached, compacting...")
        state = 20 · compact_history
        config, turn + 1 · agent_turn

      _ ->
        state
    end
  }

# =============================================================================
# LLM INTEGRATION
# =============================================================================

tool call_llm:,
  desc: "Call LLM with session context"
  @Returns response: state != _ → result != _

  state: AgentState!
  config: AgentConfig!

  → {
    # Build prompt from history
    prompt = build_prompt(state)

    # Call LLM via FFI
    match config.provider:
      "claude-code" ->
        ffi("llm_ffi", "claude_code_chat", config.model, prompt)
      "openrouter" ->
        ffi("llm_ffi", "openrouter_chat", config.model, prompt)
      _ ->
        { error: "Unknown provider: " + config.provider }
    end
  }

tool build_prompt:,
  desc: "Build prompt from session history"
  @Returns prompt: state != _ → result != ""

  state: AgentState!

  → {
    # Build context from files
    context = build_file_context(state.files)

    # Build message history
    messages = state.history
      · map(fn(msg) ->
        match msg.role:
          "type type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int}" → "type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int}: " + msg.content
          "assistant" → "Assistant: " + msg.content
          "system" → "System: " + msg.content
          _ → msg.content
        end
      end)
      |join("\n")

    context + "\n\n" + messages
  }

tool build_file_context:,
  desc: "Build context from files in context"
  @Returns context: true → build_file_context([]) → result != ""

  files: list[str]!

  → {
    if files == []:
      "You are a software engineering assistant. Help the type type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} with coding tasks."
    else:
      file_contents = files
        · map(fn(path) ->
          content = ffi("os_ffi", "read_file", path)
          match content:
            { ok: c } → "File: " + path + "\n```\n" + c + "\n```\n"
            { error: _ } → ""
          end
        end)
        |join("\n")

      "You are a software engineering assistant. Here are the relevant files:\n\n" + file_contents
    end
  }

# =============================================================================
# RESPONSE PROCESSING
# =============================================================================

tool process_response:,
  desc: "Process LLM response and update state"
  @Returns updated state: state != _ → result != _

  state: AgentState!
  response: any!
  config: AgentConfig!

  → {
    # Add assistant message to history
    assistant_msg = Message(
      role: "assistant",
      content: response.content,
      model: config.model
    )
    new_history = state.history + [assistant_msg]

    # Display response
    cli.cli_println("")
    cli.cli_println(response.content)

    AgentState(..state, history: new_history)
  }

# =============================================================================
# tool EXECUTION
# =============================================================================

tool execute_pending_tools:,
  desc: "Execute all pending tools"
  @Executes tools: state != _ → result != _

  state: AgentState!
  config: AgentConfig!

  → {
    # Get pending tools from last response
    pending = get_pending_tools(state)

    # Execute each tool
    results = pending
      · map(fn(tool) ->
        cli.cli_dbg(cli.DIM + "  Executing " + tool.name + "..." + cli.RESET)

        result = execute_tool(tool.name, tool.input)

        match result:
          { ok: _ } → cli.cli_println(" " + cli.GREEN + cli.ICON_CHECK + cli.RESET)
          { error: _ } → cli.cli_println(" " + cli.RED + cli.ICON_CROSS + cli.RESET)
        end

        result
      end)

    # Add tool results to history
    results · add_tool_results
  }

tool execute_tool:,
  desc: "Execute single tool by name"
  @Executes tool: name != "" → result != _

  name: str!
  input: any!

  → {
    # Dispatch to appropriate handler
    match name:
      # File operations
      "swe_read" → tools.swe_read(input.path)
      "swe_write" → tools.swe_write(input.path, input.content)
      "swe_search" → tools.swe_search(input.pattern, input.path)

      # Git operations
      "git_status" → tools.swe_git_status()
      "git_diff" → tools.swe_git_diff()

      # Build operations
      "swe_build" → tools.swe_build()
      "swe_test" → tools.swe_test_run(input.module)

      _ → { error: "Unknown tool: " + name }
    end
  }

# =============================================================================
# COMMANDS
# =============================================================================

tool parse_command:,
  desc: "Parse type type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} input into command"
  @Returns command: input != "" → result != _

  input: str!

  → {
    trimmed = input · trim()

    match trimmed:
      "/help" | "/h" | "/?" → { cmd: "help" }
      "/version" | "/v" → { cmd: "version" }
      "/quit" | "/exit" | "/q" → { cmd: "quit" }
      "/clear" → { cmd: "clear" }
      "/map" → { cmd: "map" }
      "/spec" → { cmd: "spec" }
      "/git status" | "/gs" → { cmd: "git_status" }
      "/git diff" | "/gd" → { cmd: "git_diff" }
      "/config" → { cmd: "config" }
      "/" | "/?" → { cmd: "menu" }

      # Number shortcuts
      "1" → { cmd: "help" }
      "2" → { cmd: "config" }
      "3" → { cmd: "quit" }
      "4" → { cmd: "mode", args: "chat" }
      "5" → { cmd: "mode", args: "code" }
      "6" → { cmd: "mode", args: "architect" }
      "7" → { cmd: "provider", args: "claude-code" }
      "8" → { cmd: "provider", args: "openrouter" }
      "9" → { cmd: "model", args: "sonnet" }
      "0" → { cmd: "model", args: "opus" }

      _ ->
        if trimmed · starts_with("/"):
          parse_slash_command(trimmed)
        else:
          { cmd: "chat", message: trimmed }
        end
    end
  }

tool parse_slash_command:,
  desc: "Parse slash command with arguments"
  @Returns parsed: input != "" → result != _

  input: str!

  → {
    parts = input · drop_start(1) · split(" ")

    match parts:
      [name] → { cmd: name, args: "" }
      [name, ..rest] → { cmd: name, args: rest |join(" ") }
      _ → { cmd: "unknown", args: input }
    end
  }

# =============================================================================
# COMMAND HANDLERS
# =============================================================================

tool handle_command:,
  desc: "Handle parsed command"
  @Returns result: state != _ → result != _

  state: AgentState!
  cmd: any!

  → {
    match cmd.cmd:
      "help" ->
        { state, output: cli.cli_help(), quit: false }

      "version" ->
        { state, output: AGENT_NAME + " v" + VERSION, quit: false }

      "quit" ->
        { state, output: cli.DIM + "Goodbye! " + cli.ICON_BEE + cli.RESET, quit: true }

      "clear" ->
        new_state = AgentState(..state, history: [])
        { state: new_state, output: cli.cli_success("History cleared."), quit: false }

      "menu" ->
        { state, output: cli.cli_menu(), quit: false }

      "config" ->
        output = show_config(state)
        { state, output, quit: false }

      "map" ->
        output = tools.swe_map()
        { state, output, quit: false }

      "spec" ->
        output = tools.swe_spec()
        { state, output, quit: false }

      "git_status" ->
        output = tools.swe_git_status()
        { state, output: cli.cli_colorize_git_status(output), quit: false }

      "git_diff" ->
        output = tools.swe_git_diff()
        { state, output: cli.cli_colorize_diff(output), quit: false }

      "mode" ->
        new_state = AgentState(..state, mode: cmd.args)
        output = cli.cli_status_bar(cmd.args, state.model, state.provider)
        { state: new_state, output, quit: false }

      "model" ->
        new_state = AgentState(..state, model: cmd.args)
        { state: new_state, output: cli.cli_info("Model set to: " + cmd.args), quit: false }

      "provider" ->
        new_state = AgentState(..state, provider: cmd.args)
        { state: new_state, output: cli.cli_success("Provider: " + cmd.args), quit: false }

      "chat" ->
        config = AgentConfig(
          max_turns: MAX_TURNS,
          model: state.model,
          provider: state.provider,
          verbose: state.verbose
        )
        new_state = cmd.message, config · agent_run
        { state: new_state, output: "", quit: false }

      _ ->
        { state, output: cli.cli_error("Unknown command: " + cmd.cmd), quit: false }
    end
  }

tool show_config:,
  desc: "Show agent configuration"
  @Returns config: state != _ → result != ""

  state: AgentState!

  → {
    provider_name = match state.provider:
      "claude-code" → "Claude Code " + cli.ICON_BEE
      "openrouter" → "OpenRouter"
      _ → state.provider
    end

    cli.cli_panel("Configuration",
      cli.DIM + "Provider: " + cli.RESET + cli.BRIGHT_YELLOW + provider_name + cli.RESET + "\n" +
      cli.DIM + "Mode: " + cli.RESET + cli.YELLOW + state.mode + cli.RESET + "\n" +
      cli.DIM + "Model: " + cli.RESET + cli.CYAN + state.model + cli.RESET + "\n" +
      cli.DIM + "Files in context: " + cli.RESET + (state.files |len() · to_string()) + "\n" +
      cli.DIM + "History size: " + cli.RESET + (state.history |len() · to_string()),
      40
    )
  }

# =============================================================================
# REPL
# =============================================================================

tool agent_repl:,
  desc: "Run interactive REPL"
  @Runs REPL: true → agent_repl() → result != _

  → {
    # Clear screen and show banner
    cli.cli_clear_screen()
    cli.cli_println(cli.cli_banner())

    # Create initial state
    state = agent_create()

    # Check if Claude Code is available
    if ffi("llm_ffi", "is_claude_code_available"):
      state = AgentState(..state, provider: "claude-code", model: "sonnet")
    else:
      state = AgentState(..state, provider: "openrouter", model: "deepseek/deepseek-chat")
    end

    # Show status bar
    cli.cli_println(cli.cli_status_bar(state.mode, state.model, state.provider))
    cli.cli_println("")

    # Start REPL loop
    repl_loop(state)
  }

tool repl_loop:,
  desc: "Main REPL loop"
  @Runs loop: state != _ → result != _

  state: AgentState!

  → {
    # Get current directory basename
    cwd = ffi("os_ffi", "cwd") · basename()

    # Print prompt
    cli.cli_dbg(cli.cli_prompt(state.mode, cwd))

    # Read input
    input = cli.cli_read_line()

    match input:
      "eof" ->
        cli.cli_println("\nGoodbye!")
        state

      "" ->
        # Empty input - show menu
        cli.cli_println(cli.cli_menu())
        repl_loop(state)

      _ ->
        # Parse and handle command
        cmd = parse_command(input)
        result = cmd · handle_command

        cli.cli_println(result.output)

        if result.quit:
          result.state
        else:
          repl_loop(result.state)
        end
    end
  }

# =============================================================================
# HELPERS
# =============================================================================

tool compact_history:,
  desc: "Compact conversation history"
  @Returns compacted: state != _ → result != _

  state: AgentState!
  keep_last: int = 20

  → {
    compacted = state.history · take_last(keep_last)
    AgentState(..state, history: compacted)
  }

tool show_final_result:,
  desc: "Show final result summary"
  @Shows result: state != _ → result == "ok"

  state: AgentState!
  turns: int!

  → {
    cli.cli_println("")
    cli.cli_println(cli.DIM + "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" + cli.RESET)
    cli.cli_println(cli.DIM + "Completed in " + turns + " turn(s)" + cli.RESET)
    "ok"
  }

tool get_pending_tools:,
  desc: "Get pending tools from last response"
  @Returns tools: state != _ → result != _

  state: AgentState!

  → {
    # Extract tool_use blocks from last assistant message
    []  # Placeholder - actual implementation via FFI
  }

tool add_tool_results:,
  desc: "Add tool results to history"
  @Returns updated: state != _ → result != _

  state: AgentState!
  results: list[any]!

  → {
    # Add tool results as messages
    state  # Placeholder
  }

tool basename:,
  desc: "Get basename of path"
  @Returns basename: path != "" → result != ""

  path: str!

  → {
    parts = path · split("/")
    parts · last() · or_else("vibee")
  }

# =============================================================================
# MAIN ENTRY POINT
# =============================================================================

tool main:,
  desc: "Main entry point for SWE Agent"
  @Runs agent: true → main() → result != _

  → {
    agent_repl()
  }

