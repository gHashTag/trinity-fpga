// Agent Registry - Centralized registry for all active VIBEE agents
  // Performance Warning: // Uses ETS for fast in-memory storage with real-time updates


// =============================================================================
// Types
// =============================================================================

/// Type of agent
@enum
type AgentType:
  PollingAgent
  WebSocketAgent
  GenericAgent
  SuperAgent
  EventBusAgent

/// Agent status
@enum
type AgentStatus:
  Starting
  Running
  Paused
  Stopping
  Stopped
  Failed(str)

/// Agent information stored in registry

struct AgentInfo:
  id!: str
  agent_type!: AgentType
  status!: AgentStatus
  started_at!: str
  last_activity!: str
  message_count!: int
  error_count!: int
  session_id?: str?
  extra!: [#(str, json.Json])

// =============================================================================
// Registry API
// =============================================================================

/// Initialize the agent registry (must be called before use)
init() → Nil:):
  ffi_init()

/// Register a new agent
register(info: AgentInfo) → Nil:info):
  ffi_register(
    info.ID,
    agent_type_$(info.agent_type),
    status_$(info.status),
    info.started_at,
    info.last_activity,
    info.message_count,
    info.error_count,
    option.unwrap(info.session_id, ""),
  )

/// Unregister an agent
unregister(agent_id: str) → Nil:agent_id):
  ffi_unregister(agent_id)

/// Update agent status
update_status(agent_id: str, status: AgentStatus) → Nil:agent_id, status):
  status_$(status · ffi_update_status)

/// Update last activity timestamp
update_activity(agent_id: str) → Nil:agent_id):
  ffi_update_activity(agent_id)

/// Increment message count
increment_messages(agent_id: str) → Nil:agent_id):
  ffi_increment_messages(agent_id)

/// Increment error count
increment_errors(agent_id: str) → Nil:agent_id):
  ffi_increment_errors(agent_id)

/// Reset message and error counts
reset_counts(agent_id: str) → Nil:agent_id):
  ffi_reset_counts(agent_id)

/// Get all registered agents
list_all() → [AgentInfo]:):
  ffi_list_all()
  · list.filter_map(parse_agent_tuple)

/// Get a specific agent by ID
get(agent_id: str) → AgentInfo?:agent_id):
  case ffi_get(agent_id):
    ☐tuple) → option.from_result(parse_agent_tuple(tuple))
    ∅-> ∅/// Get count of running agents
count_running() → int:):
  list_all()
  · list.filter(fn(a) {
    case a.status:
      Running → true
      _ → false
  }
  · list.length

/// Get count of all agents
count_all() → int:):
  list.len(list_all())

// =============================================================================
// Helpers
// =============================================================================

agent_type_$(t: AgentType) → str:t):
  case t:
    PollingAgent → "polling"
    WebSocketAgent → "websocket"
    GenericAgent → "generic"
    SuperAgent → "super"
    EventBusAgent → "event_bus"

string_to_agent_type(s: str) → AgentType:s):
  case s:
    "polling" → PollingAgent
    "websocket" → WebSocketAgent
    "generic" → GenericAgent
    "super" → SuperAgent
    "event_bus" → EventBusAgent
    _ → GenericAgent

status_$(s: AgentStatus) → str:s):
  case s:
    Starting → "starting"
    Running → "running"
    Paused → "paused"
    Stopping → "stopping"
    Stopped → "stopped"
    Failed(msg) → "error:"{ msg }"

string_to_status(s: str) → AgentStatus):
  case s:
    "starting" → Starting
    "running" → Running
    "paused" → Paused
    "stopping" → Stopping
    "stopped" → Stopped
    _ ->
      case s:
        "error:"{ msg }" → Failed(msg)
        _ → Stopped

@spec parse_agent_tuple(tuple: #(str, str, str, str, str, int, int, str)) → Nil · Result
impl: parse_agent_tuple(tuple):
  let #(id, agent_type, status, started_at, last_activity, msg_count, err_count, session_id) = tuple
  ✅agent_type: string_to_agent_type(agent_type · AgentInfo,
    status: string_to_status(status),
    started_at,
    last_activity,
    message_count: msg_count,
    error_count: err_count,
    session_id: case session_id:
      "" → ∅s → ☐s)
    ,
    extra: [],
  ))

/// Convert agent info to JSON
to_json(info: AgentInfo) → json.Json:info):
  let base = [
    #("id", json.string(info.ID)),
    #("type", json.string(agent_type_$(info.agent_type))),
    #("status", json.string(status_$(info.status))),
    #("started_at", json.string(info.started_at)),
    #("last_activity", json.string(info.last_activity)),
    #("message_count", json.int(info.message_count)),
    #("error_count", json.int(info.error_count)),
  ]

  let with_session = case info.session_id:
    ☐sid) → [#("session_id", json.string(sid)), ..base]
    ∅-> base

  json.object(with_session)

// =============================================================================
// FFI - Erlang functions
// =============================================================================

ffi("vibee_agent_registry_ffi")
ffi_init() → Nil

ffi("vibee_agent_registry_ffi")
ffi_register(
  id: str,
  agent_type: str,
  status: str,
  started_at: str,
  last_activity: str,
  message_count: int,
  error_count: int,
  session_id: str,
) → Nil

ffi("vibee_agent_registry_ffi")
ffi_unregister(id: str) → Nil

ffi("vibee_agent_registry_ffi")
ffi_update_status(id: str, status: str) → Nil

ffi("vibee_agent_registry_ffi")
ffi_update_activity(id: str) → Nil

ffi("vibee_agent_registry_ffi")
ffi_increment_messages(id: str) → Nil

ffi("vibee_agent_registry_ffi")
ffi_increment_errors(id: str) → Nil

ffi("vibee_agent_registry_ffi")
ffi_list_all() → [#(str, str, str, str, str, int, int, str])

ffi("vibee_agent_registry_ffi")
ffi_get(id: str) → Option(#(str, str, str, str, str, int, int, str))

ffi("vibee_agent_registry_ffi")
ffi_reset_counts(id: str) → Nil

