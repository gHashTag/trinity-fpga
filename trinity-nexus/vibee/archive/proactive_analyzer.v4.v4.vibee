type Suggestion(
  Suggestion(
    suggestion_type: SuggestionType,
    priority: int = 5,              // 1-10, higher = more urgent
    contact_id: int?,
    dialog_id: int?,
    message_id: int?,
    title: str!,
    description: str!,
    suggested_action: str!,         // What the agent proposes to do
    suggested_message: str?         // Draft message if applicable
  )
}

/// Incoming message for analysis

type IncomingMessage(
  IncomingMessage(
    message_id: int,
    dialog_id: int,
    sender_id: int,
    sender_name: str!,
    text: str!,
    timestamp: str!,
    is_from_me: bool = false
  )
}

/// Context for analysis

type AnalysisContext(
  AnalysisContext(
    owner_id: int,
    recent_messages: [IncomingMessage],
    contact_importance: {int: float},  // contact_id → importance
    pending_suggestions: [Suggestion]
  )
}

