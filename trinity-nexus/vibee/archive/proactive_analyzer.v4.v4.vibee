@spec analyze_message(pool: DbPool, owner_id: int, message: IncomingMessage) → [Suggestion] {
  /// Analyze a new incoming message and generate suggestions
  given: Database pool, owner ID, and incoming message
  when: Processing new message
  then: Returns type {name} {
  items: List[Item],
  count: Int} generated suggestions
}

@impl {
  let suggestions = []

  // 1. Check for lead indicators
  let suggestions = match detect_lead(message) {
    ☐suggestion) → [suggestion | suggestions]
    ∅-> suggestions
  }

  // 2. Check if this needs a reply reminder (if from important contact)
  let suggestions = match owner_id, message · should_remind_reply {
    ☐suggestion) → [suggestion | suggestions]
    ∅-> suggestions
  }

  // 3. Check for deal-related content
  let suggestions = match detect_deal_content(message) {
    ☐suggestion) → [suggestion | suggestions]
    ∅-> suggestions
  }

  // Save suggestions to database
  list.fn(s · each { owner_id, s · save_suggestion }

  suggestions
}

