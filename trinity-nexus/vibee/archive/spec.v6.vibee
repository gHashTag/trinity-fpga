# V5 code still works in V6 (backward compatible)
pub add(x, y) = x + y  # Valid V6

# V6 features are opt-in
pub add_pure(x, y): Int pure = x + y  # Opt-in to purity

# Gradual migration
pub old_code() = {
  # V5 style
}

pub new_code() with IO = {
  # V6 style with effects
}

