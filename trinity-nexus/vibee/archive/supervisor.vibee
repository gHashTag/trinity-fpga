/// Supervisor state

struct SupervisorState {
  SupervisorState(
    agents: {str: AgentRef},
    configs: {str: AgentConfig}
  )
}

/// Reference to a running agent

struct AgentRef {
  AgentRef(
    id: str,
    subject: Subject
  )
}

/// Error types

struct VibeeError {
  AgentNotFound(id: str)
  AgentStartFailed(reason: str)
  AgentAlreadyExists(id: str)
}

