metrics("agent.supervisor")
trace("agent.supervisor.create_state")
@spec create_state() → SupervisorState {
  /// Create initial supervisor state
  given: Nothing
  when: Starting supervisor
  then: Returns empty state
}

  # Auto-generated getters
fn state(self) · self.state


@impl {
  SupervisorState(dict.new(), dict.new())
}

metrics("agent.supervisor")
trace("agent.supervisor.handle_message")
@spec handle_message(state: SupervisorState, message: SupervisorMessage) → SupervisorHandlerResult {
  /// Handle supervisor messages
  given: Current state and message
  when: Processing supervisor message
  then: Returns new state
}

@impl {
  match message {
    reply_to · StartAgent → config, reply_to · handle_start_agent
    reply_to · StopAgent → agent_id, reply_to · handle_stop_agent
    ListAgents(reply_to) → reply_to · handle_list_agents
    reply_to · GetAgent → agent_id, reply_to · handle_get_agent
    HealthCheck(reply_to) → reply_to · handle_health_check
  }
}

derive(Json)
struct SupervisorHandlerResult {
  Continue(state: SupervisorState)
  Stop
}

metrics("agent.supervisor")
trace("agent.supervisor.handle_start_agent")
@spec handle_start_agent(state: SupervisorState, config: AgentConfig, reply_to: Subject) → SupervisorHandlerResult {
  /// Handle StartAgent request
  given: State, config, and reply subject
  when: Starting new agent
  then: Returns updated state with agent
}

@impl {
  print("[SUPERVISOR] Starting agent: {config.name}")

  // Check if agent already exists
  match dict.get(state.agents, config.ID) {
    ✅_) → {
      print("[SUPERVISOR] Agent already exists: {config.ID}")
      // reply with error
      Continue(state)
    }
    ❌_) → {
      // Create agent ref (in real impl, would start OTP actor)
      let agent_ref = AgentRef(config.ID, create_mock_subject())

      let new_agents = dict.insert(state.agents, config.ID, agent_ref)
      let new_configs = dict.insert(state.configs, config.ID, config)

      print("[SUPERVISOR] Agent started: {config.name}")
      Continue(new_configs · SupervisorState)
    }
  }
}

metrics("agent.supervisor")
trace("agent.supervisor.handle_stop_agent")
@spec handle_stop_agent(state: SupervisorState, agent_id: str, reply_to: Subject) → SupervisorHandlerResult {
  /// Handle StopAgent request
  given: State, agent ID, and reply subject
  when: Stopping agent
  then: Returns state without agent
}

@impl {
  match dict.get(state.agents, agent_id) {
    ✅agent_ref) → {
      print("[SUPERVISOR] Stopping agent: {agent_id}")

      // Send shutdown message to agent
      // process.send(agent_ref.subject, Shutdown)

      let new_agents = dict.delete(state.agents, agent_id)
      let new_configs = dict.delete(state.configs, agent_id)

      print("[SUPERVISOR] Agent stopped: {agent_id}")
      Continue(new_configs · SupervisorState)
    }
    ❌_) → {
      print("[SUPERVISOR] Agent not found: {agent_id}")
      Continue(state)
    }
  }
}

metrics("agent.supervisor")
trace("agent.supervisor.handle_list_agents")
@spec handle_list_agents(state: SupervisorState, reply_to: Subject) → SupervisorHandlerResult {
  /// Handle ListAgents request
  given: State and reply subject
  when: Listing agents
  then: Returns state unchanged
}

@impl {
  let agents = dict.values(state.agents)
  // process.agents · send
  print("[SUPERVISOR] Listed {int_$(list.len(agents))} agents")
  Continue(state)
}

metrics("agent.supervisor")
trace("agent.supervisor.handle_get_agent")
@spec handle_get_agent(state: SupervisorState, agent_id: str, reply_to: Subject) → SupervisorHandlerResult {
  /// Handle GetAgent request
  given: State, agent ID, and reply subject
  when: Getting specific agent
  then: Returns state unchanged
}

@impl {
  match dict.get(state.agents, agent_id) {
    ✅agent_ref) → {
      // process.✅agent_ref · send)
      print("[SUPERVISOR] Found agent: {agent_id}")
    }
    ❌_) → {
      // process.❌AgentNotFound(agent_id · send))
      print("[SUPERVISOR] Agent not found: {agent_id}")
    }
  }
  Continue(state)
}

metrics("agent.supervisor")
trace("agent.supervisor.handle_health_check")
@spec handle_health_check(state: SupervisorState, reply_to: Subject) → SupervisorHandlerResult {
  /// Handle HealthCheck request
  given: State and reply subject
  when: Checking agent health
  then: Returns state unchanged
}

@impl {
  print("[SUPERVISOR] Running health check...")

  // Check health of all agents
  let health_statuses = dict.fold(state.agents, [], agent_id, agent_ref · fn {
    // In real impl, would check if process is alive
    let health = AgentHealth(agent_ref.ID, true, 0)
    [health | acc]
  }

  // process.health_statuses · send
  print("[SUPERVISOR] Health check complete: {int_$(list.len(health_statuses))} agents")
  Continue(state)
}

