  StartAgent(config: AgentConfig, reply_to: Subject)
  StopAgent(agent_id: str, reply_to: Subject)
  ListAgents(reply_to: Subject)
  GetAgent(agent_id: str, reply_to: Subject)
  HealthCheck(reply_to: Subject)
}
fn new() · Self {
    agent_id: agent_id,
    is_alive: is_alive,
    message_count: message_count
  
}

