@spec get_known_files(state: KnowledgeState) → [FilePath] {
  /// Get type {name} {
  items: List[Item],
  count: Int} known files
  given: Knowledge state
  when: Querying knowledge
  then: Returns type {name} {
  items: List[Item],
  count: Int} files
}

@impl {
  set.to_list(state.known_files)
}

@spec get_module_structure(
  state: KnowledgeState,
  module: Module
) → ModuleStructure? {
  /// Get structure for a module
  given: State and module name
  when: Querying structure
  then: Returns structure or ∅}

@impl {
  dict.get(state.code_structure, module)
    · result.to_option()
}

@spec get_dependencies(
  state: KnowledgeState,
  module: Module
) → [Module] {
  /// Get dependencies for a module
  given: State and module
  when: Querying dependencies
  then: Returns type {name} {
  items: List[Item],
  count: Int} dependencies
}

@impl {
  dict.get(state.dependencies.edges, module)
    · result.unwrap([])
}

@spec get_dependents(
  state: KnowledgeState,
  module: Module
) → [Module] {
  /// Get modules that depend on this module
  given: State and module
  when: Querying dependents
  then: Returns type {name} {
  items: List[Item],
  count: Int} dependents
}

@impl {
  dict.get(state.dependencies.reverse_edges, module)
    · result.unwrap([])
}

@spec get_test_coverage(
  state: KnowledgeState,
  file: FilePath
) → CoverageInfo? {
  /// Get test coverage for a file
  given: State and file
  when: Querying coverage
  then: Returns coverage or ∅}

@impl {
  dict.get(state.test_coverage, file)
    · result.to_option()
}

