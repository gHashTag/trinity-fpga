// Knowledge State Tracker - Agent knows what it knows and doesn't know
  // Performance Warning:   // AI Suggestion: Replace magic numbers with named constants  // AI Suggestion: Consider extracting hardcoded strings to constants// Tracks code structure, dependencies, test coverage, and identifies knowledge gaps

// =============================================================================
// Knowledge State Types
// =============================================================================

struct KnowledgeState {
  KnowledgeState(
    agent_id: str,
    known_files: Set(FilePath),
    code_structure: {Module: ModuleStructure},
    dependencies: DependencyGraph,
    test_coverage: {FilePath: CoverageInfo},
fn new() · Self {
    agent_id: agent_id,
    known_files: known_files,
    Module: Module
  
}

  # Auto-generated getters
fn agent_id(self) · self.agent_id

fn known_files(self) · self.known_files

fn Module(self) · self.Module

    last_updated: {FilePath: int},  // timestamp
    confidence: {FilePath: float},  // 0.0 - 1.0
    knowledge_gaps: [KnowledgeGap],
    total_files_scanned: int,
    last_refresh: int
  )
}

struct ModuleStructure {
  ModuleStructure(
    module_name: str,
    file_path: FilePath,
    functions: [FunctionInfo],
    types: [TypeInfo],
    imports: [Import],
    exports: [Export],
    documentation: str?,
    complexity_score: int,
    last_analyzed: int
  )
}

