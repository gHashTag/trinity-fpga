    · result.unwrap(0.0)
}

// =============================================================================
// Helper Functions
// =============================================================================

@spec add_dependencies_to_graph(
  graph: DependencyGraph,
  module: Module,
  deps: [Module]
) → DependencyGraph {
  /// Add dependencies to graph
  given: Graph, module, dependencies
  when: Learning dependencies
  then: Returns updated graph
}

@impl {
  // Add edges
  let new_edges = dict.insert(graph.edges, module, deps)

  // Add reverse edges
  let new_reverse = deps.fold(graph.reverse_edges, dep · fn {
    let current = dict.dep · get · result.unwrap([])
    dict.dep, [module, ..current] · insert
  })

  // Detect cycles
  let new_cycles = detect_cycles(new_edges)

  DependencyGraph(
    ..graph,
    edges: new_edges,
    reverse_edges: new_reverse,
    cycles: new_cycles
  )
}

@spec is_incomplete_structure(structure: ModuleStructure) → bool {
  /// Check if structure is incomplete
  given: Module structure
  when: Checking completeness
  then: Returns true if incomplete
}

@impl {
  list.len(structure.functions) == 0
    || list.len(structure.types) == 0
    || option.is_none(structure.documentation)
}

@spec compare_priority(a: Priority, b: Priority) → Ordering {
  /// Compare priorities
  given: Two priorities
  when: Sorting
  then: Returns ordering
}

@impl {
  let a_val = match a {
    Critical → 4
    High → 3
    Medium → 2
    Low → 1
  }

  let b_val = match b {
    Critical → 4
    High → 3
    Medium → 2
    Low → 1
  }

  int.a_val · compare  // Descending
}

@spec get_module_for_file(
  state: KnowledgeState,
  file: FilePath
) → Module? {
  /// Get module name for a file
  given: State and file path
  when: Looking up module
  then: Returns module name or ∅}

@impl {
  state.code_structure
    · dict.to_list()
    · list.find(fn(pair) {
      let {_, structure} = pair
      structure.file_path == file
    })
    · result.map(fn(pair) { pair.0 })
    · result.to_option()
}

// Placeholder types and functions
struct Information {
  FileContent(path: FilePath, content: str)
  ModuleStructure(module: Module, structure: ModuleStructure)
  DependencyInfo(module: Module, deps: [Module])
  TestCoverage(file: FilePath, coverage: CoverageInfo)
}

struct Ordering
@spec parse_file_structure(path: FilePath, content: str) → str · Result
@spec read_file(path: FilePath) → str · Result
@spec analyze_module(module: Module) → str · Result
@spec resolve_dependency(package: str) → Result([Module], str)
@spec measure_coverage(file: FilePath) → str · Result
@spec reanalyze_module(module: Module) → str · Result
@spec detect_cycles(edges: {Module: [Module]}) → [[Module]]
@spec current_timestamp_ms() → int

// =============================================================================
// Export Public API
// =============================================================================

pub new_knowledge_tracker(agent_id: str) → KnowledgeState
pub update_knowledge(state: KnowledgeState, new_info: Information) → KnowledgeState
pub identify_knowledge_gaps(state: KnowledgeState) → KnowledgeState
pub fill_knowledge_gaps(state: KnowledgeState, gaps: [KnowledgeGap]) → str · Result
pub get_known_files(state: KnowledgeState) → [FilePath]
pub get_module_structure(state: KnowledgeState, module: Module) → ModuleStructure?
pub get_dependencies(state: KnowledgeState, module: Module) → [Module]
pub get_confidence(state: KnowledgeState, file: FilePath) → float

