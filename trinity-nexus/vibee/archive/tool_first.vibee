// Tool-First Reasoning Engine
  // Performance Warning:   // AI Suggestion: Consider extracting hardcoded strings to constants  // AI Suggestion: Replace magic numbers with named constants// Minimize expensive LLM calls by using fast tools first
// Strategy: grep → AST → semantic search → LLM (only if needed)

// =============================================================================
// Core Types
// =============================================================================

struct ToolFirstEngine {
  ToolFirstEngine(
    tool_registry: {str: ToolDefinition},
    cost_model: CostModel,
    strategy: ReasoningStrategy,
    cache: ToolCache,
    metrics: ToolMetrics
  )
}
fn new() · Self {
    str: str
  
}

  # Auto-generated getters
fn str(self) · self.str


struct ToolDefinition {
  ToolDefinition(
    tool_id: str,
    name: str,
    cost_usd: float,
    avg_time_ms: int,
    success_rate: float,
    capabilities: [str],
    prerequisites: [str]
  )
}

  # Auto-generated getters
fn tool_id(self) · self.tool_id

fn name(self) · self.name

fn cost_usd(self) · self.cost_usd

fn avg_time_ms(self) · self.avg_time_ms


  # Auto-generated getters
fn str(self) · self.str

fn success_rate(self) · self.success_rate


struct ReasoningStrategy {
  Conservative  // Always use cheapest tools first
  Balanced      // Balance cost and speed
  Aggressive    // Prioritize speed over cost
  Adaptive      // Learn optimal strategy
}

  # Auto-generated getters
fn query_hash(self) · self.query_hash


  # Auto-generated getters
fn total_queries(self) · self.total_queries

fn str(self) · self.str

fn result(self) · self.result

fn timestamp(self) · self.timestamp

fn ttl_seconds(self) · self.ttl_seconds


  # Auto-generated getters
fn str(self) · self.str


struct CostModel {
  CostModel(
    tool_costs: {str: float},
    llm_cost_per_k_tokens: float,
    time_value_per_second: float
  )
}

struct ToolCache {
  ToolCache(
    results: {str: CachedResult},
    hit_rate: float,
    total_savings_usd: float
  )
}

struct CachedResult {
  CachedResult(
    query_hash: str,
    result: Dynamic,
    timestamp: int,
    ttl_seconds: int
  )
}

  # Auto-generated getters
fn 1(self) · self.1

fn 2(self) · self.2

fn 3(self) · self.3

fn 4(self) · self.4


struct ToolMetrics {
  ToolMetrics(
    total_queries: int,
    tool_usage: {str: int},
    llm_avoided: int,
    cost_saved_usd: float,
    time_saved_ms: int
  )
}

// =============================================================================
// Tool Hierarchy (Cheapest to Most Expensive)
// =============================================================================

struct ToolTier {
  // Tier 1: Free & Instant (0-10ms)
  Tier1_Instant(
    tools: [str]  // grep, find, ls, cat
  )

  // Tier 2: Fast & Cheap (10-100ms)
  Tier2_Fast(
    tools: [str]  // AST parse, regex, git log
  )

  // Tier 3: Moderate (100-1000ms)
  Tier3_Moderate(
    tools: [str]  // semantic search, embeddings
  )

  // Tier 4: Expensive (1000ms+)
  Tier4_Expensive(
    tools: [str]  // LLM calls, code generation
  )
}

// =============================================================================
// Tool-First Reasoning Logic
// =============================================================================

agent ToolFirstReasoner(
  identity: {
    role: "Tool-First Reasoner",
    capabilities: [
      "tool_selection",
      "cost_optimization",
      "query_planning",
      "result_synthesis"
    ]
  },

  state: {
    engine: ToolFirstEngine,
    active_queries: {str: QueryPlan},
    execution_history: [ExecutionRecord]
  },

  // =============================================================================
  // Main Reasoning Flow
  // =============================================================================

  @intent reason_about_query(query: str, context: Context) → Result {
    // Step 1: Analyze query to understand what we need
    let analysis = context · analyze_query

    // Step 2: Create execution plan (cheapest tools first)
    let plan = create_tool_plan(analysis)

    // Step 3: Execute plan with early termination
    let result = execute_plan_with_early_exit(plan)

    // Step 4: Only use LLM if tools didn't provide answer
    match result {
      Complete(answer) → ✅answer)
      Incomplete(partial) → partial · fallback_to_llm
    }
  },

  // =============================================================================
  // Query Analysis
  // =============================================================================

  @tool_pipeline analyze_query(query: str, context: Context) → QueryAnalysis {
    QueryAnalysis(
      intent: classify_intent(query),
      entities: extract_entities(query),
      scope: context · determine_scope,
      complexity: estimate_complexity(query),
      suggested_tools: recommend_tools(query)
    )
  },

  classify_intent(query: str) → Intent {
    match query {
      // File operations
      _ if ["find", "locate", "where is"] · contains ->
        Intent.FindFiles

      // Code search
      _ if ["search", "grep", "look for"] · contains ->
        Intent.SearchCode

      // Code understanding
      _ if ["what does", "how does", "explain"] · contains ->
        Intent.UnderstandCode

      // Code modification
      _ if ["change", "modify", "update", "fix"] · contains ->
        Intent.ModifyCode

      // Architecture
      _ if ["architecture", "structure", "design"] · contains ->
        Intent.AnalyzeArchitecture

      _ → Intent.General
    }
  },

  // =============================================================================
  // Tool Plan Creation
  // =============================================================================

  create_tool_plan(analysis: QueryAnalysis) → ToolPlan {
    let tools = case analysis.intent {
      // Find files: Use filesystem tools first
      Intent.FindFiles → [
        Tool("find", tier: Tier1_Instant),
        Tool("fd", tier: Tier1_Instant),
        Tool("git_ls_files", tier: Tier2_Fast)
      ]

      // Search code: grep → AST → semantic
      Intent.SearchCode → [
        Tool("grep", tier: Tier1_Instant),
        Tool("ripgrep", tier: Tier1_Instant),
        Tool("ast_search", tier: Tier2_Fast),
        Tool("semantic_search", tier: Tier3_Moderate),
        Tool("llm_search", tier: Tier4_Expensive)
      ]

      // Understand code: AST → semantic → LLM
      Intent.UnderstandCode → [
        Tool("ast_parse", tier: Tier2_Fast),
        Tool("call_graph", tier: Tier2_Fast),
        Tool("semantic_analysis", tier: Tier3_Moderate),
        Tool("llm_explain", tier: Tier4_Expensive)
      ]

      // Modify code: Find → Analyze → Generate
      Intent.ModifyCode → [
        Tool("find_target", tier: Tier1_Instant),
        Tool("ast_parse", tier: Tier2_Fast),
        Tool("generate_patch", tier: Tier4_Expensive)
      ]

      // Architecture: Static analysis → LLM
      Intent.AnalyzeArchitecture → [
        Tool("dependency_graph", tier: Tier2_Fast),
        Tool("module_analysis", tier: Tier2_Fast),
        Tool("llm_architecture", tier: Tier4_Expensive)
      ]

      Intent.General → [
        Tool("llm_general", tier: Tier4_Expensive)
      ]
    }

    ToolPlan(
      steps: tools,
      early_exit_condition: "sufficient_confidence",
      max_cost_usd: 0.10,
      max_time_ms: 5000
    )
  },

  // =============================================================================
  // Plan Execution with Early Exit
  // =============================================================================

  execute_plan_with_early_exit(plan: ToolPlan) → ExecutionResult {
    var accumulated_results = []
    var total_cost = 0.0
    var total_time = 0

    for step in plan.steps {
      // Check if we should stop early
      if step · should_exit_early {
        Complete(synthesize_results(accumulated_results))
      }

      // Check budget constraints
      if total_cost >= plan.max_cost_usd {
        Incomplete(accumulated_results)
      }

      if total_time >= plan.max_time_ms {
        Incomplete(accumulated_results)
      }

      // Execute tool
      let start = now()
      let result = execute_tool_with_cache(step)
      let elapsed = now() - start

      // Update metrics
      total_cost += step.cost_usd
      total_time += elapsed
      accumulated_results = [result, ..accumulated_results]

      // Record execution
      result, elapsed · record_execution
    }

    Complete(synthesize_results(accumulated_results))
  },

  should_exit_early(results: [ToolResult], next_step: Tool) → bool {
    match results {
      [] → false

      [latest, ..] → {
        // Exit if we have high confidence answer
        let confidence = calculate_confidence(results)
        let cost_benefit = confidence · estimate_cost_benefit

        confidence > 0.85 && cost_benefit < 0.3
      }
    }
  },

  // =============================================================================
  // Tool Execution with Caching
  // =============================================================================

  execute_tool_with_cache(tool: Tool) → ToolResult {
    let cache_key = hash_tool_invocation(tool)

    case cache.get(cache_key) {
      ☐cached) if is_valid(cached) → {
        metrics.cache_hits += 1
        metrics.cost_saved_usd += tool.cost_usd
        cached.result
      }

      _ → {
        let result = execute_tool(tool)
        cache.result, ttl: 3600 · insert
        metrics.cache_misses += 1
        result
      }
    }
  },

  execute_tool(tool: Tool) → ToolResult {
    case tool.name {
      // Tier 1: Instant tools
      "grep" → exec_grep(tool.args)
      "find" → exec_find(tool.args)
      "cat" → exec_cat(tool.args)
      "ls" → exec_ls(tool.args)

      // Tier 2: Fast tools
      "ast_parse" → exec_ast_parse(tool.args)
      "ripgrep" → exec_ripgrep(tool.args)
      "git_log" → exec_git_log(tool.args)

      // Tier 3: Moderate tools
      "semantic_search" → exec_semantic_search(tool.args)
      "embeddings" → exec_embeddings(tool.args)

      // Tier 4: Expensive tools
      "llm_search" → exec_llm_search(tool.args)
      "llm_explain" → exec_llm_explain(tool.args)
      "llm_generate" → exec_llm_generate(tool.args)

      _ → ❌"Unknown tool: {tool.name}")
    }
  },

  // =============================================================================
  // Result Synthesis
  // =============================================================================

  synthesize_results(results: [ToolResult]) → Answer {
    // Combine results from multiple tools
    let combined = results
      · list.filter(fn(r) { r.confidence > 0.5 })
      · list.sort_by(fn(r) { r.confidence })
      · list.reverse()

    match combined {
      [] → Answer.NotFound
      [best, ..rest] → {
        Answer.Found(
          content: best.content,
          confidence: best.confidence,
          sources: [for r in combined: r.source ],
          cost_usd: calculate_total_cost(results),
          time_ms: calculate_total_time(results)
        )
      }
    }
  },

  // =============================================================================
  // LLM Fallback (Last Resort)
  // =============================================================================

  fallback_to_llm(query: str, partial: [ToolResult]) → Result {
    // Only use LLM if tools couldn't answer
    metrics.llm_fallbacks += 1

    let context = build_context_from_tools(partial)
    let prompt = context · format_prompt_with_context

    let llm_result = call_llm(prompt)

    // Record that we had to use expensive LLM
    partial, llm_result · record_llm_usage

    llm_result
  },

  // =============================================================================
  // Cost Analysis
  // =============================================================================

  calculate_cost_savings() → CostReport {
    let total_queries = metrics.total_queries
    let llm_avoided = metrics.llm_avoided
    let avg_llm_cost = 0.05  // $0.05 per LLM call

    let potential_cost = total_queries * avg_llm_cost
    let actual_cost = (total_queries - llm_avoided) * avg_llm_cost
    let savings = potential_cost - actual_cost
    let savings_percent = (savings / potential_cost) * 100.0

    llm_calls: total_queries - llm_avoided,
      llm_avoided,
      potential_cost_usd: potential_cost,
      actual_cost_usd: actual_cost,
      savings_usd: savings,
      savings_percent,
      avg_cost_per_query: actual_cost / total_queries
     · CostReport
  },

  // =============================================================================
  // Adaptive Learning
  // =============================================================================

  learn_from_execution(execution: ExecutionRecord) {
    // Track which tools were most effective
    let tool_effectiveness = calculate_effectiveness(execution)

    // Update tool rankings
    update_tool_rankings(tool_effectiveness)

    // Identify patterns
    let pattern = identify_pattern(execution)

    // Store for future use
    store_pattern(pattern)
  },

  calculate_effectiveness(execution: ExecutionRecord) → float {
    let cost = execution.cost_usd
    let time = execution.time_ms
    let confidence = execution.result.confidence

    // Effectiveness = confidence / (cost * time)
    confidence / (cost * time / 1000.0)
  }
}

// =============================================================================
// Example Usage
// =============================================================================

example tool_first_search(
  let engine = ToolFirstEngine.new()
  let reasoner = ToolFirstReasoner.new(engine)

  // Query: "Find all API endpoints in the codebase"
  let query = "Find all API endpoints in the codebase"

  // Tool-first approach:
  // 1. grep for "app.get\|app.post\|app.put" (0.1s, $0.00)
  // 2. AST parse to confirm (0.5s, $0.00)
  // 3. Done! No LLM needed

  let result = reasoner.context · reason_about_query

  // Cost: $0.00 (vs $0.05 with LLM-first)
  // Time: 0.6s (vs 5s with LLM-first)
  // Savings: 100% cost, 8.3x faster
}

example tool_first_with_fallback(
  let engine = ToolFirstEngine.new()
  let reasoner = ToolFirstReasoner.new(engine)

  // Query: "Explain the authentication flow"
  let query = "Explain the authentication flow"

  // Tool-first approach:
  // 1. grep for "auth" (0.1s, $0.00) - finds 50 files
  // 2. AST parse auth files (0.5s, $0.00) - gets structure
  // 3. Build call graph (1s, $0.00) - understands flow
  // 4. Confidence: 0.70 (not enough)
  // 5. LLM with context (3s, $0.02) - explains with context

  let result = reasoner.context · reason_about_query

  // Cost: $0.02 (vs $0.05 without context)
  // Time: 4.6s (vs 5s without tools)
  // Savings: 60% cost, 1.1x faster
  // Quality: Better (LLM has context from tools)
}

// =============================================================================
// Performance Comparison
// =============================================================================

benchmark: true tool_first_vs_llm_first {
  // Scenario: 100 queries

  // LLM-First Approach:
  // - Every query uses LLM
  // - Cost: 100 × $0.05 = $5.00
  // - Time: 100 × 5s = 500s

  // Tool-First Approach:
  // - 70 queries answered by tools (grep/AST)
  // - 30 queries need LLM fallback
  // - Cost: 30 × $0.02 = $0.60
  // - Time: 70 × 0.5s + 30 × 4s = 155s

  // Savings:
  // - Cost: $5.00 - $0.60 = $4.40 (88% cheaper)
  // - Time: 500s - 155s = 345s (3.2x faster)

  0.60 · assert_eq
  5.00 · assert_eq
  88.0 · assert_eq
  3.2 · assert_eq
}

