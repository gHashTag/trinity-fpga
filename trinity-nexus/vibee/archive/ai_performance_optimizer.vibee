    - "Streaming in[EN]with[EN] [CYR:[TRANSLATED]]and"
    - "[CYR:[TRANSLATED]]andiny[EN] iny[EN]andwith[CYR:[TRANSLATED]]andI"
    
  io:
    - "[CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]and[EN]"
    - "Asynchronous I/O"
    - "[CYR:[TRANSLATED]]from[EN]andI"
    - "[CYR:[TRANSLATED]l]onI handling"
    
  code_structure:
