name: ai_performance_optimizer
version: 1.0.0
description: AI-powered optimization [CYR:pro]fromin[EN]and[CYR:[EN]lno]with[EN]and - on[CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]and[EN] [EN]with[EN] and [CYR:[TRANSLATED]acts] [CYR:[TRANSLATED]]andI

metadata:
  author: VIBEE Team
  category: ai_optimization
  tags: [ai, performance, optimization, profiling]
  created: 2024-01-10

types:
  PerformanceProfile:
    function_name: string
    execution_time_ms: number
    memory_usage_mb: number
    cpu_usage_percent: number
    call_count: number
    hotspots: list<Hotspot>
    
  Hotspot:
    location: Location
    type: string  # cpu, memory, io, network
    severity: string  # critical, high, medium, low
    impact_percent: number
    
  OptimizationHint:
    hint_id: string
    title: string
    description: string
    code_before: string
    code_after: string
    expected_improvement: ImprovementMetrics
    difficulty: string
    priority: number
    
  ImprovementMetrics:
    speed_improvement_percent: number
    memory_reduction_percent: number
    complexity_reduction: number
    
  OptimizationResult:
    applied_hints: list<OptimizationHint>
    actual_improvement: ImprovementMetrics
    benchmark_results: BenchmarkResults
    
  BenchmarkResults:
    before: PerformanceMetrics
    after: PerformanceMetrics
    improvement: PerformanceMetrics
    
  PerformanceMetrics:
    execution_time_ms: number
    memory_usage_mb: number
    throughput_ops_per_sec: number

constants:
  OPTIMIZATION_PATTERNS:
    list_operations:
      pattern: "list |> list.filter(...) |> list.map(...)"
      optimization: "[... for ... in list if ...]"
      improvement: "30-50% faster, less memory"
      
    nested_loops:
      pattern: "for x in list1 { for y in list2 { ... } }"
      optimization: "Use hash map or set for O(1) lookup"
      improvement: "O(n²) → O(n)"
      
    string_concatenation:
      pattern: "str1 <> str2 <> str3 <> ..."
      optimization: "Use string builder or list.join"
      improvement: "O(n²) → O(n)"
      
    repeated_computation:
      pattern: "expensive_function() called multiple times"
      optimization: "Cache result or memoize"
      improvement: "Depends on call frequency"
      
    unnecessary_allocations:
      pattern: "Creating temporary objects in loop"
      optimization: "Reuse objects or use iterators"
      improvement: "Reduce GC pressure"

  AI_PROMPTS:
    analyze_performance: |
      [EN]y - [EN]with[CYR:[TRANSLATED]] [EN] [CYR:[TRANSLATED]]and[EN]from[EN]andand [CYR:pro]fromin[EN]and[CYR:[EN]lno]with[EN]and VIBEE code[EN].
      
      [CYR:Code] for analysis[EN]:
      ```vibee
      {code}
      ```
      
      [CYR:[TRANSLATED]]andl [CYR:pro]fromin[EN]and[CYR:[EN]lno]with[EN]and:
      - [CYR:[TRANSLATED]I] in[CYR:y[TRANSLATED]]not[EN]andI: {execution_time}ms
      - [CYR:[TRANSLATED]I[EN]]: {memory_usage}MB
      - CPU: {cpu_usage}%
      - [CYR:[TRANSLATED]]and[EN]with[EN]in[EN] in[CYR:y[EN]]in[EN]in: {call_count}
      
      [CYR:[TRANSLATED]]: [CYR:[TRANSLATED]]and [CYR:[TRANSLATED]]and[EN] [EN]with[EN] and [CYR:[TRANSLATED]]and [CYR:[TRANSLATED]]and[EN]from[EN]andand.
      
      [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]]:
      1. [CYR:A[EN]go[EN]]and[EN]and[EN]with[CYR:[TRANSLATED]] with[CYR:[TRANSLATED]]with[EN] (O-notation)
      2. [EN]with[CYR:[EN]l[EN]]in[EN]and[EN] [CYR:[TRANSLATED]I[EN]]and
      3. [CYR:[TRANSLATED]y[EN]] [CYR:[TRANSLATED]]andand
      4. [EN]in[CYR:[TRANSLATED]I[EN]]and[EN]withI iny[EN]andwith[CYR:[TRANSLATED]]andI
      5. [CYR:[EN]effect]andin[CYR:[EN]y[EN]] with[CYR:[TRANSLATED]y] [CYR:data]
      6. I/O [CYR:[TRANSLATED]]andand
      
      [CYR:[TRANSLATED]] response[EN]:
      [CYR:[TRANSLATED]]and[EN] [EN]with[EN]:
      1. [EN]with[EN]: <location>
         [CYR:[TRANSLATED]]: <[EN]andwith[EN]and[EN]>
         [CYR:[TRANSLATED]I] with[CYR:[TRANSLATED]]with[EN]: <O-notation>
         Impact: <[CYR:pro[TRANSLATED]] [EN] [CYR:[TRANSLATED]go] in[CYR:[EN]me]and>
      
      [CYR:[TRANSLATED]]and[EN]from[EN]andand:
      1. [CYR:[TRANSLATED]]in[EN]and[EN]: <[CYR:[TRANSLATED]] on[EN]in[EN]and[EN]>
         [EN]:
         ```vibee
         <[CYR:[TRANSLATED]]and[EN] code>
         ```
         [EN]with[EN]:
         ```vibee
         <[CYR:[TRANSLATED]]and[EN]fromand[EN]in[CYR:[EN]ny] code>
         ```
         [CYR:[TRANSLATED]]and[EN]: <[CYR:[TRANSLATED]]and[EN]and>
         [CYR:[TRANSLATED]]with[EN]: <easy/medium/hard>
         [EN]and[EN]and[CYR:[TRANSLATED]]: <1-10>
      
    suggest_algorithm: |
      [EN]y - [EN]with[CYR:[TRANSLATED]] [EN] [CYR:algorithm]and[CYR:[TRANSLATED]] and with[CYR:[TRANSLATED]] [CYR:data].
      
      [CYR:[TRANSLATED]]and[EN] code:
      ```vibee
      {code}
      ```
      
      [CYR:[TRANSLATED]I] with[CYR:[TRANSLATED]]with[EN]: {current_complexity}
      [CYR:[TRANSLATED]]: {problem_description}
      
      [CYR:[TRANSLATED]]: [CYR:[TRANSLATED]]and [CYR:[TRANSLATED]] [CYR:effect]andin[CYR:ny] [CYR:algorithm]and[EN].
      
      [EN]withwith[CYR:[TRANSLATED]]and:
      - [CYR:[TRANSLATED]]-tables for O(1) lookup
      - [CYR:[TRANSLATED]]and[EN]in[EN] for [EN]andon[CYR:[TRANSLATED]go] [EN]andwith[EN]
      - [EN]andon[EN]and[EN]with[CYR:[TRANSLATED]] [CYR:pro[TRANSLATED]]and[EN]in[EN]and[EN]
      - [CYR:[TRANSLATED]y[EN]] [CYR:algorithm]and[CYR:tmy]
      - Divide and conquer
      
      [CYR:[TRANSLATED]] response[EN]:
      [CYR:[TRANSLATED]me[TRANSLATED]y[EN]] [CYR:algorithm]and[EN]: <on[EN]in[EN]and[EN]>
      [CYR:[TRANSLATED]]with[EN]: <O-notation>
      [CYR:Code]:
      ```vibee
      <[CYR:[TRANSLATED]]and[EN]fromand[EN]in[CYR:[EN]ny] code>
      ```
      [CYR:[TRANSLATED]I]withnot[EN]and[EN]: <[CYR:[TRANSLATED]] this [CYR:[TRANSLATED]]>
      Trade-offs: <[CYR:[TRANSLATED]]promisewithy>
      
    memory_optimization: |
      [EN]y - [EN]with[CYR:[TRANSLATED]] [EN] [CYR:[TRANSLATED]]and[EN]from[EN]andand [CYR:[TRANSLATED]I[EN]]and.
      
      [CYR:Code]:
      ```vibee
      {code}
      ```
      
      [EN]with[CYR:[EN]l[EN]]in[EN]and[EN] [CYR:[TRANSLATED]I[EN]]and: {memory_usage}MB
      [CYR:[TRANSLATED]]: {memory_issue}
      
      [CYR:[TRANSLATED]]: [CYR:[TRANSLATED]]and[EN]fromand[CYR:[TRANSLATED]] andwith[CYR:[EN]l[EN]]in[EN]and[EN] [CYR:[TRANSLATED]I[EN]]and.
      
      [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]]:
      - [CYR:[TRANSLATED]]and [CYR:[TRANSLATED]I[EN]]and
      - [CYR:[TRANSLATED]y[EN]] [CYR:[TRANSLATED]]and[EN]in[EN]andI
      - [CYR:[EN]l[EN]]and[EN] in[CYR:[TRANSLATED]nye] objecty
      - [CYR:[EN]effect]andin[CYR:[EN]y[EN]] with[CYR:[TRANSLATED]y] [CYR:data]
      - [CYR:[TRANSLATED]can[EN]]with[EN] streaming
      
      [CYR:[TRANSLATED]] response[EN]:
      [CYR:[TRANSLATED]y]:
      - <list [CYR:pro[TRANSLATED]]>
      
      [CYR:[TRANSLATED]]andI:
      ```vibee
      <[CYR:[TRANSLATED]]and[EN]fromand[EN]in[CYR:[EN]ny] code>
      ```
      
      [CYR:[TRANSLATED]]andI [CYR:[TRANSLATED]I[EN]]and: <[CYR:pro[TRANSLATED]]>

behaviors:
  analyze_performance:
    input:
      code: string
      profile: PerformanceProfile
    output:
      hotspots: list<Hotspot>
      hints: list<OptimizationHint>
    description: Aon[EN]from [CYR:pro]fromin[EN]and[CYR:[EN]lno]with[EN]and with AI
    steps:
      - [CYR:[TRANSLATED]]or[EN]in[CYR:ate] code
      - [CYR:[EN]law]inand[EN] on analysis AI
      - [CYR:[TRANSLATED]]and[EN] list [CYR:[TRANSLATED]]and[EN] [EN]with[EN]
      - [CYR:[TRANSLATED]]not[EN]and[EN]in[CYR:ate] hints
      - [EN]and[EN]and[EN]fromand[EN]in[CYR:ate] hints
      - [CYR:[TRANSLATED]] resulty
      
  suggest_optimizations:
    input:
      hotspot: Hotspot
      code: string
    output:
      hints: list<OptimizationHint>
    description: [CYR:[TRANSLATED]]andI [EN] [CYR:[TRANSLATED]]and[EN]from[EN]andand
    steps:
      - [CYR:[TRANSLATED]]analyze [CYR:[TRANSLATED]] [EN]with[EN]
      - [CYR:[TRANSLATED]]and[EN] type [CYR:pro[TRANSLATED]y]
      - [CYR:[TRANSLATED]]not[EN]and[EN]in[CYR:ate] in[EN]and[CYR:[TRANSLATED]y] [CYR:[TRANSLATED]]and[EN]from[EN]andand
      - [CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]andI
      - [CYR:[TRANSLATED]]and[EN]in[CYR:ate] [EN] [EN]and[EN]and[CYR:[TRANSLATED]]
      - [CYR:[TRANSLATED]] hints
      
  apply_optimization:
    input:
      hint: OptimizationHint
      code: string
    output:
      optimized_code: string
      result: OptimizationResult
    description: [EN]and[EN]not[EN]and[EN] [CYR:[TRANSLATED]]and[EN]from[EN]andand
    steps:
      - [EN]and[CYR:me]and[EN] from[EN]not[EN]andI
      - [CYR:[TRANSLATED]]with[EN]and[EN] testy
      - [CYR:[TRANSLATED]]and[EN] performance
      - [CYR:[TRANSLATED]]in[EN]and[EN] with baseline
      - [CYR:[TRANSLATED]]and[EN]and[EN]in[CYR:ate] improvement
      - [CYR:[TRANSLATED]] result
      
  benchmark_code:
    input:
      code: string
      iterations: number
    output:
      metrics: PerformanceMetrics
    description: [CYR:[TRANSLATED]] code[EN]
    steps:
      - [EN]compile code
      - [CYR:[TRANSLATED]] JIT
      - [CYR:[TRANSLATED]]with[EN]and[EN] iterations [CYR:[TRANSLATED]]
      - [CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]and[EN]and
      - [EN]with[CYR:[TRANSLATED]]and[EN] resulty
      - [CYR:[TRANSLATED]] metrics
      
  compare_algorithms:
    input:
      algorithm_a: string
      algorithm_b: string
      test_data: list<any>
    output:
      comparison: AlgorithmComparison
    description: [CYR:[TRANSLATED]]innot[EN]and[EN] [CYR:algorithm]and[CYR:[TRANSLATED]]in
    steps:
      - [CYR:[TRANSLATED]] algorithm_a
      - [CYR:[TRANSLATED]] algorithm_b
      - [CYR:[TRANSLATED]]in[EN]and[EN] [CYR:[TRANSLATED]]and[EN]and
      - [CYR:[TRANSLATED]]and[EN] winner
      - [CYR:[TRANSLATED]] comparison

functions:
  - name: profile_code
    params:
      code: string
      input_data: any
    returns: PerformanceProfile
    description: [CYR:[TRANSLATED]]or[EN]in[EN]and[EN] code[EN]
    
  - name: detect_hotspots
    params:
      profile: PerformanceProfile
      threshold_percent: number
    returns: list<Hotspot>
    description: [CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]and[EN] [EN]with[EN]
    
  - name: estimate_improvement
    params:
      current_code: string
      optimized_code: string
    returns: ImprovementMetrics
    description: [CYR:[TRANSLATED]] [CYR:[TRANSLATED]]andI
    
  - name: validate_optimization
    params:
      original: string
      optimized: string
      test_cases: list<TestCase>
    returns: boolean
    description: [CYR:[TRANSLATED]]and[CYR:[TRANSLATED]]andI [CYR:[TRANSLATED]]and[EN]from[EN]andand

tests:
  - name: detect_list_operation_hotspot
    behavior: analyze_performance
    input:
      code: |
        list
          |> list.filter(fn(x) { x > 0 })
          |> list.map(fn(x) { x * 2 })
      profile:
        execution_time_ms: 100
        memory_usage_mb: 50
    expected:
      hotspots: length > 0
      hints: length > 0
      hints[0].title: contains("list comprehension")
      
  - name: suggest_algorithm_optimization
    behavior: suggest_optimizations
    input:
      hotspot:
        type: "cpu"
        severity: "high"
      code: |
        for x in list1 {
          for y in list2 {
            if x == y { found = true }
          }
        }
    expected:
      hints: length > 0
      hints[0].expected_improvement.speed_improvement_percent: > 50
      
  - name: apply_list_comprehension
    behavior: apply_optimization
    input:
      hint:
        code_before: "list |> list.filter(...) |> list.map(...)"
        code_after: "[... for ... in list if ...]"
      code: "list |> list.filter(fn(x) { x > 0 }) |> list.map(fn(x) { x * 2 })"
    expected:
      optimized_code: contains("[x * 2 for x in list if x > 0]")
      result.actual_improvement.speed_improvement_percent: > 30

examples:
  - name: "[CYR:[TRANSLATED]]and[EN]from[EN]andI with[EN]andwith[EN]in"
    description: "AI on[CYR:[TRANSLATED]]and[EN] not[CYR:effect]andin[CYR:[EN]y[EN]] [CYR:[TRANSLATED]]andand with[EN] with[EN]andwith[CYR:[TRANSLATED]]and"
    input:
      code: |
        pub process_items(items) = {
          items
            |> list.filter(fn(i) { i.active })
            |> list.map(fn(i) { i.price })
            |> list.filter(fn(p) { p > 100 })
        }
      profile:
        execution_time_ms: 150
        memory_usage_mb: 80
    output:
      hint:
        title: "[CYR:[TRANSLATED]]and[EN]and[EN] filter [CYR:[TRANSLATED]]andand"
        code_after: |
          pub process_items(items) = {
            [i.price for i in items if i.active && i.price > 100]
          }
        improvement: "50% faster, 40% less memory"
        
  - name: "[CYR:[TRANSLATED]]and[EN]from[EN]andI [CYR:algorithm]and[CYR:[TRANSLATED]]"
    description: "AI [CYR:[TRANSLATED]acts] [CYR:[TRANSLATED]] [CYR:effect]andin[CYR:ny] [CYR:algorithm]and[EN]"
    input:
      code: |
        pub find_duplicates(list) = {
          for x in list {
            for y in list {
              if x == y && x != y { return true }
            }
          }
          false
        }
      complexity: "O(n²)"
    output:
      hint:
        title: "[EN]with[CYR:[EN]l[EN]]in[CYR:ate] Set for O(n)"
        code_after: |
          pub find_duplicates(list) = {
            let seen = set.new()
            for x in list {
              if set.contains(seen, x) { return true }
              set.insert(seen, x)
            }
            false
          }
        improvement: "O(n²) → O(n), 100x faster on [CYR:[EN]l[EN]]and[EN] [CYR:data]"
        
  - name: "[CYR:[TRANSLATED]]and[EN]from[EN]andI [CYR:[TRANSLATED]I[EN]]and"
    description: "AI on[CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]and and [EN]and[EN]and[EN] [CYR:[TRANSLATED]]andand"
    input:
      code: |
        pub process_large_file(path) = {
          let content = file.read_all(path)  // [CYR:[TRANSLATED]acts] in[EN]with[EN] file
          content
            |> string.split("\n")
            |> list.map(process_line)
        }
      memory_usage_mb: 500
    output:
      hint:
        title: "[EN]with[CYR:[EN]l[EN]]in[CYR:ate] streaming"
        code_after: |
          pub process_large_file(path) = {
            file.stream_lines(path)
              |> stream.map(process_line)
              |> stream.collect()
          }
        improvement: "500MB → 10MB, streaming handling"

