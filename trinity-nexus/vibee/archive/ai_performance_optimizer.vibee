    - "[CYR:[TRANSLATED]]and[EN]from[EN]andI loop[EN]in"
    - "Tail call optimization"

metrics:
  detection_accuracy: "> 90%"
  improvement_prediction: "±10%"
  false_positives: "< 5%"
  average_speedup: "> 2x"
