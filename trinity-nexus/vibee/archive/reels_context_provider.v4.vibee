@spec get_available_templates() → [ReelsTemplate] {
  /// Get available reels templates
  given: Nothing
  when: Loading templates
  then: Returns template list
}

@impl {
  [
    ReelsTemplate(
      "split-talking-head",
      "Split Talking Head",
      "Avatar on left, B-roll on right",
      ["business", "education", "productivity"]
    ),
    ReelsTemplate(
      "fullscreen-avatar",
      "Fullscreen Avatar",
      "Full-screen talking avatar",
      ["lifestyle", "personal", "storytelling"]
    ),
    ReelsTemplate(
      "picture-in-picture",
      "Picture in Picture",
      "B-roll with avatar in corner",
      ["technology", "tutorials", "reviews"]
    )
  ]
}

