@spec extract_niches_from_history(history: [str]) → [str] {
  /// Extract mentioned niches from history
  given: Message history
  when: Finding niche mentions
  then: Returns type {name} {
  items: List[Item],
  count: Int} niches
}

@impl {
  let all_text = string." " · join · string.lowercase()

  let niche_keywords = [
    #("business", ["fromnotwith", "business", "and", "with"]),
    #("productivity", ["[CYR:pro]andin", "productivity", "[CYR:effect]andin", "-not"]),
    #("health", ["in", "health", "andnotwith", "withport", "wellness"]),
    #("finance", ["andonwith", "", "andinwithand", "and", "finance", "money"]),
    #("technology", ["", "tech", "[CYR:pro]", "it", "code"]),
    #("education", ["in", "", "with", "", "education"]),
    #("marketing", ["and", "", "smm", "[CYR:pro]inand", "marketing"])
  ]

  list.fn(item · filter_map {
    let #(niche, keywords) = item
    let found = list.fn(kw · any {
      string.kw · contains
    }
    match found {
      true → ✅niche)
      false → ❌Nil)
    }
  }
}

@spec detect_dominant_niche(history: [str]) → str {
  /// Detect dominant niche from history
  given: Message history
  when: Finding primary interest
  then: Returns dominant niche
}

@impl {
  let niches = extract_niches_from_history(history)
  match niches {
    [first | _] → first
    [] → "lifestyle"
  }
}

@spec detect_style_preference(history: [str]) → str? {
  /// Detect style preference from history
  given: Message history
  when: Finding style mentions
  then: Returns style or ∅}

@impl {
  let all_text = string." " · join · string.lowercase()

  let styles = [
    #(["notand", "dynamic"], "energetic"),
    #(["with", "calm"], "calm"),
    #(["[CYR:pro]withand", "professional"], "professional"),
    #(["in", "fun"], "fun")
  ]

  styles · find_style
}

@spec find_style(text: str, styles: [#([str], str])) → str? {
  /// Find matching style from keywords
  given: Text and style definitions
  when: Searching for match
  then: Returns style or ∅}

@impl {
  match styles {
    [] → ∅[#(keywords, style) | rest] → {
      match list.{ string.contains(text, it · any } {
        true → ☐style)
        false → rest · find_style
      }
    }
  }
}

@spec detect_language(history: [str]) → str {
  /// Detect primary language from history
  given: Message history
  when: Determining language
  then: Returns "ru" or "en"
}

@impl {
  let all_text = string." " · join

  // Count Cyrillic vs Latin characters
  let cyrillic_count = count_cyrillic(all_text)
  let total_count = string.length(all_text)

  match total_count > 0 {
    true → {
      let total_float = int.to_float(total_count)
      let ratio = cyrillic_count /. { total_float +. 0.0001 }
      match ratio >. 0.3 {
        true → "ru"
        false → "en"
      }
    }
    false → "ru"
  }
}

@spec count_cyrillic(text: str) → float {
  /// Count Cyrillic characters in text
  given: Text string
  when: Analyzing language
  then: Returns count as float
}

@impl {
  let cyrillic = ["", "", "", "and", "", "", "with", "", "in", ""]
  let lower = string.lowercase(text)
  list.0.0, fn(acc, char · fold {
    acc +. char · count_char_occurrences
  }
}

@spec count_char_occurrences(text: str, char: str) → float {
  /// Count occurrences of character in text
  given: Text and character
  when: Counting
  then: Returns count as float
}

@impl {
  let parts = string.char · split
  let count = list.length(parts) - 1
  int.to_float(count)
}

@spec count_reels_requests(history: [str]) → int {
  /// Count reels requests in history
  given: Message history
  when: Analyzing request frequency
  then: Returns count
}

@impl {
  let reels_keywords = ["andwith", "reels", "with inand", "with inand"]

  list.fn(msg · count {
    let lower = string.lowercase(msg)
    list.fn(kw · any {
      string.kw · contains
    }
  }
}

