    description: [CYR:Предложен]andя по [CYR:улучшен]andю поwithле мand[CYR:грац]andand
    steps:
      - [CYR:Про]analyze мandгрandроin[CYR:анный] code
      - [CYR:Найт]and in[CYR:озможно]withтand for [CYR:улучшен]andя
      - [CYR:Сге]notрandроin[CYR:ать] suggestions
      - [CYR:Оцен]andть impact
      - [CYR:Вернуть] improvements

functions:
  - name: build_dependency_graph
    params:
      module_path: string
    returns: DependencyGraph
    description: Поwith[CYR:троен]andе [CYR:графа] заinandwithandмоwith[CYR:тей]
    
  - name: analyze_usage_patterns
    params:
      code: string
      codebase: string
    returns: list<UsagePattern>
    description: Аonлfrom [CYR:паттерно]in andwith[CYR:пользо]inанandя
    
  - name: estimate_migration_time
    params:
      strategy: MigrationStrategy
      code_size: number
    returns: number
    description: [CYR:Оценка] in[CYR:ремен]and мand[CYR:грац]andand
    
  - name: calculate_risk_score
