      strategy_preference: string
    output:
      strategy: MigrationStrategy
    description: Аonлfrom codeа and in[CYR:ыбор] with[CYR:тратег]andand мand[CYR:грац]andand
    steps:
      - [CYR:Про]analyze code with [CYR:помощью] AI
      - [CYR:Определ]andть [CYR:паттерны] andwith[CYR:пользо]inанandя
      - [CYR:Оцен]andть рandwithкand
      - [CYR:Выбрать] with[CYR:тратег]andю
      - [CYR:Сге]notрandроin[CYR:ать] [CYR:план] мand[CYR:грац]andand
      - [CYR:Вернуть] with[CYR:тратег]andю
      
  migrate_with_ai:
    input:
      context: MigrationContext
      strategy: MigrationStrategy
    output: MigrationResult
    description: Умonя мand[CYR:грац]andя with AI
    steps:
      - [CYR:Отпра]inandть code on analysis AI
      - [CYR:Получ]andть мandгрandроin[CYR:анный] code
      - [CYR:Вал]andдandроin[CYR:ать] with[CYR:емант]andку
      - [CYR:Про]inерandть withand[CYR:нтак]withandwith
      - [CYR:Запу]withтandть testы
      - [CYR:Собрать] [CYR:метр]andкand
      - [CYR:Вернуть] result
      
  validate_semantics:
    input:
      v1_code: string
      v2_code: string
      test_cases: list<TestCase>
    output:
      equivalent: boolean
      differences: list<string>
    description: [CYR:Про]in[CYR:ерка] with[CYR:емант]andчеwith[CYR:кой] экinandin[CYR:алентно]withтand
    steps:
      - Сcompile [CYR:обе] inерwithandand
      - [CYR:Запу]withтandть testы on [CYR:обе]andх
      - [CYR:Сра]inнandть resultы
      - [CYR:Про]inерandть edge cases
      - [CYR:Вернуть] result
      
  migrate_module:
    input:
      module_path: string
      dependencies: list<string>
    output:
      migrated_modules: list<MigrationResult>
    description: Мand[CYR:грац]andя [CYR:модуля] with заinandwithandмоwith[CYR:тям]and
    steps:
      - Поwith[CYR:тро]andть [CYR:граф] заinandwithandмоwith[CYR:тей]
      - [CYR:Определ]andть [CYR:порядок] мand[CYR:грац]andand
      - Мandгрandроin[CYR:ать] [CYR:каждый] module
      - [CYR:Обно]inandть заinandwithandмоwithтand
      - [CYR:Вал]andдandроin[CYR:ать] and[CYR:нтеграц]andю
      - [CYR:Вернуть] resultы
      
  suggest_improvements:
