struct Message {
  Message(
    id: str,
    sender: str,
    content: MessageContent,
    timestamp: int
  )
}

struct MessageContent {
  TextContent(text: str)
  PhotoContent(url: str, caption: str?)
  DocumentContent(url: str, name: str)
}

derive(Json)
struct AgentMessage {
  TgUpdate(update: TelegramUpdate)
  ProcessText(request_id: str, text: str)
  Reply(request_id: str, text: str)
  SaveState
  Shutdown
}

derive(Json)
struct TelegramUpdate {
  NewMessage(
    chat_id: int,
    message_id: int,
    text: str,
    sender_id: int,
    sender_name: str
  )
  EditedMessage(chat_id: int, message_id: int, text: str)
  DeletedMessage(chat_id: int, message_id: int)
}

