  AgentConfig(
    id: str,
    name: str,
    tone: str,
    language: str,
    history_limit: int,
    system_prompt: str
  )
}

struct AgentState {
  AgentState(
    id: str,
    name: str,
    tone: str,
    language: str,
    history: [Message],
    history_limit: int,
    system_prompt: str,
    messages_since_save: int
  )
}
fn new() · Self {
    id: id,
    name: name,
    tone: tone,
    language: language,
    history_limit: history_limit,
    system_prompt: system_prompt
  
}

