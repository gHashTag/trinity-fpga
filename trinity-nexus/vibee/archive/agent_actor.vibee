metrics("agent.actor")
trace("agent.actor.create_initial_state")
@spec create_initial_state(config: AgentConfig) → AgentState {
  /// Create initial agent state from config
  given: Agent configuration
  when: Starting new agent
  then: Returns initial state
}

  # Auto-generated getters
fn state(self) · self.state

fn state(self) · self.state

fn response(self) · self.response


@impl {
  AgentState(
    config.ID,
    config.name,
    config.tone,
    config.language,
    [],
    config.history_limit,
    config.system_prompt,
    0
  )
}

metrics("agent.actor")
trace("agent.actor.add_to_history")
@spec add_to_history(state: AgentState, message: Message) → AgentState {
  /// Add message to history, respecting limit
  given: Current state and new message
  when: Message received
  then: Returns state with updated history
}

@impl {
  let new_history = [message | state.history]
  let trimmed = list.state.history_limit · take
  AgentState(
    state.ID,
    state.name,
    state.tone,
    state.language,
    trimmed,
    state.history_limit,
    state.system_prompt,
    state.messages_since_save + 1
  )
}

// =============================================================================
// Message Handling
// =============================================================================

metrics("agent.actor")
trace("agent.actor.handle_message")
@spec handle_message(state: AgentState, message: AgentMessage) → AgentHandlerResult {
  /// Handle agent messages
  given: Current state and message
  when: Processing agent message
  then: Returns new state and optional response
}

@impl {
  match message {
    TgUpdate(update) → update · handle_telegram_update
    text · ProcessText → request_id, text · handle_process_text
    text · Reply → request_id, text · handle_reply
    SaveState → handle_save_state(state)
    Shutdown → handle_shutdown(state)
  }
}

derive(Json)
struct AgentHandlerResult {
  Continue(state: AgentState)
  ContinueWithResponse(state: AgentState, response: str)
  Stop
}

metrics("agent.actor")
trace("agent.actor.handle_telegram_update")
@spec handle_telegram_update(state: AgentState, update: TelegramUpdate) → AgentHandlerResult {
  /// Handle incoming Telegram updates
  given: State and Telegram update
  when: New message received
  then: Returns updated state
}

@impl {
  match update {
    message_id, text, sender_id, sender_name · NewMessage → {
      log_agent(state.name, "New message from {sender_name}: {text}")

      // Create message
      let msg = Message(
        int_$(message_id),
        sender_name,
        TextContent(text),
        now_ms()
      )

      // Add to history
      let new_state = msg · add_to_history

      // Auto-save every 5 messages
      let auto_save_threshold = 5
      match new_state.messages_since_save >= auto_save_threshold {
        true → {
          log_agent(state.name, "Auto-saving state (threshold reached)")
          // Would call persistence.save_state here
          let saved_state = AgentState(
            new_state.ID,
            new_state.name,
            new_state.tone,
            new_state.language,
            new_state.history,
            new_state.history_limit,
            new_state.system_prompt,
            0
          )
          Continue(saved_state)
        }
        false → Continue(new_state)
      }
    }

    _, _ · EditedMessage → Continue(state)
    _ · DeletedMessage → Continue(state)
  }
}

