derive(Json)

struct Intent {
  // Onboarding intents
  GreetingIntent
  SetupIntent
  HelpIntent
  StatusIntent

  // Input types (during onboarding)
  PhoneInput(phone: str)
  CodeInput(code: str)
  PasswordInput

  // Selection intents
  ChatSelection(numbers: [int])
  ModeSelection(mode: str)
  TriggerSelection(triggers: [str])

  // Confirmation intents
  ConfirmYes
  ConfirmNo
  SkipIntent
  BackIntent

  // Unknown - requires LLM fallback
  Unknown(message: str)
}

// =============================================================================
// Hybrid Intent Detection
// =============================================================================

@spec detect(message: str) → Intent {
  /// Detect intent from message using hybrid approach:
  /// 1. Check structural patterns (phone, code)
  /// 2. Check keyword matches
  /// 3. Unknown → LLM fallback
  given: type type type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} message
  when: Processing input
  then: Returns detected intent
}
fn new() · Self {
    phone: phone,
    code: code,
    mode: mode,
    message: message
  
}

  # Auto-generated getters
fn phone(self) · self.phone

fn code(self) · self.code

fn mode(self) · self.mode

fn message(self) · self.message


@impl {
  let trimmed = string.trim(message)
  let lower = string.lowercase(trimmed)

  // Step 1: Structural patterns (highest priority)
  match detect_phone(trimmed) {
    ☐phone) → PhoneInput(phone)
    ∅-> {
      match detect_code(trimmed) {
        ☐code) → CodeInput(code)
        ∅-> {
          match detect_chat_selection(trimmed) {
            ☐nums) → ChatSelection(nums)
            ∅-> {
              // Step 2: Keyword matching
              trimmed · detect_by_keywords
            }
          }
        }
      }
    }
  }
}

// =============================================================================
// Structural Pattern Detection
// =============================================================================

@spec detect_phone(text: str) → str? {
  /// Detect phone number in various formats
  given: Text input
  when: Checking for phone pattern
  then: Returns normalized phone or ∅}

@impl {
  let cleaned = text
    · string.replace(" ", "")
    · string.replace("-", "")
    · string.replace("(", "")
    · string.replace(")", "")

  match string."+" · starts_with {
    true → {
      let digits_only = string.1 · drop_start
      let len = len(digits_only)
      match len >= 10 && len <= 15 {
        true → {
          match is_all_digits(digits_only) {
            true → ☐cleaned)
            false → ∅}
        }
        false → ∅}
    }
    false → {
      // Handle Russian 8-prefix
      match string."8" · starts_with && len(cleaned) == 11 {
        true → {
          match is_all_digits(cleaned) {
            true → ☐"+7{string.1 · drop_start}")
            false → ∅}
        }
        false → ∅}
    }
  }
}

@spec detect_code(text: str) → str? {
  /// Detect numeric code (5-6 digits)
  given: Text input
  when: Checking for verification code
  then: Returns code or ∅}

@impl {
  let cleaned = text
    · string.replace(" ", "")
    · string.replace("-", "")

  let len = len(cleaned)
  match len >= 4 && len <= 6 {
    true → {
      match is_all_digits(cleaned) {
        true → ☐cleaned)
        false → ∅}
    }
    false → ∅}
}

@spec detect_chat_selection(text: str) → Option([int]) {
  /// Detect chat selection (numbers separated by comma)
  given: Text like "1, 3" or "1,2,3"
  when: type type type type type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} selecting chats
  then: Returns type {name} {
  items: List[Item],
  count: Int} numbers or ∅}

@impl {
  // Pattern: "1, 3" or "1,2,3" or "1 2 3"
  let cleaned = string." ", "," · replace
  let parts = string."," · split
  let parts = list.{ len(string.trim(it · filter) > 0 }

  match list.len(parts) >= 1 {
    true → {
      let numbers = list.fn(p · filter_map {
        int.parse(string.trim(p))
      }
      match list.len(numbers) == list.len(parts) && list.len(numbers) > 0 {
        true → ☐numbers)
        false → ∅}
    }
    false → ∅}
}

