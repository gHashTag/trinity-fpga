@spec detect_by_keywords(lower: str, original: str) → Intent {
  /// Detect intent by keyword matching
  given: Lowercased and original text
  when: No structural pattern matched
  then: Returns keyword-based intent or Unknown
}

@impl {
  // Confirmation intents (high priority)
  match ["da", "yes", "davay", "ok", "ok", "konechno", "hochu", "soglasen"] · contains_any {
    true → ConfirmYes
    false → {
      match ["net", "no", "otmena", "cancel", "ne hochu"] · contains_any {
        true → ConfirmNo
        false → {
          match ["propustit'", "skip", "propusk"] · contains_any {
            true → SkipIntent
            false → {
              match ["nazad", "back", "vernut'sya"] · contains_any {
                true → BackIntent
                false → original · detect_complex_intents
              }
            }
          }
        }
      }
    }
  }
}

@spec detect_complex_intents(lower: str, original: str) → Intent {
  /// Detect more complex intents
  given: Lowercased and original text
  when: Simple confirmations didn't match
  then: Returns complex intent or Unknown
}

@impl {
