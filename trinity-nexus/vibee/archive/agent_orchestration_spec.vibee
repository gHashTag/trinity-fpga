# Agent Orchestration Specification
# Spec-driven development: This spec is the SINGLE SOURCE OF TRUTH
# All code, tests, and documentation are GENERATED from this spec

metadata:
  name: agent_orchestration
  version: 1.0.0
  description: Agent orchestration system for coordinating multiple agents and workflows
  author: VIBEE Team
  license: MIT
  generated_from: spec
  manual_code_forbidden: true

# Type definitions
types:
  - name: Workflow
    description: Agent workflow
    fields:
      - name: id
        type: String
        description: Workflow ID
        required: true
      - name: name
        type: String
        description: Workflow name
        required: true
      - name: steps
        type: List<WorkflowStep>
        description: Workflow steps
        required: true
      - name: status
        type: String
        description: Workflow status (pending, running, completed, failed)
        default: "pending"
      - name: current_step
        type: Int
        description: Current step index
        default: 0
      - name: result
        type: Map<String, String>
        description: Workflow result
        default: {}
      - name: error
        type: String
        description: Workflow error
        required: false
      - name: created_at
        type: String
        description: Creation timestamp
        required: true
      - name: completed_at
        type: String
        description: Completion timestamp
        required: false

  - name: WorkflowStep
    description: Workflow step
    fields:
      - name: id
        type: String
        description: Step ID
        required: true
      - name: name
        type: String
        description: Step name
        required: true
      - name: agent_type
        type: String
        description: Required agent type
        required: true
      - name: action
        type: String
        description: Action to perform
        required: true
      - name: params
        type: Map<String, String>
        description: Step parameters
        default: {}
      - name: dependencies
        type: List<String>
        description: Step dependencies (step IDs)
        default: []
      - name: retry_on_failure
        type: Bool
        description: Whether to retry on failure
        default: true
      - name: timeout_ms
        type: Int
        description: Step timeout in milliseconds
        default: 60000

  - name: AgentPool
    description: Pool of agents
    fields:
      - name: id
        type: String
        description: Pool ID
        required: true
      - name: name
        type: String
        description: Pool name
        required: true
      - name: agent_type
        type: String
        description: Agent type in pool
        required: true
      - name: min_size
        type: Int
        description: Minimum pool size
        default: 1
      - name: max_size
        type: Int
        description: Maximum pool size
        default: 10
      - name: current_size
        type: Int
        description: Current pool size
        default: 0
      - name: available_agents
        type: List<String>
        description: Available agent IDs
        default: []
      - name: busy_agents
        type: List<String>
        description: Busy agent IDs
        default: []

  - name: Coordination
    description: Agent coordination
    fields:
      - name: id
        type: String
        description: Coordination ID
        required: true
      - name: type
        type: String
        description: Coordination type (sequential, parallel, conditional)
        required: true
      - name: agents
        type: List<String>
        description: Agent IDs involved
        required: true
      - name: status
        type: String
        description: Coordination status
        default: "pending"
      - name: results
        type: Map<String, String>
        description: Results from agents
        default: {}

  - name: LoadBalancer
    description: Load balancer configuration
    fields:
      - name: strategy
        type: String
        description: Load balancing strategy (round_robin, least_busy, random)
        required: true
      - name: health_check_interval_ms
        type: Int
        description: Health check interval
        default: 5000
      - name: max_retries
        type: Int
        description: Maximum retries
        default: 3

# Behavior specifications with test cases
behaviors:
  - name: workflow_management
    description: Workflow management operations
    functions:
      - name: create_workflow
        description: Create a new workflow
        params:
          - name: name
            type: String
          - name: steps
            type: List<WorkflowStep>
        returns: Result<Workflow, String>
        test_cases:
          - input:
              name: "Data Processing Pipeline"
              steps:
                - id: "step-1"
                  name: "Fetch Data"
                  agent_type: "data_fetcher"
                  action: "fetch"
                  params: {source: "database"}
                - id: "step-2"
                  name: "Process Data"
                  agent_type: "data_processor"
                  action: "process"
                  dependencies: ["step-1"]
            expected:
              Ok:
                id: "workflow-123"
                name: "Data Processing Pipeline"
                status: "pending"
                current_step: 0

      - name: start_workflow
        description: Start workflow execution
        params:
          - name: workflow_id
            type: String
        returns: Result<Workflow, String>
        test_cases:
          - input:
              workflow_id: "workflow-123"
            expected:
              Ok:
                id: "workflow-123"
                status: "running"

      - name: get_workflow_status
        description: Get workflow status
        params:
          - name: workflow_id
            type: String
        returns: Result<Workflow, String>
        test_cases:
          - input:
              workflow_id: "workflow-123"
            expected:
              Ok:
                id: "workflow-123"
                status: "running"
                current_step: 1

      - name: cancel_workflow
        description: Cancel workflow execution
        params:
          - name: workflow_id
            type: String
        returns: Result<Workflow, String>
        test_cases:
          - input:
              workflow_id: "workflow-123"
            expected:
              Ok:
                id: "workflow-123"
                status: "failed"
                error: "Workflow cancelled"

  - name: agent_pool_management
    description: Agent pool management
    functions:
      - name: create_pool
        description: Create agent pool
        params:
          - name: name
            type: String
          - name: agent_type
            type: String
          - name: min_size
            type: Int
          - name: max_size
            type: Int
        returns: Result<AgentPool, String>
        test_cases:
          - input:
              name: "Worker Pool"
              agent_type: "worker"
              min_size: 2
              max_size: 10
            expected:
              Ok:
                id: "pool-123"
                name: "Worker Pool"
                agent_type: "worker"
                min_size: 2
                max_size: 10
                current_size: 2

      - name: scale_pool
        description: Scale agent pool
        params:
          - name: pool_id
            type: String
          - name: target_size
            type: Int
        returns: Result<AgentPool, String>
        test_cases:
          - input:
              pool_id: "pool-123"
              target_size: 5
            expected:
              Ok:
                id: "pool-123"
                current_size: 5

      - name: get_available_agent
        description: Get available agent from pool
        params:
          - name: pool_id
            type: String
        returns: Result<String, String>
        test_cases:
          - input:
              pool_id: "pool-123"
            expected:
              Ok: "agent-456"

      - name: release_agent
        description: Release agent back to pool
        params:
          - name: pool_id
            type: String
          - name: agent_id
            type: String
        returns: Result<Bool, String>
        test_cases:
          - input:
              pool_id: "pool-123"
              agent_id: "agent-456"
            expected:
              Ok: true

  - name: coordination_patterns
    description: Agent coordination patterns
    functions:
      - name: coordinate_sequential
        description: Coordinate agents sequentially
        params:
          - name: agent_ids
            type: List<String>
          - name: task_params
            type: Map<String, String>
        returns: Result<Coordination, String>
        test_cases:
          - input:
              agent_ids: ["agent-1", "agent-2", "agent-3"]
              task_params: {action: "process", data: "test"}
            expected:
              Ok:
                id: "coord-123"
                type: "sequential"
                agents: ["agent-1", "agent-2", "agent-3"]
                status: "running"

      - name: coordinate_parallel
        description: Coordinate agents in parallel
        params:
          - name: agent_ids
            type: List<String>
          - name: task_params
            type: Map<String, String>
        returns: Result<Coordination, String>
        test_cases:
          - input:
              agent_ids: ["agent-1", "agent-2", "agent-3"]
              task_params: {action: "analyze", data: "test"}
            expected:
              Ok:
                id: "coord-456"
                type: "parallel"
                agents: ["agent-1", "agent-2", "agent-3"]
                status: "running"

      - name: coordinate_conditional
        description: Coordinate agents conditionally
        params:
          - name: condition
            type: String
          - name: true_agents
            type: List<String>
          - name: false_agents
            type: List<String>
          - name: task_params
            type: Map<String, String>
        returns: Result<Coordination, String>
        test_cases:
          - input:
              condition: "data_valid"
              true_agents: ["agent-1", "agent-2"]
              false_agents: ["agent-3"]
              task_params: {action: "validate"}
            expected:
              Ok:
                id: "coord-789"
                type: "conditional"
                status: "running"

  - name: load_balancing
    description: Load balancing operations
    functions:
      - name: configure_load_balancer
        description: Configure load balancer
        params:
          - name: strategy
            type: String
          - name: health_check_interval_ms
            type: Int
        returns: Result<LoadBalancer, String>
        test_cases:
          - input:
              strategy: "least_busy"
              health_check_interval_ms: 5000
            expected:
              Ok:
                strategy: "least_busy"
                health_check_interval_ms: 5000
                max_retries: 3

      - name: select_agent
        description: Select agent using load balancer
        params:
          - name: pool_id
            type: String
          - name: balancer
            type: LoadBalancer
        returns: Result<String, String>
        test_cases:
          - input:
              pool_id: "pool-123"
              balancer: {strategy: "round_robin", health_check_interval_ms: 5000, max_retries: 3}
            expected:
              Ok: "agent-456"

# Function declarations
functions:
  # Workflow management
  - name: create_workflow
    params: [name: String, steps: List<WorkflowStep>]
    returns: Result<Workflow, String>
    behavior: workflow_management

  - name: start_workflow
    params: [workflow_id: String]
    returns: Result<Workflow, String>
    behavior: workflow_management

  - name: get_workflow_status
    params: [workflow_id: String]
    returns: Result<Workflow, String>
    behavior: workflow_management

  - name: cancel_workflow
    params: [workflow_id: String]
    returns: Result<Workflow, String>
    behavior: workflow_management

  # Agent pool management
  - name: create_pool
    params: [name: String, agent_type: String, min_size: Int, max_size: Int]
    returns: Result<AgentPool, String>
    behavior: agent_pool_management

  - name: scale_pool
    params: [pool_id: String, target_size: Int]
    returns: Result<AgentPool, String>
    behavior: agent_pool_management

  - name: get_available_agent
    params: [pool_id: String]
    returns: Result<String, String>
    behavior: agent_pool_management

  - name: release_agent
    params: [pool_id: String, agent_id: String]
    returns: Result<Bool, String>
    behavior: agent_pool_management

  # Coordination patterns
  - name: coordinate_sequential
    params: [agent_ids: List<String>, task_params: Map<String, String>]
    returns: Result<Coordination, String>
    behavior: coordination_patterns

  - name: coordinate_parallel
    params: [agent_ids: List<String>, task_params: Map<String, String>]
    returns: Result<Coordination, String>
    behavior: coordination_patterns

  - name: coordinate_conditional
    params: [condition: String, true_agents: List<String>, false_agents: List<String>, task_params: Map<String, String>]
    returns: Result<Coordination, String>
    behavior: coordination_patterns

  # Load balancing
  - name: configure_load_balancer
    params: [strategy: String, health_check_interval_ms: Int]
    returns: Result<LoadBalancer, String>
    behavior: load_balancing

  - name: select_agent
    params: [pool_id: String, balancer: LoadBalancer]
    returns: Result<String, String>
    behavior: load_balancing

# Documentation
documentation:
  overview: |
    # Agent Orchestration System
    
    Agent orchestration for coordinating multiple agents and workflows.
    
    ## Features
    - Workflow management (create, start, status, cancel)
    - Agent pool management (create, scale, get/release agents)
    - Coordination patterns (sequential, parallel, conditional)
    - Load balancing (round robin, least busy, random)
    
  examples:
    - title: Create and Start Workflow
      code: |
        let steps = [
          WorkflowStep(
            id: "step-1",
            name: "Fetch Data",
            agent_type: "data_fetcher",
            action: "fetch",
            params: map.from_list([#("source", "database")]),
            dependencies: [],
            retry_on_failure: true,
            timeout_ms: 60000
          ),
          WorkflowStep(
            id: "step-2",
            name: "Process Data",
            agent_type: "data_processor",
            action: "process",
            params: map.from_list([]),
            dependencies: ["step-1"],
            retry_on_failure: true,
            timeout_ms: 60000
          )
        ]
        let result = create_workflow("Data Pipeline", steps)
        case result {
          Ok(workflow) -> start_workflow(workflow.id)
          Error(err) -> io.println("Error: " <> err)
        }
    
    - title: Create Agent Pool
      code: |
        let result = create_pool("Worker Pool", "worker", 2, 10)
        case result {
          Ok(pool) -> {
            io.println("Pool created: " <> pool.id)
            io.println("Current size: " <> int.to_string(pool.current_size))
          }
          Error(err) -> io.println("Error: " <> err)
        }
    
    - title: Parallel Coordination
      code: |
        let agents = ["agent-1", "agent-2", "agent-3"]
        let params = map.from_list([
          #("action", "analyze"),
          #("data", "dataset.csv")
        ])
        let result = coordinate_parallel(agents, params)

# Generation metadata
generation:
  target_language: gleam
  output_path: src/agent_orchestration.gleam
  test_path: test/agent_orchestration_test.gleam
  generate_docs: true
  generate_tests: true
  generate_helpers: true
