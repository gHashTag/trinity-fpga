// Converted from infra/agent/actions/help_action.gleam → dsl/infra/agent/actions/help_action.vibee

import "../eliza.vibee" as eliza
import "../intent.vibee" as intent

// =============================================================================
// Help Action
// =============================================================================

@spec create_action() → Action {
  /// Create the help action
  given: Nothing
  when: Setting up action registry
  then: Returns help action definition
}

@impl {
  Action(
    "HELP",
    "Responds to help requests with type {name} {
  items: List[Item],
  count: Int} capabilities",
    // Similes for NLP matching
    [
      "что умеешь", "что ты умеешь", "помощь", "help",
      "возможности", "функции", "что можешь"
    ],
    // Example messages
    [
      "Что ты умеешь?",
      "Помощь",
      "Какие у тебя возможности?",
      "What can you do?"
    ],
    { validate_help(it) },
    { handle_help(it) }
  )
}

// =============================================================================
// Validate Function
// =============================================================================

trace("agent.help_action.validate")
@spec validate_help(context: ActionContext) → bool {
  /// Validate if this action should handle the message
  given: Action context with message
  when: Checking for help intent
  then: Returns true if help intent detected
}

@impl {
  print("[HELP_ACTION] validate_help called with message: {context.message}")

  let detected = intent.detect(context.message)
  print("[HELP_ACTION] Intent detected: {intent.to_string(detected)}")

  let result = match detected {
    HelpIntent → true
    _ → false
  }

  print("[HELP_ACTION] Returning: {match result { true → "TRUE" false → "FALSE" }}
  result
}

// =============================================================================
// Handler Function
// =============================================================================

trace("agent.help_action.handle")
@spec handle_help(context: ActionContext) → ActionResult {
  /// Handle help request
  given: Action context
  when: type type type type type type User {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} {
  name: String,
  email: String,
  id: Int} asks for help
  then: Returns comprehensive help message
}

@impl {
  print("[HELP_ACTION] Handling help request")

  let response = """
Я твой персональный AI-помощник VIBEE! Вот что я умею:

**Видео и Рилсы**
- Создавать рилсы - скажи "создай рилс про [тему]"
- Генерировать video - скажи "сделай видео про [тему]"

**Изображения**
