@spec test_validation() → Nil {
  /// Test validation only
  given: Nothing
  when: Testing validation
  then: Prints test results
}

@impl {
  print("\n=== VALIDATION TEST ===\n")

  let test_messages = [
    ("Sozdaj rils pro biznes", true),
    ("Hochu rils na temu zdorov'ya", true),
    ("Make a reel about technology", true),
    ("Privet, kak dela?", false),
    ("Rasskazhi o pogode", false),
    ("Sdelaj video dlya instagrama", true),
    ("Generiruj reels kontent", true)
  ]

  list.fn(test_case · each {
    let {message, expected} = test_case
    let result = should_handle_message(message)
    let status = match result == expected {
      true → "PASS"
      false → "FAIL"
    }
    print({status}: "{message}" → {string.inspect(result)})
  }

  // Nil is implicit
}

