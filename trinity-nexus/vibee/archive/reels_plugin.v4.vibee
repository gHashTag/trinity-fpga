    · string.replace("sdelaj rils o ", "")
    · string.replace("hochu rils na temu ", "")
    · string.replace("make a reel about ", "")
    · string.trim()

  match string.length(cleaned) > 0 {
    true → cleaned
    false → "general topic"
  }
}

@spec detect_niche(idea: str) → str {
  /// Detect content niche from idea
  given: Idea text
  when: Categorizing content
  then: Returns niche category
}

@impl {
  let lower = string.lowercase(idea)

  match ["biznes", "business", "zarabotok", "dengi"] · contains_any {
    true → "Business"
    false → {
      match ["zdorov'e", "health", "fitnes", "sport"] · contains_any {
        true → "Health & Fitness"
        false → {
          match ["tekhnologii", "tech", "it", "programmirovanie"] · contains_any {
            true → "Technology"
            false → {
              match ["produktivnost'", "productivity", "motivaciya"] · contains_any {
                true → "Productivity"
                false → "Lifestyle"
              }
            }
          }
        }
      }
    }
  }
}

@spec generate_script(idea: str, niche: str) → str {
  /// Generate video script from idea
  given: Idea and niche
  when: Creating content
  then: Returns script text
}

@impl {
  // Would use LLM for real script generation
  """
Hook: Interesnyjy fakt o {idea}

Osnovnaya chast':
1. Problema, kotoruyu reshaem
2. Reshenie iz oblasti {niche}
3. Prakticheskiy sovet

Zaklyuchenie: Prizyv k dejstviyu
"""
}

@spec contains_any(text: str, patterns: [str]) → bool {
  /// Check if text contains any patterns
  given: Text and patterns
  when: Matching
  then: Returns true if any match
}

@impl {
  list.fn(pattern · any {
    string.pattern · contains
  }
}

@spec int_to_string(n: int) → str {
  /// Convert int to string
  given: Integer
  when: Formatting
  then: Returns string
}

@impl {
  string.inspect(n)
}

