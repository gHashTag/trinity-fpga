  given: Nothing
  when: Initializing plugin
  then: Returns evaluator definition
}

@impl {
  Evaluator(
    "reels_evaluator",
    "Evaluates reels creation results and extracts insights",
    result · fn { result · evaluate_reels_result }
  )
}

@spec evaluate_reels_result(context: ActionContext, result: ActionResult) → EvaluatorResult {
