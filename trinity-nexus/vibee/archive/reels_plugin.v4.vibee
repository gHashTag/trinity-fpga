import "./eliza.vibee" as eliza

// =============================================================================
// Plugin Initialization
// =============================================================================

@spec init() → ActionRegistry {
  /// Initialize the Reels Plugin with all components
  given: Nothing
  when: Starting reels functionality
  then: Returns registry with reels actions
}

@impl {
  print("[REELS_PLUGIN] Initializing...")

  let registry = eliza.new_registry()

  // Register actions
  let registry = eliza.create_reels_action( · register_action)

  // Register providers
  let registry = eliza.create_reels_context_provider( · register_provider)

  // Register evaluators
  let registry = eliza.create_reels_evaluator( · register_evaluator)
  let registry = eliza.create_analytics_evaluator( · register_evaluator)

  print("[REELS_PLUGIN] Initialized with 1 action, 1 provider, 2 evaluators")

  registry
}

