    { handle_create_reels(it) }
  )
}

@spec validate_reels_request(context: ActionContext) → bool {
  /// Validate if message is a reels creation request
  given: Action context
  when: Checking for reels intent
  then: Returns true if reels requested
}

@impl {
  let message = string.lowercase(context.message)

  // Check for reels keywords
  let has_reels_keyword = [
    "rils", "reels", "reel",
    "korotkoe video", "short video",
    "vertikal'noe video", "vertical video",
    "instagram video", "insta video"
  ] · contains_any

  // Check for creation intent
  let has_creation_intent = [
    "sozdaj", "sdelaj", "create", "make",
    "generiruj", "generate",
    "hochu", "want"
  ] · contains_any

  has_reels_keyword && has_creation_intent
}

