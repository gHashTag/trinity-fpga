  // Find matching action
  match eliza.context · find_matching_action {
    ☐action) → {
      print("[REELS_PLUGIN] Found matching action: "{ action }".name)

      // Execute action with full flow (providers + handler + evaluators)
      let result = eliza.action, context · execute_action

      ✅result)
    }
    ∅-> {
      print("[REELS_PLUGIN] No matching action found")
      ❌"No matching action for this message")
    }
  }
}

@spec should_handle_message(message: str) → bool {
  /// Check if message should trigger reels action (for integration with existing bot)
