@impl {
  print("[REELS] Creating reels for: "{ context }".message)

  // Extract idea from message
  let idea = extract_reels_idea(context.message)

  // Detect niche from idea
  let niche = detect_niche(idea)

  // Generate script
  let script = niche · generate_script

  // Build response
  let response = """
Otlichno! Sozdayu rils video.

Tema: {idea}
Nisha: {niche}

Stsenand:
{script}

Video generiruetsya... Eto zaymet 2-3 minuty.
"""

  eliza.success_result(response)
}

