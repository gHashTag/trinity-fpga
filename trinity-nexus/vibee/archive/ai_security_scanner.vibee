name: ai_security_scanner
version: 1.0.0
description: AI-powered with[CYR:[TRANSLATED]]and[EN]in[EN]and[EN] [CYR:without[TRANSLATED]]with[EN]with[EN]and - on[CYR:[TRANSLATED]]and[EN] [CYR:[EN]I[EN]]inand[EN]with[EN]and and [CYR:[TRANSLATED]acts] andwith[CYR:law]in[CYR:[TRANSLATED]]andI

metadata:
  author: VIBEE Team
  category: ai_security
  tags: [ai, security, vulnerabilities, owasp]
  created: 2024-01-10

types:
  SecurityScan:
    scan_id: string
    timestamp: timestamp
    code_analyzed: number
    vulnerabilities_found: number
    severity_breakdown: map<string, number>
    
  Vulnerability:
    vuln_id: string
    type: string  # injection, xss, csrf, etc
    severity: string  # critical, high, medium, low
    cwe_id: string
    owasp_category: string
    location: Location
    description: string
    exploit_scenario: string
    fix_suggestion: string
    code_example: string
    
  SecurityFix:
    vuln_id: string
    fix_type: string  # patch, refactor, config
    code_before: string
    code_after: string
    explanation: string
    validation: ValidationResult
    
  ValidationResult:
    is_secure: boolean
    remaining_issues: list<string>
    security_score: number

constants:
  OWASP_TOP_10:
    - id: "A01"
      name: "Broken Access Control"
      description: "[CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]I] [EN]with[CYR:[TRANSLATED]]"
      
    - id: "A02"
      name: "Cryptographic Failures"
      description: "[EN]and[CYR:[TRANSLATED]]and[EN]with[EN]and[EN] [EN]and[EN]and"
      
    - id: "A03"
      name: "Injection"
      description: "SQL, NoSQL, OS injection"
      
    - id: "A04"
      name: "Insecure Design"
      description: "[CYR:[EN]without[TRANSLATED]]with[CYR:ny] [EN]from[CYR:[TRANSLATED]]"
      
    - id: "A05"
      name: "Security Misconfiguration"
      description: "[CYR:[EN]law]inandlonI configuration"
      
    - id: "A06"
      name: "Vulnerable Components"
      description: "[CYR:[EN]I[EN]]inand[CYR:[EN]y[EN]] componenty"
      
    - id: "A07"
      name: "Authentication Failures"
      description: "[EN]and[EN]and [CYR:[TRANSLATED]]and[EN]and[CYR:[TRANSLATED]]andand"
      
    - id: "A08"
      name: "Data Integrity Failures"
      description: "[CYR:[TRANSLATED]]and[EN] [CYR:[TRANSLATED]]with[CYR:[TRANSLATED]]with[EN]and [CYR:data]"
      
    - id: "A09"
      name: "Logging Failures"
      description: "[CYR:[TRANSLATED]]with[CYR:[TRANSLATED]] [CYR:[TRANSLATED]]and[EN]in[EN]and[EN]"
      
    - id: "A10"
      name: "SSRF"
      description: "Server-Side Request Forgery"

  VULNERABILITY_PATTERNS:
    sql_injection:
      pattern: 'query("SELECT * FROM users WHERE id = " <> user_input)'
      severity: "critical"
      cwe: "CWE-89"
      fix: "[EN]with[CYR:[EN]l[EN]]in[CYR:ate] parameterfrom[EN]in[CYR:[EN]nye] queryy"
      
    xss:
      pattern: 'html.render(user_input)'
      severity: "high"
      cwe: "CWE-79"
      fix: "[CYR:[TRANSLATED]]and[EN]in[CYR:ate] HTML"
      
    path_traversal:
      pattern: 'file.read(user_input)'
      severity: "high"
      cwe: "CWE-22"
      fix: "[CYR:[TRANSLATED]]and[EN]and[EN]in[CYR:ate] [CYR:[TRANSLATED]]and file[EN]in"
      
    weak_crypto:
      pattern: 'md5(password)'
      severity: "high"
      cwe: "CWE-327"
      fix: "[EN]with[CYR:[EN]l[EN]]in[CYR:ate] bcrypt or argon2"
      
    hardcoded_secrets:
      pattern: 'api_key = "sk-..."'
      severity: "critical"
      cwe: "CWE-798"
      fix: "[EN]with[CYR:[EN]l[EN]]in[CYR:ate] [CYR:[TRANSLATED]nye] [CYR:[TRANSLATED]]andI"

  AI_PROMPTS:
    security_scan: |
      [EN]y - [EN]with[CYR:[TRANSLATED]] [EN] [CYR:without[TRANSLATED]]with[EN]with[EN]and [EN]and[CYR:[TRANSLATED]]and[EN] (OWASP Top 10).
      
      [CYR:Code] for analysis[EN]:
      ```vibee
      {code}
      ```
      
      [CYR:[TRANSLATED]]with[EN]:
      - [EN]and[EN] [EN]and[CYR:[TRANSLATED]]andI: {app_type}
      - [EN]with[CYR:[EN]l[TRANSLATED]y[EN]] [EN]and[EN]and[CYR:[TRANSLATED]]and: {libraries}
      - [CYR:[EN]work[EN]y]in[CYR:[TRANSLATED]y[EN]] [CYR:data]: {data_types}
      
      [CYR:[TRANSLATED]]: [CYR:[TRANSLATED]]and inwith[EN] [CYR:[EN]I[EN]]inand[EN]with[EN]and [CYR:without[TRANSLATED]]with[EN]with[EN]and.
      
      [CYR:[TRANSLATED]]in[CYR:[TRANSLATED]] on:
      1. Injection (SQL, NoSQL, OS, LDAP)
      2. XSS (Reflected, Stored, DOM)
      3. CSRF
      4. Broken Authentication
      5. Sensitive Data Exposure
      6. XML External Entities (XXE)
      7. Broken Access Control
      8. Security Misconfiguration
      9. Insecure Deserialization
      10. Using Components with Known Vulnerabilities
      
      [CYR:[TRANSLATED]] response[EN]:
      [CYR:[EN]I[EN]]inand[EN]with[EN]and:
      1. [EN]and[EN]: <on[EN]in[EN]and[EN]>
         Severity: <critical/high/medium/low>
         CWE: <CWE-ID>
         OWASP: <A01-A10>
         [EN]with[EN]: <location>
         [EN]andwith[EN]and[EN]: <that not [CYR:[TRANSLATED]]>
         [EN]with[CYR:[TRANSLATED]]: <how [CYR:can[EN]] andwith[CYR:[EN]l[EN]]in[CYR:ate]>
         [EN]with[CYR:law]in[CYR:[TRANSLATED]]and[EN]:
         ```vibee
         <[CYR:without[TRANSLATED]]with[CYR:ny] code>
         ```
         [CYR:[TRANSLATED]I]withnot[EN]and[EN]: <[CYR:[TRANSLATED]] this [CYR:without[TRANSLATED]]with[EN]>
      
    exploit_analysis: |
      [EN]y - [EN]with[CYR:[TRANSLATED]] [EN] [EN]with[CYR:[TRANSLATED]]andand [CYR:[EN]I[EN]]inand[EN]with[CYR:[TRANSLATED]].
      
      [CYR:[EN]I[EN]]inand[EN]with[EN]:
      ```vibee
      {vulnerable_code}
      ```
      
      [EN]and[EN]: {vulnerability_type}
      
      [CYR:[TRANSLATED]]: [EN]and[EN]and with[EN]on[EN]and[EN] [EN]with[CYR:[TRANSLATED]]andand.
      
      [CYR:[TRANSLATED]] response[EN]:
      [CYR:[TRANSLATED]]on[EN]and[EN] [CYR:[TRANSLATED]]and:
      1. [CYR:[TRANSLATED]]: <[CYR:[TRANSLATED]]with[EN]inand[EN] [CYR:[TRANSLATED]go]>
         Payload: <example payload>
         [CYR:[TRANSLATED]l[TRANSLATED]]: <that [CYR:pro]from[CYR:[TRANSLATED]]>
      
      Impact:
      - [CYR:[TRANSLATED]]and[CYR:[TRANSLATED]]and[CYR:[EN]lno]with[EN]: <high/medium/low>
      - [CYR:[TRANSLATED]]with[CYR:[TRANSLATED]]with[EN]: <high/medium/low>
      - [EN]with[CYR:[TRANSLATED]]with[EN]: <high/medium/low>
      
      CVSS Score: <0-10>
      
    secure_coding: |
      [EN]y - [EN]with[CYR:[TRANSLATED]] [EN] [CYR:without[TRANSLATED]]with[CYR:[TRANSLATED]] [CYR:[TRANSLATED]work[TRANSLATED]].
      
      [CYR:[EN]without[TRANSLATED]]with[CYR:ny] code:
      ```vibee
      {insecure_code}
      ```
      
      [CYR:[TRANSLATED]]: {vulnerability_description}
      
      [CYR:[TRANSLATED]]: [CYR:[TRANSLATED]]and [CYR:without[TRANSLATED]]with[CYR:[TRANSLATED]] [CYR:[TRANSLATED]]from[EN]and[EN].
      
      [CYR:[TRANSLATED]]in[EN]andI:
      - [CYR:[TRANSLATED]]and[EN] [EN] fromin[EN]with[CYR:[EN]y[EN]] [CYR:[TRANSLATED]]
      - [CYR:[TRANSLATED]]and[CYR:[TRANSLATED]]andI entry[CYR:[EN]y[EN]] [CYR:data]
      - [CYR:[TRANSLATED]]inandlonI handling [EN]and[CYR:[TRANSLATED]]
      - [EN]and[EN]and[CYR:[EN]l[EN]y[EN]] [EN]andinand[CYR:[TRANSLATED]]andand
      - Defense in depth
      
      [CYR:[TRANSLATED]] response[EN]:
      [CYR:[TRANSLATED]]with[CYR:ny] code:
      ```vibee
      <andwith[CYR:law]in[CYR:[TRANSLATED]ny] code>
      ```
      
      [CYR:[TRANSLATED]]and[EN]:
      - [EN] [CYR:[EN]go] [CYR:[TRANSLATED]]and[CYR:[EN]acts]: <list [CYR:[TRANSLATED]]>
      - [CYR:[TRANSLATED]] [CYR:work[EN]]: <[CYR:[TRANSLATED]I]withnot[EN]and[EN]>
      - [CYR:[TRANSLATED]]and[CYR:[EN]l[EN]y[EN]] [CYR:[TRANSLATED]y]: <[CYR:[TRANSLATED]me[TRANSLATED]]andand>

behaviors:
  scan_code:
    input:
      code: string
      scan_config: ScanConfig
    output:
      scan: SecurityScan
      vulnerabilities: list<Vulnerability>
    description: [CYR:[TRANSLATED]]and[EN]in[EN]and[EN] code[EN] on [CYR:[EN]I[EN]]inand[EN]with[EN]and
    steps:
      - [CYR:[TRANSLATED]]withand[EN] code in AST
      - [CYR:[EN]law]inand[EN] on analysis AI
      - [CYR:[TRANSLATED]]and[EN] list [CYR:[EN]I[EN]]inand[EN]with[CYR:[TRANSLATED]]
      - [CYR:[TRANSLATED]]withwithand[EN]and[EN]and[EN]in[CYR:ate] [EN] severity
      - [CYR:[TRANSLATED]]inand[EN] CWE/OWASP [CYR:[TRANSLATED]go[EN]]andand
      - [CYR:[TRANSLATED]] resulty
      
  analyze_vulnerability:
    input:
      vuln: Vulnerability
      code: string
    output:
      analysis: VulnerabilityAnalysis
    description: [CYR:[TRANSLATED]al] analysis [CYR:[EN]I[EN]]inand[EN]with[EN]and
    steps:
      - [CYR:[TRANSLATED]]analyze [CYR:[EN]I[EN]]inand[EN]with[EN]
