    description: [CYR:[TRANSLATED]]and[EN] andwith[CYR:law]in[CYR:[TRANSLATED]]andI
    steps:
      - [CYR:[TRANSLATED]]and[EN] type [CYR:[EN]I[EN]]inand[EN]with[EN]and
      - [CYR:[TRANSLATED]]not[EN]and[EN]in[CYR:ate] [CYR:without[TRANSLATED]]with[CYR:ny] code
      - [CYR:[TRANSLATED]]and[EN]and[EN]in[CYR:ate] fix
      - [CYR:[TRANSLATED]]in[EN]and[EN] on [EN]iny[EN] [CYR:[EN]I[EN]]inand[EN]with[EN]and
      - [CYR:[TRANSLATED]] fix
      
  apply_fix:
    input:
      fix: SecurityFix
      code: string
    output:
      patched_code: string
      validation: ValidationResult
    description: [EN]and[EN]not[EN]and[EN] andwith[CYR:law]in[CYR:[TRANSLATED]]andI
