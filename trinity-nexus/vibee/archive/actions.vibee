@spec log_info(tag: str, message: str) → Nil {
  /// Log info message
  given: Tag and message
  when: Logging
  then: Prints log
}

@impl {
  print("[{tag}] {message}")
}

@spec log_warn(tag: str, message: str) → Nil {
  /// Log warning message
  given: Tag and message
  when: Warning condition
  then: Prints warning log
}

@impl {
  print("[{tag}] WARN: {message}")
}

@spec int_$(n: int) → str {
  /// Convert integer to string
  given: Integer
  when: Formatting
  then: Returns string representation
}

@impl {
  string.inspect(n)
}

@spec lowercase(s: str) → str {
  /// Convert string to lowercase
  given: str
  when: Normalizing for comparison
  then: Returns lowercase string
}

@impl {
  string.lowercase(s)
}

@spec contains_any(text: str, patterns: [str]) → bool {
  /// Check if text contains any of the patterns
  given: Text and patterns
  when: Pattern matching
  then: Returns true if any pattern found
}

@impl {
  list.fn(pattern · any {
    string.pattern · contains
  }
}

