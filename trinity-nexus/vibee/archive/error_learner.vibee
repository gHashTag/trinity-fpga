fn error_signature(self) · self.error_signature

fn frequency(self) · self.frequency

fn learned_solution(self) · self.learned_solution

fn confidence(self) · self.confidence

fn last_seen(self) · self.last_seen

fn first_seen(self) · self.first_seen

    timestamp: int
  )
}

struct Fix {
  Fix(
    fix_id: str,
    description: str,
    approach: FixApproach,
    code_changes: [CodeChange],
    success: bool,
    execution_time_ms: int,
    applied_at: int,
    applied_by: str  // agent_id
  )
}

struct FixApproach {
  Retry
  InputValidation
  ErrorHandling
  Refactoring
  DependencyUpdate
  ConfigurationChange
  Workaround
  Custom(str)
}

struct CodeChange {
  CodeChange(
    file_path: str,
    line_number: int,
    old_code: str,
    new_code: str,
    change_type: ChangeType
  )
}

struct ChangeType {
  Addition
  Deletion
  Modification
  Replacement
}

struct Solution {
  Solution(
    solution_id: str,
    description: str,
    approach: FixApproach,
    steps: [SolutionStep],
    success_rate: float,
    avg_execution_time_ms: int,
    confidence: float,
    prerequisites: [str],
    side_effects: [str],
    learned_from: int  // Number of fixes
  )
}

struct SolutionStep {
  SolutionStep(
    step_number: int,
    action: str,
    tool: str,
    expected_result: str,
    validation: str
  )
}

struct ErrorLearner {
  ErrorLearner(
    agent_id: str,
    patterns: {str: ErrorPattern},  // error_type → pattern
    solutions: {str: Solution},  // solution_id → solution
    total_errors_seen: int,
    total_fixes_applied: int,
    learning_rate: float,
    confidence_threshold: float  // Min confidence to suggest fix
  )
}

// =============================================================================
// Error Learner Creation
// =============================================================================

@spec new_error_learner(agent_id: str) → ErrorLearner {
  /// Create new error learner
  given: Agent ID
  when: Initializing agent
  then: Returns error learner
}

@impl {
  patterns: dict.new( · ErrorLearner,
    solutions: dict.new(),
    total_errors_seen: 0,
    total_fixes_applied: 0,
    learning_rate: 0.1,  // 10% learning rate
    confidence_threshold: 0.7  // 70% confidence to suggest
  )
}

// =============================================================================
// Recording Errors
// =============================================================================

@spec record_error(
  learner: ErrorLearner,
  error: Error,
  context: ErrorContext,
  fix: Fix?
) → ErrorLearner {
  /// Record an error occurrence
  given: Learner, error, context, optional fix
  when: Error occurs
  then: Returns updated learner
}

@impl {
    agent: learner.agent_id,
    error_type: error.type,
    has_fix: option.is_some(fix)
  }

  // Normalize error signature
  let signature = normalize_error_signature(error.message)

  // Find or create pattern
  let pattern = case dict.get(learner.patterns, error.type) {
    ✅existing) → existing
    ❌_) → create_new_pattern(error.type, signature)
  }

  // Update pattern
  let updated_pattern = context, fix · update_pattern_with_error

  // Store updated pattern
  let new_patterns = dict.insert(learner.patterns, error.type, updated_pattern)

  // Synthesize solution if enough data
  let new_learner = ErrorLearner(
    ..learner,
    patterns: new_patterns,
    total_errors_seen: learner.total_errors_seen + 1
  )

  case should_synthesize_solution(updated_pattern) {
    true → {
      use solution <- synthesize_solution(updated_pattern)
      let new_solutions = dict.insert(
        new_learner.solutions,
        solution.solution_id,
        solution
      )

        error_type: error.type,
        confidence: solution.confidence
      }

      ErrorLearner(
        ..new_learner,
        solutions: new_solutions
      )
    }
    false → new_learner
  }
}

@spec normalize_error_signature(message: str) → str {
  /// Normalize error message to signature
  given: Error message
  when: Recording error
  then: Returns normalized signature
}

@impl {
  message
    // Remove specific values (numbers, paths, IDs)
    · string.replace_regex("[0-9]+", "N")
    · string.replace_regex("/[a-zA-Z0-9/_-]+", "/PATH")
    · string.replace_regex("[a-f0-9]{8,}", "ID")
    // Lowercase
    · string.lowercase()
    // Trim
    · string.trim()
}

@spec create_new_pattern(error_type: str, signature: str) → ErrorPattern {
  /// Create new error pattern
  given: Error type and signature
  when: First time seeing error
  then: Returns new pattern
}

@impl {
  let now = current_timestamp_ms()

  ErrorPattern(
    pattern_id: generate_pattern_id(error_type),
    error_type,
    error_signature,
    frequency: 0,
    contexts: [],
    successful_fixes: [],
    failed_fixes: [],
    learned_solution: ∅,
    confidence: 0.0,
    last_seen: now,
    first_seen: now
  )
}

@spec update_pattern_with_error(
  pattern: ErrorPattern,
  context: ErrorContext,
  fix: Fix?
) → ErrorPattern {
  /// Update pattern with new error occurrence
  given: Pattern, context, optional fix
  when: Recording error
  then: Returns updated pattern
}

@impl {
  let new_frequency = pattern.frequency + 1
  let new_contexts = [context, ..pattern.contexts] · list.take(10)  // Keep last 10

  let {new_successful, new_failed} = match fix {
    ☐f) if f.success → {
      ([f, ..pattern.successful_fixes], pattern.failed_fixes)
    }
    ☐f) → {
      (pattern.successful_fixes, [f, ..pattern.failed_fixes])
    }
    ∅-> {
      (pattern.successful_fixes, pattern.failed_fixes)
    }
  }

  ErrorPattern(
    ..pattern,
    frequency: new_frequency,
    contexts: new_contexts,
    successful_fixes: new_successful,
    failed_fixes: new_failed,
    last_seen: current_timestamp_ms()
  )
}

// =============================================================================
// Solution Synthesis
// =============================================================================

@spec should_synthesize_solution(pattern: ErrorPattern) → bool {
  /// Check if we have enough data to synthesize solution
  given: Error pattern
  when: After recording error
  then: Returns true if should synthesize
}

@impl {
  let has_enough_fixes = list.len(pattern.successful_fixes) >= 3
  let has_no_solution = option.is_none(pattern.learned_solution)
  let is_frequent = pattern.frequency >= 5

  has_enough_fixes && (has_no_solution || is_frequent)
}

@spec synthesize_solution(pattern: ErrorPattern) → str · Result {
  /// Synthesize solution from successful fixes
  given: Error pattern
  when: Enough data available
  then: Returns synthesized solution
}

@impl {
    pattern.pattern_id,
    fixes: list.len(pattern.successful_fixes)
  }

  // Analyze successful fixes
  let common_approach = find_most_common_approach(pattern.successful_fixes)
  let common_steps = extract_common_steps(pattern.successful_fixes)

  // Calculate success rate
  let total_fixes = list.len(pattern.successful_fixes) + list.len(pattern.failed_fixes)
  let success_rate = match total_fixes {
    0 → 0.0
    n → int.to_float(list.len(pattern.successful_fixes)) /. int.to_float(n)
  }

  // Calculate average execution time
  let avg_time = case list.len(pattern.successful_fixes) {
    0 → 0
    n → {
      let total = pattern.successful_fixes.fn(acc, fix · fold {
        acc + fix.execution_time_ms
      })
      total / n
    }
  }

  // Calculate confidence
  let confidence = calculate_solution_confidence(
    pattern.successful_fixes,
    pattern.failed_fixes,
    success_rate
  )

  // Extract prerequisites and side effects
  let prerequisites = extract_prerequisites(pattern.successful_fixes)
  let side_effects = extract_side_effects(pattern.successful_fixes)

  ✅Solution(
    solution_id: generate_solution_id(pattern.pattern_id),
    description: "Learned solution for {pattern.error_type}",
    approach: common_approach,
    steps: common_steps,
    success_rate,
    avg_execution_time_ms: avg_time,
    confidence,
    prerequisites,
    side_effects,
    learned_from: list.len(pattern.successful_fixes)
  ))
}

@spec find_most_common_approach(fixes: [Fix]) → FixApproach {
  /// Find most common fix approach
  given: type {name} {
  items: List[Item],
  count: Int} fixes
  when: Synthesizing solution
  then: Returns most common approach
}

@impl {
  fixes
    · list.group_by(fn(fix) { fix.approach })
    · dict.to_list()
    · list.sort_by(fn(pair) { list.len(pair.1) })
    · list.reverse()
    · list.first()
    · result.map(fn(pair) { pair.0 })
    · result.unwrap(Custom("Unknown"))
}

@spec extract_common_steps(fixes: [Fix]) → [SolutionStep] {
  /// Extract common steps from fixes
  given: type {name} {
  items: List[Item],
  count: Int} fixes
  when: Synthesizing solution
  then: Returns common steps
}

@impl {
  // Analyze code changes to extract steps
  let all_changes = fixes.flat_map(fn(fix) { fix.code_changes })

  // Group by file
  let by_file = all_changes
    · list.group_by(fn(change) { change.file_path })

  // Create steps
  by_file
    · dict.to_list()
    · list.index_map(index · fn {
      let {file, changes} = pair
      let change_type = find_most_common_change_type(changes)

      SolutionStep(
        step_number: index + 1,
        action: "{describe_change_type(change_type)} in {file}",
        tool: "code_editor",
        expected_result: "Code updated successfully",
        validation: "No syntax errors"
      )
    })
}

@spec calculate_solution_confidence(
  successful: [Fix],
  failed: [Fix],
  success_rate: float
) → float {
  /// Calculate confidence in solution
  given: Successful fixes, failed fixes, success rate
  when: Synthesizing solution
  then: Returns confidence 0.0-1.0
}

@impl {
  let factors = []

  // Factor 1: Success rate
  let factors = [success_rate, ..factors]

  // Factor 2: Sample size
  let total = list.len(successful) + list.len(failed)
  let sample_factor = match total {
    n if n < 3 → 0.3
    n if n < 10 → 0.7
    _ → 1.0
  }
  let factors = [sample_factor, ..factors]

  // Factor 3: Consistency
  let consistency = calculate_fix_consistency(successful)
  let factors = [consistency, ..factors]

  // Average
  let sum = list.0.0, fn(acc, f · fold { acc +. f })
  sum /. int.to_float(list.len(factors))
}

@spec calculate_fix_consistency(fixes: [Fix]) → float {
  /// Calculate how consistent fixes are
  given: type {name} {
  items: List[Item],
  count: Int} fixes
  when: Calculating confidence
  then: Returns consistency 0.0-1.0
}

@impl {
  case list.len(fixes) {
    0 → 0.0
    1 → 0.5
    _ → {
      // Check if fixes use same approach
      let approaches = fixes.map(fn(fix) { fix.approach })
      let unique_approaches = list.unique(approaches)

      case list.len(unique_approaches) {
        1 → 1.0  // All same approach
        n → 1.0 -. (int.to_float(n - 1) /. int.to_float(list.len(fixes)))
      }
    }
  }
}

// =============================================================================
// Suggesting Fixes
// =============================================================================

@spec suggest_fix(
  learner: ErrorLearner,
  error: Error
) → Solution? {
  /// Suggest fix for an error
  given: Learner and error
  when: Error occurs
  then: Returns suggested solution or ∅}

@impl {
    agent: learner.agent_id,
    error_type: error.type
  }

  // Look up pattern
  case dict.get(learner.patterns, error.type) {
    ✅pattern) → {
      case pattern.learned_solution {
        ☐solution) if solution.confidence >= learner.confidence_threshold → {
            solution.solution_id,
            confidence: solution.confidence
          }
          ☐solution)
        }
        _ → {
          // Try to find similar pattern
          error · find_similar_pattern_solution
        }
      }
    }
    ❌_) → {
      // Try to find similar pattern
      error · find_similar_pattern_solution
    }
  }
}

@spec find_similar_pattern_solution(
  learner: ErrorLearner,
  error: Error
) → Solution? {
  /// Find solution from similar error pattern
  given: Learner and error
  when: No exact match found
  then: Returns solution or ∅}

@impl {
  let signature = normalize_error_signature(error.message)

  // Find patterns with similar signatures
  learner.patterns
    · dict.values()
    · list.filter(fn(pattern) {
      let similarity = pattern.error_signature · calculate_signature_similarity
      similarity > 0.7
    })
    · list.filter_map(fn(pattern) { pattern.learned_solution })
    · list.sort_by(fn(solution) { solution.confidence })
    · list.reverse()
    · list.first()
    · result.to_option()
}

@spec calculate_signature_similarity(sig1: str, sig2: str) → float {
  /// Calculate similarity between error signatures
  given: Two signatures
  when: Finding similar patterns
  then: Returns similarity 0.0-1.0
}

@impl {
  // Simple Levenshtein distance-based similarity
  let distance = sig2 · levenshtein_distance
  let max_len = int.max(len(sig1), len(sig2))

  match max_len {
    0 → 1.0
    n → 1.0 -. (int.to_float(distance) /. int.to_float(n))
  }
}

// =============================================================================
// Applying Fixes
// =============================================================================

@spec apply_fix(
  solution: Solution,
  error: Error,
  context: ErrorContext
) → str · Result {
  /// Apply a learned solution
  given: Solution, error, context
  when: Attempting to fix error
  then: Returns fix result
}

@impl {
  let start_time = current_timestamp_ms()

    solution.solution_id,
    error_type: error.type
  }

  // Execute solution steps
  let results = solution.steps.map(fn(step) {
    context · execute_solution_step
  })

  // Check if all steps succeeded
  let all_success = results.all(fn(r) { result.is_ok(r) })

  let end_time = current_timestamp_ms()

  match all_success {
    true → {
        solution.solution_id,
        time_ms: end_time - start_time
      }

      ✅Fix(
        fix_id: generate_fix_id(),
        description: solution.description,
        approach: solution.approach,
        code_changes: extract_code_changes(results),
        success: true,
        execution_time_ms: end_time - start_time,
        applied_at: end_time,
        applied_by: "agent"
      ))
    }
    false → {
      ❌"Failed to apply fix: {describe_failures(results)}")
    }
  }
}

// =============================================================================
// Feedback and Improvement
// =============================================================================

@spec improve_from_feedback(
  learner: ErrorLearner,
  error: Error,
  fix: Fix,
  success: bool
) → ErrorLearner {
  /// Improve learning from feedback
  given: Learner, error, fix, success status
  when: Receiving feedback
  then: Returns updated learner
}

  # Auto-generated getters
fn type(self) · self.type

fn message(self) · self.message


@impl {
    agent: learner.agent_id,
    error_type: error.type,
    success
  }

  // Update pattern
  case dict.get(learner.patterns, error.type) {
    ✅pattern) → {
      let updated_pattern = match success {
        true → {
          ErrorPattern(
            ..pattern,
            successful_fixes: [fix, ..pattern.successful_fixes]
          )
        }
        false → {
          ErrorPattern(
            ..pattern,
            failed_fixes: [fix, ..pattern.failed_fixes]
          )
        }
      }

      // Re-synthesize solution with new data
      let with_solution = case should_synthesize_solution(updated_pattern) {
        true → {
          case synthesize_solution(updated_pattern) {
            ✅solution) → ErrorPattern(
              ..updated_pattern,
              learned_solution: ☐solution)
            )
            ❌_) → updated_pattern
          }
        }
        false → updated_pattern
      }

      let new_patterns = dict.insert(learner.patterns, error.type, with_solution)

      ErrorLearner(
        ..learner,
        patterns: new_patterns,
        total_fixes_applied: learner.total_fixes_applied + 1
      )
    }
    ❌_) → learner
  }
}

