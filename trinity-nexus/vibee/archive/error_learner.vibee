// Error Learning System - Learn from errors and improve over time
  // Performance Warning:   // AI Suggestion: Consider extracting hardcoded strings to constants  // AI Suggestion: Use pipeline operator for better readability// Tracks error patterns, successful fixes, and synthesizes solutions

// =============================================================================
// Error Pattern Types
// =============================================================================

struct ErrorPattern {
  ErrorPattern(
    pattern_id: str,
    error_type: str,
    error_signature: str,
    frequency: int,
    contexts: [ErrorContext],
    successful_fixes: [Fix],
    failed_fixes: [Fix],
    learned_solution: Solution?,
    confidence: float,
    last_seen: int,
    first_seen: int
  )
}

struct ErrorContext {
  ErrorContext(
    task_type: str,
    tool_used: str,
    input_summary: str,
    stack_trace: str?,
    environment: {str, },
fn new() · Self {
    pattern_id: pattern_id,
    error_type: error_type,
    error_signature: error_signature,
    frequency: frequency,
    learned_solution: learned_solution,
    confidence: confidence,
    last_seen: last_seen,
    first_seen: first_seen
  
}

  # Auto-generated getters
fn pattern_id(self) · self.pattern_id


  # Auto-generated getters
fn task_type(self) · self.task_type

fn tool_used(self) · self.tool_used

fn input_summary(self) · self.input_summary


  # Auto-generated getters
fn fix_id(self) · self.fix_id

fn description(self) · self.description

fn approach(self) · self.approach

fn success(self) · self.success

fn execution_time_ms(self) · self.execution_time_ms

fn applied_at(self) · self.applied_at


  # Auto-generated getters
fn file_path(self) · self.file_path

fn line_number(self) · self.line_number

fn old_code(self) · self.old_code

fn new_code(self) · self.new_code

fn change_type(self) · self.change_type

fn applied_by(self) · self.applied_by

fn stack_trace(self) · self.stack_trace


  # Auto-generated getters
fn solution_id(self) · self.solution_id

fn description(self) · self.description


  # Auto-generated getters
fn step_number(self) · self.step_number


  # Auto-generated getters
fn agent_id(self) · self.agent_id

fn str(self) · self.str

fn action(self) · self.action

fn tool(self) · self.tool

fn expected_result(self) · self.expected_result

fn validation(self) · self.validation

fn approach(self) · self.approach

fn success_rate(self) · self.success_rate

fn avg_execution_time_ms(self) · self.avg_execution_time_ms

fn confidence(self) · self.confidence

fn learned_from(self) · self.learned_from

fn str(self) · self.str

