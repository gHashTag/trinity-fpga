// Helper Functions
// =============================================================================

@spec generate_pattern_id(error_type: str) → str
@spec generate_solution_id(pattern_id: str) → str
@spec generate_fix_id() → str
@spec extract_prerequisites(fixes: [Fix]) → [str]
@spec extract_side_effects(fixes: [Fix]) → [str]
@spec find_most_common_change_type(changes: [CodeChange]) → ChangeType
@spec describe_change_type(change_type: ChangeType) → str
@spec execute_solution_step(step: SolutionStep, context: ErrorContext) → str · Result
@spec extract_code_changes(results: [str] · Result) → [CodeChange]
@spec describe_failures(results: [str] · Result) → str
@spec levenshtein_distance(s1: str, s2: str) → int
@spec current_timestamp_ms() → int

struct Error {
  type: str
  message: str
}

// =============================================================================
// Export Public API
// =============================================================================

pub new_error_learner(agent_id: str) → ErrorLearner
pub record_error(learner: ErrorLearner, error: Error, context: ErrorContext, fix: Fix?) → ErrorLearner
pub suggest_fix(learner: ErrorLearner, error: Error) → Solution?
pub apply_fix(solution: Solution, error: Error, context: ErrorContext) → str · Result
pub improve_from_feedback(learner: ErrorLearner, error: Error, fix: Fix, success: bool) → ErrorLearner

