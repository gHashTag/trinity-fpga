# ============================================================================
# EXAMPLES & USE CASES
# ============================================================================

# 1. Image Classification (ResNet)
# ============================================================================

pub train_resnet() = {
  let model = ResNet50.new(num_classes: 1000)
  let data = ImageNet.load(batch_size: 256)
  
  let trained = distributed_train(model, data)
  
  trained.save("resnet50.pth")
}

# 2. Language Model (GPT)
# ============================================================================

pub train_gpt() = {
  let model = GPT.new(
    vocab_size: 50257,
    n_layers: 12,
    n_heads: 12,
    d_model: 768,
  )
  
  let data = TextDataset.load("corpus.txt", batch_size: 32)
  
  let trained = mixed_precision_train(model, data)
  
  trained.save("gpt.pth")
}

# 3. Reinforcement Learning (Atari)
# ============================================================================

pub train_atari() = {
  let env = gym("PongNoFrameskip-v4")
  let agent = PPO.new(
    policy: "CnnPolicy",
    learning_rate: 0.00025,
  )
  
  let trained = train_rl(env, agent)
  
  trained.save("ppo_pong.pth")
}

# 4. Distributed System (Microservices)
# ============================================================================

supervisor App {
  strategy: one_for_one
  
  child Database { restart: permanent }
  child WebServer { restart: permanent }
  child Worker { restart: transient, count: 10 }
  child CircuitBreaker { restart: permanent }
}

# 5. Real-Time Analytics (Stream Processing)
# ============================================================================

pub analytics_pipeline() = {
  let events = kafka_source("events")
  
  events
  |> parallel_map(parse_event)
  |> filter(validate_event)
  |> window(duration: 60000)  # 1 minute windows
  |> parallel_map(aggregate)
  |> sink(database)
}

