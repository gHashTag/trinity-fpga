# ═══════════════════════════════════════════════════════════════════════════════
# TRI CLI — Arch Linux AUR Package
# Unified Trinity Command Line Interface
# φ² + 1/φ² = 3 = TRINITY
# ═══════════════════════════════════════════════════════════════════════════════

pkgname=tri-cli
pkgver=0.11.0
pkgrel=1
pkgdesc="Unified Trinity CLI — Chat, Code, Vision, Voice, Tools, Autonomous Agents"
arch=('x86_64' 'aarch64')
url="https://github.com/gHashTag/trinity"
license=('MIT')
depends=('glibc' 'zig>=0.15')
makedepends=('git')
optdepends=(
  'ollama: Local LLM support'
  'ffmpeg: Vision and voice I/O'
)
source=("git+https://github.com/gHashTag/trinity.git#tag=v${pkgver}")
sha256sums=('SKIP')

prepare() {
  cd "${srcdir}/trinity"
  echo "φ² + 1/φ² = 3 = TRINITY"
}

build() {
  cd "${srcdir}/trinity"

  # Build TRI CLI
  echo "Building TRI CLI..."
  zig build tri

  # Build VIBEE compiler
  echo "Building VIBEE compiler..."
  zig build vibee

  # Build release binaries
  echo "Building release binaries..."
  zig build tri-Determine-release
}

package() {
  cd "${srcdir}/trinity"

  # Install binaries
  install -Dm755 "zig-out/bin/tri" "${pkgdir}/usr/bin/tri"
  install -Dm755 "zig-out/bin/vibee" "${pkgdir}/usr/bin/vibee"

  # Install shell completions
  install -Dm644 "completions/tri.bash" "${pkgdir}/usr/share/bash-completion/completions/tri"
  install -Dm644 "completions/tri.zsh" "${pkgdir}/usr/share/zsh/site-functions/_tri"
  install -Dm644 "completions/tri.fish" "${pkgdir}/usr/share/fish/vendor_completions.d/tri.fish"

  # Install documentation
  install -Dm644 "README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  # Install man pages (if available)
  if [ -f "docs/tri.1" ]; then
    install -Dm644 "docs/tri.1" "${pkgdir}/usr/share/man/man1/tri.1"
  fi

  # Install .vibee specifications
  mkdir -p "${pkgdir}/usr/share/tri/specs"
  cp -r specs/tri/*.vibee "${pkgdir}/usr/share/tri/specs/"

  # Install templates (if available)
  if [ -d "templates" ]; then
    mkdir -p "${pkgdir}/usr/share/tri/templates"
    cp -r templates/* "${pkgdir}/usr/share/tri/templates/"
  fi
}

post_install() {
  echo "╔═══════════════════════════════════════════════════════════════╗"
  echo "║           TRI CLI installed successfully                     ║"
  echo "╚═══════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Quick start:"
  echo "  tri                    # Start interactive REPL"
  echo "  tri chat 'hello'       # Chat with AI"
  echo "  tri code 'fibonacci'   # Generate code"
  echo "  tri --help             # Show all commands"
  echo ""
  echo "φ² + 1/φ² = 3 = TRINITY"
}

post_upgrade() {
  post_install
}
