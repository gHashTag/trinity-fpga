name: hdc_golden_chain_v1_3_vsa_onchain
version: "1.3.0"
language: zig
module: golden_chain_vsa_onchain

description: |
  Golden Chain v1.3: VSA-Semantic Quark Query + On-Chain Export.
  Builds on v1.2 (32 quarks, gluon DAG entanglement, 23 tests).
  Adds: QuarkSearchQuery (structured filtering), QuarkChainExport (binary serialize),
  QuarkVerbosity (full/summary/silent), 3 new QuarkTypes (19 total), 40 quarks/query,
  phi-hash verification (Phase C), cross-chain verification (Phase D).
  phi^2 + 1/phi^2 = 3 = TRINITY

constants:
  # Existing (unchanged from v1.2)
  QUARK_HASH_SIZE: 32
  MAX_QUARK_RECORDS: 48
  MAX_ENTANGLE_REFS: 2
  QUARK_CONTENT_DIGEST_LEN: 48
  PROVENANCE_HASH_SIZE: 32
  MAX_PROVENANCE_RECORDS: 16
  CONTENT_DIGEST_LEN: 64
  # v1.3: Export
  QUARK_EXPORT_MAGIC: "QGC1"        # 4-byte magic header
  QUARK_EXPORT_VERSION: 1            # u16 version
  PROVENANCE_RECORD_EXPORT_SIZE: 158 # bytes per serialized provenance record
  QUARK_RECORD_EXPORT_SIZE: 131      # bytes per serialized quark record
  QUARK_EXPORT_HEADER_SIZE: 10       # magic(4) + version(2) + prov_count(1) + quark_count(1) + verified(1) + quark_verified(1)

types:
  QuarkType_v1_3:
    description: "19 sub-step types: 14 original work + 2 verification + 3 v1.3 adversarial/accounting"
    variants:
      # v1.0-v1.2 (unchanged)
      - input_capture       # 0  — Capture raw user input
      - goal_classify       # 1  — Classify intent type
      - task_decompose      # 2  — Break into subtasks
      - dependency_check    # 3  — Check subtask dependencies
      - schedule_plan       # 4  — Plan execution order
      - route_decision      # 5  — Choose execution backend
      - api_call            # 6  — Invoke LLM/tool
      - tvc_cross_check     # 7  — TVC corpus verification
      - vsa_bind            # 8  — VSA bind operation
      - quality_gate        # 9  — Quality threshold check
      - adapt_decision      # 10 — Adaptation decision
      - merge_result        # 11 — Merge subtask outputs
      - format_output       # 12 — Format final response
      - chain_integrity     # 13 — Full chain integrity check
      - hash_verify         # 14 — SHA256 hash verification sub-step
      - gluon_verify        # 15 — Gluon entanglement verification
      # v1.3: Adversarial + Accounting
      - fake_injection_detect  # 16 — Detect injection attacks / hallucination markers
      - oracle_cross_check     # 17 — Cross-check against oracle / known-good data
      - energy_accounting      # 18 — Track energy/compute cost of sub-step

  QuarkVerbosity:
    description: "Controls quark chat message output volume"
    variants:
      - full      # Emit every quark line (47+ lines, v1.2 default)
      - summary   # Emit one summary line per node (~18 lines)
      - silent    # No quark messages (records still stored)

  QuarkSearchQuery:
    description: "Structured filter for searching quark chain"
    fields:
      filter_type: Option<QuarkType>       # Filter by specific quark type
      filter_node: Option<ChainNode>       # Filter by parent node
      min_confidence: Float                # Minimum confidence (default 0.0)
      max_confidence: Float                # Maximum confidence (default 1.0)
      verification_only: Bool              # Return only verification quarks
      work_only: Bool                      # Return only work quarks
      min_entangle: Int                    # Minimum entanglement count

  QuarkExportHeader:
    description: "Binary header for on-chain quark chain export"
    fields:
      magic: List<Int>                     # 4 bytes: 'Q','G','C','1'
      version: Int                         # u16
      provenance_count: Int                # u8
      quark_count: Int                     # u8
      chain_verified: Bool                 # provenance chain verified flag
      quark_chain_verified: Bool           # quark chain verified flag

behaviors:
  - name: searchQuarks
    given: A QuarkSearchQuery with optional filters
    when: User or system wants to find specific quarks in the chain
    then: |
      Linear scan over quark chain. For each quark:
        1. If filter_type set and quark_type != filter_type, skip
        2. If filter_node set and parent_node != filter_node, skip
        3. If confidence < min_confidence or > max_confidence, skip
        4. If verification_only and !isVerificationQuark(), skip
        5. If work_only and isVerificationQuark(), skip
        6. If entangle_count < min_entangle, skip
        7. Otherwise, add quark index to result array
      Returns count of matching indices.

  - name: serializeQuarkChain
    given: Complete provenance + quark chain state, output buffer
    when: Exporting chain for on-chain shard storage
    then: |
      1. Compute total size: header(10) + prov(count*158) + quarks(count*131)
      2. If buffer too small, return null
      3. Write header: magic "QGC1", version 1, counts, verified flags
      4. For each provenance record: write fixed-size 158-byte block
         (step_index:1 + node:1 + digest:64 + digest_len:1 + conf:4 + tvc:4 +
          verdict:1 + timestamp:8 + latency:8 + source:1 + prev_hash:32 + current_hash:32)
      5. For each quark record: write fixed-size 131-byte block
         (quark_index:1 + type:1 + node:1 + digest:48 + digest_len:1 + conf:4 +
          timestamp:8 + prev_hash:32 + current_hash:32 + ent_indices:2 + ent_count:1)
      Returns slice of written bytes.

  - name: deserializeQuarkChain
    given: Binary buffer from serializeQuarkChain
    when: Restoring chain from on-chain shard storage
    then: |
      1. Validate magic == "QGC1", version == 1
      2. Read counts from header
      3. Validate buffer size matches expected
      4. Restore provenance records from fixed-size blocks
      5. Restore quark records from fixed-size blocks
      6. Restore verified flags
      Returns bool (true if valid and restored).

  - name: phiHashCheck
    given: Complete quark chain
    when: Phase C verification after Phase A (linear) and Phase B (DAG)
    then: |
      1. XOR all quark current_hashes together -> combined_hash[32]
      2. Count byte distribution across mod-3 residue classes:
         class_0 = count of bytes where byte % 3 == 0
         class_1 = count of bytes where byte % 3 == 1
         class_2 = count of bytes where byte % 3 == 2
      3. Count how many classes have at least 1 byte: classes_present
      4. Pass if classes_present >= 2 (trinity balance: phi^2 + 1/phi^2 = 3)
      SHA256 hashes are well-distributed, so valid chains always pass.

  - name: crossChainVerify
    given: Complete provenance chain + quark chain
    when: Phase D verification after Phase C
    then: |
      1. Track node order: for each quark, record parent_node
      2. Verify node ordering is non-decreasing (nodes appear in pipeline order)
      3. Verify every provenance node has at least one quark with matching parent_node
      Returns bool.

  - name: emitNodeQuarkSummary
    given: Node label, quark chain, verbosity == summary
    when: After emitting quarks for a node
    then: |
      Scan quarks for given node. Compute:
        count: number of quarks for this node
        avg_conf: average confidence
        total_ent: sum of entangle_count
      Emit one QuarkStep message:
        "[QUARKS] NODE: N quarks | avg:X% | ent:Y | OK"

test_cases:
  - name: quark_type_19_variants
    given: "All 19 QuarkType values"
    expected: "All accessible and distinct"

  - name: new_quark_type_labels_unique
    given: "3 new QuarkType labels (FAKE_DET, ORACLE_CHK, ENERGY_ACC)"
    expected: "Unique across all 19"

  - name: is_adversarial_quark_classification
    given: "fake_injection_detect and oracle_cross_check"
    expected: "isAdversarialQuark() returns true; all others return false"

  - name: is_accounting_quark_classification
    given: "energy_accounting"
    expected: "isAccountingQuark() returns true; all others return false"

  - name: search_quarks_by_type
    given: "3 quarks (vsa_bind, api_call, vsa_bind), filter_type=vsa_bind"
    expected: "Returns 2 matching indices"

  - name: search_quarks_by_node
    given: "Quarks from multiple nodes, filter_node=Execute"
    expected: "Returns only quarks with parent_node==Execute"

  - name: search_quarks_by_confidence
    given: "Quarks with varied confidence, min=0.7 max=0.9"
    expected: "Returns only quarks within confidence range"

  - name: search_quarks_verification_only
    given: "Mix of work and verification quarks, verification_only=true"
    expected: "Returns only hash_verify and gluon_verify quarks"

  - name: serialize_roundtrip
    given: "1 provenance record + 1 quark record"
    expected: "Serialize then deserialize restores all fields"

  - name: serialize_magic_version
    given: "Serialized buffer"
    expected: "First 4 bytes == 'QGC1', next 2 bytes == version 1; invalid magic fails"

  - name: quark_verbosity_modes
    given: "QuarkVerbosity enum"
    expected: "3 distinct values: full, summary, silent"

  - name: phi_hash_check_valid
    given: "Realistic SHA256-like quark hashes"
    expected: "phiHashCheck returns true (at least 2 of 3 mod-3 classes present)"
