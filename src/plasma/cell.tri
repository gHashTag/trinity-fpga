[cell]
id = "trinity.plasma"
name = "plasma"
version = "0.1.0"
kind = "library"
path = "src/plasma"
min_core_version = "1.0.0"
status = "experimental"
description = "Plasma physics formulas and validation (Debye, Larmor, Saha)"
capabilities = ["plasmaFrequency", "debyeLength", "larmorRadius", "sahaEquation", "eVToKelvin"]
files = 1
tests = 0
owner = "agent:ralph"

[tags]
scope = "physics"
type = "library"

[contributes]
commands = ["main"]
tri_subcommands = []
events = []

[dependencies]

[permissions]
level = "L0"
filesystem = "read"
network = "none"
process = "none"
ffi = "none"
concurrency = "none"
