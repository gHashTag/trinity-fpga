[cell]
id = "trinity.arena"
name = "Arena 2.0"
version = "1.0.0"
kind = "tool"
path = "src/arena"
min_core_version = "1.0.0"
status = "stable"
description = "LLM battle platform with ELO ratings and scientific metrics"
capabilities = ["arena", "elo", "battle", "leaderboard"]
files = 7
tests = 30
owner = "agent:ralph"
spec_version = 2
api_version = "1.0.0"

[tags]
scope = "hslm"
type = "tool"

[contributes]
commands = ["battle", "leaderboard", "judge"]
tri_subcommands = ["arena battle", "arena leaderboard"]
events = ["on_battle_complete", "on_elo_update"]
binaries = ["arena"]
exports = ["expectedScore", "updateRatings", "formatElo", "findTask", "tasksByCategory"]

[dependencies]

[permissions]
level = "L2"
filesystem = "write"
network = "external"
process = "spawn"

ffi = "none"
concurrency = "none"
[security]
signed = true
signature = "sha256:1773254f10f298d3f436cce0bc21f29b6ed94c56d62e54ea20744d93b8d2a6cf"
