description = "Auto-generated cell for vm"
capabilities = ["init", "deinit", "executeSacred", "benchmarkSacredOpcode", "init"]
files = 2
tests = 9
owner = "agent:ralph"

[tags]
scope = "vsa"
type = "library"

[contributes]
commands = ["init", "deinit", "executeSacred"]
exports = ["execute", "compile"]
