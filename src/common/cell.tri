[cell]
id = "trinity.infra"
name = "Infrastructure"
version = "0.1.0"
kind = "library"
path = "src/common"
min_core_version = "1.0.0"
status = "experimental"
description = "Infrastructure: shared utilities, economy, orchestration, OS interfaces, WASM stubs, LLM routing, MCP protocol, neural models, IGLA simulator"
capabilities = ["isRecoverable", "getDescription", "from", "value", "isZero", "amountTri", "selectStrategy", "bootKernel", "loadFromEnv", "needsRestart", "inference", "benchmark"]
files = 5
tests = 42
owner = "agent:ralph"

[tags]
scope = "infra"
type = "library"

[contributes]
commands = ["isRecoverable", "getDescription", "from"]
tri_subcommands = []
events = []

[dependencies]
trinity.sacred = "^1.0.0"
trinity.quantum = "^1.0.0"

[permissions]
level = "L0"
filesystem = "read"
network = "none"
process = "none"
ffi = "none"
concurrency = "none"

[security]
signed = "true"
signature = "sha256:fae26a17abdcd22d1099effc18679a7623cdcce023a48691b1bf5e6c11c51fe2"
