# Agent Cell Template
# Variables: {{CELL_ID}}, {{NAME}}, {{PATH}}, {{DEFINITION}}

[cell]
id = "{{CELL_ID}}"
name = "{{NAME}} Agent"
version = "0.1.0"
kind = "agent"
path = "{{PATH}}"
status = "experimental"
description = "Autonomous agent for specialized tasks"
capabilities = ["autonomous", "tools", "context"]
owner = "agent:ralph"

[tags]
scope = "agent"
type = "agent"

[agent]
definition = "{{DEFINITION}}"
model = "sonnet"
max_turns = 20
tools = "Read,Edit,Write,Bash,Grep,Glob"
isolation = ""

[permissions]
level = "L2"
filesystem = "write"
network = "external"
process = "spawn"
ffi = "native"
concurrency = "yes"

[biology]
system = "organism"
organ = "agent"

[security]
signed = false
