fn cmdSingularity(args: []const []const u8) !void {
    _ = args;

    tri_colors.printGold("\n╔══════════════════════════════════════════════════════════════╗\n", .{});
    tri_colors.printGold("║  SINGULARITY PHYSICS — Formulas 197-202                        ║\n", .{});
    tri_colors.printGold("╚══════════════════════════════════════════════════════════════╝\n\n", .{});

    const GAMMA = 0.23606797749978969641; // φ⁻³
    const RHO_PLANCK = 5.1e96;
    const T_PLANCK = 1.4e32;
    const L_PLANCK = 1.6e-35;
    const H_PLANCK = 6.6e43;
    const C = 299792458.0;

    // Formula 197: Max density
    const rho_max = std.math.pow(f64, 1.0 / GAMMA, 3) * RHO_PLANCK;
    tri_colors.printCyan("[197] MAX DENSITY (finite, not infinite):\n", .{});
    tri_colors.printWhite("      ρ_max = γ⁻³ × ρ_P\n", .{});
    tri_colors.printWhite("      ρ_max = {e:.3} kg/m³\n", .{rho_max});
    tri_colors.printWhite("      (γ⁻³ = {d:.3})\n\n", .{std.math.pow(f64, 1.0 / GAMMA, 3)});

    // Formula 198: Min curvature
    const R_min = (1.0 / GAMMA) * 1.0e70;
    tri_colors.printCyan("[198] MIN CURVATURE:\n", .{});
    tri_colors.printWhite("      R_min = γ⁻¹ × R_P\n", .{});
    tri_colors.printWhite("      R_min = {e:.3} m⁻²\n\n", .{R_min});

    // Formula 199: Bounce radius
    const a_bounce = GAMMA * L_PLANCK;
    tri_colors.printCyan("[199] BOUNCE RADIUS:\n", .{});
    tri_colors.printWhite("      a_bounce = γ × l_P\n", .{});
    tri_colors.printWhite("      a_bounce = {e:.4} m\n", .{a_bounce});
    tri_colors.printWhite("      ({d:.1}% of Planck length)\n\n", .{GAMMA * 100.0});

    // Formula 200: Quantum pressure
    const rho_test = 1.0e20;
    const P_Q = std.math.pow(f64, 1.0 / GAMMA, 2) * rho_test * C * C;
    tri_colors.printCyan("[200] QUANTUM PRESSURE (at ρ = {e:.1} kg/m³):\n", .{rho_test});
    tri_colors.printWhite("      P_Q = γ⁻² × ρc²\n", .{});
    tri_colors.printWhite("      P_Q = {e:.3} Pa\n\n", .{P_Q});

    // Formula 201: Temperature floor
    const T_min = GAMMA * T_PLANCK;
    tri_colors.printCyan("[201] TEMPERATURE FLOOR:\n", .{});
    tri_colors.printWhite("      T_min = γ × T_P\n", .{});
    tri_colors.printWhite("      T_min = {e:.4} K\n\n", .{T_min});

    // Formula 202: Hubble at bounce
    const H_bounce = GAMMA * H_PLANCK;
    tri_colors.printCyan("[202] HUBBLE AT BOUNCE:\n", .{});
    tri_colors.printWhite("      H_bounce = γ × H_P\n", .{});
    tri_colors.printWhite("      H_bounce = {e:.4} s⁻¹\n\n", .{H_bounce});

    tri_colors.printGold("══════════════════════════════════════════════════════════════\n", .{});
    tri_colors.printWhite("CONCLUSION: No singularity exists. ρ_max is {d:.1}× ρ_P,\n", .{std.math.pow(f64, 1.0 / GAMMA, 3)});
    tri_colors.printWhite("but still finite. The Big Bang was a γ-bounce.\n", .{});
    tri_colors.printGold("══════════════════════════════════════════════════════════════\n\n", .{});
}

fn cmdBounce(args: []const []const u8) !void {
    _ = args;

    tri_colors.printGold("\n╔══════════════════════════════════════════════════════════════╗\n", .{});
    tri_colors.printGold("║  BOUNCE DYNAMICS — Formulas 203-209                             ║\n", .{});
    tri_colors.printGold("╚══════════════════════════════════════════════════════════════╝\n\n", .{});

    const GAMMA = 0.23606797749978969641;
    const T_PLANCK = 5.39e-44;
    const H0 = 70.0;
    const E_PLANCK = 1.96e9; // GeV
    const L_PLANCK = 1.6e-35;

    // Formula 203: Bounce time
    const t_bounce = GAMMA * GAMMA * T_PLANCK;
    tri_colors.printCyan("[203] BOUNCE TIME:\n", .{});
    tri_colors.printWhite("      t_bounce = γ² × t_P\n", .{});
    tri_colors.printWhite("      t_bounce = {e:.5} s\n\n", .{t_bounce});

    // Formula 204-205: Contraction/Expansion
    const H_contract = -(1.0 / GAMMA) * H0;
    const H_expand = (1.0 / GAMMA) * H0;
    tri_colors.printCyan("[204-205] CONTRACTION/EXPANSION:\n", .{});
    tri_colors.printWhite("      H_contract = -γ⁻¹ × H = {d:.1} km/s/Mpc\n", .{H_contract});
    tri_colors.printWhite("      H_expand   = +γ⁻¹ × H = {d:.1} km/s/Mpc\n\n", .{H_expand});

    // Formula 206: Scale factor
    tri_colors.printCyan("[206] SCALE FACTOR SYMMETRIC BOUNCE:\n", .{});
    tri_colors.printWhite("      a(t) = a_bounce × sech(γ × t/t_P)\n", .{});
    tri_colors.printWhite("      At t = 0:  a = {e:.4} m (minimum)\n\n", .{GAMMA * L_PLANCK});

    // Formula 207: Bounce energy
    const E_bounce = std.math.pow(f64, GAMMA, 4) * E_PLANCK;
    tri_colors.printCyan("[207] BOUNCE ENERGY:\n", .{});
    tri_colors.printWhite("      E_bounce = γ⁴ × E_P\n", .{});
    tri_colors.printWhite("      E_bounce = {e:.4} GeV\n\n", .{E_bounce});

    // Formula 208: Penrose parameter
    const k = GAMMA * GAMMA;
    tri_colors.printCyan("[208] PENROSE PARAMETER (CCC):\n", .{});
    tri_colors.printWhite("      k = γ² = {d:.4}\n\n", .{k});

    // Formula 209: No singularity theorem
    tri_colors.printCyan("[209] NO SINGULARITY THEOREM:\n", .{});
    tri_colors.printGreen("      ∀γ>0: ρ<∞ ✓ PROVEN\n\n", .{});

    tri_colors.printGold("══════════════════════════════════════════════════════════════\n", .{});
    tri_colors.printWhite("The bounce is symmetric: contraction → expansion via γ-bounce.\n", .{});
    tri_colors.printGold("══════════════════════════════════════════════════════════════\n\n", .{});
}

