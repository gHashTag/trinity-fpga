    tri_colors.printGold("\n╔══════════════════════════════════════════════════════════════╗\n", .{});
    tri_colors.printGold("║  EQUATION OF STATE EVOLUTION — Formulas 243-248              ║\n", .{});
    tri_colors.printGold("╚══════════════════════════════════════════════════════════════╝\n\n", .{});

    // Formula 243: Present w₀
    const w0_val = -1.0 + GAMMA;
    tri_colors.printCyan("[243] PRESENT EQUATION OF STATE:\n", .{});
    tri_colors.printWhite("      w₀ = -1 + γ = {d:.4}\n", .{w0_val});
    tri_colors.printWhite("      (Quintessence-like, NOT constant Λ = -1)\n\n", .{});

    // Formula 244: Evolution parameter
    const wa_val = GAMMA_SQ;
    tri_colors.printCyan("[244] EVOLUTION PARAMETER:\n", .{});
    tri_colors.printWhite("      w_a = γ² = {d:.4}\n", .{wa_val});
    tri_colors.printWhite("      (Slow evolution rate)\n\n", .{});

    // Formula 245: w(z) parameterization with table
    tri_colors.printCyan("[245] w(z) PARAMETERIZATION (CPL):\n", .{});
    tri_colors.printWhite("      w(z) = w₀ + w_a × (1 - a) = w₀ + w_a × z/(1+z)\n\n", .{});
    tri_colors.printWhite("  Redshift (z)    | w(z) value\n", .{});
    tri_colors.printWhite("  ----------------+----------------------\n", .{});
    const z_values = [_]f64{ 0.0, 0.2, 0.5, 1.0, 2.0, 3.0 };
    for (z_values) |z| {
        const a = 1.0 / (1.0 + z);
        const w_z = w0_val + wa_val * (1.0 - a);
        tri_colors.printWhite("  z = {d:4.1}        | w = {d:.5}\n", .{ z, w_z });
    }
    tri_colors.printWhite("\n", .{});

    // Formula 246: Scale factor
    tri_colors.printCyan("[246] SCALE FACTOR:\n", .{});
    tri_colors.printWhite("      a = 1/(1+z)\n", .{});
    tri_colors.printWhite("      a(z=0) = 1.0 (today)\n", .{});
    tri_colors.printWhite("      a(z=1) = 0.5 (half current size)\n\n", .{});

    // Formula 247: Phantom crossing
    const z_crossing = PHI_INV_SQ;
    tri_colors.printCyan("[247] PHANTOM CROSSING REDSHIFT:\n", .{});
    tri_colors.printWhite("      z_c = φ⁻² = {d:.4}\n", .{z_crossing});
    tri_colors.printWhite("      (Where w = -1 exactly; boundary of phantom divide)\n\n", .{});

    // Formula 248: Critical density
    tri_colors.printCyan("[248] CRITICAL DENSITY EVOLUTION:\n", .{});
    tri_colors.printWhite("      ρ_Λ(z) = ρ_Λ₀ × a^{{-3(1+w)}}\n", .{});
    tri_colors.printWhite("      Since w > -1, ρ_Λ INCREASES with redshift\n\n", .{});

    tri_colors.printGold("══════════════════════════════════════════════════════════════\n", .{});
    tri_colors.printWhite("KEY INSIGHT: DESI DR2/DR3 shows w ≠ -1 at 3.5-4.2σ\n", .{});
    tri_colors.printCyan("  w₀ = -0.764 explains the tension with ΛCDM\n", .{});
