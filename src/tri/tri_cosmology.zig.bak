    tri_colors.printWhite("      This sets the fundamental time scale over which\n", .{});
    tri_colors.printWhite("      consciousness integrates sensory information.\n\n", .{});

    // Formula 257: Gamma frequency shift
    tri_colors.printCyan("[257] GAMMA FREQUENCY SHIFT:\n", .{});
    tri_colors.printWhite("      Δf/f = γ × (1 + z)\n\n", .{});
