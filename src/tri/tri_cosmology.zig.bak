    tri_colors.printWhite("      f_γ(z) = f_γ₀ / (1 + γ × z)\n\n", .{});
    tri_colors.printWhite("      f_γ(z=0) = {d:.1} Hz (today)\n", .{fg0});
    const fg_z1 = fg0 / (1.0 + GAMMA * 1.0);
