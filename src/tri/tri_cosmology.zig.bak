        tri_colors.printWhite("  z = {d:4.1}        | Λ/Λ₀ = {d:.5}\n", .{ z, lambda_ratio });
    }
    tri_colors.printWhite("\n", .{});

    // Formula 250: Λ(z) exact
    tri_colors.printCyan("[250] Λ(z) EXACT (EXPONENTIAL):\n", .{});
    tri_colors.printWhite("      Λ(z) = Λ₀ × exp(γ × z)\n", .{});
    tri_colors.printWhite("      Exact solution from field equations\n\n", .{});
    tri_colors.printWhite("  Redshift (z)    | Λ(z)/Λ₀ (exact)\n", .{});
    tri_colors.printWhite("  ----------------+----------------------\n", .{});
    for (z_values) |z| {
        const lambda_ratio = std.math.exp(GAMMA * z);
        tri_colors.printWhite("  z = {d:4.1}        | Λ/Λ₀ = {d:.5}\n", .{ z, lambda_ratio });
    }
    tri_colors.printWhite("\n", .{});

    // Formula 251: Ω_Λ(z)
    tri_colors.printCyan("[251] Ω_Λ(z) EVOLUTION:\n", .{});
    tri_colors.printWhite("      Ω_Λ(z) = Ω_Λ₀ × (1 + γ × z) / E(z)²\n", .{});
    tri_colors.printWhite("      where E(z) = H(z)/H₀\n\n", .{});
    const omega_z0 = OMEGA_LAMBDA_0;
    const omega_z1 = OMEGA_LAMBDA_0 * (1.0 + GAMMA * 1.0) / std.math.pow(f64, 1.0 + GAMMA * 1.0, 2.0);
    const omega_z2 = OMEGA_LAMBDA_0 * (1.0 + GAMMA * 2.0) / std.math.pow(f64, 1.0 + GAMMA * 2.0, 2.0);
    tri_colors.printWhite("      Ω_Λ(z=0) = {d:.3}\n", .{omega_z0});
    tri_colors.printWhite("      Ω_Λ(z=1) = {d:.3}\n", .{omega_z1});
    tri_colors.printWhite("      Ω_Λ(z=2) = {d:.3}\n", .{omega_z2});
    tri_colors.printWhite("\n", .{});

    // Formula 252: Transition redshift
    const z_transition = PHI_INV;
    tri_colors.printCyan("[252] TRANSITION REDSHIFT:\n", .{});
    tri_colors.printWhite("      z_t = φ⁻¹ = {d:.4}\n", .{z_transition});
    tri_colors.printWhite("      (Matter → Dark Energy equality)\n\n", .{});

    // Formula 253: Phantom divide
    tri_colors.printCyan("[253] PHANTOM DIVIDE:\n", .{});
    tri_colors.printWhite("      w = -1 is the boundary\n", .{});
    tri_colors.printWhite("      In TRINITY: w approaches -1+γ but NEVER crosses\n", .{});
    tri_colors.printWhite("      w_min = {d:.4} > -1 ✓ (no phantom)\n\n", .{-1.0 + GAMMA});

    // Formula 254: Future asymptote
    const w_inf = -1.0 + GAMMA + GAMMA * GAMMA;
    tri_colors.printCyan("[254] FUTURE ASYMPTOTE:\n", .{});
    tri_colors.printWhite("      w_∞ = w₀ + w_a = {d:.4}\n", .{w_inf});
    tri_colors.printWhite("      (As z → -1, far future)\n\n", .{});

    tri_colors.printGold("══════════════════════════════════════════════════════════════\n", .{});
    tri_colors.printWhite("Λ EVOLVES — Dark energy is NOT constant!\n", .{});
    tri_colors.printCyan("  At z=1: Λ was {d:.1}% of today's value\n", .{(1.0 + GAMMA * 1.0) * 100.0});
    tri_colors.printGold("══════════════════════════════════════════════════════════════\n\n", .{});
