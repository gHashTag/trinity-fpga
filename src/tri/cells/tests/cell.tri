[cell]
id = "trinity.tri.tests"
name = "E2E Tests"
version = "1.0.0"
kind = "virtual-sub"
path = "src/tri"
parent = "trinity.tri"
status = "stable"
description = "End-to-end test suites: jobs, registry, negative, toxic"
capabilities = ["testing", "e2e"]
tests = 54
owner = "agent:ralph"

[tags]
scope = "core"
type = "infra"

[source]
file_patterns = ["e2e_*.zig", "tri_test.zig", "tri_integration_test.zig", "multi_cluster_test.zig"]

[contributes]
commands = ["test"]
exports = []

[dependencies]

[permissions]
level = "L1"
filesystem = "write"
network = "none"
process = "spawn"

[security]
signed = true
signature = "sha256:a8765290c6681b7df39f2f888d9a49261a7fc27d43894011c7afa123658d0ffd"
