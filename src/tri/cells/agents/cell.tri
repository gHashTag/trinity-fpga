[cell]
id = "trinity.tri.agents"
name = "Agent Orchestration"
version = "1.0.0"
kind = "virtual-sub"
path = "src/tri"
parent = "trinity.tri"
status = "stable"
description = "Agent swarm: spawning, orchestration, loop decisions, chimera commands, hub"
capabilities = ["swarm", "orchestration", "agents"]
tests = 30
owner = "agent:ralph"

[tags]
scope = "infra"
type = "agent"

[source]
file_patterns = ["tri_swarm.zig", "tri_agent_run.zig", "mu_agent.zig", "tri_loop.zig", "tri_chimera.zig", "orchestrator*.zig", "ralph_*.zig", "tri_hub.zig"]

[contributes]
commands = ["swarm", "agent run", "loop", "chimera"]
exports = ["registerCommand", "getCommand", "calculateSacredScore", "printStats", "verifyTrinityIdentity"]

[dependencies]

[permissions]
level = "L2"
filesystem = "write"
network = "none"
process = "spawn"

ffi = "none"
concurrency = "yes"
[security]
signed = true
signature = "sha256:72b0e4f52cc6dc61a9cc4840615b7cf235d5454e1bfb123752e41b468b8ad4c9"
