/// Raw gradient vector and clip threshold
/// When: Gradient clipping is applied
/// Then: Return clipped gradients where norm <= threshold
      const std = @import("std");
      const math = std.math;

      pub fn clipGradients(
          allocator: std.mem.Allocator,
          gradients: []const f64,
          threshold: f64,
      ) !struct {
          clipped: []f64,
          original_norm: f64,
          clipped_norm: f64,
          was_clipped: bool,
      } {
          // Compute L2 norm
          var norm_sq: f64 = 0.0;
          for (gradients) |g| {
              norm_sq += g * g;
          }
          const original_norm = @sqrt(norm_sq);

          // Check if clipping needed
          if (original_norm <= threshold) {
              // No clipping needed, return copy
              const clipped = try allocator.alloc(f64, gradients.len);
              @memcpy(clipped, gradients);

              return .{
                  .clipped = clipped,
                  .original_norm = original_norm,
                  .clipped_norm = original_norm,
                  .was_clipped = false,
              };
          }

          // Clip gradients: g_clipped = g * threshold / ||g||
          const scale = threshold / original_norm;
          const clipped = try allocator.alloc(f64, gradients.len);

          var clipped_norm_sq: f64 = 0.0;
          for (gradients, 0..) |g, i| {
              clipped[i] = g * scale;
              clipped_norm_sq += clipped[i] * clipped[i];
          }

          return .{
              .clipped = clipped,
              .original_norm = original_norm,
              .clipped_norm = @sqrt(clipped_norm_sq),
              .was_clipped = true,
          };
      }



/// Set of EWC synapses and parameter importance
/// When: Parameter consolidation runs
/// Then: Return consolidated parameters with EWC regularization applied
      const std = @import("std");

      pub fn consolidateParameters(
          allocator: std.mem.Allocator,
          current_params: []const f64,
          reference_params: []const f64,
          synapses: []const EWCSynapse,
          lambda_base: f64,
      ) !struct {
          consolidated: []f64,
          regularization_penalty: f64,
      } {
          const consolidated = try allocator.alloc(f64, current_params.len);
          @memcpy(consolidated, current_params);

          var penalty: f64 = 0.0;

          // Apply EWC regularization: L = L_task + sum(lambda_i * F_i * (theta_i - theta*_i)^2)
          for (synapses, 0..) |synapse, i| {
              if (i >= current_params.len or i >= reference_params.len) break;

              const delta = current_params[i] - reference_params[i];
              const delta_sq = delta * delta;
              const ewc_penalty = synapse.effective_lambda * delta_sq;

              penalty += ewc_penalty;
          }

          return .{
              .consolidated = consolidated,
              .regularization_penalty = penalty,
          };
      }

      const EWCSynapse = struct {
          synapse_id: u32,
          parameter_name: []const u8,
          fisher_information: f64,
          importance: f64,
          consolidation_count: u32,
          effective_lambda: f64,
      };



