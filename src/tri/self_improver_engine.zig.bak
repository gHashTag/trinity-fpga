/// Current velocity, gradient, and momentum decay
/// When: Velocity update occurs
/// Then: Return updated velocity with momentum and decay applied
      const std = @import("std");

      pub fn updateMomentum(
          allocator: std.mem.Allocator,
          velocity: []const f64,
          gradient: []const f64,
          momentum_decay: f64,
          learning_rate: f64,
      ) ![]f64 {
          const new_velocity = try allocator.alloc(f64, velocity.len);

          // v_t = decay * v_{t-1} + lr * gradient_t
          for (velocity, gradient, 0..) |v, g, i| {
              new_velocity[i] = momentum_decay * v + learning_rate * g;
          }

          return new_velocity;
      }



