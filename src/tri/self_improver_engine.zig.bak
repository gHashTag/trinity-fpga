/// Current parameters and gradients
/// When: Optimization step executes
/// Then: Return updated GradientState with momentum
      const std = @import("std");
      const math = std.math;

      pub fn gradientDescentStep(
          allocator: std.mem.Allocator,
          parameter_value: f64,
          gradient: f64,
          learning_rate: f64,
          momentum: f64,
          step_count: u32,
      ) !GradientState {
          // Apply momentum: v_t = momentum * v_{t-1} + learning_rate * gradient
          const momentum_value = momentum * 0.0 + learning_rate * gradient;

          // Update parameter: theta_t = theta_{t-1} - v_t
          const updated_value = parameter_value - momentum_value;

          return GradientState{
              .parameter_name = "param",
              .current_value = updated_value,
              .gradient = gradient,
              .momentum_value = momentum_value,
              .step_count = step_count + 1,
          };
      }

      const GradientState = struct {
          parameter_name: []const u8,
          current_value: f64,
          gradient: f64,
          momentum_value: f64,
          step_count: u32,
      };



/// Full optimization history
/// When: User requests trajectory
/// Then: Return OptimizationTrajectory with best score info
      const std = @import("std");

      pub fn analyzeTrajectory(
          allocator: std.mem.Allocator,
          scores: []const f64,
          trajectory_id: u32,
      ) !OptimizationTrajectory {
          var best_score: f64 = scores[0];
          var best_iteration: usize = 0;

          // Find best score and its iteration
          for (scores, 0..) |score, i| {
              if (score > best_score) {
                  best_score = score;
                  best_iteration = i;
              }
          }

          // Clone scores for output
          const scores_copy = try allocator.alloc(f64, scores.len);
          @memcpy(scores_copy, scores);

          return OptimizationTrajectory{
              .trajectory_id = trajectory_id,
              .scores = scores_copy,
              .best_score = best_score,
              .best_iteration = @intCast(best_iteration),
              .total_time_ms = 0, // Track externally
          };
      }

      const OptimizationTrajectory = struct {
          trajectory_id: u32,
          scores: []f64,
          best_score: f64,
          best_iteration: u32,
          total_time_ms: u32,
      };



/// GradientDescentState with current m_t and v_t estimates
/// When: Adam optimizer executes one step
/// Then: Return updated GradientDescentState with biased-corrected m_t and v_t, applying beta1 and beta2
      const std = @import("std");
      const math = std.math;

      const ADAM_BETA_1: f64 = 0.9;
      const ADAM_BETA_2: f64 = 0.999;
      const ADAM_EPSILON: f64 = 1e-8;

      pub fn adamOptimizationStep(
          allocator: std.mem.Allocator,
          state: *GradientDescentState,
      ) !GradientDescentState {
          const t: f64 = @floatFromInt(state.iteration + 1);
          const beta1_correction = 1.0 - std.math.pow(ADAM_BETA_1, t);
          const beta2_correction = 1.0 - std.math.pow(ADAM_BETA_2, t);

          // Allocate new arrays for updated state
          const new_m_t = try allocator.alloc(f64, state.m_t.len);
          const new_v_t = try allocator.alloc(f64, state.v_t.len);
          const new_params = try allocator.alloc(f64, state.parameter_values.len);

          // Update m_t and v_t for each parameter
          for (state.gradients, state.m_t, state.v_t, 0..) |g, m_prev, v_prev, i| {
              // m_t = beta1 * m_{t-1} + (1 - beta1) * g
              new_m_t[i] = ADAM_BETA_1 * m_prev + (1.0 - ADAM_BETA_1) * g;

              // v_t = beta2 * v_{t-1} + (1 - beta2) * g^2
              new_v_t[i] = ADAM_BETA_2 * v_prev + (1.0 - ADAM_BETA_2) * g * g;

              // Bias-corrected estimates
              const m_hat = new_m_t[i] / beta1_correction;
              const v_hat = new_v_t[i] / beta2_correction;

              // Parameter update: theta = theta - lr * m_hat / (sqrt(v_hat) + epsilon)
              const sqrt_v_hat = @sqrt(v_hat);
              const update = state.learning_rate * m_hat / (sqrt_v_hat + ADAM_EPSILON);
              new_params[i] = state.parameter_values[i] - update;
          }

          return GradientDescentState{
              .iteration = state.iteration + 1,
              .learning_rate = state.learning_rate,
              .momentum = state.momentum,
              .gradients = state.gradients,
              .parameter_values = new_params,
              .velocity = state.velocity,
              .m_t = new_m_t,
              .v_t = new_v_t,
          };
      }

      const GradientDescentState = struct {
          iteration: u32,
          learning_rate: f64,
          momentum: f64,
          gradients: []const f64,
          parameter_values: []f64,
          velocity: []const f64,
          m_t: []const f64,
          v_t: []const f64,
      };



/// Fisher information matrix and parameter importance
/// When: EWC++ synapse consolidation runs
/// Then: Return EWCSynapse with effective lambda and consolidation count
      const std = @import("std");
      const EWC_LAMBDA: f64 = 100.0;

      pub fn computeEWCSynapse(
          synapse_id: u32,
          parameter_name: []const u8,
          fisher_information: f64,
          importance: f64,
          consolidation_count: u32,
      ) EWCSynapse {
          // Effective lambda scales with Fisher information and importance
          // lambda_eff = lambda * F * importance / (1 + consolidation_count)
          const effective_lambda = EWC_LAMBDA * fisher_information * importance /
              @as(f64, @floatFromInt(consolidation_count + 1));

          return EWCSynapse{
              .synapse_id = synapse_id,
              .parameter_name = parameter_name,
              .fisher_information = fisher_information,
              .importance = importance,
              .consolidation_count = consolidation_count,
              .effective_lambda = effective_lambda,
          };
      }

      const EWCSynapse = struct {
          synapse_id: u32,
          parameter_name: []const u8,
          fisher_information: f64,
          importance: f64,
          consolidation_count: u32,
          effective_lambda: f64,
      };



