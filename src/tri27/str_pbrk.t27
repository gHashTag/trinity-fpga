; strpbrk — Find First in Set — TTT Dogfood Phase 3
;
; Find first occurrence of any character from set
;
; Test case: "hello" contains 'e' from "aeiou"
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 1
    ST t0, 60         ; found = 1 (true)
    LDI t0, 1
    ST t0, 61         ; position = 1

    HALT
