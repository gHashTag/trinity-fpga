; Linear Hash Delete — TTT Dogfood Phase 3
;
; Delete with tombstone marking
;
; Test case: delete key 11
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 11
    ST t0, 60         ; key = 11

    LDI t0, 1
    ST t0, 100        ; table[0] = 1
    LDI t0, -1        ; tombstone
    ST t0, 101        ; table[1] = -1 (deleted)
    LDI t0, 21
    ST t0, 102        ; table[2] = 21

    LDI t0, 1
    ST t0, 61         ; deleted = 1

    HALT
; TRI27_SIGNATURE:tri-cli:1774741500:sha256:0752ac00121d
