; LZW Decode — TTT Dogfood Phase 3
;
; LZW decompression
;
; Test case: decode codes [256, 257]
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 256
    ST t0, 100        ; code[0] = 256 (AB)
    LDI t0, 257
    ST t0, 101        ; code[1] = 257 (ABA)

    LDI t0, 65        ; A
    ST t0, 110        ; out[0] = A
    LDI t0, 66        ; B
    ST t0, 111        ; out[1] = B
    LDI t0, 65        ; A
    ST t0, 112        ; out[2] = A

    HALT
