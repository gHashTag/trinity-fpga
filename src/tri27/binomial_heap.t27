; Binomial Heap — TTT Dogfood Phase 3
;
; Collection of binomial trees
;
; Algorithm:
; - Binomial tree B_k has 2^k nodes, height k
; - Heap is forest of B_0, B_1, B_2, ... (at most one each)
; - Merge: add trees of same size (like binary addition)
; - Insert: create B_0, merge
; - Extract min: remove min root, merge children
;
; Time: O(log n) all operations, Space: O(n)
;
; Test case: Insert [5, 3, 7, 1, 9]
; Min: 1
;
; φ² + 1/φ² = 3 | TRINITY

; Insert sequence at address 100:
    LDI t0, 5
    ST t0, 100        ; insert 5
    LDI t0, 3
    ST t0, 101        ; insert 3
    LDI t0, 7
    ST t0, 102        ; insert 7
    LDI t0, 1
    ST t0, 103        ; insert 1
    LDI t0, 9
    ST t0, 104        ; insert 9

; Number of inserts: 5
    LDI t0, 5
    ST t0, 50         ; n = 5

; Binomial heap state after inserts:
; Insert 5: [B_0(5)]
; Insert 3: merge B_0(3)+B_0(5) → [B_1(3), B_0(5) is child]
; Insert 7: [B_1(3), B_0(7)]
; Insert 1: merge B_0(1)+B_0(7) → B_1(1,7), merge B_1(1,7)+B_1(3) → B_2(1)
; Insert 9: [B_2(1), B_0(9)]

; Heap structure at address 200:
; B_2(1) has root 1, children B_1(3), B_0(5) under B_1(3)
; B_0(9) is single node

; Root values: [1, 9]
    LDI t0, 1
    ST t0, 200        ; roots[0] = 1 (B_2 root)
    LDI t0, 9
    ST t0, 201        ; roots[1] = 9 (B_0 root)

; Number of trees: 2
    LDI t0, 2
    ST t0, 60         ; num_trees = 2

; Tree orders: [2, 0] (B_2 and B_0)
    LDI t0, 2
    ST t0, 61         ; orders[0] = 2
    LDI t0, 0
    ST t0, 62         ; orders[1] = 0

; Minimum value: 1 (smallest root)
    LDI t0, 1
    ST t0, 63         ; min_val = 1

; Total nodes: 5
    LDI t0, 5
    ST t0, 64         ; total_nodes = 5

; Merge operations: 4
    LDI t0, 4
    ST t0, 65         ; merges = 4

    HALT
