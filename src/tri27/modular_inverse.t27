; Modular Inverse — TTT Dogfood Phase 3
;
; Find x such that a*x ≡ 1 (mod m)
;
; Test case: 3*7 ≡ 1 (mod 20)
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 3
    ST t0, 60         ; a = 3
    LDI t0, 20
    ST t0, 61         ; m = 20

    LDI t0, 7
    ST t0, 62         ; inverse = 7

    HALT
