; IP Header Parse — TTT Dogfood Phase 3
;
; Parse IPv4 header fields
;
; Test case: version 4, ihl 5, protocol TCP
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 4
    ST t0, 60         ; version = 4
    LDI t0, 5
    ST t0, 61         ; ihl = 5
    LDI t0, 6
    ST t0, 62         ; protocol = 6 (TCP)

    HALT
