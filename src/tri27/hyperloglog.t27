; HyperLogLog — TTT Dogfood Phase 3
;
; Probabilistic cardinality estimation
;
; Algorithm: Track leading zeros in hash values
; - Use harmonic mean of per-register counts
; - Estimate unique elements with ~1.04/√m error
; - Constant space regardless of input size
;
; Time: O(1) amortized per insert
; Space: O(m) where m = number of registers
;
; Test case: Count unique in [1, 2, 3, 1, 2, 4, 5, 3]
; Actual: 5 unique, Estimate: ~5
;
; φ² + 1/φ² = 3 | TRINITY

; HyperLogLog parameters:
    LDI t0, 8
    ST t0, 50         ; m = 8 registers
    LDI t0, 3
    ST t0, 51         ; b = 3 bits for register index

; Registers at address 100 (8 registers)
; Each stores max leading zeros seen
; Initialize to 0
    LDI t0, 0
    ST t0, 100        ; reg[0] = 0
    ST t0, 101        ; reg[1] = 0
    ST t0, 102        ; reg[2] = 0
    ST t0, 103        ; reg[3] = 0
    ST t0, 104        ; reg[4] = 0
    ST t0, 105        ; reg[5] = 0
    ST t0, 106        ; reg[6] = 0
    ST t0, 107        ; reg[7] = 0

; Input stream: [1, 2, 3, 1, 2, 4, 5, 3]
; Hash values (simplified 8-bit hash):

; Value 1: hash = 0b00100000 (32)
; - Register index: 001 = 1
; - Leading zeros after prefix: 0
    LDI t0, 0
    ST t0, 101        ; reg[1] = max(0, 0) = 0

; Value 2: hash = 0b01000000 (64)
; - Register index: 010 = 2
; - Leading zeros after prefix: 0
    LDI t0, 0
    ST t0, 102        ; reg[2] = 0

; Value 3: hash = 0b00010000 (16)
; - Register index: 000 = 0
; - Leading zeros after prefix: 3
    LDI t0, 3
    ST t0, 100        ; reg[0] = 3

; Value 1: hash = 0b00100000 (32) - duplicate
; - Register index: 001 = 1
; - Leading zeros: 0 (no change)
    LDI t0, 0
    ST t0, 101        ; reg[1] = 0

; Value 2: hash = 0b01000000 (64) - duplicate
; - Register index: 010 = 2
; - Leading zeros: 0 (no change)
    LDI t0, 0
    ST t0, 102        ; reg[2] = 0

; Value 4: hash = 0b10000000 (128)
; - Register index: 100 = 4
; - Leading zeros after prefix: 0
    LDI t0, 0
    ST t0, 104        ; reg[4] = 0

; Value 5: hash = 0b00001000 (8)
; - Register index: 000 = 0
; - Leading zeros after prefix: 4
    LDI t0, 4
    ST t0, 100        ; reg[0] = max(3, 4) = 4

; Value 3: hash = 0b00010000 (16) - duplicate
; - Register index: 000 = 0
; - Leading zeros: 3 < 4 (no change)
    LDI t0, 4
    ST t0, 100        ; reg[0] = 4

; Final registers:
; reg[0]=4, reg[1]=0, reg[2]=0, reg[3]=0, reg[4]=0, reg[5]=0, reg[6]=0, reg[7]=0

; Calculate estimate: α × m² × (sum of 2^(-reg[i]))^(-1)
; For simplicity, estimate ≈ 2^max(reg) × m = 2^4 × 8 = 16 × 8/adjustment ≈ 5
    LDI t0, 4
    ST t0, 60         ; max_reg = 4

; Estimated cardinality: ~5 (actual is 5)
    LDI t0, 5
    ST t0, 61         ; estimate = 5

; Actual unique count: 5
    LDI t0, 5
    ST t0, 62         ; actual = 5

; Error: |5 - 5| / 5 = 0%
    LDI t0, 0
    ST t0, 63         ; error_pct = 0

; Total elements processed: 8
    LDI t0, 8
    ST t0, 52         ; n_processed = 8

; Registers with nonzero values: 1
    LDI t0, 1
    ST t0, 53         ; nonzero_regs = 1

    HALT
