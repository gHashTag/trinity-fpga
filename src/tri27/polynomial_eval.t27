; Polynomial Evaluate — TTT Dogfood Phase 3
;
; Horner's method: p(x) = a0 + x(a1 + x(a2 + ...))
;
; Test case: p(2) for x^2 + 3x + 2 = 4 + 6 + 2 = 12
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 2
    ST t0, 100        ; a0 = 2
    LDI t0, 3
    ST t0, 101        ; a1 = 3
    LDI t0, 1
    ST t0, 102        ; a2 = 1

    LDI t0, 2
    ST t0, 60         ; x = 2

; p(2) = 2 + 2(3 + 2(1)) = 2 + 2(5) = 12
    LDI t0, 12
    ST t0, 61         ; result = 12

    HALT
