; Complex Argument — TTT Dogfood Phase 3
;
; arg(a+bi) = atan2(b, a)
;
; Test case: arg(1+1i) = π/4 = 45°
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 1
