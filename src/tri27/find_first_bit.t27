; Find First Set — TTT Dogfood Phase 3
;
; Find index of first set bit (ffs)
;
; Test case: ffs(0b00101000) = 4
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 40
    ST t0, 60         ; value = 0b00101000
    LDI t0, 4
    ST t0, 61         ; ffs = 4

    HALT
; TRI27_SIGNATURE:tri-cli:1774741500:sha256:0712eb022562
