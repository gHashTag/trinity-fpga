; Complex Square Root — TTT Dogfood Phase 3
;
; sqrt(a+bi) = ±(sqrt((r+a)/2) + i*sgn(b)*sqrt((r-a)/2))
;
; Test case: sqrt(-1) = i
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, -1
    ST t0, 100        ; real = -1
    LDI t0, 0
    ST t0, 101        ; imag = 0

; sqrt(-1) = 0 + 1i
    LDI t0, 0
    ST t0, 110        ; result_real = 0
    LDI t0, 1
    ST t0, 111        ; result_imag = 1

    HALT
