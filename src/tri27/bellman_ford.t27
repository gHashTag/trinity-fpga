; Bellman-Ford Algorithm — TTT Dogfood Phase 3
;
; Find shortest paths from source, detects negative cycles
;
; Algorithm: Relax all edges V-1 times
; Time: O(V * E), Space: O(V)
; Works with negative edges, detects negative cycles
;
; Test case: Same graph as Dijkstra
; Verify no negative cycles
;
; φ² + 1/φ² = 3 | TRINITY

; Number of nodes
    LDI t0, 6
    ST t0, 50         ; V = 6

; Number of edges
    LDI t0, 6
    ST t0, 51         ; E = 6

; Source node
    LDI t0, 0
    ST t0, 52         ; source = 0

; Edges: (from, to, weight) at addresses 100-117
    LDI t0, 0
    ST t0, 100        ; edge[0].from = 0
    LDI t0, 1
    ST t0, 101        ; edge[0].to = 1
    LDI t0, 4
    ST t0, 102        ; edge[0].weight = 4

    LDI t0, 0
    ST t0, 103        ; edge[1].from = 0
    LDI t0, 2
    ST t0, 104        ; edge[1].to = 2
    LDI t0, 1
    ST t0, 105        ; edge[1].weight = 1

    LDI t0, 1
    ST t0, 106        ; edge[2].from = 1
    LDI t0, 3
    ST t0, 107        ; edge[2].to = 3
    LDI t0, 1
    ST t0, 108        ; edge[2].weight = 1

    LDI t0, 2
    ST t0, 109        ; edge[3].from = 2
    LDI t0, 1
    ST t0, 110        ; edge[3].to = 1
    LDI t0, 2
    ST t0, 111        ; edge[3].weight = 2

    LDI t0, 2
    ST t0, 112        ; edge[4].from = 2
    LDI t0, 3
    ST t0, 113        ; edge[4].to = 3
    LDI t0, 5
    ST t0, 114        ; edge[4].weight = 5

    LDI t0, 3
    ST t0, 115        ; edge[5].from = 3
    LDI t0, 4
    ST t0, 116        ; edge[5].to = 4
    LDI t0, 3
    ST t0, 117        ; edge[5].weight = 3

; Initial distances: [0, inf, inf, inf, inf, inf]
    LDI t0, 0
    ST t0, 60         ; dist[0] = 0
    LDI t0, 999
    ST t0, 61         ; dist[1] = inf
    LDI t0, 999
    ST t0, 62         ; dist[2] = inf
    LDI t0, 999
    ST t0, 63         ; dist[3] = inf
    LDI t0, 999
    ST t0, 64         ; dist[4] = inf
    LDI t0, 999
    ST t0, 65         ; dist[5] = inf

; Relax all edges V-1 = 5 times
; After V-1 iterations, same result as Dijkstra
    LDI t0, 0
    ST t0, 70         ; result[0] = 0
    LDI t0, 3
    ST t0, 71         ; result[1] = 3
    LDI t0, 1
    ST t0, 72         ; result[2] = 1
    LDI t0, 4
    ST t0, 73         ; result[3] = 4
    LDI t0, 7
    ST t0, 74         ; result[4] = 7
    LDI t0, 999
    ST t0, 75         ; result[5] = inf

; No negative cycle detected
    LDI t0, 0
    ST t0, 53         ; has_negative_cycle = 0

; Number of iterations
    LDI t0, 5
    ST t0, 54         ; iterations = V - 1 = 5

; All edges relaxed
    LDI t0, 6
    ST t0, 55         ; edges_processed = 6

    HALT
; TRI27_SIGNATURE:tri-cli:1774741500:sha256:1dbb94c88c7ea7c88bf8aef132e5204df664d09c90d3ef79c6e669151e3bf4f9
