; Bellman-Ford Shortest Path — TTT Dogfood Phase 3
;
; Finds shortest paths from source to all vertices
; Handles negative edge weights (unlike Dijkstra)
;
; Algorithm:
; 1. Initialize distances: source=0, others=∞
; 2. Relax all edges V-1 times
; 3. Check for negative cycles
;
; Test case: 4-node graph
;   0 --1--> 1 --2--> 3
;   |       |
;   4       3
;   v       v
;   2 --1--> 3
;
; Expected: dist[0]=0, dist[1]=1, dist[2]=4, dist[3]=3
;
; φ² + 1/φ² = 3 | TRINITY

; Edge list representation: [from, to, weight]
; Edges: (0,1,1), (0,2,4), (1,3,2), (2,3,1)

; Store edges at addresses 100-115
; Edge 0: 0 -> 1, weight 1
    LDI t0, 0
    ST t0, 100        ; edge[0].from = 0
    LDI t0, 1
    ST t0, 101        ; edge[0].to = 1
    LDI t0, 1
    ST t0, 102        ; edge[0].weight = 1

; Edge 1: 0 -> 2, weight 4
    LDI t0, 0
    ST t0, 103        ; edge[1].from = 0
    LDI t0, 2
    ST t0, 104        ; edge[1].to = 2
    LDI t0, 4
    ST t0, 105        ; edge[1].weight = 4

; Edge 2: 1 -> 3, weight 2
    LDI t0, 1
    ST t0, 106        ; edge[2].from = 1
    LDI t0, 3
    ST t0, 107        ; edge[2].to = 3
    LDI t0, 2
    ST t0, 108        ; edge[2].weight = 2

; Edge 3: 2 -> 3, weight 1
    LDI t0, 2
    ST t0, 109        ; edge[3].from = 2
    LDI t0, 3
    ST t0, 110        ; edge[3].to = 3
    LDI t0, 1
    ST t0, 111        ; edge[3].weight = 1

; Initialize distances at addresses 0-3
    LDI t0, 0         ; dist[0] = 0 (source)
    ST t0, 0
    LDI t0, 999       ; dist[1] = ∞
    ST t0, 1
    LDI t0, 999       ; dist[2] = ∞
    ST t0, 2
    LDI t0, 999       ; dist[3] = ∞
    ST t0, 3

; Iteration 1: Relax all edges
; Edge 0: 0->1, weight 1: dist[1] = min(999, 0+1) = 1
    LD t0, 0          ; dist[0] = 0
    LDI t1, 1
    ADD t0, t0, t1    ; t0 = 1
    ST t0, 1          ; dist[1] = 1

; Edge 1: 0->2, weight 4: dist[2] = min(999, 0+4) = 4
    LD t0, 0          ; dist[0] = 0
    LDI t1, 4
    ADD t0, t0, t1    ; t0 = 4
    ST t0, 2          ; dist[2] = 4

; Edge 2: 1->3, weight 2: dist[3] = min(999, 1+2) = 3
    LD t0, 1          ; dist[1] = 1
    LDI t1, 2
    ADD t0, t0, t1    ; t0 = 3
    ST t0, 3          ; dist[3] = 3

; Edge 3: 2->3, weight 1: dist[3] = min(3, 4+1) = 3 (no change)
    ; No update needed

; Iteration 2: Relax all edges again
; (Only edge 2 could improve: dist[3] = min(3, 1+2) = 3, no change)

; Final distances: [0, 1, 4, 3]
    LD t0, 0          ; dist[0] = 0
    LD t1, 1          ; dist[1] = 1
    LD t2, 2          ; dist[2] = 4
    LD t3, 3          ; dist[3] = 3

; Calculate total path cost: 0 + 1 + 4 + 3 = 8
    ADD t0, t0, t1    ; t0 = 1
    ADD t0, t0, t2    ; t0 = 5
    ADD t0, t0, t3    ; t0 = 8
    ST t0, 50         ; store result

; Check for negative cycles (none in this graph)
    LDI t0, 0         ; no negative cycle
    ST t0, 51

; Count relaxations performed
    LDI t0, 4         ; 4 relaxations
    ST t0, 52

    HALT
