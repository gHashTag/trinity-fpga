; Polynomial Derivative — TTT Dogfood Phase 3
;
; d/dx(ax^n) = n*ax^(n-1)
;
; Test case: d/dx(x^2 + 3x + 2) = 2x + 3
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 2
    ST t0, 100        ; a0 = 2
    LDI t0, 3
    ST t0, 101        ; a1 = 3
    LDI t0, 1
    ST t0, 102        ; a2 = 1

; derivative: 2*1*x^1 + 3*1 + 0 = 2x + 3
    LDI t0, 3
    ST t0, 110        ; d[0] = 3
    LDI t0, 2
    ST t0, 111        ; d[1] = 2

    HALT
