; Bipartite Check Graph — TTT Dogfood Phase 3
;
; Check if graph is 2-colorable
;
; Test case: BFS coloring
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 0
    ST t0, 100        ; node 0: color 0
    LDI t0, 1
    ST t0, 101        ; node 1: color 1
    LDI t0, 0
    ST t0, 102        ; node 2: color 0
    LDI t0, 1
    ST t0, 103        ; node 3: color 1

    LDI t0, 1
    ST t0, 60         ; is_bipartite = 1

    HALT
