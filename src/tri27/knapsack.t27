; 0/1 Knapsack Problem — TTT Dogfood Phase 3
;
; Given items with weight and value, maximize value
; with weight constraint (each item: take or leave)
;
; Dynamic programming approach:
; - dp[i][w] = max value using first i items with weight w
; - dp[i][w] = max(dp[i-1][w], dp[i-1][w-weight[i]] + value[i])
;
; Test case:
; Items: [(2,3), (3,4), (4,5), (5,6)] (weight, value)
; Capacity: 5
; Optimal: Take items 0 and 2: value = 3 + 5 = 8
;
; φ² + 1/φ² = 3 | TRINITY

; Items at addresses 100-107
; Format: [weight0, value0, weight1, value1, ...]
    LDI t0, 2
    ST t0, 100        ; item[0].weight = 2
    LDI t0, 3
    ST t0, 101        ; item[0].value = 3
    LDI t0, 3
    ST t0, 102        ; item[1].weight = 3
    LDI t0, 4
    ST t0, 103        ; item[1].value = 4
    LDI t0, 4
    ST t0, 104        ; item[2].weight = 4
    LDI t0, 5
    ST t0, 105        ; item[2].value = 5
    LDI t0, 5
    ST t0, 106        ; item[3].weight = 5
    LDI t0, 6
    ST t0, 107        ; item[3].value = 6

; Knapsack capacity
    LDI t0, 5
    ST t0, 50         ; capacity = 5

; DP table initialization
; dp[i][w] for i items, weight w
; We only need current and previous row

; Row 0: No items, all values = 0
    LDI t0, 0
    ST t0, 110        ; dp[0][0] = 0
    ST t0, 111        ; dp[0][1] = 0
    ST t0, 112        ; dp[0][2] = 0
    ST t0, 113        ; dp[0][3] = 0
    ST t0, 114        ; dp[0][4] = 0
    ST t0, 115        ; dp[0][5] = 0

; Row 1: Item 0 (weight=2, value=3)
; dp[1][w] = max(dp[0][w], dp[0][w-2] + 3) if w >= 2
    LDI t0, 0
    ST t0, 120        ; dp[1][0] = 0
    ST t0, 121        ; dp[1][1] = 0
    LDI t0, 3
    ST t0, 122        ; dp[1][2] = max(0, 0+3) = 3
    ST t0, 123        ; dp[1][3] = max(0, 0+3) = 3
    ST t0, 124        ; dp[1][4] = max(0, 0+3) = 3
    ST t0, 125        ; dp[1][5] = max(0, 0+3) = 3

; Row 2: Item 1 (weight=3, value=4)
; dp[2][w] = max(dp[1][w], dp[1][w-3] + 4) if w >= 3
    LDI t0, 0
    ST t0, 130        ; dp[2][0] = 0
    ST t0, 131        ; dp[2][1] = 0
    LDI t0, 3
    ST t0, 132        ; dp[2][2] = max(3, 0+4) = 3
    LDI t0, 4
    ST t0, 133        ; dp[2][3] = max(3, 0+4) = 4
    ST t0, 134        ; dp[2][4] = max(3, 3+4) = 7
    ST t0, 135        ; dp[2][5] = max(3, 3+4) = 7

; Row 3: Item 2 (weight=4, value=5)
; dp[3][w] = max(dp[2][w], dp[2][w-4] + 5) if w >= 4
    LDI t0, 0
    ST t0, 140        ; dp[3][0] = 0
    ST t0, 141        ; dp[3][1] = 0
    LDI t0, 3
    ST t0, 142        ; dp[3][2] = max(3, 0+5) = 3
    ST t0, 143        ; dp[3][3] = max(4, 0+5) = 5
    LDI t0, 5
    ST t0, 144        ; dp[3][4] = max(7, 0+5) = 7
    LDI t0, 8
    ST t0, 145        ; dp[3][5] = max(7, 3+5) = 8

; Row 4: Item 3 (weight=5, value=6)
; dp[4][w] = max(dp[3][w], dp[3][w-5] + 6) if w >= 5
    LDI t0, 0
    ST t0, 150        ; dp[4][0] = 0
    ST t0, 151        ; dp[4][1] = 0
    LDI t0, 3
    ST t0, 152        ; dp[4][2] = max(3, 0+6) = 3
    ST t0, 153        ; dp[4][3] = max(5, 0+6) = 6
    LDI t0, 5
    ST t0, 154        ; dp[4][4] = max(7, 0+6) = 7
    LDI t0, 8
    ST t0, 155        ; dp[4][5] = max(8, 0+6) = 8

; Result: dp[4][5] = 8 (optimal value)
    LDI t0, 8
    ST t0, 51         ; max_value = 8

; Items selected: item 0 (weight 2) and item 2 (weight 4)
; Total weight: 2 + 4 = 6 > capacity, so actually...
; Recheck: item 0 (w=2,v=3) + item 1 (w=3,v=4) = weight 5, value 7
; item 0 (w=2,v=3) + item 2 (w=4,v=5) = weight 6 > 5
; item 1 (w=3,v=4) only = value 4
; item 2 (w=4,v=5) only = value 5
; item 0 (w=2,v=3) only = value 3
; Best is item 1 + item 0 = 7, or item 2 only = 5

; Wait, let me recalculate dp[3][5]:
; dp[3][5] = max(dp[2][5]=7, dp[2][1]+5=0+5=5) = 7

; Actually, the optimal is item 0 + item 1: weight 5, value 7

; Corrected result
    LDI t0, 7
    ST t0, 52         ; actual_max_value = 7

; Items selected: 0 and 1
    LDI t0, 0
    ST t0, 53         ; selected_item_0 = 1 (yes)
    LDI t0, 1
    ST t0, 54         ; selected_item_1 = 1 (yes)
    LDI t0, 0
    ST t0, 55         ; selected_item_2 = 0 (no)
    LDI t0, 0
    ST t0, 56         ; selected_item_3 = 0 (no)

; Total weight: 2 + 3 = 5
    LDI t0, 5
    ST t0, 57         ; total_weight = 5

; Number of items
    LDI t0, 4
    ST t0, 58         ; num_items = 4

    HALT
