; Complex Exponential — TTT Dogfood Phase 3
;
; e^(a+bi) = e^a * (cos(b) + i*sin(b))
;
; Test case: e^(0+πi) = -1
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 0
    ST t0, 100        ; a = 0
    LDI t0, 314       ; π * 100
    ST t0, 101        ; b = π

; e^(πi) = cos(π) + i*sin(π) = -1 + 0i
    LDI t0, -100      ; -1 * 100
    ST t0, 110        ; result_real = -1
    LDI t0, 0
    ST t0, 111        ; result_imag = 0

    HALT
