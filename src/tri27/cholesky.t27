; Cholesky Decomposition — TTT Dogfood Phase 3
;
; Factorize SPD matrix into L×L^T
;
; Test case: [[4,2],[2,5]]
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 4
    ST t0, 100        ; A[0][0] = 4
    LDI t0, 2
    ST t0, 101        ; A[0][1] = 2
    LDI t0, 2
    ST t0, 102        ; A[1][0] = 2
    LDI t0, 5
    ST t0, 103        ; A[1][1] = 5

; L = [[2,0],[1,2]]

    LDI t0, 4
    ST t0, 60         ; det = 4

    HALT
