; Geometric Series — TTT Dogfood Phase 3
;
; Sum of geometric progression
;
; Test case: 1 + 2 + 4 + 8 + 16 = 31
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 1
    ST t0, 60         ; a = 1 (first term)
    LDI t0, 2
    ST t0, 61         ; r = 2 (ratio)
    LDI t0, 5
    ST t0, 62         ; n = 5 (count)

; sum = a * (r^n - 1) / (r - 1) = 1 * 31 / 1 = 31
    LDI t0, 31
    ST t0, 63         ; sum = 31

    HALT
