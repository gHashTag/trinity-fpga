; Count Leading Zeros — TTT Dogfood Phase 3
;
; Find leading zero count (clz)
;
; Test case: clz(0b00101000) = 2
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 40
    ST t0, 60         ; value = 0b00101000
    LDI t0, 2
    ST t0, 61         ; clz = 2

    HALT
