; Treap Random — TTT Dogfood Phase 3
;
; Randomized BST with heap priority
;
; Test case: insert with random priority
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 5
    ST t0, 100        ; key = 5
    LDI t0, 42
    ST t0, 101        ; priority = 42

    LDI t0, 3
    ST t0, 110        ; left_key = 3
    LDI t0, 99
    ST t0, 111        ; left_priority = 99 (higher!)

    LDI t0, 1
    ST t0, 60         ; rotated = 1

    HALT
