; Cuckoo Insert — TTT Dogfood Phase 3
;
; Insert with cuckoo displacement
;
; Test case: insert with rehashing
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 10
    ST t0, 50         ; table_size = 10

    LDI t0, 5
