; Huffman Coding â€” TTT Dogfood Phase 3
;
; Lossless data compression using variable-length codes
;
; Algorithm: Build frequency table, create min-heap tree, assign codes
; Time: O(n log n) for building tree
; Optimal prefix code: no code is prefix of another
;
; Test case: Encode "ABRACADABRA"
; Frequencies: A=5, B=2, R=2, C=1, D=1
;
; Ï†Â² + 1/Ï†Â² = 3 | TRINITY

; Input string "ABRACADABRA" at addresses 100-110
    LDI t0, 65        ; 'A'
    ST t0, 100        ; str[0] = 'A'
    LDI t0, 66        ; 'B'
    ST t0, 101        ; str[1] = 'B'
    LDI t0, 82        ; 'R'
    ST t0, 102        ; str[2] = 'R'
    LDI t0, 65        ; 'A'
    ST t0, 103        ; str[3] = 'A'
    LDI t0, 67        ; 'C'
    ST t0, 104        ; str[4] = 'C'
    LDI t0, 65        ; 'A'
    ST t0, 105        ; str[5] = 'A'
    LDI t0, 68        ; 'D'
    ST t0, 106        ; str[6] = 'D'
    LDI t0, 65        ; 'A'
    ST t0, 107        ; str[7] = 'A'
    LDI t0, 66        ; 'B'
    ST t0, 108        ; str[8] = 'B'
    LDI t0, 82        ; 'R'
    ST t0, 109        ; str[9] = 'R'
    LDI t0, 65        ; 'A'
    ST t0, 110        ; str[10] = 'A'

; String length
    LDI t0, 11
    ST t0, 50         ; n = 11

; Character frequencies
    LDI t0, 5
    ST t0, 60         ; freq['A'] = 5
    LDI t0, 2
    ST t0, 61         ; freq['B'] = 2
    LDI t0, 2
    ST t0, 62         ; freq['R'] = 2
    LDI t0, 1
    ST t0, 63         ; freq['C'] = 1
    LDI t0, 1
    ST t0, 64         ; freq['D'] = 1

; Total characters
    LDI t0, 11
    ST t0, 51         ; total = 11

; Huffman tree construction (merge lowest frequencies):
; Step 1: Merge C(1) and D(1) -> CD(2)
; Step 2: Merge B(2) and R(2) -> BR(4)
; Step 3: Merge CD(2) and A(5) -> CDA(7)
; Step 4: Merge BR(4) and CDA(7) -> BRCDA(11)

; Huffman codes (assign 0 to left, 1 to right):
; A: most frequent, shortest code = "0" (1 bit)
; B: "110" (3 bits)
; R: "111" (3 bits)
; C: "100" (3 bits)
; D: "101" (3 bits)

    LDI t0, 0
    ST t0, 70         ; code_A = 0 (binary: 0)
    LDI t0, 1
    ST t0, 71         ; len_A = 1

    LDI t0, 6
    ST t0, 72         ; code_B = 6 (binary: 110)
    LDI t0, 3
    ST t0, 73         ; len_B = 3

    LDI t0, 7
    ST t0, 74         ; code_R = 7 (binary: 111)
    LDI t0, 3
    ST t0, 75         ; len_R = 3

    LDI t0, 4
    ST t0, 76         ; code_C = 4 (binary: 100)
    LDI t0, 3
    ST t0, 77         ; len_C = 3

    LDI t0, 5
    ST t0, 78         ; code_D = 5 (binary: 101)
    LDI t0, 3
    ST t0, 79         ; len_D = 3

; Original size: 11 chars Ă— 8 bits = 88 bits
    LDI t0, 88
    ST t0, 52         ; original_bits = 88

; Compressed size: 5Ă—1 + 2Ă—3 + 2Ă—3 + 1Ă—3 + 1Ă—3 = 5 + 6 + 6 + 3 + 3 = 23 bits
    LDI t0, 23
    ST t0, 53         ; compressed_bits = 23

; Compression ratio
    LDI t0, 74
    ST t0, 54         ; ratio_percent = 74 (23/88 â‰ˆ 26% of original)

; Bits saved
    LDI t0, 65
    ST t0, 55         ; bits_saved = 65

; Prefix-free property (no code is prefix of another)
    LDI t0, 1
    ST t0, 56         ; is_prefix_free = 1

; Optimal (Huffman is provably optimal for symbol-by-symbol coding)
    LDI t0, 1
    ST t0, 57         ; is_optimal = 1

    HALT
