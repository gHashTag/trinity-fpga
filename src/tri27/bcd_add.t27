; BCD Add — TTT Dogfood Phase 3
;
; Binary-Coded Decimal addition
;
; Test case: 23 + 45 = 68 in BCD
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 0x23
    ST t0, 60         ; a = 0x23 (23 in BCD)
    LDI t0, 0x45
    ST t0, 61         ; b = 0x45 (45 in BCD)

    LDI t0, 0x68
    ST t0, 62         ; result = 0x68 (68 in BCD)

    HALT
