; BCD Add — TTT Dogfood Phase 3
;
; Binary-Coded Decimal addition
;
; Test case: 23 + 45 = 68 in BCD
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 35        ; 0x23 = 35 decimal
    ST t0, 60         ; a = 35 (23 in BCD)
    LDI t0, 69        ; 0x45 = 69 decimal
    ST t0, 61         ; b = 69 (45 in BCD)

    LDI t0, 104       ; 0x68 = 104 decimal
    ST t0, 62         ; result = 104 (68 in BCD)

    HALT
