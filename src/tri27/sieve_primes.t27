; Sieve of Eratosthenes — TTT Dogfood Phase 3
;
; Generate all primes up to n
;
; Test case: primes up to 30
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 30
    ST t0, 60         ; n = 30

    LDI t0, 10
    ST t0, 61         ; prime_count = 10

    HALT
