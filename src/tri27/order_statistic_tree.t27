; Order Statistic Tree — TTT Dogfood Phase 3
;
; BST with rank operations
;
; Test case: find 3rd smallest
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 5
    ST t0, 100        ; root = 5
    LDI t0, 3
    ST t0, 101        ; left = 3 (size 2)
    LDI t0, 7
    ST t0, 102        ; right = 7

    LDI t0, 3
    ST t0, 60         ; 3rd smallest = 5

    HALT
