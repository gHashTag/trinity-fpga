; Infinite Series — TTT Dogfood Phase 3
;
; Sum to infinity: S = a / (1 - r) for |r| < 1
;
; Test case: 1 + 1/2 + 1/4 + ... = 2
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 1
    ST t0, 60         ; a = 1
    LDI t0, 50        ; 0.5 * 100
    ST t0, 61         ; r = 0.5

; S = 1 / (1 - 0.5) = 1 / 0.5 = 2
    LDI t0, 2
    ST t0, 62         ; sum = 2

    HALT
