; Matrix Trace — TTT Dogfood Phase 3
;
; Sum of diagonal elements
;
; Test case: tr([[1,2],[3,4]]) = 1+4 = 5
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 1
    ST t0, 100        ; m[0][0] = 1
    LDI t0, 2
    ST t0, 101        ; m[0][1] = 2
    LDI t0, 3
    ST t0, 102        ; m[1][0] = 3
    LDI t0, 4
    ST t0, 103        ; m[1][1] = 4

; trace = 1 + 4 = 5
    LDI t0, 5
    ST t0, 60         ; trace = 5

    HALT
