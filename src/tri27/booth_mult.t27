; Booth Multiply — TTT Dogfood Phase 3
;
; Signed multiplication with fewer operations
;
; Test case: -5 * 3 = -15
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, -5
    ST t0, 60         ; multiplicand = -5
    LDI t0, 3
    ST t0, 61         ; multiplier = 3

    LDI t0, -15
    ST t0, 62         ; result = -15

    HALT
