; Hamming Distance — TTT Dogfood Phase 3
;
; Count differing bits between integers
;
; Test case: hamming(7, 10) = hamming(0111, 1010) = 3
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 7
    ST t0, 50         ; a = 7
    LDI t0, 10
    ST t0, 51         ; b = 10

; 7 = 0111, 10 = 1010
; Bits differ at positions 0, 2, 3
; Hamming = 3

    LDI t0, 3
    ST t0, 60         ; hamming = 3

    HALT
