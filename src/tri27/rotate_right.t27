; Rotate Right — TTT Dogfood Phase 3
;
; Circular right shift
;
; Test case: rotr(0b1001, 2) = 0b0010
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 9
    ST t0, 60         ; value = 0b1001
    LDI t0, 2
    ST t0, 61         ; shift = 2
    LDI t0, 2
    ST t0, 62         ; result = 0b0010

    HALT
