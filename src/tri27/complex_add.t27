; Complex Add — TTT Dogfood Phase 3
;
; (a+bi) + (c+di) = (a+c) + (b+d)i
;
; Test case: (3+2i) + (1+4i) = 4+6i
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 3
    ST t0, 100        ; a = 3
    LDI t0, 2
    ST t0, 101        ; b = 2

    LDI t0, 1
    ST t0, 110        ; c = 1
    LDI t0, 4
    ST t0, 111        ; d = 4

    LDI t0, 4
    ST t0, 120        ; real = 4
    LDI t0, 6
    ST t0, 121        ; imag = 6

    HALT
