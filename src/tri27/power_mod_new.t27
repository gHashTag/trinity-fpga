; Power Mod — TTT Dogfood Phase 3
;
; Compute (base^exp) mod mod
;
; Test case: 2^10 mod 1000 = 24
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 2
    ST t0, 50         ; base = 2
    LDI t0, 10
    ST t0, 51         ; exp = 10
    LDI t0, 1000
    ST t0, 52         ; mod = 1000

; 2^10 = 1024, 1024 % 1000 = 24
    LDI t0, 24
    ST t0, 60         ; result = 24

    HALT
