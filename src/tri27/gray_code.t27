; Gray Code — TTT Dogfood Phase 3
;
; Binary code where adjacent values differ by 1 bit
;
; Test case: binary 5 (101) → Gray 7 (111)
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 5
    ST t0, 60         ; binary = 5 (101)

; gray = binary ^ (binary >> 1)
; gray = 5 ^ 2 = 7 (111)
    LDI t0, 7
    ST t0, 61         ; gray = 7

    HALT
