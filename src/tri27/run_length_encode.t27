; Run-Length Encoding — TTT Dogfood Phase 3
;
; Simple repetition compression
;
; Test case: "AAAABBB" → "4A3B"
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 7
    ST t0, 60         ; input_len = 7
    LDI t0, 4
    ST t0, 61         ; output_len = 4

    HALT
