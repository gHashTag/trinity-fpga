; Quaternion Norm — TTT Dogfood Phase 3
;
; |q| = sqrt(w^2 + x^2 + y^2 + z^2)
;
; Test case: |(1,0,0,0)| = 1
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 1
    ST t0, 100        ; w = 1
    LDI t0, 0
    ST t0, 101        ; x = 0
    LDI t0, 0
    ST t0, 102        ; y = 0
    LDI t0, 0
    ST t0, 103        ; z = 0

; |q| = sqrt(1 + 0 + 0 + 0) = 1
    LDI t0, 1
    ST t0, 60         ; norm = 1

    HALT
