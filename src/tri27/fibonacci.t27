; Fibonacci with Memoization — TTT Dogfood Phase 3
;
; Dynamic Programming: cache computed values
;
; fib(n) = fib(n-1) + fib(n-2)
; Base cases: fib(0) = 0, fib(1) = 1
;
; Test case: fib(10) = 55
;
; φ² + 1/φ² = 3 | TRINITY

; Memoization table at addresses 100-120
; Each entry stores computed fibonacci value

; Initialize base cases
    LDI t0, 0
    ST t0, 100        ; fib(0) = 0
    LDI t0, 1
    ST t0, 101        ; fib(1) = 1

; Compute fib(2) = fib(1) + fib(0) = 1 + 0 = 1
    LD t0, 101        ; t0 = fib(1) = 1
    LD t1, 100        ; t1 = fib(0) = 0
    ADD t0, t0, t1    ; t0 = 1
    ST t0, 102        ; fib(2) = 1

; Compute fib(3) = fib(2) + fib(1) = 1 + 1 = 2
    LD t0, 102        ; t0 = fib(2) = 1
    LD t1, 101        ; t1 = fib(1) = 1
    ADD t0, t0, t1    ; t0 = 2
    ST t0, 103        ; fib(3) = 2

; Compute fib(4) = fib(3) + fib(2) = 2 + 1 = 3
    LD t0, 103        ; t0 = fib(3) = 2
    LD t1, 102        ; t1 = fib(2) = 1
    ADD t0, t0, t1    ; t0 = 3
    ST t0, 104        ; fib(4) = 3

; Compute fib(5) = fib(4) + fib(3) = 3 + 2 = 5
    LD t0, 104        ; t0 = fib(4) = 3
    LD t1, 103        ; t1 = fib(3) = 2
    ADD t0, t0, t1    ; t0 = 5
    ST t0, 105        ; fib(5) = 5

; Compute fib(6) = fib(5) + fib(4) = 5 + 3 = 8
    LD t0, 105        ; t0 = fib(5) = 5
    LD t1, 104        ; t1 = fib(4) = 3
    ADD t0, t0, t1    ; t0 = 8
    ST t0, 106        ; fib(6) = 8

; Compute fib(7) = fib(6) + fib(5) = 8 + 5 = 13
    LD t0, 106        ; t0 = fib(6) = 8
    LD t1, 105        ; t1 = fib(5) = 5
    ADD t0, t0, t1    ; t0 = 13
    ST t0, 107        ; fib(7) = 13

; Compute fib(8) = fib(7) + fib(6) = 13 + 8 = 21
    LD t0, 107        ; t0 = fib(7) = 13
    LD t1, 106        ; t1 = fib(6) = 8
    ADD t0, t0, t1    ; t0 = 21
    ST t0, 108        ; fib(8) = 21

; Compute fib(9) = fib(8) + fib(7) = 21 + 13 = 34
    LD t0, 108        ; t0 = fib(8) = 21
    LD t1, 107        ; t1 = fib(7) = 13
    ADD t0, t0, t1    ; t0 = 34
    ST t0, 109        ; fib(9) = 34

; Compute fib(10) = fib(9) + fib(8) = 34 + 21 = 55
    LD t0, 109        ; t0 = fib(9) = 34
    LD t1, 108        ; t1 = fib(8) = 21
    ADD t0, t0, t1    ; t0 = 55
    ST t0, 110        ; fib(10) = 55

; Verify result
    LD t0, 110        ; t0 = fib(10) = 55
    ST t0, 50         ; store result

; Verify golden ratio approximation
; fib(10) / fib(9) = 55 / 34 ≈ 1.618 (φ)
; For integer: 55 * 100 / 34 = 161
    LDI t0, 55
    LDI t1, 100
    MUL t0, t0, t1    ; t0 = 5500
    LDI t1, 34
    DIV t0, t0, t1    ; t0 = 161
    ST t0, 51         ; store ratio approximation

    HALT
