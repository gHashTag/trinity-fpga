; Bit Reverse — TTT Dogfood Phase 3
;
; Reverse bits in integer
;
; Test case: reverse(0b1101) = 0b1011
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 13
    ST t0, 60         ; value = 0b1101
    LDI t0, 11
    ST t0, 61         ; reversed = 0b1011

    HALT
