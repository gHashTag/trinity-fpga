; Pascal's Triangle — TTT Dogfood Phase 3
;
; Generate binomial coefficients
;
; Each element: C(n,k) = C(n-1,k-1) + C(n-1,k)
;
; Row 4: [1, 4, 6, 4, 1]
; C(4,0)=1, C(4,1)=4, C(4,2)=6, C(4,3)=4, C(4,4)=1
;
; φ² + 1/φ² = 3 | TRINITY

; Row 0: [1]
    LDI t0, 1
    ST t0, 100        ; row[0][0] = 1

; Row 1: [1, 1]
    LDI t0, 1
    ST t0, 110        ; row[1][0] = 1
    ST t0, 111        ; row[1][1] = 1

; Row 2: [1, 2, 1]
    LDI t0, 1
    ST t0, 120        ; row[2][0] = 1
    LDI t0, 2
    ST t0, 121        ; row[2][1] = 2 (1+1)
    LDI t0, 1
    ST t0, 122        ; row[2][2] = 1

; Row 3: [1, 3, 3, 1]
    LDI t0, 1
    ST t0, 130        ; row[3][0] = 1
    LDI t0, 3
    ST t0, 131        ; row[3][1] = 3 (1+2)
    ST t0, 132        ; row[3][2] = 3 (2+1)
    LDI t0, 1
    ST t0, 133        ; row[3][3] = 1

; Row 4: [1, 4, 6, 4, 1]
    LDI t0, 1
    ST t0, 140        ; row[4][0] = 1
    LDI t0, 4
    ST t0, 141        ; row[4][1] = 4 (1+3)
    LDI t0, 6
    ST t0, 142        ; row[4][2] = 6 (3+3)
    LDI t0, 4
    ST t0, 143        ; row[4][3] = 4 (3+1)
    LDI t0, 1
    ST t0, 144        ; row[4][4] = 1

; Target row number
    LDI t0, 4
    ST t0, 50         ; row_num = 4

; Row sum (2^n = 2^4 = 16)
    LDI t0, 16
    ST t0, 51         ; row_sum = 16

; Max element (middle element for even rows)
    LDI t0, 6
    ST t0, 52         ; max_element = 6

; Verify: sum of row elements
; 1 + 4 + 6 + 4 + 1 = 16
    LDI t0, 16
    ST t0, 53         ; verified_sum = 16

; Symmetry check: row[4][1] == row[4][3]
    LDI t0, 1
    ST t0, 54         ; is_symmetric = 1

; Number of elements in row n = n + 1
    LDI t0, 5
    ST t0, 55         ; num_elements = 5

    HALT
