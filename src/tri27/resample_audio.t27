; Audio Resample — TTT Dogfood Phase 3
;
; Sample rate conversion
;
; Test case: 44.1kHz → 48kHz
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 4410      ; truncated for 15-bit limit
    ST t0, 60         ; in_rate = 4410 (truncated)
