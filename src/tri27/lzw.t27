; LZW Compression — TTT Dogfood Phase 3
;
; Dictionary-based compression
;
; Test case: "ABABABA"
; Dictionary: {AB:256, ABA:257, ...}
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 256        ; AB code
    ST t0, 60
    LDI t0, 257        ; ABA code
    ST t0, 61

    LDI t0, 2
    ST t0, 62         ; dict_size = 2

    HALT
