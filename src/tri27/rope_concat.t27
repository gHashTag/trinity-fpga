; Rope Concat — TTT Dogfood Phase 3
;
; Concatenate two ropes
;
; Test case: "Hello" + "World" = "HelloWorld"
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 72        ; H
    ST t0, 100        ; rope1[0] = H
    LDI t0, 5
    ST t0, 60         ; rope1_len = 5

    LDI t0, 87        ; W
    ST t0, 110        ; rope2[0] = W
    LDI t0, 5
    ST t0, 61         ; rope2_len = 5

    LDI t0, 10
    ST t0, 62         ; result_len = 10

    HALT
