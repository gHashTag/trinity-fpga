; Push Relabel — TTT Dogfood Phase 3
;
; Max flow with vertex heights
;
; Test case: push from excess node
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 5
    ST t0, 100        ; excess[1] = 5
    LDI t0, 3
    ST t0, 101        ; height[1] = 3

    LDI t0, 2
    ST t0, 110        ; push 2 to neighbor

    LDI t0, 3
    ST t0, 60         ; remaining = 3

    HALT
