; Prime Test — TTT Dogfood Phase 3
;
; Check if number is prime
;
; Test case: 17 is prime
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 17
    ST t0, 50         ; n = 17

; 17 is prime
    LDI t0, 1
    ST t0, 60         ; is_prime = 1

    HALT
