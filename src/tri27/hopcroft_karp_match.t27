    LDI t0, 2
    ST t0, 101        ; pair[1] = L2-R1
    LDI t0, 3
    ST t0, 102        ; pair[2] = L3-R3

    LDI t0, 3
    ST t0, 62         ; max_matching = 3

    HALT
