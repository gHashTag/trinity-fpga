; Hopcroft-Karp — TTT Dogfood Phase 3
;
; Maximum bipartite matching with BFS layering
;
; Test case: match left vertices to right vertices
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 3
    ST t0, 60         ; left_size = 3
    LDI t0, 3
    ST t0, 61         ; right_size = 3

; Match: L1-R2, L2-R1, L3-R3
    LDI t0, 1
