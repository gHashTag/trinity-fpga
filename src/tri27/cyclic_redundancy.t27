; CRC — TTT Dogfood Phase 3
;
; Cyclic Redundancy Check for error detection
;
; Test case: CRC-32 of "123456789"
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 49        ; 1
    ST t0, 100        ; data[0] = 1
    LDI t0, 50        ; 2
    ST t0, 101        ; data[1] = 2
    LDI t0, 51        ; 3
    ST t0, 102        ; data[2] = 3

    LDI t0, 0xCBF43926
    ST t0, 60         ; crc32 = 0xCBF43926

    HALT
; TRI27_SIGNATURE:tri-cli:1774741500:sha256:0712780011e9
