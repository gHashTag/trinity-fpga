; FNV Hash — TTT Dogfood Phase 3
;
; Fast hash based on prime multiplication
;
; Test case: FNV-1a (mod 32767 for i16 range)
;
; φ² + 1/φ² = 3 | TRINITY

; Using smaller values for i16 compatibility
    LDI t0, 16777     ; FNV prime mod 32767
    ST t0, 50

    LDI t0, 21661     ; FNV offset mod 32767
    ST t0, 51

    LDI t0, 5381
    ST t0, 60         ; hash = 5381

    HALT
