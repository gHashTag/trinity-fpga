; Find Last Set — TTT Dogfood Phase 3
;
; Index of most significant 1-bit
;
; Test case: fls(12) = fls(1100) = 4
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 12        ; 1100
    ST t0, 60         ; n = 12

    LDI t0, 4
    ST t0, 61         ; fls = 4 (1-indexed from MSB)

    HALT
