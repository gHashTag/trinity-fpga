; Ternary Search — TTT Dogfood Phase 3
;
; Find max/min in unimodal function
;
; Test case: divide range in 3 parts
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 0
    ST t0, 60         ; left = 0
    LDI t0, 100
    ST t0, 61         ; right = 100

; mid1 = left + (right - left) / 3
    LDI t0, 33
    ST t0, 62         ; mid1 ≈ 33

; mid2 = right - (right - left) / 3
    LDI t0, 67
    ST t0, 63         ; mid2 ≈ 67

    HALT
