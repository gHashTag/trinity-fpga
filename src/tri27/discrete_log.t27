; Discrete Logarithm — TTT Dogfood Phase 3
;
; Find x such that a^x ≡ b (mod p)
;
; Test case: 2^3 ≡ 8 (mod 13)
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 2
    ST t0, 60         ; a = 2
    LDI t0, 8
    ST t0, 61         ; b = 8
    LDI t0, 13
    ST t0, 62         ; p = 13

    LDI t0, 3
    ST t0, 63         ; x = 3

    HALT
