; Parity Bit — TTT Dogfood Phase 3
;
; Single bit error detection
;
; Test case: even parity for 1011 → 1 (odd bits)
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 11        ; 1011
    ST t0, 60         ; data = 11

; Count bits: 1 + 0 + 1 + 1 = 3 (odd)
; Even parity bit = 1 (to make total even)
    LDI t0, 1
    ST t0, 61         ; parity = 1

    HALT
; TRI27_SIGNATURE:tri-cli:1774741500:sha256:07327a0011eb
