; Vector Dot Product — TTT Dogfood Phase 3
;
; Sum of element-wise products
;
; Test case: [1,2] · [3,4] = 1*3 + 2*4 = 11
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 1
    ST t0, 100        ; a[0] = 1
    LDI t0, 2
    ST t0, 101        ; a[1] = 2

    LDI t0, 3
    ST t0, 110        ; b[0] = 3
    LDI t0, 4
    ST t0, 111        ; b[1] = 4

; dot = 1*3 + 2*4 = 11
    LDI t0, 11
    ST t0, 60         ; result = 11

    HALT
