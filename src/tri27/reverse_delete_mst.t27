; Reverse Delete MST — TTT Dogfood Phase 3
;
; MST by deleting edges in reverse weight order
;
; Test case: start from all edges
;
; φ² + 1/φ² = 3 | TRINITY

    LDI t0, 5
    ST t0, 60         ; num_vertices = 5
    LDI t0, 7
    ST t0, 61         ; num_edges = 7

    LDI t0, 1
    ST t0, 70         ; connected = 1

    LDI t0, 4
    ST t0, 62         ; mst_weight = 4

    HALT
