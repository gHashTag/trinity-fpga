        "vibee",
        "vib"
      ],
      "injection-regex": "vibee",
      "highlights": "queries/highlights.scm",
      "indents": "queries/indents.scm",
      "folds": "queries/folds.scm"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for VIBEE DSL (.vibee specification files)",
    "links": {
