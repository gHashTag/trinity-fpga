# W1 Worker Configuration
PROJECT_NAME="trinity-w1"
PROJECT_TYPE="zig"
MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=30
CLAUDE_OUTPUT_FORMAT="json"
ALLOWED_TOOLS="Write,Read,Edit,Grep,Glob,Bash(git *),Bash(zig *),Bash(ls *),Bash(cat *)"
SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=24
TASK_SOURCES="local"
CB_NO_PROGRESS_THRESHOLD=5
CB_SAME_ERROR_THRESHOLD=7
CLAUDE_MIN_VERSION="2.0.76"
RALPH_VERBOSE=true
