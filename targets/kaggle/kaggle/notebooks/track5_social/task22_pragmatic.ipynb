  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Trinity Social Cognition Probe \u2014 Pragmatic Inference\n",
    "**Task 22 of 25** | Track 5: Social | Brain Zone: WERNICKE",
    "Measures sarcasm/irony/implicature understanding.",
    "## Trinity Neuroanatomical Foundation\n",
    "### Ternary Scoring {-1, 0, +1}",
    "- **+1**: Correct\n",
    "- **0**: Partial with uncertainty\n",
    "- **-1**: Wrong\n",
    "### \u03c6-Scaling\n",
    "Context cues: 1, 2, 3, 4, 5"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import kaggle_benchmarks as kbench\n",
    "import pandas as pd\n",
    "df = pd.read_csv('../../data/tscp_social.csv')\n",
    "prag_df = df[df['task'] == 'Pragmatic Inference'].copy()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@dataclass\n",
    "class PragmaticResponse:\n",
    "    interpretation: str\n",
    "    confidence: float\n",
    "    def ternary_score(self, expected) -> int:\n",
    "        if self.interpretation == expected:\n",
    "            return 1\n",
    "        elif 0.3 < self.confidence < 0.7:\n",
    "            return 0\n",
    "        else:\n",
    "            return -1\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@kbench.task(name=\"trinity_wernicke_pragmatic\")\n",
    "def pragmatic_inference(llm, utterance, context, expected) -> float:\n",
    "    prompt = f\"\"Utterance: '{utterance}'\\nContext: {context}\\nQuestion: What does this mean?\\nConfidence (0-1)\"\n",
    "    response = llm.prompt(prompt, schema=PragmaticResponse)\n",
    "    ternary = response.ternary_score(expected)\n",
    "    confidence_score = (response.confidence - 0.5) * 2\n",
    "    final_score = 0.7 * ternary + 0.3 * confidence_score\n",
    "    return max(-1.0, min(1.0, final_score))\n",
    "    print(\"Task registered\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = pragmatic_inference.evaluate(llm=[kbench.llm], evaluation_data=prag_df.head(10))\n",
    "print(results.head())"
   ]
  },
  {
