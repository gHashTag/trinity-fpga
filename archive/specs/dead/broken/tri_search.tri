name: tri_search
version: "1.0.0"
language: zig
module: commands

cli:
  main_command: search
  description: "Semantic code search with tree-sitter"

commands:
  - name: search
    description: "Search codebase using semantic matching"
    function: "runSearchCommand"
    args: "<query>"
    flags:
      - name: "case-insensitive"
        type: "bool"
        default: true
        description: "Ignore case in matching"

      - name: "limit"
        type: "int"
        default: 10
        description: "Maximum number of results"

      - name: "path"
        type: "string"
        default: null
        description: "Search in specific directory"

      - name: "ast"
        type: "bool"
        default: false
        description: "Use AST-based search (requires -Dtreesitter=true)"

    examples:
      - 'tri search "phi power"'
      - 'tri search "Vector Symbolic Architecture"'
      - 'tri search --limit 20 --path src/vibeec'
