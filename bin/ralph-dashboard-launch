#!/bin/bash
# RALPH COMMAND CENTER - Tabs Layout
# 6 tabs: Loop | Workers | Tasks | TechTree | Memory | Log

set -e

RALPH_DIR="/Users/playra/trinity"
SESSION_NAME="ralph"

# Kill existing session
tmux kill-session -t "$SESSION_NAME" 2>/dev/null || true
sleep 0.5

cd "$RALPH_DIR"

# Tab 0: Ralph Loop Status
tmux new-session -s "$SESSION_NAME" -n "Loop" -d \
  "while true; do clear; .ralph/scripts/tmux_status.sh panel0; sleep 2; done"

# Tab 1: Workers
tmux new-window -t "$SESSION_NAME" -n "Workers" \
  "while true; do clear; .ralph/scripts/tmux_status.sh panel1; sleep 5; done"

# Tab 2: Active Tasks (P1/P2/P3)
tmux new-window -t "$SESSION_NAME" -n "Tasks" \
  "while true; do clear; .ralph/scripts/tmux_status.sh panel2; sleep 5; done"

# Tab 3: Tech Tree
tmux new-window -t "$SESSION_NAME" -n "TechTree" \
  "while true; do clear; .ralph/scripts/tmux_status.sh panel3; sleep 10; done"

# Tab 4: Memory Systems
tmux new-window -t "$SESSION_NAME" -n "Memory" \
  "while true; do clear; .ralph/scripts/tmux_status.sh panel4; sleep 15; done"

# Tab 5: Live Log
tmux new-window -t "$SESSION_NAME" -n "Log" -c "$RALPH_DIR/.ralph/logs" \
  "while true; do latest=\$(ls -t *.log 2>/dev/null | head -1); if [ -n \"\$latest\" ]; then clear; tail -30 \"\$latest\"; else echo \"No logs yet\"; fi; sleep 2; done"

# Status bar
tmux set-option -t "$SESSION_NAME" status-interval 2
tmux set-option -t "$SESSION_NAME" status-left '#[fg=colour220]RALPH #[fg=colour075]CMD'
tmux set-option -t "$SESSION_NAME" status-right '#(.ralph/scripts/tmux_status.sh statusline)'
tmux set-option -t "$SESSION_NAME" status-style 'bg=colour235,fg=colour255'
tmux set-option -t "$SESSION_NAME" window-status-format '#[fg=colour244]#I:#[fg=colour255]#W'
tmux set-option -t "$SESSION_NAME" window-status-current-format '#[fg=colour220,bold]#I:#[fg=colour255]#W*'

echo "Ralph Command Center started!"
echo "Tabs: Ctrl-B 0-5 | Detach: Ctrl-B D"
echo ""

# Attach (first window is already selected by default)
exec tmux attach-session -t "$SESSION_NAME"
